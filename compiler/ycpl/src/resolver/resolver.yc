    body_return_nodes := 0
    body_if_nodes := 0
    body_for_nodes := 0
    body_first_node_kind := 0
    body_last_node_kind := 0
    body_node_digest := 17
    body_transition_digest := 17
    body_local_assign_edges := 0
    body_assign_call_edges := 0
    body_call_return_edges := 0
    body_return_local_edges := 0
    body_if_for_edges := 0
    body_for_return_edges := 0
    body_identifier_payloads := 0
    body_literal_payloads := 0
    body_type_payloads := 0
    body_control_payloads := 0
    body_payload_digest := 17
    body_local_symbol_refs := 0
    body_assignment_target_refs := 0
    body_call_target_refs := 0
    body_return_symbol_refs := 0
    body_return_literal_refs := 0
    body_type_refs := 0
    body_control_refs := 0
    body_semantic_digest := 17
    body_slot_count := 0
    body_nonempty_slots := 0
    body_max_nodes_per_slot := 0
    body_slot_digest := 17
    return_exprs := 0
    return_literal_exprs := 0
    return_name_exprs := 0
    return_call_exprs := 0
    return_expr_digest := 17
    function_name_digest := 17
    typed_decl_nodes := 0
    typed_stmt_nodes := 0
    typed_expr_nodes := 0
    typed_type_nodes := 0
    typed_digest := 17
    symbol_modules := 0
    symbol_imports := 0
    symbol_std_imports := 0
    symbol_relative_imports := 0
    symbol_import_aliases := 0
    symbol_functions := 0
    symbol_structs := 0
    symbol_externs := 0
    symbol_intrinsics := 0
    symbol_public := 0
    symbol_local := 0
    symbol_zero_param_functions := 0
    symbol_nonzero_param_functions := 0
    symbol_total_function_params := 0
    symbol_max_function_params := 0
    symbol_functions_with_return_type := 0
    symbol_function_signature_digest := 17
    symbol_call_sites := 0
    symbol_zero_arg_calls := 0
    symbol_nonzero_arg_calls := 0
    symbol_total_call_args := 0
    symbol_max_call_args := 0
    symbol_call_arity_digest := 17
    signature_nodes := 0
    signature_function_nodes := 0
    signature_call_nodes := 0
    signature_arity_slots := 0
    signature_max_arity := 0
    signature_return_functions := 0
    signature_typed_return_functions := 0
    signature_digest := 17
    expr_table_nodes := 0
    expr_primary_nodes := 0
    expr_identifier_nodes := 0
    expr_literal_nodes := 0
    expr_string_nodes := 0
    expr_bool_nodes := 0
    expr_none_nodes := 0
    expr_call_nodes := 0
    expr_member_nodes := 0
