fn join_path(left string, right string) string {
    left_len := str.len(left)
    right_len := str.len(right)
    needs_slash := true
    if left_len > 0 && left[left_len - 1] == '/' {
        needs_slash = false
    }

    extra := 1
    if !needs_slash {
        extra = 0
    }

    out: string := mem.calloc(left_len + right_len + extra + 1, 1)
    mem.copy(out, left, left_len)
    at := left_len
    if needs_slash {
        out[at] = '/'
        at += 1
    }
    mem.copy(out + at, right, right_len)
    return out
}

pub fn is_compiler_project(path string) bool {
    if str.eq(path, "compiler/ycpl") || str.eq(path, "compiler/ycpl/") {
        return true
    }
    config := join_path(path, "YCPL.json")
    return fs.exists(config)
}

pub fn file_count() i32 {
    return 17
}

fn file_suffix(index i32) string {
    if index == 0 { return "/src/ast/ast.yc" }
    if index == 1 { return "/src/ast/body.yc" }
    if index == 2 { return "/src/ast/shape.yc" }
    if index == 3 { return "/src/checker/checker.yc" }
    if index == 4 { return "/src/diag/diag.yc" }
    if index == 5 { return "/src/driver/driver.yc" }
    if index == 6 { return "/src/codegen/irgen.yc" }
    if index == 7 { return "/src/codegen/nodeir.yc" }
    if index == 8 { return "/src/codegen/projectir.yc" }
    if index == 9 { return "/src/codegen/tinyir.yc" }
    if index == 10 { return "/src/lexer/lexer.yc" }
    if index == 11 { return "/src/main.yc" }
    if index == 12 { return "/src/parser/body.yc" }
    if index == 13 { return "/src/parser/parser.yc" }
    if index == 14 { return "/src/resolver/resolver.yc" }
    if index == 15 { return "/src/source/source.yc" }
    return "/src/lexer/token.yc"
}

pub fn file_path(root string, index i32) string {
    suffix := file_suffix(index)
    left := str.len(root)
    right := str.len(suffix)
    out: string := mem.calloc(left + right + 1, 1)
    mem.copy(out, root, left)
    mem.copy(out + left, suffix, right)
    return out
}

fn count_source_lines(text string) i32 {
    count := 0
    i := 0
    saw_any := false
    last_was_newline := false
    for (; text[i] != 0; i++) {
        saw_any = true
        if text[i] == 10 {
            count += 1
            last_was_newline = true
        } else {
            last_was_newline = false
        }
    }
    if saw_any && !last_was_newline {
        count += 1
    }
    return count
}

pub fn discover_sources(root string) SourceList {
    found := fs.find_yc_files(root)
    if !found.ok {
        return sources_fail(found.message)
    }
    count := count_source_lines(found.text)
    if count <= 0 {
        return sources_fail("project has no YCPL source files")
    }
    return sources_ok(found.text, count)
}

pub fn source_path_at(sources SourceList, index i32) string {
    start := 0
    current := 0
    i := 0
    for (; sources.text[i] != 0; i++) {
        if sources.text[i] == 10 {
            if current == index {
                count := i - start
                out: string := mem.calloc(count + 1, 1)
                mem.copy(out, sources.text + start, count)
                return out
            }
            current += 1
            start = i + 1
        }
    }
    if current == index && i > start {
        count := i - start
        out: string := mem.calloc(count + 1, 1)
        mem.copy(out, sources.text + start, count)
        return out
    }
    return ""
}

pub fn parse_project(root string) ProjectResult {
    files := 0
    tokens := 0
    decls := 0
    functions := 0
    structs := 0
    imports := 0
    nodes := 0
    externs := 0
    intrinsics := 0
    statements := 0
    expressions := 0
    locals := 0
    returns := 0
    calls := 0
    branches := 0
    loops := 0
    strings := 0
    members := 0
    indexes := 0
    assignments := 0
    function_bodies := 0
    function_body_tokens := 0
    function_body_digest := 17
    local_decl_digest := 17
    call_expr_digest := 17
    control_flow_digest := 17
    body_node_count := 0
    body_local_nodes := 0
