pub struct SourceList {
    ok bool
    message string
    text string
    count i32
}

fn sources_ok(text string, count i32) SourceList {
    return SourceList{ok: true, message: "", text: text, count: count}
}

fn sources_fail(message string) SourceList {
    return SourceList{ok: false, message: message, text: "", count: 0}
}

