    stmt_expr_tail_nodes := 0
    stmt_expr_digest := 17
    symbol_digest := 17
    symbol_import_digest := 17
    symbol_module_digest := 17
    has_main := false
    digest := 17

    sources := discover_sources(root)
    if !sources.ok {
        return result_fail(root, 1, 1, sources.message)
    }

    i: i32 := 0
    n := sources.count
    for (; i < n; i++) {
        path := source_path_at(sources, i)
        src := source.load(path)
        if !src.ok {
            return result_fail(path, 1, 1, "could not read project source")
        }

        parsed := parser.parse(path, src.text)
        if !parsed.ok {
            return result_fail(path, parsed.line, parsed.col, parsed.message)
        }
        sym := symbols.scan(path, src.text)
        if !sym.ok {
            return result_fail(path, sym.line, sym.col, sym.message)
        }
        sig_table := signature.parse(path, src.text)
        if !sig_table.ok {
            return result_fail(path, sig_table.line, sig_table.col, sig_table.message)
        }
        expr_table := exprparser.parse(path, src.text)
        if !expr_table.ok {
            return result_fail(path, expr_table.line, expr_table.col, expr_table.message)
        }

        files += 1
        tokens += parsed.tokens
        decls += parsed.decls
        functions += parsed.functions
        structs += parsed.structs
        imports += parsed.imports
        nodes += parsed.program.arena.nodes
        externs += parsed.program.externs
        intrinsics += parsed.program.intrinsics
        statements += parsed.program.statements
        expressions += parsed.program.expressions
        locals += parsed.program.locals
        returns += parsed.program.returns
        calls += parsed.program.calls
        branches += parsed.program.branches
        loops += parsed.program.loops
        strings += parsed.program.strings
        members += parsed.program.members
        indexes += parsed.program.indexes
        assignments += parsed.program.assignments
        function_bodies += parsed.program.function_bodies
        function_body_tokens += parsed.program.function_body_tokens
        function_body_digest = function_body_digest * 31 + parsed.program.function_body_digest
        local_decl_digest = local_decl_digest * 31 + parsed.program.local_decl_digest
        call_expr_digest = call_expr_digest * 31 + parsed.program.call_expr_digest
        control_flow_digest = control_flow_digest * 31 + parsed.program.control_flow_digest
        body_node_count += parsed.program.body_node_count
        body_local_nodes += parsed.program.body_local_nodes
        body_assignment_nodes += parsed.program.body_assignment_nodes
        body_call_nodes += parsed.program.body_call_nodes
        body_return_nodes += parsed.program.body_return_nodes
        body_if_nodes += parsed.program.body_if_nodes
        body_for_nodes += parsed.program.body_for_nodes
        if body_first_node_kind == 0 && parsed.program.body_first_node_kind != 0 {
            body_first_node_kind = parsed.program.body_first_node_kind
        }
        if parsed.program.body_last_node_kind != 0 {
            body_last_node_kind = parsed.program.body_last_node_kind
        }
        body_node_digest = body_node_digest * 31 + parsed.program.body_node_digest
        body_transition_digest = body_transition_digest * 31 + parsed.program.body_transition_digest
        body_local_assign_edges += parsed.program.body_local_assign_edges
        body_assign_call_edges += parsed.program.body_assign_call_edges
        body_call_return_edges += parsed.program.body_call_return_edges
        body_return_local_edges += parsed.program.body_return_local_edges
        body_if_for_edges += parsed.program.body_if_for_edges
        body_for_return_edges += parsed.program.body_for_return_edges
        body_identifier_payloads += parsed.program.body_identifier_payloads
        body_literal_payloads += parsed.program.body_literal_payloads
        body_type_payloads += parsed.program.body_type_payloads
        body_control_payloads += parsed.program.body_control_payloads
        body_payload_digest = body_payload_digest * 31 + parsed.program.body_payload_digest
        body_local_symbol_refs += parsed.program.body_local_symbol_refs
        body_assignment_target_refs += parsed.program.body_assignment_target_refs
        body_call_target_refs += parsed.program.body_call_target_refs
        body_return_symbol_refs += parsed.program.body_return_symbol_refs
        body_return_literal_refs += parsed.program.body_return_literal_refs
        body_type_refs += parsed.program.body_type_refs
        body_control_refs += parsed.program.body_control_refs
        body_semantic_digest = body_semantic_digest * 31 + parsed.program.body_semantic_digest
        body_slot_count += parsed.program.body_slot_count
        body_nonempty_slots += parsed.program.body_nonempty_slots
        if parsed.program.body_max_nodes_per_slot > body_max_nodes_per_slot {
            body_max_nodes_per_slot = parsed.program.body_max_nodes_per_slot
        }
        body_slot_digest = body_slot_digest * 31 + parsed.program.body_slot_digest
        return_exprs += parsed.program.return_exprs
        return_literal_exprs += parsed.program.return_literal_exprs
        return_name_exprs += parsed.program.return_name_exprs
        return_call_exprs += parsed.program.return_call_exprs
        return_expr_digest = return_expr_digest * 31 + parsed.program.return_expr_digest
        function_name_digest = function_name_digest * 31 + parsed.program.function_name_digest
        typed_decl_nodes += parsed.program.typed_decl_nodes
        typed_stmt_nodes += parsed.program.typed_stmt_nodes
        typed_expr_nodes += parsed.program.typed_expr_nodes
        typed_type_nodes += parsed.program.typed_type_nodes
        typed_digest = typed_digest * 31 + parsed.program.typed_digest
        symbol_modules += sym.modules
        symbol_imports += sym.imports
        symbol_std_imports += sym.std_imports
        symbol_relative_imports += sym.relative_imports
        symbol_import_aliases += sym.import_aliases
        symbol_functions += sym.functions
        symbol_structs += sym.structs
        symbol_externs += sym.externs
        symbol_intrinsics += sym.intrinsics
        symbol_public += sym.public_symbols
        symbol_local += sym.local_symbols
        symbol_zero_param_functions += sym.zero_param_functions
        symbol_nonzero_param_functions += sym.nonzero_param_functions
        symbol_total_function_params += sym.total_function_params
        if sym.max_function_params > symbol_max_function_params {
            symbol_max_function_params = sym.max_function_params
        }
        symbol_functions_with_return_type += sym.functions_with_return_type
        symbol_function_signature_digest = symbol_function_signature_digest * 31 + sym.function_signature_digest
        symbol_call_sites += sym.call_sites
        symbol_zero_arg_calls += sym.zero_arg_calls
        symbol_nonzero_arg_calls += sym.nonzero_arg_calls
        symbol_total_call_args += sym.total_call_args
        if sym.max_call_args > symbol_max_call_args {
            symbol_max_call_args = sym.max_call_args
        }
        symbol_call_arity_digest = symbol_call_arity_digest * 31 + sym.call_arity_digest
        signature_nodes += sig_table.nodes
        signature_function_nodes += sig_table.function_nodes
        signature_call_nodes += sig_table.call_nodes
        signature_arity_slots += sig_table.arity_slots
        if sig_table.max_arity > signature_max_arity {
            signature_max_arity = sig_table.max_arity
        }
        signature_return_functions += sig_table.functions_with_return_type
        signature_typed_return_functions += sig_table.functions_with_typed_return
        signature_digest = signature_digest * 31 + sig_table.digest
        expr_table_nodes += expr_table.nodes
        expr_primary_nodes += expr_table.primary_nodes
        expr_identifier_nodes += expr_table.identifier_nodes
        expr_literal_nodes += expr_table.literal_nodes
        expr_string_nodes += expr_table.string_nodes
        expr_bool_nodes += expr_table.bool_nodes
        expr_none_nodes += expr_table.none_nodes
        expr_call_nodes += expr_table.call_nodes
        expr_member_nodes += expr_table.member_nodes
        expr_index_nodes += expr_table.index_nodes
        expr_binary_nodes += expr_table.binary_nodes
        expr_unary_nodes += expr_table.unary_nodes
        expr_table_digest = expr_table_digest * 31 + expr_table.digest
        expr_slot_count += expr_table.expr_slot_count
        expr_nonempty_slots += expr_table.expr_nonempty_slots
        if expr_table.expr_max_nodes_per_slot > expr_max_nodes_per_slot {
            expr_max_nodes_per_slot = expr_table.expr_max_nodes_per_slot
        }
        expr_slot_digest = expr_slot_digest * 31 + expr_table.expr_slot_digest
        file_stmt_expr_links := parsed.program.statement_expr_links
        file_stmt_expr_tail_nodes := expr_table.nodes - parsed.program.statement_expr_nodes
        if file_stmt_expr_tail_nodes < 0 {
            file_stmt_expr_tail_nodes = 0
        }
        stmt_expr_links += file_stmt_expr_links
        stmt_expr_tail_nodes += file_stmt_expr_tail_nodes
        stmt_expr_digest = stmt_expr_digest * 31 + file_stmt_expr_links
        stmt_expr_digest = stmt_expr_digest * 31 + file_stmt_expr_tail_nodes
        stmt_expr_digest = stmt_expr_digest * 31 + parsed.program.statement_expr_digest
        stmt_expr_digest = stmt_expr_digest * 31 + parsed.program.statement_expr_max_per_node
        stmt_expr_digest = stmt_expr_digest * 31 + parsed.program.statement_expr_orphans
        stmt_expr_digest = stmt_expr_digest * 31 + expr_table.digest
        symbol_digest = symbol_digest * 31 + sym.symbol_digest
        symbol_import_digest = symbol_import_digest * 31 + sym.import_digest
        symbol_module_digest = symbol_module_digest * 31 + sym.module_digest
        if parsed.program.has_main {
            has_main = true
        }
        digest = digest * 31 + parsed.tokens
        digest = digest * 31 + parsed.decls
        digest = digest * 31 + parsed.functions
        digest = digest * 31 + parsed.structs
        digest = digest * 31 + parsed.imports
        digest = digest * 31 + parsed.program.arena.nodes
        digest = digest * 31 + parsed.program.function_name_digest
        digest = digest * 31 + parsed.program.function_body_digest
        digest = digest * 31 + parsed.program.body_node_digest
        digest = digest * 31 + parsed.program.body_transition_digest
        digest = digest * 31 + parsed.program.body_payload_digest
        digest = digest * 31 + parsed.program.body_semantic_digest
        digest = digest * 31 + parsed.program.body_slot_digest
        digest = digest * 31 + parsed.program.return_expr_digest
        digest = digest * 31 + parsed.program.typed_digest
        digest = digest * 31 + sym.symbol_digest
        digest = digest * 31 + sym.function_signature_digest
        digest = digest * 31 + sym.call_arity_digest
        digest = digest * 31 + sig_table.digest
        digest = digest * 31 + expr_table.digest
        digest = digest * 31 + expr_table.expr_slot_digest
        digest = digest * 31 + stmt_expr_digest
        digest = digest * 31 + sym.import_digest
        digest = digest * 31 + sym.module_digest
    }

    return result_ok(files, tokens, decls, functions, structs, imports, digest, nodes, externs, intrinsics, statements, expressions, locals, returns, calls, branches, loops, strings, members, indexes, assignments, function_bodies, function_body_tokens, function_body_digest, local_decl_digest, call_expr_digest, control_flow_digest, body_node_count, body_local_nodes, body_assignment_nodes, body_call_nodes, body_return_nodes, body_if_nodes, body_for_nodes, body_first_node_kind, body_last_node_kind, body_node_digest, body_transition_digest, body_local_assign_edges, body_assign_call_edges, body_call_return_edges, body_return_local_edges, body_if_for_edges, body_for_return_edges, body_identifier_payloads, body_literal_payloads, body_type_payloads, body_control_payloads, body_payload_digest, body_local_symbol_refs, body_assignment_target_refs, body_call_target_refs, body_return_symbol_refs, body_return_literal_refs, body_type_refs, body_control_refs, body_semantic_digest, body_slot_count, body_nonempty_slots, body_max_nodes_per_slot, body_slot_digest, return_exprs, return_literal_exprs, return_name_exprs, return_call_exprs, return_expr_digest, function_name_digest, typed_decl_nodes, typed_stmt_nodes, typed_expr_nodes, typed_type_nodes, typed_digest, symbol_modules, symbol_imports, symbol_std_imports, symbol_relative_imports, symbol_import_aliases, symbol_functions, symbol_structs, symbol_externs, symbol_intrinsics, symbol_public, symbol_local, symbol_zero_param_functions, symbol_nonzero_param_functions, symbol_total_function_params, symbol_max_function_params, symbol_functions_with_return_type, symbol_function_signature_digest, symbol_call_sites, symbol_zero_arg_calls, symbol_nonzero_arg_calls, symbol_total_call_args, symbol_max_call_args, symbol_call_arity_digest, signature_nodes, signature_function_nodes, signature_call_nodes, signature_arity_slots, signature_max_arity, signature_return_functions, signature_typed_return_functions, signature_digest, expr_table_nodes, expr_primary_nodes, expr_identifier_nodes, expr_literal_nodes, expr_string_nodes, expr_bool_nodes, expr_none_nodes, expr_call_nodes, expr_member_nodes, expr_index_nodes, expr_binary_nodes, expr_unary_nodes, expr_table_digest, expr_slot_count, expr_nonempty_slots, expr_max_nodes_per_slot, expr_slot_digest, stmt_expr_links, stmt_expr_tail_nodes, stmt_expr_digest, symbol_digest, symbol_import_digest, symbol_module_digest, has_main)
}

pub fn check_project(root string) ProjectResult {
    result := parse_project(root)
    if !result.ok {
        return result
    }
    if result.functions <= 0 {
        return result_fail(root, 1, 1, "project has no functions")
    }
    if result.function_bodies <= 0 {
        return result_fail(root, 1, 1, "project has no function bodies")
    }
    if result.function_body_tokens <= 0 {
        return result_fail(root, 1, 1, "project has no function body tokens")
    }
    if result.body_node_count <= 0 {
        return result_fail(root, 1, 1, "project has no statement nodes")
    }
    if result.body_transition_digest == 17 {
        return result_fail(root, 1, 1, "project has no statement node transitions")
    }
    if result.body_identifier_payloads <= 0 || result.body_type_payloads <= 0 || result.body_control_payloads <= 0 {
        return result_fail(root, 1, 1, "project has incomplete body payload tables")
    }
    if result.body_payload_digest == 17 {
        return result_fail(root, 1, 1, "project has no body payload digest")
    }
    if result.body_local_symbol_refs <= 0 || result.body_assignment_target_refs <= 0 || result.body_call_target_refs <= 0 {
        return result_fail(root, 1, 1, "project has incomplete body symbol roles")
    }
    if result.body_type_refs <= 0 || result.body_control_refs <= 0 || result.body_semantic_digest == 17 {
        return result_fail(root, 1, 1, "project has incomplete body semantic roles")
    }
    if result.body_slot_count != result.function_bodies || result.body_nonempty_slots <= 0 {
        return result_fail(root, 1, 1, "project body slot table does not match function bodies")
    }
    if result.body_max_nodes_per_slot <= 0 || result.body_slot_digest == 17 {
        return result_fail(root, 1, 1, "project has incomplete body slot table")
    }
    if result.body_if_nodes <= 0 || result.body_for_nodes <= 0 {
        return result_fail(root, 1, 1, "project has incomplete control-flow body nodes")
    }
    if result.imports <= 0 {
        return result_fail(root, 1, 1, "project has no imports")
    }
    if result.returns <= 0 {
        return result_fail(root, 1, 1, "project has no return statements")
    }
    if result.return_exprs <= 0 {
        return result_fail(root, 1, 1, "project has no return expressions")
    }
    if result.typed_decl_nodes <= 0 || result.typed_stmt_nodes <= 0 || result.typed_expr_nodes <= 0 || result.typed_type_nodes <= 0 {
        return result_fail(root, 1, 1, "project has incomplete typed AST shape")
    }
    if result.symbol_functions != result.functions || result.symbol_structs != result.structs || result.symbol_imports != result.imports {
        return result_fail(root, 1, 1, "project symbol table does not match parser declarations")
    }
    if result.symbol_modules <= 0 || result.symbol_std_imports <= 0 || result.symbol_import_aliases <= 0 {
        return result_fail(root, 1, 1, "project has incomplete module/import symbols")
    }
    if result.symbol_public <= 0 || result.symbol_local <= 0 || result.symbol_digest == 17 {
        return result_fail(root, 1, 1, "project has incomplete declaration symbols")
    }
    if result.symbol_import_digest == 17 || result.symbol_module_digest == 17 {
        return result_fail(root, 1, 1, "project has incomplete symbol digests")
    }
    if result.symbol_zero_param_functions + result.symbol_nonzero_param_functions != result.symbol_functions {
        return result_fail(root, 1, 1, "project function signature table does not match symbols")
    }
    if result.symbol_functions_with_return_type <= 0 || result.symbol_function_signature_digest == 17 {
        return result_fail(root, 1, 1, "project has incomplete function signature table")
    }
    if result.symbol_call_sites <= 0 || result.symbol_call_sites != result.calls {
        return result_fail(root, 1, 1, "project call-site arity table does not match parser calls")
    }
    if result.symbol_nonzero_arg_calls <= 0 || result.symbol_call_arity_digest == 17 {
        return result_fail(root, 1, 1, "project has incomplete call-site arity table")
    }
    if result.signature_nodes <= 0 || result.signature_digest == 17 {
        return result_fail(root, 1, 1, "project has no signature node table")
    }
    if result.signature_function_nodes != result.symbol_functions || result.signature_call_nodes != result.calls {
        return result_fail(root, 1, 1, "project signature node table does not match parser symbols")
    }
    if result.signature_arity_slots <= result.signature_function_nodes || result.signature_max_arity <= 0 {
        return result_fail(root, 1, 1, "project signature node table has no arity slots")
    }
    if result.signature_return_functions != result.symbol_functions_with_return_type {
        return result_fail(root, 1, 1, "project signature return table does not match symbols")
    }
    if result.signature_typed_return_functions <= 0 || result.signature_typed_return_functions > result.signature_return_functions {
        return result_fail(root, 1, 1, "project signature return type table is incomplete")
    }
    if result.expr_table_nodes <= 0 || result.expr_primary_nodes <= 0 || result.expr_table_digest == 17 {
        return result_fail(root, 1, 1, "project has no expression node table")
    }
    if result.expr_primary_nodes != result.expressions {
        return result_fail(root, 1, 1, "project expression node table does not match parser expressions")
    }
    if result.expr_call_nodes != result.calls || result.expr_member_nodes != result.members || result.expr_index_nodes != result.indexes {
        return result_fail(root, 1, 1, "project expression node table does not match parser expression shapes")
    }
    if result.expr_identifier_nodes <= 0 || result.expr_literal_nodes <= 0 || result.expr_string_nodes <= 0 {
        return result_fail(root, 1, 1, "project expression node table has incomplete primary nodes")
    }
    if result.expr_binary_nodes <= 0 || result.expr_unary_nodes <= 0 {
        return result_fail(root, 1, 1, "project expression node table has incomplete operator nodes")
    }
    if result.expr_slot_count != result.function_bodies || result.expr_nonempty_slots <= 0 {
        return result_fail(root, 1, 1, "project expression slot table does not match function bodies")
    }
    if result.expr_max_nodes_per_slot <= 0 || result.expr_slot_digest == 17 {
        return result_fail(root, 1, 1, "project has incomplete expression slot table")
    }
    if result.stmt_expr_links <= 0 || result.stmt_expr_digest == 17 {
        return result_fail(root, 1, 1, "project has incomplete statement-expression links")
    }
    if !result.has_main {
        return result_fail(root, 1, 1, "project has no main function")
    }
    return result
}
