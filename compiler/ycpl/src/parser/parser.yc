module compiler.ycpl.parser

import "ast/nodes" as ast
import "parser/real" as real

pub fn parse_ast(path string, source string) ProgramAst {
    return real.parse(path, source)
}

pub fn parse_ast_with_file(path string, source string, file_id i32) ProgramAst {
    result := real.parse(path, source)
    result.file_id = file_id
    return result
}
