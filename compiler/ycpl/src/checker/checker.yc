fn lookup_var(p TinyParser, name string) TinyParser {
    if p.vars > 0 && str.eq(p.name0, name) {
        p.value = p.value0
        p.value_type = p.type0
        return p
    }
    if p.vars > 1 && str.eq(p.name1, name) {
        p.value = p.value1
        p.value_type = p.type1
        return p
    }
    if p.vars > 2 && str.eq(p.name2, name) {
        p.value = p.value2
        p.value_type = p.type2
        return p
    }
    if p.vars > 3 && str.eq(p.name3, name) {
        p.value = p.value3
        p.value_type = p.type3
        return p
    }
    if p.vars > 4 && str.eq(p.name4, name) {
        p.value = p.value4
        p.value_type = p.type4
        return p
    }
    if p.vars > 5 && str.eq(p.name5, name) {
        p.value = p.value5
        p.value_type = p.type5
        return p
    }
    if p.vars > 6 && str.eq(p.name6, name) {
        p.value = p.value6
        p.value_type = p.type6
        return p
    }
    if p.vars > 7 && str.eq(p.name7, name) {
        p.value = p.value7
        p.value_type = p.type7
        return p
    }
    if p.vars > 8 && str.eq(p.name8, name) {
        p.value = p.value8
        p.value_type = p.type8
        return p
    }
    if p.vars > 9 && str.eq(p.name9, name) {
        p.value = p.value9
        p.value_type = p.type9
        return p
    }
    if p.vars > 10 && str.eq(p.name10, name) {
        p.value = p.value10
        p.value_type = p.type10
        return p
    }
    if p.vars > 11 && str.eq(p.name11, name) {
        p.value = p.value11
        p.value_type = p.type11
        return p
    }
    if p.vars > 12 && str.eq(p.name12, name) {
        p.value = p.value12
        p.value_type = p.type12
        return p
    }
    if p.vars > 13 && str.eq(p.name13, name) {
        p.value = p.value13
        p.value_type = p.type13
        return p
    }
    if p.vars > 14 && str.eq(p.name14, name) {
        p.value = p.value14
        p.value_type = p.type14
        return p
    }
    if p.vars > 15 && str.eq(p.name15, name) {
        p.value = p.value15
        p.value_type = p.type15
        return p
    }
    return fail_parser(p, "unknown local symbol")
}

fn set_var(p TinyParser, name string, value i32, type_kind i32) TinyParser {
    if p.vars > 0 && str.eq(p.name0, name) {
        p.value0 = value
        p.type0 = type_kind
        return p
    }
    if p.vars > 1 && str.eq(p.name1, name) {
        p.value1 = value
        p.type1 = type_kind
        return p
    }
    if p.vars > 2 && str.eq(p.name2, name) {
        p.value2 = value
        p.type2 = type_kind
        return p
    }
    if p.vars > 3 && str.eq(p.name3, name) {
        p.value3 = value
        p.type3 = type_kind
        return p
    }
    if p.vars > 4 && str.eq(p.name4, name) {
        p.value4 = value
        p.type4 = type_kind
        return p
    }
    if p.vars > 5 && str.eq(p.name5, name) {
        p.value5 = value
        p.type5 = type_kind
        return p
    }
    if p.vars > 6 && str.eq(p.name6, name) {
        p.value6 = value
        p.type6 = type_kind
        return p
    }
    if p.vars > 7 && str.eq(p.name7, name) {
        p.value7 = value
        p.type7 = type_kind
        return p
    }
    if p.vars > 8 && str.eq(p.name8, name) {
        p.value8 = value
        p.type8 = type_kind
        return p
    }
    if p.vars > 9 && str.eq(p.name9, name) {
        p.value9 = value
        p.type9 = type_kind
        return p
    }
    if p.vars > 10 && str.eq(p.name10, name) {
        p.value10 = value
        p.type10 = type_kind
        return p
    }
    if p.vars > 11 && str.eq(p.name11, name) {
        p.value11 = value
        p.type11 = type_kind
        return p
    }
    if p.vars > 12 && str.eq(p.name12, name) {
