        p.helper13_return_type = return_type
        return p
    }
    if p.helper_count > 14 && str.eq(p.helper14_name, name) {
        p.helper14_value = value
        p.helper14_params = param_count
        p.helper14_signature = param_signature
        p.helper14_return_type = return_type
        return p
    }
    if p.helper_count > 15 && str.eq(p.helper15_name, name) {
        p.helper15_value = value
        p.helper15_params = param_count
        p.helper15_signature = param_signature
        p.helper15_return_type = return_type
        return p
    }
    if p.helper_count == 0 {
        p.helper0_name = name
        p.helper0_value = value
        p.helper0_params = param_count
        p.helper0_signature = param_signature
        p.helper0_return_type = return_type
        p.helper_count = 1
        return p
    }
    if p.helper_count == 1 {
        p.helper1_name = name
        p.helper1_value = value
        p.helper1_params = param_count
        p.helper1_signature = param_signature
        p.helper1_return_type = return_type
        p.helper_count = 2
        return p
    }
    if p.helper_count == 2 {
        p.helper2_name = name
        p.helper2_value = value
        p.helper2_params = param_count
        p.helper2_signature = param_signature
        p.helper2_return_type = return_type
        p.helper_count = 3
        return p
    }
    if p.helper_count == 3 {
        p.helper3_name = name
        p.helper3_value = value
        p.helper3_params = param_count
        p.helper3_signature = param_signature
        p.helper3_return_type = return_type
        p.helper_count = 4
        return p
    }
    if p.helper_count == 4 {
        p.helper4_name = name
        p.helper4_value = value
        p.helper4_params = param_count
        p.helper4_signature = param_signature
        p.helper4_return_type = return_type
        p.helper_count = 5
        return p
    }
    if p.helper_count == 5 {
        p.helper5_name = name
        p.helper5_value = value
        p.helper5_params = param_count
        p.helper5_signature = param_signature
        p.helper5_return_type = return_type
        p.helper_count = 6
        return p
    }
    if p.helper_count == 6 {
        p.helper6_name = name
        p.helper6_value = value
        p.helper6_params = param_count
        p.helper6_signature = param_signature
        p.helper6_return_type = return_type
        p.helper_count = 7
        return p
    }
    if p.helper_count == 7 {
        p.helper7_name = name
        p.helper7_value = value
        p.helper7_params = param_count
        p.helper7_signature = param_signature
        p.helper7_return_type = return_type
        p.helper_count = 8
        return p
    }
    if p.helper_count == 8 {
        p.helper8_name = name
        p.helper8_value = value
        p.helper8_params = param_count
        p.helper8_signature = param_signature
        p.helper8_return_type = return_type
        p.helper_count = 9
        return p
    }
    if p.helper_count == 9 {
        p.helper9_name = name
        p.helper9_value = value
        p.helper9_params = param_count
        p.helper9_signature = param_signature
        p.helper9_return_type = return_type
        p.helper_count = 10
        return p
    }
    if p.helper_count == 10 {
        p.helper10_name = name
        p.helper10_value = value
        p.helper10_params = param_count
        p.helper10_signature = param_signature
        p.helper10_return_type = return_type
        p.helper_count = 11
        return p
    }
    if p.helper_count == 11 {
        p.helper11_name = name
        p.helper11_value = value
        p.helper11_params = param_count
        p.helper11_signature = param_signature
        p.helper11_return_type = return_type
        p.helper_count = 12
        return p
    }
    if p.helper_count == 12 {
        p.helper12_name = name
        p.helper12_value = value
        p.helper12_params = param_count
        p.helper12_signature = param_signature
        p.helper12_return_type = return_type
        p.helper_count = 13
        return p
    }
    if p.helper_count == 13 {
        p.helper13_name = name
        p.helper13_value = value
        p.helper13_params = param_count
        p.helper13_signature = param_signature
        p.helper13_return_type = return_type
        p.helper_count = 14
        return p
    }
    if p.helper_count == 14 {
        p.helper14_name = name
        p.helper14_value = value
        p.helper14_params = param_count
        p.helper14_signature = param_signature
        p.helper14_return_type = return_type
        p.helper_count = 15
        return p
    }
    if p.helper_count == 15 {
        p.helper15_name = name
        p.helper15_value = value
        p.helper15_params = param_count
        p.helper15_signature = param_signature
        p.helper15_return_type = return_type
        p.helper_count = 16
        return p
    }
    return unsupported_parser(p, "self checker currently supports up to 16 helper functions")
}

fn parse_factor(p TinyParser) TinyParser {
    if !p.ok { return p }

    if p.lx.kind == tok.bang() {
        p = advance_sig(p)
        p = parse_factor(p)
        if !p.ok { return p }
        p = ensure_bool_value(p)
        if !p.ok { return p }
        if p.value == 0 {
            p.value = 1
        } else {
            p.value = 0
        }
        p.value_type = tiny_bool_type_kind()
        return p
    }

    sign := 1
    if p.lx.kind == tok.minus() {
        sign = -1
        p = advance_sig(p)
    }

    if p.lx.kind == tok.lparen() {
        p = advance_sig(p)
        p = parse_expr(p)
        if !p.ok { return p }
        if p.lx.kind != tok.rparen() {
            return fail_parser(p, "expected ')' after expression")
        }
        if sign < 0 {
            p = ensure_i32_value(p, "self checker unary minus requires i32")
            if !p.ok { return p }
            p.value = -p.value
        }
        return advance_sig(p)
    }

    if p.lx.kind == tok.int_lit() {
        p.value = parse_i32(p.lx.lexeme) * sign
        p.value_type = tiny_i32_type_kind()
        return advance_sig(p)
    }

    if p.lx.kind == tok.bool_lit() {
        if sign < 0 {
            return unsupported_parser(p, "self checker unary minus requires i32")
        }
        if str.eq(p.lx.lexeme, "true") {
            p.value = 1
        } else {
            p.value = 0
        }
        p.value_type = tiny_bool_type_kind()
        return advance_sig(p)
    }

    if p.lx.kind == tok.string_lit() {
        if sign < 0 {
            return unsupported_parser(p, "self checker unary minus requires i32")
        }
        p.value = 1
        p.value_type = tiny_string_type_kind()
        return advance_sig(p)
    }

    if p.lx.kind == tok.none_lit() {
        if sign < 0 {
            return unsupported_parser(p, "self checker unary minus requires i32")
        }
        p.value = 0
        p.value_type = tiny_ptr_type_kind()
        return advance_sig(p)
    }

    if p.lx.kind == tok.ident() {
        name := p.lx.lexeme
        p = advance_sig(p)
        if !p.ok { return p }

        if p.lx.kind == tok.lbrack() {
            p = lookup_var(p, name)
            if !p.ok { return p }
            if p.value_type != tiny_i32_array3_type_kind() {
                return unsupported_parser(p, "self checker index expression requires i32[3] local")
            }
            p = advance_sig(p)
            p = parse_expr_or_comparison(p)
            if !p.ok { return p }
            p = ensure_i32_value(p, "self checker array index requires i32")
            if !p.ok { return p }
            index := p.value
            if p.lx.kind != tok.rbrack() {
                return fail_parser(p, "expected ']' after array index")
            }
            p = load_array3_value(p, name, index)
            if !p.ok { return p }
            if sign < 0 {
                p.value = -p.value
            }
            return advance_sig(p)
        }

        if p.lx.kind == tok.lparen() {
            p = advance_sig(p)
            p = lookup_helper(p, name)
            if !p.ok { return p }
            callee_value := p.helper_value
            callee_param_count := p.helper_param_count
            callee_signature := p.helper_signature
            callee_return_type := p.helper_return_type
            if p.lx.kind == tok.rparen() {
                if callee_param_count != 0 {
                    return unsupported_parser(p, "self checker helper call arity mismatch")
                }
                p.value = callee_value * sign
                p.value_type = callee_return_type
                if sign < 0 {
                    p = ensure_i32_value(p, "self checker unary minus requires i32")
                    if !p.ok { return p }
                }
                return advance_sig(p)
            }
            p = parse_expr_or_comparison(p)
            if !p.ok { return p }
            p = ensure_value_type(p, tiny_signature_param(callee_signature, 0), "self checker helper argument type mismatch")
            if !p.ok { return p }
            arg_value := p.value
            arg1_value := arg_value
            arg2_value := arg_value
            arg3_value := arg_value
            arg4_value := arg_value
            arg5_value := arg_value
            arg6_value := arg_value
            arg7_value := arg_value
            arg_count := 1
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 1), "self checker helper argument type mismatch")
                if !p.ok { return p }
                arg1_value = p.value
                arg_count = 2
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 2), "self checker helper argument type mismatch")
                if !p.ok { return p }
                arg2_value = p.value
                arg_count = 3
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 3), "self checker helper argument type mismatch")
                if !p.ok { return p }
                arg3_value = p.value
                arg_count = 4
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 4), "self checker helper argument type mismatch")
                if !p.ok { return p }
                arg4_value = p.value
                arg_count = 5
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 5), "self checker helper argument type mismatch")
                if !p.ok { return p }
                arg5_value = p.value
                arg_count = 6
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 6), "self checker helper argument type mismatch")
                if !p.ok { return p }
                arg6_value = p.value
                arg_count = 7
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 7), "self checker helper argument type mismatch")
                if !p.ok { return p }
                arg7_value = p.value
                arg_count = 8
            }
            if p.lx.kind != tok.rparen() {
                return unsupported_parser(p, "self checker currently supports up to eight helper arguments")
            }
            if callee_param_count != arg_count {
                return unsupported_parser(p, "self checker helper call arity mismatch")
            }
            if arg_count == 1 && tiny_signature_param(callee_signature, 0) == tiny_i32_struct3_type_kind() && callee_return_type == tiny_i32_type_kind() {
                p.value = ((arg_value % 1000) + ((arg_value / 1000) % 1000) + (arg_value / 1000000) + callee_value) * sign
            } else if arg_count == 1 && tiny_signature_param(callee_signature, 0) == tiny_i32_struct2_type_kind() && callee_return_type == tiny_i32_type_kind() {
                p.value = ((arg_value % 100000) + (arg_value / 100000) + callee_value) * sign
            } else if arg_count == 1 {
                p.value = (arg_value + callee_value) * sign
            } else if arg_count == 2 {
                p.value = (arg_value + arg1_value + callee_value) * sign
            } else if arg_count == 3 {
                p.value = (arg_value + arg1_value + arg2_value + callee_value) * sign
            } else if arg_count == 4 {
                p.value = (arg_value + arg1_value + arg2_value + arg3_value + callee_value) * sign
            } else if arg_count == 5 {
                p.value = (arg_value + arg1_value + arg2_value + arg3_value + arg4_value + callee_value) * sign
            } else if arg_count == 6 {
                p.value = (arg_value + arg1_value + arg2_value + arg3_value + arg4_value + arg5_value + callee_value) * sign
            } else if arg_count == 7 {
                p.value = (arg_value + arg1_value + arg2_value + arg3_value + arg4_value + arg5_value + arg6_value + callee_value) * sign
            } else {
                p.value = (arg_value + arg1_value + arg2_value + arg3_value + arg4_value + arg5_value + arg6_value + arg7_value + callee_value) * sign
            }
            p.value_type = callee_return_type
            if sign < 0 {
                p = ensure_i32_value(p, "self checker unary minus requires i32")
                if !p.ok { return p }
            }
            return advance_sig(p)
        }

        if p.lx.kind == tok.dot() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected member name after '.'")
            }
            field := p.lx.lexeme
            p = load_struct2_field(p, name, field)
            if !p.ok { return p }
            if sign < 0 {
                p.value = -p.value
            }
            return advance_sig(p)
        }

        p = lookup_var(p, name)
        if !p.ok { return p }
        if sign < 0 {
            p = ensure_i32_value(p, "self checker unary minus requires i32")
            if !p.ok { return p }
        }
        p.value = p.value * sign
        return p
    }

    return unsupported_parser(p, "self checker currently supports i32/bool literals, locals, array indexes, and helper call expressions")
}

fn parse_term(p TinyParser) TinyParser {
    p = parse_factor(p)
    for (; p.ok && (p.lx.kind == tok.star() || p.lx.kind == tok.slash() || p.lx.kind == tok.percent()); ) {
        op := p.lx.kind
        p = ensure_i32_value(p, "self checker arithmetic currently requires i32 operands")
        if !p.ok { return p }
        left := p.value
        p = advance_sig(p)
        p = parse_factor(p)
        if !p.ok { return p }
        p = ensure_i32_value(p, "self checker arithmetic currently requires i32 operands")
        if !p.ok { return p }
        right := p.value
        if op == tok.star() {
            p.value = left * right
        } else if op == tok.slash() {
            if right == 0 {
                return fail_parser(p, "division by zero in constant expression")
            }
            p.value = left / right
        } else {
            if right == 0 {
                return fail_parser(p, "modulo by zero in constant expression")
            }
            p.value = left % right
        }
        p.value_type = tiny_i32_type_kind()
    }
    return p
}

fn parse_expr(p TinyParser) TinyParser {
    p = parse_term(p)
    for (; p.ok && (p.lx.kind == tok.plus() || p.lx.kind == tok.minus()); ) {
        op := p.lx.kind
        p = ensure_i32_value(p, "self checker arithmetic currently requires i32 operands")
        if !p.ok { return p }
        left := p.value
        p = advance_sig(p)
        p = parse_term(p)
        if !p.ok { return p }
        p = ensure_i32_value(p, "self checker arithmetic currently requires i32 operands")
        if !p.ok { return p }
        if op == tok.plus() {
            p.value = left + p.value
        } else {
            p.value = left - p.value
        }
        p.value_type = tiny_i32_type_kind()
    }
    return p
}

fn compare_values(op i32, left i32, right i32) i32 {
    if op == tok.eq() {
        if left == right { return 1 }
        return 0
    }
    if op == tok.neq() {
        if left != right { return 1 }
        return 0
    }
    if op == tok.lt() {
        if left < right { return 1 }
        return 0
    }
    if op == tok.gt() {
        if left > right { return 1 }
        return 0
    }
    if op == tok.le() {
        if left <= right { return 1 }
        return 0
    }
    if op == tok.ge() {
        if left >= right { return 1 }
        return 0
    }
    return 0
}

fn parse_condition(p TinyParser) TinyParser {
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    return ensure_bool_value(p)
}

fn parse_expr_or_comparison(p TinyParser) TinyParser {
    p = parse_expr(p)
    if !p.ok { return p }
    left := p.value
    left_type := p.value_type
    op := p.lx.kind
    if op != tok.eq() && op != tok.neq() && op != tok.lt() && op != tok.gt() && op != tok.le() && op != tok.ge() {
        return p
    }
    p = advance_sig(p)
    p = parse_expr(p)
    if !p.ok { return p }
    if left_type != p.value_type {
        return unsupported_parser(p, "self checker comparison operands must have the same type")
    }
    if left_type == tiny_bool_type_kind() && op != tok.eq() && op != tok.neq() {
        return unsupported_parser(p, "self checker bool comparisons support == and !=")
    }
    p.value = compare_values(op, left, p.value)
    p.value_type = tiny_bool_type_kind()
    return p
}

fn skip_import_or_module(p TinyParser) TinyParser {
    for (; p.ok && p.lx.kind != tok.eof() && p.lx.kind != tok.newline(); ) {
        p.lx = lexer.next(p.lx)
        if !p.lx.ok {
            p.ok = false
            p.supported = true
            p.message = p.lx.message
            p.line = p.lx.tok_line
            p.col = p.lx.tok_col
            return p
        }
    }
    return advance_sig(p)
}

fn skip_block(p TinyParser) TinyParser {
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected block")
    }
    depth := 1
    p = advance_sig(p)
    for (; p.ok && depth > 0 && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.lbrace() {
            depth += 1
        } else if p.lx.kind == tok.rbrace() {
            depth -= 1
        }
        p = advance_sig(p)
    }
    if !p.ok { return p }
    if depth != 0 {
        return fail_parser(p, "expected '}' after block")
    }
    return p
}

fn skip_to_block_end(p TinyParser) TinyParser {
    depth := 0
    for (; p.ok && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.lbrace() {
            depth += 1
        } else if p.lx.kind == tok.rbrace() {
            if depth == 0 {
                return p
            }
            depth -= 1
        }
        p = advance_sig(p)
    }
    return p
}

fn skip_function_body(p TinyParser) TinyParser {
    if p.lx.kind != tok.kw_fn() {
        return unsupported_parser(p, "self checker currently supports fn declarations")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected function name")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.lparen() {
        return fail_parser(p, "expected '(' after function name")
    }
    depth := 1
    p = advance_sig(p)
    for (; p.ok && depth > 0 && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.lparen() {
            depth += 1
        } else if p.lx.kind == tok.rparen() {
            depth -= 1
        }
        p = advance_sig(p)
    }
    if !p.ok { return p }
    if depth != 0 {
        return fail_parser(p, "expected ')' after function parameters")
    }
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected function return type")
    }
    return_type := tiny_type_from_name(p.lx.lexeme)
    if return_type == 0 {
        return unsupported_parser(p, "self checker currently supports i32, bool, and string return types")
    }
    p = advance_sig(p)
    return skip_block(p)
}

fn parse_type_name(p TinyParser, message string) TinyParser {
    if p.lx.kind == tok.star() {
        p = advance_sig(p)
        if p.lx.kind == tok.kw_byte() || (p.lx.kind == tok.ident() && str.eq(p.lx.lexeme, "string")) {
            p.value_type = tiny_ptr_type_kind()
            return advance_sig(p)
        }
        return unsupported_parser(p, "self checker currently supports only *byte and *string pointer types")
    }
    if p.lx.kind != tok.ident() {
        return fail_parser(p, message)
    }
    if p.saw_struct && str.eq(p.lx.lexeme, p.struct_name) {
        if p.struct_fields == 3 {
            p.value_type = tiny_i32_struct3_type_kind()
        } else {
            p.value_type = tiny_i32_struct2_type_kind()
        }
        return advance_sig(p)
    }
    p.value_type = tiny_type_from_name(p.lx.lexeme)
    if p.value_type == 0 {
        return unsupported_parser(p, "self checker currently supports i32, i64, bool, string, *byte, and *string types")
    }
    return advance_sig(p)
}

fn scan_struct_decl(p TinyParser) TinyParser {
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected struct name")
    }
    p.struct_name = p.lx.lexeme
    p = advance_sig(p)
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after struct name")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected struct field name")
    }
    p.struct_field0 = p.lx.lexeme
    p = advance_sig(p)
    p = parse_type_name(p, "expected struct field type")
    if !p.ok { return p }
    if p.value_type != tiny_i32_type_kind() {
        return unsupported_parser(p, "self checker currently supports two- or three-field i32 structs")
    }
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected second struct field name")
    }
    p.struct_field1 = p.lx.lexeme
    p = advance_sig(p)
    p = parse_type_name(p, "expected struct field type")
    if !p.ok { return p }
    if p.value_type != tiny_i32_type_kind() {
        return unsupported_parser(p, "self checker currently supports two- or three-field i32 structs")
    }
    p.struct_fields = 2
    if p.lx.kind == tok.ident() {
        p.struct_field2 = p.lx.lexeme
        p = advance_sig(p)
        p = parse_type_name(p, "expected struct field type")
        if !p.ok { return p }
        if p.value_type != tiny_i32_type_kind() {
            return unsupported_parser(p, "self checker currently supports two- or three-field i32 structs")
        }
        p.struct_fields = 3
    }
    if p.lx.kind != tok.rbrace() {
        return unsupported_parser(p, "self checker currently supports two or three i32 struct fields")
    }
    p.saw_struct = true
    return advance_sig(p)
}

fn scan_extern_value(p TinyParser) TinyParser {
    p = advance_sig(p)
    if p.lx.kind != tok.kw_fn() {
        return fail_parser(p, "expected fn after extern")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected extern function name")
    }
    source_name := p.lx.lexeme
    p = advance_sig(p)
    if p.lx.kind != tok.lparen() {
        return fail_parser(p, "expected '(' after extern function name")
    }
    p = advance_sig(p)
    param_count := 0
    param0_type := 0
    param1_type := 0
    param2_type := 0
    param3_type := 0
    param4_type := 0
    param5_type := 0
    param6_type := 0
    param7_type := 0
    if p.lx.kind != tok.rparen() {
        if p.lx.kind != tok.ident() {
            return fail_parser(p, "expected extern parameter name")
        }
        p = advance_sig(p)
        p = parse_type_name(p, "expected extern parameter type")
        if !p.ok { return p }
        param0_type = p.value_type
        param_count = 1
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param1_type = p.value_type
            param_count = 2
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param2_type = p.value_type
            param_count = 3
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param3_type = p.value_type
            param_count = 4
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param4_type = p.value_type
            param_count = 5
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param5_type = p.value_type
            param_count = 6
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param6_type = p.value_type
            param_count = 7
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param7_type = p.value_type
            param_count = 8
        }
        if p.lx.kind != tok.rparen() {
            return unsupported_parser(p, "self checker currently supports up to eight extern parameters")
        }
    }
    p = advance_sig(p)
    return_type := tiny_void_type_kind()
    if p.lx.kind == tok.ident() || p.lx.kind == tok.star() {
        p = parse_type_name(p, "expected extern return type")
        if !p.ok { return p }
        return_type = p.value_type
    }
    if p.lx.kind == tok.kw_as() {
        p = advance_sig(p)
        if p.lx.kind != tok.string_lit() {
            return fail_parser(p, "expected extern symbol name")
        }
        p = advance_sig(p)
    }
    if p.lx.kind == tok.lbrace() {
        return fail_parser(p, "extern function cannot have a body")
    }
    value := 0
    if return_type == tiny_string_type_kind() || return_type == tiny_bool_type_kind() || return_type == tiny_ptr_type_kind() {
        value = 1
    }
    signature := tiny_signature8(param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, param6_type, param7_type)
    return add_helper(p, source_name, value, param_count, signature, return_type)
}

fn skip_extern_decl(p TinyParser) TinyParser {
    for (; p.ok && p.lx.kind != tok.eof() && p.lx.kind != tok.newline(); ) {
        if p.lx.kind == tok.lbrace() {
            return fail_parser(p, "extern function cannot have a body")
        }
        p.lx = lexer.next(p.lx)
        if !p.lx.ok {
            p.ok = false
            p.supported = true
            p.message = p.lx.message
            p.line = p.lx.tok_line
            p.col = p.lx.tok_col
            return p
        }
    }
    return advance_sig(p)
}

fn scan_helper_values(p TinyParser) TinyParser {
    p = advance_sig(p)
    if !p.ok { return p }
    for (; p.lx.kind == tok.kw_import() || p.lx.kind == tok.kw_module() || p.lx.kind == tok.kw_package(); ) {
        p = skip_import_or_module(p)
        if !p.ok { return p }
    }
    for (; p.ok && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.kw_extern() {
            p = scan_extern_value(p)
            if !p.ok { return p }
            continue
        }
        if p.lx.kind == tok.kw_struct() {
            p = scan_struct_decl(p)
            if !p.ok { return p }
            continue
        }
        if p.lx.kind != tok.kw_fn() {
            return unsupported_parser(p, "self checker currently supports fn declarations")
        }
        probe := p
        probe = advance_sig(probe)
        if !probe.ok { return probe }
        if probe.lx.kind != tok.ident() {
            return fail_parser(probe, "expected function name")
        }
        if str.eq(probe.lx.lexeme, "main") {
            p = skip_function_body(p)
        } else {
            p = parse_function(p)
        }
        if !p.ok { return p }
    }
    return p
}

fn parse_i32_array3_local(p TinyParser, name string) TinyParser {
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker i32[3] array literal requires i32 elements")
    if !p.ok { return p }
    value0 := p.value
    if p.lx.kind != tok.comma() {
        return fail_parser(p, "expected ',' in i32[3] array literal")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker i32[3] array literal requires i32 elements")
    if !p.ok { return p }
    value1 := p.value
    if p.lx.kind != tok.comma() {
        return fail_parser(p, "expected ',' in i32[3] array literal")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker i32[3] array literal requires i32 elements")
    if !p.ok { return p }
    value2 := p.value
    if p.lx.kind != tok.rbrack() {
        return fail_parser(p, "expected ']' after i32[3] array literal")
    }
    p = advance_sig(p)
    return set_array3_var(p, name, value0, value1, value2)
}

fn parse_struct2_local(p TinyParser, name string) TinyParser {
    if !p.saw_struct {
        return unsupported_parser(p, "self checker struct literal requires a struct declaration")
    }
    if p.lx.kind != tok.ident() || !str.eq(p.lx.lexeme, p.struct_name) {
        return unsupported_parser(p, "self checker struct literal type mismatch")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after struct literal type")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() || !str.eq(p.lx.lexeme, p.struct_field0) {
        return fail_parser(p, "expected first struct field initializer")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.colon() {
        return fail_parser(p, "expected ':' after struct field name")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker struct field initializer requires i32")
    if !p.ok { return p }
    value0 := p.value
    if p.lx.kind == tok.comma() {
        p = advance_sig(p)
    }
    if p.lx.kind != tok.ident() || !str.eq(p.lx.lexeme, p.struct_field1) {
        return fail_parser(p, "expected second struct field initializer")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.colon() {
        return fail_parser(p, "expected ':' after struct field name")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker struct field initializer requires i32")
    if !p.ok { return p }
    value1 := p.value
    value2 := 0
    if p.struct_fields == 3 {
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
        }
        if p.lx.kind != tok.ident() || !str.eq(p.lx.lexeme, p.struct_field2) {
            return fail_parser(p, "expected third struct field initializer")
        }
        p = advance_sig(p)
        if p.lx.kind != tok.colon() {
            return fail_parser(p, "expected ':' after struct field name")
        }
        p = advance_sig(p)
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        p = ensure_i32_value(p, "self checker struct field initializer requires i32")
        if !p.ok { return p }
        value2 = p.value
    }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after struct literal")
    }
    p = advance_sig(p)
    if p.struct_fields == 3 {
        return set_var(p, name, pack_struct3(value0, value1, value2), tiny_i32_struct3_type_kind())
    }
    return set_var(p, name, pack_struct2(value0, value1), tiny_i32_struct2_type_kind())
}

fn parse_array3_assignment(p TinyParser, name string) TinyParser {
    p = lookup_var(p, name)
    if !p.ok { return p }
    if p.value_type != tiny_i32_array3_type_kind() {
        return unsupported_parser(p, "self checker indexed assignment requires i32[3] local")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker array index requires i32")
    if !p.ok { return p }
    index := p.value
    if p.lx.kind != tok.rbrack() {
        return fail_parser(p, "expected ']' after array index")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.assign() {
        return fail_parser(p, "expected '=' after indexed assignment target")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker indexed assignment requires i32 value")
    if !p.ok { return p }
    return set_array3_element_value(p, name, index, p.value)
}

fn parse_struct2_member_assignment(p TinyParser, name string) TinyParser {
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected member name after '.'")
    }
    field := p.lx.lexeme
    p = advance_sig(p)
    if p.lx.kind != tok.assign() {
        return fail_parser(p, "expected '=' after member assignment target")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker member assignment requires i32 value")
    if !p.ok { return p }
    return set_struct2_field(p, name, field, p.value)
}

fn parse_var_or_assign(p TinyParser) TinyParser {
    name := p.lx.lexeme
    p = advance_sig(p)
    if !p.ok { return p }

    if p.lx.kind == tok.lbrack() {
        return parse_array3_assignment(p, name)
    }

    if p.lx.kind == tok.dot() {
        return parse_struct2_member_assignment(p, name)
    }

    if is_declare_assign(p.lx.kind, p.lx.lexeme) {
        p = advance_sig(p)
        if p.lx.kind == tok.lbrack() {
            return parse_i32_array3_local(p, name)
        }
        if p.saw_struct && p.lx.kind == tok.ident() && str.eq(p.lx.lexeme, p.struct_name) {
            return parse_struct2_local(p, name)
        }
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        if p.value_type == tiny_void_type_kind() {
            return unsupported_parser(p, "self checker cannot store void expression in a local")
        }
        return set_var(p, name, p.value, p.value_type)
    }

    if p.lx.kind == tok.colon() {
        p = advance_sig(p)
        if p.lx.kind == tok.assign() {
            p = advance_sig(p)
            if p.lx.kind == tok.lbrack() {
                return parse_i32_array3_local(p, name)
            }
            if p.saw_struct && p.lx.kind == tok.ident() && str.eq(p.lx.lexeme, p.struct_name) {
                return parse_struct2_local(p, name)
            }
            p = parse_expr_or_comparison(p)
            if !p.ok { return p }
            if p.value_type == tiny_void_type_kind() {
                return unsupported_parser(p, "self checker cannot store void expression in a local")
            }
            return set_var(p, name, p.value, p.value_type)
        }
        if p.lx.kind != tok.ident() {
            return fail_parser(p, "expected local type")
        }
        declared_type := tiny_type_from_name(p.lx.lexeme)
        if declared_type == 0 {
            return unsupported_parser(p, "self codegen currently supports only i32 and bool local variables")
        }
        p = advance_sig(p)
        if p.lx.kind != tok.assign() {
            return fail_parser(p, "expected '=' after local type")
        }
        p = advance_sig(p)
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        p = ensure_value_type(p, declared_type, "self checker local initializer type mismatch")
        if !p.ok { return p }
        return set_var(p, name, p.value, declared_type)
    }

    if p.lx.kind == tok.assign() {
        p = lookup_var(p, name)
        if !p.ok { return p }
        slot_type := p.value_type
        p = advance_sig(p)
        if p.lx.kind == tok.assign() {
            return unsupported_parser(p, "self codegen does not support comparison statements yet")
        }
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        p = ensure_value_type(p, slot_type, "self checker assignment type mismatch")
        if !p.ok { return p }
        return set_var(p, name, p.value, slot_type)
    }

    return unsupported_parser(p, "self codegen currently supports i32/bool local declarations and assignments")
}

fn parse_block_body(p TinyParser) TinyParser {
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' to start block")
    }
    p = advance_sig(p)
    for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
        p = parse_statement(p)
        if !p.ok { return p }
        if p.returned || p.loop_break || p.loop_continue {
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.lx.kind == tok.semicolon() {
            p = advance_sig(p)
        }
    }
    if !p.ok { return p }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after block")
    }
    return advance_sig(p)
}

fn parse_if_statement(p TinyParser) TinyParser {
    p = advance_sig(p)
    p = parse_condition(p)
    if !p.ok { return p }
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after if condition")
    }
    if p.value != 0 {
        p = parse_block_body(p)
        if !p.ok { return p }
        if p.lx.kind == tok.kw_else() {
            p = advance_sig(p)
            return skip_block(p)
        }
        return p
    }
    p = skip_block(p)
    if !p.ok { return p }
    if p.lx.kind == tok.kw_else() {
        p = advance_sig(p)
        return parse_block_body(p)
    }
    return p
}

fn parse_for_in_statement(p TinyParser, item_name string) TinyParser {
    p = advance_sig(p)
    if p.lx.kind == tok.ident() {
        array_name := p.lx.lexeme
        probe := lookup_var(p, array_name)
        if probe.ok && probe.value_type == tiny_i32_array3_type_kind() {
            p = probe
            p = advance_sig(p)
            if p.lx.kind != tok.lbrace() {
                return fail_parser(p, "expected '{' after for-in header")
            }
            body_lx := p.lx
            skipped := skip_block(p)
            if !skipped.ok { return skipped }
            after_lx := skipped.lx

            index := 0
            for (; index < 3; index++) {
                p = load_array3_value(p, array_name, index)
                if !p.ok { return p }
                item_value := p.value
                p = set_var(p, item_name, item_value, tiny_i32_type_kind())
                if !p.ok { return p }
                body_run := p
                body_run.lx = body_lx
                body_run = parse_block_body(body_run)
                if !body_run.ok { return body_run }
                p = body_run
                if p.returned {
                    p.lx = after_lx
                    return p
                }
                if p.loop_break {
                    p.loop_break = false
                    p.loop_continue = false
                    p.lx = after_lx
                    return p
                }
                if p.loop_continue {
                    p.loop_continue = false
                }
            }
            p.lx = after_lx
            return p
        }
    }

    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self checker numeric for-in limit requires i32")
    if !p.ok { return p }
    limit := p.value
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after for-in header")
    }
    body_lx := p.lx
    skipped := skip_block(p)
    if !skipped.ok { return skipped }
    after_lx := skipped.lx

    index := 0
    for (; index < limit; index++) {
        p = set_var(p, item_name, index, tiny_i32_type_kind())
        if !p.ok { return p }
        body_run := p
        body_run.lx = body_lx
        body_run = parse_block_body(body_run)
        if !body_run.ok { return body_run }
        p = body_run
        if p.returned {
            p.lx = after_lx
            return p
        }
        if p.loop_break {
            p.loop_break = false
            p.loop_continue = false
            p.lx = after_lx
            return p
        }
        if p.loop_continue {
            p.loop_continue = false
        }
    }
    p.lx = after_lx
    return p
}

fn parse_for_statement(p TinyParser) TinyParser {
    p = advance_sig(p)
    if p.lx.kind == tok.ident() {
        item_name := p.lx.lexeme
        probe := p
        probe = advance_sig(probe)
        if !probe.ok { return probe }
        if probe.lx.kind == tok.kw_in() {
            return parse_for_in_statement(probe, item_name)
        }
    }
    if p.lx.kind != tok.lparen() {
        return unsupported_parser(p, "self checker currently supports C-style for loops only")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected for-loop initializer")
    }
    p = parse_var_or_assign(p)
    if !p.ok { return p }
    if p.lx.kind != tok.semicolon() {
        return fail_parser(p, "expected ';' after for-loop initializer")
    }

    p = advance_sig(p)
    cond_lx := p.lx
    cond_probe := p
    cond_probe = parse_condition(cond_probe)
    if !cond_probe.ok { return cond_probe }
    if cond_probe.lx.kind != tok.semicolon() {
        return fail_parser(cond_probe, "expected ';' after for-loop condition")
    }

    update_probe := cond_probe
    update_probe = advance_sig(update_probe)
    update_lx := update_probe.lx
    if update_probe.lx.kind != tok.ident() {
        return fail_parser(update_probe, "expected for-loop update")
    }
    update_probe = parse_var_or_assign(update_probe)
    if !update_probe.ok { return update_probe }
    if update_probe.lx.kind != tok.rparen() {
        return fail_parser(update_probe, "expected ')' after for-loop update")
    }
    update_probe = advance_sig(update_probe)
    if update_probe.lx.kind != tok.lbrace() {
        return fail_parser(update_probe, "expected '{' after for-loop header")
    }
    body_lx := update_probe.lx
    skipped := skip_block(update_probe)
    if !skipped.ok { return skipped }
    after_lx := skipped.lx

    iterations := 0
    for (; true; ) {
        if iterations > 4096 {
            return fail_parser(p, "self checker loop iteration limit exceeded")
        }
        cond_run := p
        cond_run.lx = cond_lx
        cond_run = parse_condition(cond_run)
        if !cond_run.ok { return cond_run }
        if cond_run.value == 0 {
            p.lx = after_lx
            return p
        }

        body_run := p
        body_run.lx = body_lx
        body_run = parse_block_body(body_run)
        if !body_run.ok { return body_run }
        if body_run.returned {
            body_run.lx = after_lx
            return body_run
        }
        if body_run.loop_break {
            body_run.loop_break = false
            body_run.loop_continue = false
            body_run.lx = after_lx
            return body_run
        }

        update_run := body_run
        if update_run.loop_continue {
            update_run.loop_continue = false
        }
        update_run.lx = update_lx
        update_run = parse_var_or_assign(update_run)
        if !update_run.ok { return update_run }
        if update_run.lx.kind != tok.rparen() {
            return fail_parser(update_run, "expected ')' after for-loop update")
        }
        p = update_run
        iterations += 1
    }
    return p
}

fn parse_statement(p TinyParser) TinyParser {
    if p.lx.kind == tok.kw_break() {
        p.loop_break = true
        return advance_sig(p)
    }

    if p.lx.kind == tok.kw_continue() {
        p.loop_continue = true
        return advance_sig(p)
    }

    if p.lx.kind == tok.kw_return() {
        p = advance_sig(p)
        if p.current_return_type == tiny_void_type_kind() {
            if p.lx.kind == tok.newline() || p.lx.kind == tok.semicolon() || p.lx.kind == tok.rbrace() {
                p.return_value = 0
                p.value_type = tiny_void_type_kind()
                p.returned = true
                return p
            }
        }
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        p = ensure_value_type(p, p.current_return_type, "self checker return expression type mismatch")
        if !p.ok { return p }
        p.return_value = p.value
        p.returned = true
        return p
    }

    if p.lx.kind == tok.kw_if() {
        return parse_if_statement(p)
    }

    if p.lx.kind == tok.kw_for() {
        return parse_for_statement(p)
    }

    if p.lx.kind == tok.ident() {
        probe := p
        probe = advance_sig(probe)
        if !probe.ok { return probe }
        if probe.lx.kind == tok.lparen() {
            p = parse_expr_or_comparison(p)
            if !p.ok { return p }
            return p
        }
        return parse_var_or_assign(p)
    }

    return unsupported_parser(p, "self codegen currently supports local statements, if, for, and return")
}

fn parse_function(p TinyParser) TinyParser {
    if p.lx.kind != tok.kw_fn() {
        return unsupported_parser(p, "self checker currently supports fn main() i32 plus helper functions")
    }

    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected function name")
    }
    name := p.lx.lexeme
    is_main := str.eq(name, "main")

    p = advance_sig(p)
    if p.lx.kind != tok.lparen() {
        return fail_parser(p, "expected '(' after function name")
    }
    p = advance_sig(p)
    param_count := 0
    param_name := ""
    param1_name := ""
    param2_name := ""
    param3_name := ""
    param4_name := ""
    param5_name := ""
    param6_name := ""
    param7_name := ""
    param0_type := tiny_i32_type_kind()
    param1_type := tiny_i32_type_kind()
    param2_type := tiny_i32_type_kind()
    param3_type := tiny_i32_type_kind()
    param4_type := tiny_i32_type_kind()
    param5_type := tiny_i32_type_kind()
    param6_type := tiny_i32_type_kind()
    param7_type := tiny_i32_type_kind()
    if p.lx.kind != tok.rparen() {
        if p.lx.kind != tok.ident() {
            return fail_parser(p, "expected parameter name")
        }
        param_name = p.lx.lexeme
        p = advance_sig(p)
        p = parse_type_name(p, "expected parameter type")
        if !p.ok { return p }
        param0_type = p.value_type
        param_count = 1
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param1_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param1_type = p.value_type
            param_count = 2
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param2_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param2_type = p.value_type
            param_count = 3
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param3_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param3_type = p.value_type
            param_count = 4
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param4_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param4_type = p.value_type
            param_count = 5
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param5_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param5_type = p.value_type
            param_count = 6
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param6_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param6_type = p.value_type
            param_count = 7
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param7_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param7_type = p.value_type
            param_count = 8
        }
        if p.lx.kind != tok.rparen() {
            return unsupported_parser(p, "self checker currently supports up to eight helper parameters")
        }
    }
    if is_main && param_count != 0 {
        if param_count != 2 || param0_type != tiny_i32_type_kind() || param1_type != tiny_ptr_type_kind() {
            return unsupported_parser(p, "self checker main parameters must be () or (i32, *string)")
        }
    }

    p = advance_sig(p)
    return_type := tiny_void_type_kind()
    if p.lx.kind == tok.ident() || p.lx.kind == tok.star() {
        p = parse_type_name(p, "expected function return type")
        if !p.ok { return p }
        return_type = p.value_type
    }
    if is_main && return_type != tiny_i32_type_kind() {
        return unsupported_parser(p, "self checker currently requires main to return i32")
    }

    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after function signature")
    }

    p = reset_locals(p)
    p.current_return_type = return_type
    if param_count == 1 {
        p = set_var(p, param_name, 0, param0_type)
        if !p.ok { return p }
    } else if param_count == 2 {
        p = set_var(p, param_name, 0, param0_type)
        if !p.ok { return p }
        p = set_var(p, param1_name, 0, param1_type)
        if !p.ok { return p }
    } else if param_count == 3 {
        p = set_var(p, param_name, 0, param0_type)
        if !p.ok { return p }
        p = set_var(p, param1_name, 0, param1_type)
        if !p.ok { return p }
        p = set_var(p, param2_name, 0, param2_type)
        if !p.ok { return p }
    } else if param_count == 4 {
        p = set_var(p, param_name, 0, param0_type)
        if !p.ok { return p }
        p = set_var(p, param1_name, 0, param1_type)
        if !p.ok { return p }
        p = set_var(p, param2_name, 0, param2_type)
        if !p.ok { return p }
        p = set_var(p, param3_name, 0, param3_type)
        if !p.ok { return p }
    } else if param_count == 5 {
        p = set_var(p, param_name, 0, param0_type)
        if !p.ok { return p }
        p = set_var(p, param1_name, 0, param1_type)
        if !p.ok { return p }
        p = set_var(p, param2_name, 0, param2_type)
        if !p.ok { return p }
        p = set_var(p, param3_name, 0, param3_type)
        if !p.ok { return p }
        p = set_var(p, param4_name, 0, param4_type)
        if !p.ok { return p }
    } else if param_count == 6 {
        p = set_var(p, param_name, 0, param0_type)
        if !p.ok { return p }
        p = set_var(p, param1_name, 0, param1_type)
        if !p.ok { return p }
        p = set_var(p, param2_name, 0, param2_type)
        if !p.ok { return p }
        p = set_var(p, param3_name, 0, param3_type)
        if !p.ok { return p }
        p = set_var(p, param4_name, 0, param4_type)
        if !p.ok { return p }
        p = set_var(p, param5_name, 0, param5_type)
        if !p.ok { return p }
    } else if param_count == 7 {
        p = set_var(p, param_name, 0, param0_type)
        if !p.ok { return p }
        p = set_var(p, param1_name, 0, param1_type)
        if !p.ok { return p }
        p = set_var(p, param2_name, 0, param2_type)
        if !p.ok { return p }
        p = set_var(p, param3_name, 0, param3_type)
        if !p.ok { return p }
        p = set_var(p, param4_name, 0, param4_type)
        if !p.ok { return p }
        p = set_var(p, param5_name, 0, param5_type)
        if !p.ok { return p }
        p = set_var(p, param6_name, 0, param6_type)
        if !p.ok { return p }
    } else if param_count == 8 {
        p = set_var(p, param_name, 0, param0_type)
        if !p.ok { return p }
        p = set_var(p, param1_name, 0, param1_type)
        if !p.ok { return p }
        p = set_var(p, param2_name, 0, param2_type)
        if !p.ok { return p }
        p = set_var(p, param3_name, 0, param3_type)
        if !p.ok { return p }
        p = set_var(p, param4_name, 0, param4_type)
        if !p.ok { return p }
        p = set_var(p, param5_name, 0, param5_type)
        if !p.ok { return p }
        p = set_var(p, param6_name, 0, param6_type)
        if !p.ok { return p }
        p = set_var(p, param7_name, 0, param7_type)
        if !p.ok { return p }
    }
    if is_main {
        p.saw_main = true
    }
    p = advance_sig(p)
    for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
        p = parse_statement(p)
        if !p.ok {
            return p
        }
        if p.returned || p.loop_break || p.loop_continue {
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.lx.kind == tok.semicolon() {
            p = advance_sig(p)
        }
    }

    if !p.ok {
        return p
    }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after function body")
    }
    if !p.returned {
        if p.current_return_type != tiny_void_type_kind() {
            return fail_parser(p, "non-void function is missing an explicit return")
        }
    }
    if !is_main {
        signature := tiny_signature8(param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, param6_type, param7_type)
        p = add_helper(p, name, p.return_value, param_count, signature, return_type)
        if !p.ok { return p }
        p.helper_param_name = param_name
    }
    return advance_sig(p)
}

fn parse_program(p TinyParser) TinyParser {
    p = advance_sig(p)
    if !p.ok { return p }

    for (; p.lx.kind == tok.kw_import() || p.lx.kind == tok.kw_module() || p.lx.kind == tok.kw_package(); ) {
        p = skip_import_or_module(p)
        if !p.ok { return p }
    }

    for (; p.ok && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.kw_extern() {
            p = skip_extern_decl(p)
            if !p.ok { return p }
            continue
        }
        if p.lx.kind == tok.kw_struct() {
            p = scan_struct_decl(p)
            if !p.ok { return p }
            continue
        }
        probe := p
        probe = advance_sig(probe)
        if !probe.ok { return probe }
        if probe.lx.kind == tok.ident() && p.saw_main {
            p = skip_function_body(p)
        } else {
            p = parse_function(p)
        }
        if !p.ok { return p }
    }
    if !p.saw_main {
        return unsupported_parser(p, "self checker currently supports fn main() i32")
    }
    return p
}

pub fn check_tiny_main(path string, source string) CheckResult {
    p := TinyParser{lx: lexer.new(path, source), ok: true, supported: true, message: "", line: 1, col: 1, value: 0, value_type: 0, current_return_type: 0, return_value: 0, vars: 0, name0: "", name1: "", name2: "", name3: "", name4: "", name5: "", name6: "", name7: "", name8: "", name9: "", name10: "", name11: "", name12: "", name13: "", name14: "", name15: "", value0: 0, value1: 0, value2: 0, value3: 0, value4: 0, value5: 0, value6: 0, value7: 0, value8: 0, value9: 0, value10: 0, value11: 0, value12: 0, value13: 0, value14: 0, value15: 0, type0: 0, type1: 0, type2: 0, type3: 0, type4: 0, type5: 0, type6: 0, type7: 0, type8: 0, type9: 0, type10: 0, type11: 0, type12: 0, type13: 0, type14: 0, type15: 0, array0_0: 0, array0_1: 0, array0_2: 0, array1_0: 0, array1_1: 0, array1_2: 0, array2_0: 0, array2_1: 0, array2_2: 0, array3_0: 0, array3_1: 0, array3_2: 0, array4_0: 0, array4_1: 0, array4_2: 0, array5_0: 0, array5_1: 0, array5_2: 0, array6_0: 0, array6_1: 0, array6_2: 0, array7_0: 0, array7_1: 0, array7_2: 0, array8_0: 0, array8_1: 0, array8_2: 0, array9_0: 0, array9_1: 0, array9_2: 0, array10_0: 0, array10_1: 0, array10_2: 0, array11_0: 0, array11_1: 0, array11_2: 0, array12_0: 0, array12_1: 0, array12_2: 0, array13_0: 0, array13_1: 0, array13_2: 0, array14_0: 0, array14_1: 0, array14_2: 0, array15_0: 0, array15_1: 0, array15_2: 0, helper_name: "", helper_value: 0, helper_return_type: tiny_i32_type_kind(), helper_param_name: "", helper_param_count: 0, helper_count: 0, helper0_name: "", helper1_name: "", helper2_name: "", helper3_name: "", helper4_name: "", helper5_name: "", helper6_name: "", helper7_name: "", helper8_name: "", helper9_name: "", helper10_name: "", helper11_name: "", helper12_name: "", helper13_name: "", helper14_name: "", helper15_name: "", helper0_value: 0, helper1_value: 0, helper2_value: 0, helper3_value: 0, helper4_value: 0, helper5_value: 0, helper6_value: 0, helper7_value: 0, helper8_value: 0, helper9_value: 0, helper10_value: 0, helper11_value: 0, helper12_value: 0, helper13_value: 0, helper14_value: 0, helper15_value: 0, helper0_params: 0, helper1_params: 0, helper2_params: 0, helper3_params: 0, helper4_params: 0, helper5_params: 0, helper6_params: 0, helper7_params: 0, helper8_params: 0, helper9_params: 0, helper10_params: 0, helper11_params: 0, helper12_params: 0, helper13_params: 0, helper14_params: 0, helper15_params: 0, helper_signature: 0, helper0_signature: 0, helper1_signature: 0, helper2_signature: 0, helper3_signature: 0, helper4_signature: 0, helper5_signature: 0, helper6_signature: 0, helper7_signature: 0, helper8_signature: 0, helper9_signature: 0, helper10_signature: 0, helper11_signature: 0, helper12_signature: 0, helper13_signature: 0, helper14_signature: 0, helper15_signature: 0, helper0_return_type: 0, helper1_return_type: 0, helper2_return_type: 0, helper3_return_type: 0, helper4_return_type: 0, helper5_return_type: 0, helper6_return_type: 0, helper7_return_type: 0, helper8_return_type: 0, helper9_return_type: 0, helper10_return_type: 0, helper11_return_type: 0, helper12_return_type: 0, helper13_return_type: 0, helper14_return_type: 0, helper15_return_type: 0, saw_main: false, returned: false, loop_break: false, loop_continue: false, saw_struct: false, struct_name: "", struct_fields: 0, struct_field0: "", struct_field1: "", struct_field2: ""}
    p = scan_helper_values(p)
    if !p.ok {
        if !p.supported { return unsupported_result(p.line, p.col, p.message) }
        return fail_result(p.line, p.col, p.message)
    }
    p.lx = lexer.new(path, source)
    p.ok = true
    p.supported = true
    p.message = ""
    p.line = 1
    p.col = 1
    p.value = 0
    p.value_type = 0
    p.current_return_type = 0
    p.return_value = 0
    p.vars = 0
    p.saw_main = false
    p.returned = false
    p.loop_break = false
    p.loop_continue = false
    p = parse_program(p)
    if !p.ok {
        if !p.supported { return unsupported_result(p.line, p.col, p.message) }
        return fail_result(p.line, p.col, p.message)
    }
    return ok_i32(p.return_value)
}
