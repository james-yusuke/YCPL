fn ok_i32(value i32) CheckResult {
    return CheckResult{ok: true, supported: true, message: "", line: 1, col: 1, return_type: "i32", return_value: value}
}

fn fail_result(line i32, col i32, message string) CheckResult {
    return CheckResult{ok: false, supported: true, message: message, line: line, col: col, return_type: "", return_value: 0}
}

fn unsupported_result(line i32, col i32, message string) CheckResult {
    return CheckResult{ok: false, supported: false, message: message, line: line, col: col, return_type: "", return_value: 0}
}

fn fail_parser(p TinyParser, message string) TinyParser {
    p.ok = false
    p.supported = true
    p.message = message
    p.line = p.lx.tok_line
    p.col = p.lx.tok_col
    return p
}

fn unsupported_parser(p TinyParser, message string) TinyParser {
    p.ok = false
    p.supported = false
    p.message = message
    p.line = p.lx.tok_line
    p.col = p.lx.tok_col
    return p
}

fn advance_sig(p TinyParser) TinyParser {
    p.lx = lexer.next(p.lx)
    if !p.lx.ok {
        p.ok = false
        p.supported = true
        p.message = p.lx.message
        p.line = p.lx.tok_line
        p.col = p.lx.tok_col
        return p
    }
    for (; p.lx.kind == tok.newline(); ) {
        p.lx = lexer.next(p.lx)
        if !p.lx.ok {
            p.ok = false
            p.supported = true
            p.message = p.lx.message
            p.line = p.lx.tok_line
            p.col = p.lx.tok_col
            return p
        }
    }
    return p
}

fn parse_i32(text string) i32 {
    value := 0
    i: i32 := 0
    n := str.len(text)
    for (; i < n; i++) {
        ch := text[i]
        if ch >= '0' && ch <= '9' {
            value = value * 10 + (ch - '0')
        }
    }
    return value
}

fn tiny_i32_type_kind() i32 {
    return 1
}

fn tiny_bool_type_kind() i32 {
    return 2
}

fn tiny_string_type_kind() i32 {
    return 3
}

fn tiny_i64_type_kind() i32 {
    return 4
}

fn tiny_ptr_type_kind() i32 {
    return 5
}

fn tiny_void_type_kind() i32 {
    return 6
}

fn tiny_i32_array3_type_kind() i32 {
    return 7
}

fn tiny_i32_struct2_type_kind() i32 {
    return 8
}

fn tiny_i32_struct3_type_kind() i32 {
    return 9
}

fn tiny_type_from_name(name string) i32 {
    if str.eq(name, "void") {
        return tiny_void_type_kind()
    }
    if str.eq(name, "i32") {
        return tiny_i32_type_kind()
    }
    if str.eq(name, "bool") {
        return tiny_bool_type_kind()
    }
    if str.eq(name, "string") {
        return tiny_string_type_kind()
    }
    if str.eq(name, "i64") {
        return tiny_i64_type_kind()
    }
    return 0
}

fn ensure_i32_value(p TinyParser, message string) TinyParser {
    if p.value_type == tiny_i32_type_kind() {
        return p
    }
    return unsupported_parser(p, message)
}

fn ensure_bool_value(p TinyParser) TinyParser {
    if p.value_type == tiny_bool_type_kind() {
        return p
    }
    if p.value != 0 {
        p.value = 1
    }
    p.value_type = tiny_bool_type_kind()
    return p
}

fn ensure_string_value(p TinyParser, message string) TinyParser {
    if p.value_type == tiny_string_type_kind() {
        return p
    }
    return unsupported_parser(p, message)
}

fn ensure_i64_value(p TinyParser, message string) TinyParser {
    if p.value_type == tiny_i64_type_kind() {
        return p
    }
    if p.value_type == tiny_i32_type_kind() {
        p.value_type = tiny_i64_type_kind()
        return p
    }
    return unsupported_parser(p, message)
}

fn ensure_ptr_value(p TinyParser, message string) TinyParser {
    if p.value_type == tiny_ptr_type_kind() {
        return p
    }
    return unsupported_parser(p, message)
}

fn ensure_value_type(p TinyParser, expected_type i32, message string) TinyParser {
    if expected_type == tiny_void_type_kind() {
        if p.value_type == tiny_void_type_kind() {
            return p
        }
        return unsupported_parser(p, message)
    }
    if expected_type == tiny_bool_type_kind() {
        return ensure_bool_value(p)
    }
    if expected_type == tiny_string_type_kind() {
        return ensure_string_value(p, message)
    }
    if expected_type == tiny_i64_type_kind() {
        return ensure_i64_value(p, message)
    }
    if expected_type == tiny_ptr_type_kind() {
        return ensure_ptr_value(p, message)
    }
    if expected_type == tiny_i32_array3_type_kind() {
        if p.value_type == tiny_i32_array3_type_kind() {
            return p
        }
        return unsupported_parser(p, message)
    }
    if expected_type == tiny_i32_struct2_type_kind() {
        if p.value_type == tiny_i32_struct2_type_kind() {
            return p
        }
        return unsupported_parser(p, message)
    }
    if expected_type == tiny_i32_struct3_type_kind() {
        if p.value_type == tiny_i32_struct3_type_kind() {
            return p
        }
        return unsupported_parser(p, message)
    }
    return ensure_i32_value(p, message)
}

fn pack_struct2(value0 i32, value1 i32) i32 {
    return value0 + value1 * 100000
}

fn pack_struct3(value0 i32, value1 i32, value2 i32) i32 {
    return value0 + value1 * 1000 + value2 * 1000000
}

fn struct_field_index(p TinyParser, field string) i32 {
    if str.eq(field, p.struct_field0) {
        return 0
    }
    if str.eq(field, p.struct_field1) {
        return 1
    }
    if p.struct_fields == 3 && str.eq(field, p.struct_field2) {
        return 2
    }
    return -1
}

fn load_struct2_field(p TinyParser, name string, field string) TinyParser {
    p = lookup_var(p, name)
    if !p.ok { return p }
    struct_type := p.value_type
    if struct_type != tiny_i32_struct2_type_kind() && struct_type != tiny_i32_struct3_type_kind() {
        return unsupported_parser(p, "self checker member access currently supports two- or three-field i32 structs")
    }
    field_index := struct_field_index(p, field)
    if field_index < 0 {
        return fail_parser(p, "unknown struct field")
    }
    packed := p.value
    if struct_type == tiny_i32_struct3_type_kind() {
        if field_index == 0 {
            p.value = packed % 1000
        } else if field_index == 1 {
            p.value = (packed / 1000) % 1000
        } else {
            p.value = packed / 1000000
        }
    } else if field_index == 0 {
        p.value = packed % 100000
    } else {
        p.value = packed / 100000
    }
    p.value_type = tiny_i32_type_kind()
    return p
}

fn set_struct2_field(p TinyParser, name string, field string, value i32) TinyParser {
    p = lookup_var(p, name)
    if !p.ok { return p }
    struct_type := p.value_type
    if struct_type != tiny_i32_struct2_type_kind() && struct_type != tiny_i32_struct3_type_kind() {
        return unsupported_parser(p, "self checker member assignment currently supports two- or three-field i32 structs")
    }
    field_index := struct_field_index(p, field)
    if field_index < 0 {
        return fail_parser(p, "unknown struct field")
    }
    packed := p.value
    if struct_type == tiny_i32_struct3_type_kind() {
        value0 := packed % 1000
        value1 := (packed / 1000) % 1000
        value2 := packed / 1000000
        if field_index == 0 {
            value0 = value
        } else if field_index == 1 {
            value1 = value
        } else {
            value2 = value
        }
        return set_var(p, name, pack_struct3(value0, value1, value2), tiny_i32_struct3_type_kind())
    }
    value0 := packed % 100000
    value1 := packed / 100000
    if field_index == 0 {
        value0 = value
    } else {
        value1 = value
    }
    return set_var(p, name, pack_struct2(value0, value1), tiny_i32_struct2_type_kind())
}

fn tiny_signature(param_count i32, param0_type i32, param1_type i32) i32 {
    return tiny_signature8(param_count, param0_type, param1_type, 0, 0, 0, 0, 0, 0)
}

fn tiny_signature4(param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32) i32 {
    return tiny_signature8(param_count, param0_type, param1_type, param2_type, param3_type, 0, 0, 0, 0)
}

fn tiny_signature6(param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32, param4_type i32, param5_type i32) i32 {
    return tiny_signature8(param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, 0, 0)
}

fn tiny_signature8(param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32, param4_type i32, param5_type i32, param6_type i32, param7_type i32) i32 {
    if param_count == 0 {
        return 0
    }
    if param_count == 1 {
        return param0_type
    }
    if param_count == 2 {
        return param0_type + param1_type * 10
    }
    if param_count == 3 {
        return param0_type + param1_type * 10 + param2_type * 100
    }
    if param_count == 4 {
        return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000
    }
    if param_count == 5 {
        return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000 + param4_type * 10000
    }
    if param_count == 6 {
        return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000 + param4_type * 10000 + param5_type * 100000
    }
    if param_count == 7 {
        return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000 + param4_type * 10000 + param5_type * 100000 + param6_type * 1000000
    }
    return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000 + param4_type * 10000 + param5_type * 100000 + param6_type * 1000000 + param7_type * 10000000
}

fn tiny_signature_param(signature i32, index i32) i32 {
    if index == 0 {
        return signature % 10
    }
    if index == 1 {
        return (signature / 10) % 10
    }
    if index == 2 {
        return (signature / 100) % 10
    }
    if index == 3 {
        return (signature / 1000) % 10
    }
    if index == 4 {
        return (signature / 10000) % 10
    }
    if index == 5 {
        return (signature / 100000) % 10
    }
    if index == 6 {
        return (signature / 1000000) % 10
    }
    return (signature / 10000000) % 10
}

