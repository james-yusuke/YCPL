module compiler.ycpl.checker

import "lexer/lexer" as lexer
import "lexer/token" as tok
import "std/str" as str

pub struct CheckResult {
    ok bool
    supported bool
    message string
    line i32
    col i32
    return_type string
    return_value i32
}

