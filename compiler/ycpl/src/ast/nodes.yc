pub fn expr_int() i32 { return 2 }
pub fn expr_float() i32 { return 3 }
pub fn expr_char() i32 { return 4 }
pub fn expr_string() i32 { return 5 }
pub fn expr_bool() i32 { return 6 }
pub fn expr_none() i32 { return 7 }
pub fn expr_unary() i32 { return 8 }
pub fn expr_binary() i32 { return 9 }
pub fn expr_call() i32 { return 10 }
pub fn expr_member() i32 { return 11 }
pub fn expr_index() i32 { return 12 }
pub fn expr_array() i32 { return 13 }
pub fn expr_struct() i32 { return 14 }
