pub fn expr_postfix() i32 { return 16 }
pub fn expr_cast() i32 { return 17 }
pub fn expr_vec() i32 { return 18 }

pub fn vec_method_push() i64 { return -1001 }
pub fn vec_method_len() i64 { return -1002 }
pub fn vec_method_capacity() i64 { return -1003 }
pub fn vec_method_reserve() i64 { return -1004 }
pub fn vec_method_clear() i64 { return -1005 }
pub fn vec_method_as_slice() i64 { return -1006 }

