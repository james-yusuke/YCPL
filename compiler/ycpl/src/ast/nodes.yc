pub struct Span {
    file i32
    line i32
    col i32
    end_line i32
    end_col i32
}

pub struct TypeNode {
    kind i32
    span Span
    name string
    base i32
    key i32
    value i32
    flags i32
    resolved_file i32
    resolved_id i32
}

pub struct ParamNode {
    span Span
    name string
    name_id i32
    type_id i32
    flags i32
}

pub struct FieldNode {
    span Span
    name string
    type_id i32
    flags i32
    name_id i32
    value i64
}

pub struct DeclNode {
    kind i32
    span Span
    name string
    module_name string
    link_name string
    type_id i32
    body i32
    first_param i32
    param_count i32
    first_field i32
    field_count i32
    flags i32
    resolved_file i32
    resolved_id i32
}

pub struct StmtNode {
    kind i32
    span Span
    first_child i32
    child_count i32
    a i32
    b i32
    c i32
    name string
    name_id i32
    op string
    flags i32
    symbol_file i32
    symbol_id i32
}

pub struct ExprNode {
    kind i32
    span Span
    type_id i32
    left i32
    right i32
    first_arg i32
    arg_count i32
    name string
    text string
    int_value i64
    float_value double
    flags i32
    type_file i32
    symbol_file i32
    symbol_id i32
}

pub struct AstArena {
    types *TypeNode
    type_kinds *i32
    type_bases *i32
    type_resolved_files *i32
    type_resolved_ids *i32
    type_len i32
    type_cap i32
    params *ParamNode
    param_name_ids *i32
    param_type_ids *i32
    param_flags *i32
    param_len i32
    param_cap i32
    fields *FieldNode
    field_names *string
    field_name_ids *i32
    field_type_ids *i32
    field_values *i64
    field_len i32
    field_cap i32
    decls *DeclNode
    decl_names *string
    decl_module_names *string
    decl_link_names *string
    decl_kinds *i32
    decl_type_ids *i32
    decl_bodies *i32
    decl_first_params *i32
    decl_param_counts *i32
    decl_first_fields *i32
    decl_field_counts *i32
    decl_flags *i32
    decl_len i32
    decl_cap i32
    stmts *StmtNode
    stmt_name_ids *i32
    stmt_len i32
    stmt_cap i32
    exprs *ExprNode
    expr_names *string
    expr_name_ids *i32
    expr_int_values *i64
    expr_syntax_type_ids *i32
    expr_len i32
    expr_cap i32
    children []i32
}

pub struct ProgramAst {
    ok bool
    message string
    error_line i32
    error_col i32
    file_id i32
    file string
    module_name string
    arena AstArena
    root_decls []i32
}

pub fn span(file i32, line i32, col i32, end_line i32, end_col i32) Span {
    return Span{file: file, line: line, col: col, end_line: end_line, end_col: end_col}
}

pub fn empty_span() Span {
    return span(0, 1, 1, 1, 1)
}

pub fn make_type(kind i32, at Span, name string, base i32, key i32, value i32, flags i32) TypeNode {
    return TypeNode{kind: kind, span: at, name: name, base: base, key: key, value: value, flags: flags, resolved_file: invalid_id(), resolved_id: invalid_id()}
}

pub fn make_param(at Span, name string, type_id i32, flags i32) ParamNode {
    return ParamNode{span: at, name: name, name_id: name_hash32(name), type_id: type_id, flags: flags}
}

pub fn make_field(at Span, name string, type_id i32, flags i32, value i64) FieldNode {
    return FieldNode{span: at, name: name, type_id: type_id, flags: flags, name_id: name_hash32(name), value: value}
}

pub fn make_decl(kind i32, at Span, name string, module_name string, link_name string, type_id i32, body i32, first_param i32, param_count i32, first_field i32, field_count i32, flags i32) DeclNode {
    return DeclNode{kind: kind, span: at, name: name, module_name: module_name, link_name: link_name, type_id: type_id, body: body, first_param: first_param, param_count: param_count, first_field: first_field, field_count: field_count, flags: flags, resolved_file: invalid_id(), resolved_id: invalid_id()}
}

pub fn make_stmt(kind i32, at Span, first_child i32, child_count i32, a i32, b i32, c i32, name string, op string, flags i32) StmtNode {
    return StmtNode{kind: kind, span: at, first_child: first_child, child_count: child_count, a: a, b: b, c: c, name: name, name_id: name_hash32(name), op: op, flags: flags, symbol_file: invalid_id(), symbol_id: invalid_id()}
}

pub fn make_expr(kind i32, at Span, type_id i32, left i32, right i32, first_arg i32, arg_count i32, name string, text string, int_value i64, float_value double, flags i32) ExprNode {
    return ExprNode{kind: kind, span: at, type_id: type_id, left: left, right: right, first_arg: first_arg, arg_count: arg_count, name: name, text: text, int_value: int_value, float_value: float_value, flags: flags, type_file: invalid_id(), symbol_file: invalid_id(), symbol_id: invalid_id()}
}

pub fn arena_new() AstArena {
    arena := AstArena{
        types: mem.calloc(32, mem.sizeof(TypeNode)), type_kinds: mem.calloc(32, 4), type_bases: mem.calloc(32, 4), type_resolved_files: mem.calloc(32, 4), type_resolved_ids: mem.calloc(32, 4), type_len: 0, type_cap: 32,
        params: mem.calloc(64, mem.sizeof(ParamNode)), param_name_ids: mem.calloc(64, 4), param_type_ids: mem.calloc(64, 4), param_flags: mem.calloc(64, 4), param_len: 0, param_cap: 64,
        fields: mem.calloc(64, mem.sizeof(FieldNode)), field_names: mem.calloc(64, 8), field_name_ids: mem.calloc(64, 4), field_type_ids: mem.calloc(64, 4), field_values: mem.calloc(64, 8), field_len: 0, field_cap: 64,
        decls: mem.calloc(64, mem.sizeof(DeclNode)), decl_names: mem.calloc(64, 8), decl_module_names: mem.calloc(64, 8), decl_link_names: mem.calloc(64, 8), decl_kinds: mem.calloc(64, 4), decl_type_ids: mem.calloc(64, 4), decl_bodies: mem.calloc(64, 4), decl_first_params: mem.calloc(64, 4), decl_param_counts: mem.calloc(64, 4), decl_first_fields: mem.calloc(64, 4), decl_field_counts: mem.calloc(64, 4), decl_flags: mem.calloc(64, 4), decl_len: 0, decl_cap: 64,
        stmts: mem.calloc(256, mem.sizeof(StmtNode)), stmt_name_ids: mem.calloc(256, 4), stmt_len: 0, stmt_cap: 256,
        exprs: mem.calloc(512, mem.sizeof(ExprNode)), expr_names: mem.calloc(512, 8), expr_name_ids: mem.calloc(512, 4), expr_int_values: mem.calloc(512, 8), expr_syntax_type_ids: mem.calloc(512, 4), expr_len: 0, expr_cap: 512,
        children: array.new([]i32, 512),
    }
    // AstArena lives inside ProgramAst.  It crosses several recursive parser
    // frames, so its backing stores must not remain owned by arena_new's frame.
    arena.types = mem.keep(arena.types)
    arena.type_kinds = mem.keep(arena.type_kinds)
    arena.type_bases = mem.keep(arena.type_bases)
    arena.type_resolved_files = mem.keep(arena.type_resolved_files)
    arena.type_resolved_ids = mem.keep(arena.type_resolved_ids)
    arena.params = mem.keep(arena.params)
    arena.param_name_ids = mem.keep(arena.param_name_ids)
    arena.param_type_ids = mem.keep(arena.param_type_ids)
    arena.param_flags = mem.keep(arena.param_flags)
    arena.fields = mem.keep(arena.fields)
    arena.field_names = mem.keep(arena.field_names)
    arena.field_name_ids = mem.keep(arena.field_name_ids)
    arena.field_type_ids = mem.keep(arena.field_type_ids)
    arena.field_values = mem.keep(arena.field_values)
    arena.decls = mem.keep(arena.decls)
    arena.decl_names = mem.keep(arena.decl_names)
    arena.decl_module_names = mem.keep(arena.decl_module_names)
    arena.decl_link_names = mem.keep(arena.decl_link_names)
    arena.decl_kinds = mem.keep(arena.decl_kinds)
    arena.decl_type_ids = mem.keep(arena.decl_type_ids)
    arena.decl_bodies = mem.keep(arena.decl_bodies)
    arena.decl_first_params = mem.keep(arena.decl_first_params)
    arena.decl_param_counts = mem.keep(arena.decl_param_counts)
    arena.decl_first_fields = mem.keep(arena.decl_first_fields)
    arena.decl_field_counts = mem.keep(arena.decl_field_counts)
    arena.decl_flags = mem.keep(arena.decl_flags)
    arena.stmts = mem.keep(arena.stmts)
    arena.stmt_name_ids = mem.keep(arena.stmt_name_ids)
    arena.exprs = mem.keep(arena.exprs)
    arena.expr_names = mem.keep(arena.expr_names)
    arena.expr_name_ids = mem.keep(arena.expr_name_ids)
    arena.expr_int_values = mem.keep(arena.expr_int_values)
    arena.expr_syntax_type_ids = mem.keep(arena.expr_syntax_type_ids)
    arena.children = cast([]i32, mem.keep(cast(*byte, arena.children)))
    return arena
}

pub fn program_new(file string) ProgramAst {
    roots := array.new([]i32, 32)
    roots = cast([]i32, mem.keep(cast(*byte, roots)))
    return ProgramAst{ok: true, message: "", error_line: 1, error_col: 1, file_id: 0, file: file, module_name: "", arena: arena_new(), root_decls: roots}
}

pub fn add_type(arena AstArena, node TypeNode) AstArena {
    if arena.type_len >= arena.type_cap {
        arena.type_cap = arena.type_cap * 2
        arena.types = mem.realloc(arena.types, arena.type_cap * mem.sizeof(TypeNode))
        arena.type_kinds = mem.realloc(arena.type_kinds, arena.type_cap * 4)
        arena.type_bases = mem.realloc(arena.type_bases, arena.type_cap * 4)
        arena.type_resolved_files = mem.realloc(arena.type_resolved_files, arena.type_cap * 4)
        arena.type_resolved_ids = mem.realloc(arena.type_resolved_ids, arena.type_cap * 4)
    }
    arena.types = mem.keep(arena.types)
    arena.type_kinds = mem.keep(arena.type_kinds)
    arena.type_bases = mem.keep(arena.type_bases)
    arena.type_resolved_files = mem.keep(arena.type_resolved_files)
    arena.type_resolved_ids = mem.keep(arena.type_resolved_ids)
    if node.name != none { node.name = retain_string(node.name) }
    // Do not copy a struct through `*T[index]`: that was interpreted as a
    // dynamic-array access by older bootstrap codegen paths.  Field stores via
    // a typed pointer are both ABI-correct and the representation needed by
    // the self-host AST arena.
    slot: *TypeNode := arena.types + arena.type_len
    slot.kind = node.kind
    slot.span = node.span
    slot.name = node.name
    slot.base = node.base
    slot.key = node.key
    slot.value = node.value
    slot.flags = node.flags
    slot.resolved_file = node.resolved_file
    slot.resolved_id = node.resolved_id
    arena.type_kinds[arena.type_len] = node.kind
    arena.type_bases[arena.type_len] = node.base
    arena.type_resolved_files[arena.type_len] = node.resolved_file
    arena.type_resolved_ids[arena.type_len] = node.resolved_id
    arena.type_len += 1
    return arena
}

pub fn add_param(arena AstArena, node ParamNode) AstArena {
    if arena.param_len >= arena.param_cap {
        arena.param_cap = arena.param_cap * 2
        arena.params = mem.realloc(arena.params, arena.param_cap * mem.sizeof(ParamNode))
        arena.param_name_ids = mem.realloc(arena.param_name_ids, arena.param_cap * 4)
        arena.param_type_ids = mem.realloc(arena.param_type_ids, arena.param_cap * 4)
        arena.param_flags = mem.realloc(arena.param_flags, arena.param_cap * 4)
    }
    arena.params = mem.keep(arena.params)
    arena.param_name_ids = mem.keep(arena.param_name_ids)
    arena.param_type_ids = mem.keep(arena.param_type_ids)
    arena.param_flags = mem.keep(arena.param_flags)
    if node.name != none { node.name = retain_string(node.name) }
    slot: *ParamNode := arena.params + arena.param_len
    slot.span = node.span
    slot.name = node.name
    slot.name_id = node.name_id
    slot.type_id = node.type_id
    slot.flags = node.flags
    arena.param_name_ids[arena.param_len] = node.name_id
    arena.param_type_ids[arena.param_len] = node.type_id
    arena.param_flags[arena.param_len] = node.flags
    arena.param_len += 1
    return arena
}

pub fn add_field(arena AstArena, node FieldNode) AstArena {
    if arena.field_len >= arena.field_cap {
        arena.field_cap = arena.field_cap * 2
        arena.fields = mem.realloc(arena.fields, arena.field_cap * mem.sizeof(FieldNode))
        arena.field_names = mem.realloc(arena.field_names, arena.field_cap * 8)
        arena.field_name_ids = mem.realloc(arena.field_name_ids, arena.field_cap * 4)
        arena.field_type_ids = mem.realloc(arena.field_type_ids, arena.field_cap * 4)
        arena.field_values = mem.realloc(arena.field_values, arena.field_cap * 8)
    }
    arena.fields = mem.keep(arena.fields)
    arena.field_names = mem.keep(arena.field_names)
    arena.field_name_ids = mem.keep(arena.field_name_ids)
    arena.field_type_ids = mem.keep(arena.field_type_ids)
    arena.field_values = mem.keep(arena.field_values)
    if node.name != none { node.name = retain_string(node.name) }
    slot: *FieldNode := arena.fields + arena.field_len
    slot.span = node.span
    slot.name = node.name
    slot.type_id = node.type_id
    slot.flags = node.flags
    slot.name_id = node.name_id
    slot.value = node.value
    arena.field_name_ids[arena.field_len] = node.name_id
    arena.field_names[arena.field_len] = node.name
    arena.field_type_ids[arena.field_len] = node.type_id
    arena.field_values[arena.field_len] = node.value
    arena.field_len += 1
    return arena
}

pub fn add_decl(arena AstArena, node DeclNode) AstArena {
    if arena.decl_len >= arena.decl_cap {
        arena.decl_cap = arena.decl_cap * 2
        arena.decls = mem.realloc(arena.decls, arena.decl_cap * mem.sizeof(DeclNode))
        arena.decl_names = mem.realloc(arena.decl_names, arena.decl_cap * 8)
        arena.decl_module_names = mem.realloc(arena.decl_module_names, arena.decl_cap * 8)
        arena.decl_link_names = mem.realloc(arena.decl_link_names, arena.decl_cap * 8)
        arena.decl_kinds = mem.realloc(arena.decl_kinds, arena.decl_cap * 4)
        arena.decl_type_ids = mem.realloc(arena.decl_type_ids, arena.decl_cap * 4)
        arena.decl_bodies = mem.realloc(arena.decl_bodies, arena.decl_cap * 4)
        arena.decl_first_params = mem.realloc(arena.decl_first_params, arena.decl_cap * 4)
        arena.decl_param_counts = mem.realloc(arena.decl_param_counts, arena.decl_cap * 4)
        arena.decl_first_fields = mem.realloc(arena.decl_first_fields, arena.decl_cap * 4)
        arena.decl_field_counts = mem.realloc(arena.decl_field_counts, arena.decl_cap * 4)
        arena.decl_flags = mem.realloc(arena.decl_flags, arena.decl_cap * 4)
    }
    arena.decls = mem.keep(arena.decls)
    arena.decl_names = mem.keep(arena.decl_names)
    arena.decl_module_names = mem.keep(arena.decl_module_names)
    arena.decl_link_names = mem.keep(arena.decl_link_names)
    arena.decl_kinds = mem.keep(arena.decl_kinds)
    arena.decl_type_ids = mem.keep(arena.decl_type_ids)
    arena.decl_bodies = mem.keep(arena.decl_bodies)
    arena.decl_first_params = mem.keep(arena.decl_first_params)
    arena.decl_param_counts = mem.keep(arena.decl_param_counts)
    arena.decl_first_fields = mem.keep(arena.decl_first_fields)
    arena.decl_field_counts = mem.keep(arena.decl_field_counts)
    arena.decl_flags = mem.keep(arena.decl_flags)
    if node.name != none { node.name = retain_string(node.name) }
    if node.module_name != none { node.module_name = retain_string(node.module_name) }
    if node.link_name != none { node.link_name = retain_string(node.link_name) }
    slot: *DeclNode := arena.decls + arena.decl_len
    slot.kind = node.kind
    slot.span = node.span
    slot.name = node.name
    slot.module_name = node.module_name
    slot.link_name = node.link_name
    slot.type_id = node.type_id
    slot.body = node.body
    slot.first_param = node.first_param
    slot.param_count = node.param_count
    slot.first_field = node.first_field
    slot.field_count = node.field_count
    slot.flags = node.flags
    slot.resolved_file = node.resolved_file
    slot.resolved_id = node.resolved_id
    arena.decl_names[arena.decl_len] = node.name
    arena.decl_module_names[arena.decl_len] = node.module_name
    arena.decl_link_names[arena.decl_len] = node.link_name
    arena.decl_kinds[arena.decl_len] = node.kind
    arena.decl_type_ids[arena.decl_len] = node.type_id
    arena.decl_bodies[arena.decl_len] = node.body
    arena.decl_first_params[arena.decl_len] = node.first_param
    arena.decl_param_counts[arena.decl_len] = node.param_count
    arena.decl_first_fields[arena.decl_len] = node.first_field
    arena.decl_field_counts[arena.decl_len] = node.field_count
    arena.decl_flags[arena.decl_len] = node.flags
    arena.decl_len += 1
    return arena
}

pub fn add_stmt(arena AstArena, node StmtNode) AstArena {
    if arena.stmt_len >= arena.stmt_cap {
        arena.stmt_cap = arena.stmt_cap * 2
        arena.stmts = mem.realloc(arena.stmts, arena.stmt_cap * mem.sizeof(StmtNode))
        arena.stmt_name_ids = mem.realloc(arena.stmt_name_ids, arena.stmt_cap * 4)
    }
    arena.stmts = mem.keep(arena.stmts)
    arena.stmt_name_ids = mem.keep(arena.stmt_name_ids)
    if node.name != none { node.name = retain_string(node.name) }
    if node.op != none { node.op = retain_string(node.op) }
    slot: *StmtNode := arena.stmts + arena.stmt_len
    slot.kind = node.kind
    slot.span = node.span
    slot.first_child = node.first_child
    slot.child_count = node.child_count
    slot.a = node.a
    slot.b = node.b
    slot.c = node.c
    slot.name = node.name
    slot.name_id = node.name_id
    slot.op = node.op
    slot.flags = node.flags
    slot.symbol_file = node.symbol_file
    slot.symbol_id = node.symbol_id
    arena.stmt_name_ids[arena.stmt_len] = node.name_id
    arena.stmt_len += 1
    return arena
}

pub fn add_expr(arena AstArena, node ExprNode) AstArena {
    if arena.expr_len >= arena.expr_cap {
        arena.expr_cap = arena.expr_cap * 2
        arena.exprs = mem.realloc(arena.exprs, arena.expr_cap * mem.sizeof(ExprNode))
        arena.expr_names = mem.realloc(arena.expr_names, arena.expr_cap * 8)
        arena.expr_name_ids = mem.realloc(arena.expr_name_ids, arena.expr_cap * 4)
        arena.expr_int_values = mem.realloc(arena.expr_int_values, arena.expr_cap * 8)
        arena.expr_syntax_type_ids = mem.realloc(arena.expr_syntax_type_ids, arena.expr_cap * 4)
    }
    arena.exprs = mem.keep(arena.exprs)
    arena.expr_names = mem.keep(arena.expr_names)
    arena.expr_name_ids = mem.keep(arena.expr_name_ids)
    arena.expr_int_values = mem.keep(arena.expr_int_values)
    arena.expr_syntax_type_ids = mem.keep(arena.expr_syntax_type_ids)
    if node.name != none { node.name = retain_string(node.name) }
    if node.text != none { node.text = retain_string(node.text) }
    slot: *ExprNode := arena.exprs + arena.expr_len
    slot.kind = node.kind
    slot.span = node.span
    slot.type_id = node.type_id
    slot.left = node.left
    slot.right = node.right
    slot.first_arg = node.first_arg
    slot.arg_count = node.arg_count
    slot.name = node.name
    slot.text = node.text
    slot.int_value = node.int_value
    slot.float_value = node.float_value
    slot.flags = node.flags
    slot.type_file = node.type_file
    slot.symbol_file = node.symbol_file
    slot.symbol_id = node.symbol_id
    arena.expr_name_ids[arena.expr_len] = node.flags
    arena.expr_names[arena.expr_len] = node.name
    arena.expr_int_values[arena.expr_len] = node.int_value
    arena.expr_syntax_type_ids[arena.expr_len] = node.type_id
    arena.expr_len += 1
    return arena
}

pub fn add_child(arena AstArena, id i32) AstArena {
    arena.children = array.append(arena.children, id)
    return arena
}

pub fn type_count(arena AstArena) i32 { return arena.type_len }
pub fn param_count(arena AstArena) i32 { return arena.param_len }
pub fn field_count(arena AstArena) i32 { return arena.field_len }
pub fn decl_count(arena AstArena) i32 { return arena.decl_len }
pub fn decl_name(arena AstArena, id i32) string {
    if id < 0 || id >= arena.decl_len { return "" }
    return arena.decl_names[id]
}
pub fn decl_module_name(arena AstArena, id i32) string {
    if id < 0 || id >= arena.decl_len { return "" }
    return arena.decl_module_names[id]
}
pub fn decl_link_name(arena AstArena, id i32) string {
    if id < 0 || id >= arena.decl_len { return "" }
    return arena.decl_link_names[id]
}
pub fn stmt_count(arena AstArena) i32 { return arena.stmt_len }
pub fn expr_count(arena AstArena) i32 { return arena.expr_len }
pub fn child_count(arena AstArena) i32 { return array.len(arena.children) }

// Assign a stable project file id after parsing. The parser can stay focused
// on syntax while every retained span and cross-file reference uses the same
// project-local identity.
pub fn assign_file_id(program ProgramAst, file_id i32) ProgramAst {
    program.file_id = file_id
    return program
}
