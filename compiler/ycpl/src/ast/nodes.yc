module compiler.ycpl.ast.nodes

import "std/array" as array
import "std/mem" as mem
import "std/str" as str

pub fn invalid_id() i32 { return -1 }

fn retain_string(value string) string {
    if value == none { return none }
    n := str.len(value)
    copy: string := mem.calloc(n + 1, 1)
    if copy != none && n > 0 { mem.copy(copy, value, n) }
    return mem.keep(copy)
}

pub fn name_hash(value string) i64 {
    hash: i64 := 1469598103934665603
    i := 0
    n := str.len(value)
    for (; i < n; i++) {
        hash = hash ^ value[i]
        hash = hash * 1099511628211
    }
    return hash
}

pub fn name_hash32(value string) i32 {
    hash := 5381
    i := 0
    n := str.len(value)
    for (; i < n; i++) { hash = hash * 33 + value[i] }
    return hash
}

