pub fn type_i32() i32 { return 2 }
pub fn type_i64() i32 { return 3 }
pub fn type_bool() i32 { return 4 }
pub fn type_byte() i32 { return 5 }
pub fn type_char() i32 { return 6 }
pub fn type_float() i32 { return 7 }
