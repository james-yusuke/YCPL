        p.vars = 15
        return p
    }
    if p.vars == 15 {
        p.name15 = name
        p.slot15 = slot
        p.type15 = type_kind
        p.vars = 16
        return p
    }
    return unsupported_parser(p, "self codegen currently supports up to 16 local variables")
}

fn is_declare_assign(kind i32, lexeme string) bool {
    return kind == tok.assign() && lexeme[0] == ':'
}

