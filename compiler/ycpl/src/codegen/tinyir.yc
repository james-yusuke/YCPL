        return p
    }
    if p.vars > 15 && str.eq(p.name15, name) {
        p.slot15 = slot
        p.type15 = type_kind
        return p
    }

    if p.vars == 0 {
        p.name0 = name
        p.slot0 = slot
        p.type0 = type_kind
        p.vars = 1
        return p
    }
    if p.vars == 1 {
