fn scan_skip_block(p TinyIrParser) TinyIrParser {
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected function body")
    }
    depth := 1
    p = advance_sig(p)
    for (; p.ok && depth > 0 && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.lbrace() {
            depth += 1
        } else if p.lx.kind == tok.rbrace() {
            depth -= 1
        }
        p = advance_sig(p)
    }
    if !p.ok { return p }
    if depth != 0 {
        return fail_parser(p, "expected '}' after function body")
    }
    return p
}

fn skip_to_block_end(p TinyIrParser) TinyIrParser {
    depth := 0
    for (; p.ok && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.lbrace() {
            depth += 1
        } else if p.lx.kind == tok.rbrace() {
            if depth == 0 {
                return p
            }
            depth -= 1
        }
        p = advance_sig(p)
    }
    return p
}

fn parse_type_name(p TinyIrParser, message string) TinyIrParser {
    if p.lx.kind == tok.star() {
        p = advance_sig(p)
        if p.lx.kind == tok.kw_byte() || (p.lx.kind == tok.ident() && str.eq(p.lx.lexeme, "string")) {
            p.value_type = tiny_ptr_type_kind()
            return advance_sig(p)
        }
        return unsupported_parser(p, "self codegen currently supports only *byte and *string pointer types")
    }
    if p.lx.kind != tok.ident() {
        return fail_parser(p, message)
    }
    if p.saw_struct && str.eq(p.lx.lexeme, p.struct_name) {
        if p.struct_fields == 3 {
            p.value_type = tiny_i32_struct3_type_kind()
        } else {
            p.value_type = tiny_i32_struct2_type_kind()
        }
        return advance_sig(p)
    }
    p.value_type = tiny_type_from_name(p.lx.lexeme)
    if p.value_type == 0 {
        return unsupported_parser(p, "self codegen currently supports i32, i64, bool, string, *byte, and *string types")
    }
    return advance_sig(p)
}

fn scan_struct_decl(p TinyIrParser) TinyIrParser {
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected struct name")
    }
    p.struct_name = p.lx.lexeme
    p = advance_sig(p)
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after struct name")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected struct field name")
    }
    p.struct_field0 = p.lx.lexeme
    p = advance_sig(p)
    p = parse_type_name(p, "expected struct field type")
    if !p.ok { return p }
    if p.value_type != tiny_i32_type_kind() {
        return unsupported_parser(p, "self codegen currently supports two- or three-field i32 structs")
    }
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected second struct field name")
    }
    p.struct_field1 = p.lx.lexeme
    p = advance_sig(p)
    p = parse_type_name(p, "expected struct field type")
    if !p.ok { return p }
    if p.value_type != tiny_i32_type_kind() {
        return unsupported_parser(p, "self codegen currently supports two- or three-field i32 structs")
    }
    p.struct_fields = 2
    if p.lx.kind == tok.ident() {
        p.struct_field2 = p.lx.lexeme
        p = advance_sig(p)
        p = parse_type_name(p, "expected struct field type")
        if !p.ok { return p }
        if p.value_type != tiny_i32_type_kind() {
            return unsupported_parser(p, "self codegen currently supports two- or three-field i32 structs")
        }
        p.struct_fields = 3
    }
    if p.lx.kind != tok.rbrace() {
        return unsupported_parser(p, "self codegen currently supports two or three i32 struct fields")
    }
    p.saw_struct = true
    return advance_sig(p)
}

fn function_type_for_signature(p TinyIrParser, return_type i32, param_count i32, param0_type i32, param1_type i32) *byte {
    return function_type_for_signature8(p, return_type, param_count, param0_type, param1_type, 0, 0, 0, 0, 0, 0)
}

fn function_type_for_signature4(p TinyIrParser, return_type i32, param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32) *byte {
    return function_type_for_signature8(p, return_type, param_count, param0_type, param1_type, param2_type, param3_type, 0, 0, 0, 0)
}

fn function_type_for_signature6(p TinyIrParser, return_type i32, param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32, param4_type i32, param5_type i32) *byte {
    return function_type_for_signature8(p, return_type, param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, 0, 0)
}

fn function_type_for_signature8(p TinyIrParser, return_type i32, param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32, param4_type i32, param5_type i32, param6_type i32, param7_type i32) *byte {
    return_llvm_type := llvm_type_for_value(p, return_type)
    if return_type == tiny_bool_type_kind() {
        return_llvm_type = p.bool_type
    }
    if param_count == 1 {
        return llvm.function_type1(return_llvm_type, llvm_type_for_value(p, param0_type), 0)
    }
    if param_count == 2 {
        return llvm.function_type2(return_llvm_type, llvm_type_for_value(p, param0_type), llvm_type_for_value(p, param1_type), 0)
    }
    if param_count == 3 {
        return llvm.function_type3(return_llvm_type, llvm_type_for_value(p, param0_type), llvm_type_for_value(p, param1_type), llvm_type_for_value(p, param2_type), 0)
    }
    if param_count == 4 {
        return llvm.function_type4(return_llvm_type, llvm_type_for_value(p, param0_type), llvm_type_for_value(p, param1_type), llvm_type_for_value(p, param2_type), llvm_type_for_value(p, param3_type), 0)
    }
    if param_count == 5 {
        return llvm.function_type5(return_llvm_type, llvm_type_for_value(p, param0_type), llvm_type_for_value(p, param1_type), llvm_type_for_value(p, param2_type), llvm_type_for_value(p, param3_type), llvm_type_for_value(p, param4_type), 0)
    }
    if param_count == 6 {
        return llvm.function_type6(return_llvm_type, llvm_type_for_value(p, param0_type), llvm_type_for_value(p, param1_type), llvm_type_for_value(p, param2_type), llvm_type_for_value(p, param3_type), llvm_type_for_value(p, param4_type), llvm_type_for_value(p, param5_type), 0)
    }
    if param_count == 7 {
        return llvm.function_type7(return_llvm_type, llvm_type_for_value(p, param0_type), llvm_type_for_value(p, param1_type), llvm_type_for_value(p, param2_type), llvm_type_for_value(p, param3_type), llvm_type_for_value(p, param4_type), llvm_type_for_value(p, param5_type), llvm_type_for_value(p, param6_type), 0)
    }
    if param_count == 8 {
        return llvm.function_type8(return_llvm_type, llvm_type_for_value(p, param0_type), llvm_type_for_value(p, param1_type), llvm_type_for_value(p, param2_type), llvm_type_for_value(p, param3_type), llvm_type_for_value(p, param4_type), llvm_type_for_value(p, param5_type), llvm_type_for_value(p, param6_type), llvm_type_for_value(p, param7_type), 0)
    }
    return llvm.function_type(return_llvm_type, none, 0, 0)
}

fn scan_extern_decl(p TinyIrParser) TinyIrParser {
    p = advance_sig(p)
    if p.lx.kind != tok.kw_fn() {
        return fail_parser(p, "expected fn after extern")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected extern function name")
    }
    source_name := p.lx.lexeme
    p = advance_sig(p)
    if p.lx.kind != tok.lparen() {
        return fail_parser(p, "expected '(' after extern function name")
    }
    p = advance_sig(p)
    param_count := 0
    param0_type := 0
    param1_type := 0
    param2_type := 0
    param3_type := 0
    param4_type := 0
    param5_type := 0
    param6_type := 0
    param7_type := 0
    if p.lx.kind != tok.rparen() {
        if p.lx.kind != tok.ident() {
            return fail_parser(p, "expected extern parameter name")
        }
        p = advance_sig(p)
        p = parse_type_name(p, "expected extern parameter type")
        if !p.ok { return p }
        param0_type = p.value_type
        param_count = 1
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param1_type = p.value_type
            param_count = 2
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param2_type = p.value_type
            param_count = 3
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param3_type = p.value_type
            param_count = 4
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param4_type = p.value_type
            param_count = 5
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param5_type = p.value_type
            param_count = 6
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param6_type = p.value_type
            param_count = 7
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected extern parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected extern parameter type")
            if !p.ok { return p }
            param7_type = p.value_type
            param_count = 8
        }
        if p.lx.kind != tok.rparen() {
            return unsupported_parser(p, "self codegen currently supports up to eight extern parameters")
        }
    }
    p = advance_sig(p)
    return_type := tiny_void_type_kind()
    if p.lx.kind == tok.ident() || p.lx.kind == tok.star() {
        p = parse_type_name(p, "expected extern return type")
        if !p.ok { return p }
        return_type = p.value_type
    }
    llvm_name := source_name
    if p.lx.kind == tok.kw_as() {
        p = advance_sig(p)
        if p.lx.kind != tok.string_lit() {
            return fail_parser(p, "expected extern symbol name")
        }
        llvm_name = string_literal_body(p.lx.lexeme)
        p = advance_sig(p)
    }
    if p.lx.kind == tok.lbrace() {
        return fail_parser(p, "extern function cannot have a body")
    }
    fn_type := function_type_for_signature8(p, return_type, param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, param6_type, param7_type)
    fn_ref := llvm.add_function(p.mod, llvm_name, fn_type)
    signature := tiny_signature8(param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, param6_type, param7_type)
    return add_helper(p, source_name, fn_ref, fn_type, param_count, signature, return_type)
}

fn skip_extern_decl(p TinyIrParser) TinyIrParser {
    for (; p.ok && p.lx.kind != tok.eof() && p.lx.kind != tok.newline(); ) {
        if p.lx.kind == tok.lbrace() {
            return fail_parser(p, "extern function cannot have a body")
        }
        p.lx = lexer.next(p.lx)
        if !p.lx.ok {
            p.ok = false
            p.supported = true
            p.message = p.lx.message
            p.line = p.lx.tok_line
            p.col = p.lx.tok_col
            return p
        }
    }
    return advance_sig(p)
}

fn scan_function_decl(p TinyIrParser) TinyIrParser {
    if p.lx.kind != tok.kw_fn() {
        return unsupported_parser(p, "self codegen currently supports fn declarations")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected function name")
    }
    name := p.lx.lexeme
    is_main := str.eq(name, "main")
    p = advance_sig(p)
    if p.lx.kind != tok.lparen() {
        return fail_parser(p, "expected '(' after function name")
    }
    p = advance_sig(p)
    param_count := 0
    param0_type := tiny_i32_type_kind()
    param1_type := tiny_i32_type_kind()
    param2_type := tiny_i32_type_kind()
    param3_type := tiny_i32_type_kind()
    param4_type := tiny_i32_type_kind()
    param5_type := tiny_i32_type_kind()
    param6_type := tiny_i32_type_kind()
    param7_type := tiny_i32_type_kind()
    if p.lx.kind != tok.rparen() {
        if p.lx.kind != tok.ident() {
            return fail_parser(p, "expected parameter name")
        }
        p = advance_sig(p)
        p = parse_type_name(p, "expected parameter type")
        if !p.ok { return p }
        param0_type = p.value_type
        param_count = 1
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param1_type = p.value_type
            param_count = 2
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param2_type = p.value_type
            param_count = 3
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param3_type = p.value_type
            param_count = 4
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param4_type = p.value_type
            param_count = 5
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param5_type = p.value_type
            param_count = 6
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param6_type = p.value_type
            param_count = 7
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param7_type = p.value_type
            param_count = 8
        }
        if p.lx.kind != tok.rparen() {
            return unsupported_parser(p, "self codegen currently supports up to eight helper parameters")
        }
    }
    if is_main && param_count != 0 {
        if param_count != 2 || param0_type != tiny_i32_type_kind() || param1_type != tiny_ptr_type_kind() {
            return unsupported_parser(p, "self codegen main parameters must be () or (i32, *string)")
        }
    }
    p = advance_sig(p)
    return_type := tiny_void_type_kind()
    if p.lx.kind == tok.ident() || p.lx.kind == tok.star() {
        p = parse_type_name(p, "expected function return type")
        if !p.ok { return p }
        return_type = p.value_type
    }
    if is_main && return_type != tiny_i32_type_kind() {
        return unsupported_parser(p, "self codegen currently requires main to return i32")
    }
    signature := tiny_signature8(param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, param6_type, param7_type)
    current_type := function_type_for_signature8(p, return_type, param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, param6_type, param7_type)
    fn_ref := llvm.add_function(p.mod, name, current_type)
    if is_main {
        p.main_fn = fn_ref
    } else {
        p = add_helper(p, name, fn_ref, current_type, param_count, signature, return_type)
        if !p.ok { return p }
    }
    return scan_skip_block(p)
}

fn scan_program_decls(p TinyIrParser) TinyIrParser {
    p = advance_sig(p)
    if !p.ok { return p }
    for (; p.lx.kind == tok.kw_import() || p.lx.kind == tok.kw_module() || p.lx.kind == tok.kw_package(); ) {
        p = skip_import_or_module(p)
        if !p.ok { return p }
    }
    for (; p.ok && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.kw_extern() {
            p = scan_extern_decl(p)
        } else if p.lx.kind == tok.kw_struct() {
            p = scan_struct_decl(p)
        } else {
            p = scan_function_decl(p)
        }
        if !p.ok { return p }
    }
    if p.main_fn == none {
        return unsupported_parser(p, "self codegen currently supports fn main() i32")
    }
    return p
}

fn parse_factor(p TinyIrParser) TinyIrParser {
    if !p.ok { return p }

    if p.lx.kind == tok.bang() {
        p = advance_sig(p)
        p = parse_factor(p)
        if !p.ok { return p }
        p = ensure_bool_value(p)
        if !p.ok { return p }
        p.value = llvm.build_icmp(p.builder, llvm.int_eq(), p.value, bool_const(p, false), "nottmp")
        p.value_type = tiny_bool_type_kind()
        return p
    }

    sign := 1
    if p.lx.kind == tok.minus() {
        sign = -1
        p = advance_sig(p)
    }

    if p.lx.kind == tok.lparen() {
        p = advance_sig(p)
        p = parse_expr(p)
        if !p.ok { return p }
        if p.lx.kind != tok.rparen() {
            return fail_parser(p, "expected ')' after expression")
        }
        if sign < 0 {
            p = ensure_i32_value(p, "self codegen unary minus requires i32")
            if !p.ok { return p }
            zero := llvm.const_int(p.i32_type, 0, 1)
            p.value = llvm.build_sub(p.builder, zero, p.value, "negtmp")
        }
        return advance_sig(p)
    }

    if p.lx.kind == tok.int_lit() {
        p.value = llvm.const_int(p.i32_type, parse_i32(p.lx.lexeme) * sign, 1)
        p.value_type = tiny_i32_type_kind()
        return advance_sig(p)
    }

    if p.lx.kind == tok.bool_lit() {
        if sign < 0 {
            return unsupported_parser(p, "self codegen unary minus requires i32")
        }
        p.value = bool_const(p, str.eq(p.lx.lexeme, "true"))
        p.value_type = tiny_bool_type_kind()
        return advance_sig(p)
    }

    if p.lx.kind == tok.string_lit() {
        if sign < 0 {
            return unsupported_parser(p, "self codegen unary minus requires i32")
        }
        p.value = llvm.build_global_string_ptr(p.builder, string_literal_body(p.lx.lexeme), "strlit")
        p.value_type = tiny_string_type_kind()
        return advance_sig(p)
    }

    if p.lx.kind == tok.none_lit() {
        if sign < 0 {
            return unsupported_parser(p, "self codegen unary minus requires i32")
        }
        p.value = llvm.const_pointer_null(p.ptr_type)
        p.value_type = tiny_ptr_type_kind()
        return advance_sig(p)
    }

    if p.lx.kind == tok.ident() {
        name := p.lx.lexeme
        p = advance_sig(p)
        if !p.ok { return p }

        if p.lx.kind == tok.lbrack() {
            p = lookup_slot(p, name)
            if !p.ok { return p }
            slot := p.value
            slot_type := p.value_type
            if slot_type != tiny_i32_array3_type_kind() {
                return unsupported_parser(p, "self codegen index currently supports i32[3] local arrays")
            }
            p = advance_sig(p)
            p = parse_expr(p)
            if !p.ok { return p }
            p = ensure_i32_value(p, "self codegen array index currently requires i32")
            if !p.ok { return p }
            index_value := p.value
            if p.lx.kind != tok.rbrack() {
                return fail_parser(p, "expected ']' after array index")
            }
            element_ptr := build_checked_i32_array3_element_ptr(p, slot, index_value, "arrayidx")
            p.value = llvm.build_load2(p.builder, p.i32_type, element_ptr, "arrayload")
            p.value_type = tiny_i32_type_kind()
            if sign < 0 {
                zero := llvm.const_int(p.i32_type, 0, 1)
                p.value = llvm.build_sub(p.builder, zero, p.value, "negtmp")
            }
            return advance_sig(p)
        }

        if p.lx.kind == tok.lparen() {
            p = advance_sig(p)
            p = lookup_helper(p, name)
            if !p.ok { return p }
            callee_fn := p.helper_fn
            callee_fn_type := p.helper_fn_type
            callee_param_count := p.helper_param_count
            callee_signature := p.helper_signature
            callee_return_type := p.helper_return_type
            call_name := "calltmp"
            if callee_return_type == tiny_void_type_kind() {
                call_name = ""
            }
            if p.lx.kind == tok.rparen() {
                if callee_param_count != 0 {
                    return unsupported_parser(p, "self codegen helper call arity mismatch")
                }
                p.value = llvm.build_call2(p.builder, callee_fn_type, callee_fn, none, 0, call_name)
                p.value_type = callee_return_type
                if sign < 0 {
                    p = ensure_i32_value(p, "self codegen unary minus requires i32")
                    if !p.ok { return p }
                    zero := llvm.const_int(p.i32_type, 0, 1)
                    p.value = llvm.build_sub(p.builder, zero, p.value, "negtmp")
                }
                return advance_sig(p)
            }
            p = parse_expr_or_comparison(p)
            if !p.ok { return p }
            p = ensure_value_type(p, tiny_signature_param(callee_signature, 0), "self codegen helper argument type mismatch")
            if !p.ok { return p }
            arg0 := p.value
            arg1 := arg0
            arg2 := arg0
            arg3 := arg0
            arg4 := arg0
            arg5 := arg0
            arg6 := arg0
            arg7 := arg0
            arg_count := 1
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 1), "self codegen helper argument type mismatch")
                if !p.ok { return p }
                arg1 = p.value
                arg_count = 2
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 2), "self codegen helper argument type mismatch")
                if !p.ok { return p }
                arg2 = p.value
                arg_count = 3
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 3), "self codegen helper argument type mismatch")
                if !p.ok { return p }
                arg3 = p.value
                arg_count = 4
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 4), "self codegen helper argument type mismatch")
                if !p.ok { return p }
                arg4 = p.value
                arg_count = 5
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 5), "self codegen helper argument type mismatch")
                if !p.ok { return p }
                arg5 = p.value
                arg_count = 6
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 6), "self codegen helper argument type mismatch")
                if !p.ok { return p }
                arg6 = p.value
                arg_count = 7
            }
            if p.lx.kind == tok.comma() {
                p = advance_sig(p)
                p = parse_expr_or_comparison(p)
                if !p.ok { return p }
                p = ensure_value_type(p, tiny_signature_param(callee_signature, 7), "self codegen helper argument type mismatch")
                if !p.ok { return p }
                arg7 = p.value
                arg_count = 8
            }
            if p.lx.kind != tok.rparen() {
                return unsupported_parser(p, "self codegen currently supports up to eight helper arguments")
            }
            if callee_param_count != arg_count {
                return unsupported_parser(p, "self codegen helper call arity mismatch")
            }
            if arg_count == 8 {
                p.value = llvm.build_call_args8(p.builder, callee_fn_type, callee_fn, arg0, arg1, arg2, arg3, arg4, arg5, arg6, arg7, call_name)
            } else if arg_count == 7 {
                p.value = llvm.build_call_args7(p.builder, callee_fn_type, callee_fn, arg0, arg1, arg2, arg3, arg4, arg5, arg6, call_name)
            } else if arg_count == 6 {
                p.value = llvm.build_call_args6(p.builder, callee_fn_type, callee_fn, arg0, arg1, arg2, arg3, arg4, arg5, call_name)
            } else if arg_count == 5 {
                p.value = llvm.build_call_args5(p.builder, callee_fn_type, callee_fn, arg0, arg1, arg2, arg3, arg4, call_name)
            } else if arg_count == 4 {
                p.value = llvm.build_call_args4(p.builder, callee_fn_type, callee_fn, arg0, arg1, arg2, arg3, call_name)
            } else if arg_count == 3 {
                p.value = llvm.build_call_args3(p.builder, callee_fn_type, callee_fn, arg0, arg1, arg2, call_name)
            } else if arg_count == 2 {
                p.value = llvm.build_call_args2(p.builder, callee_fn_type, callee_fn, arg0, arg1, call_name)
            } else {
                p.value = llvm.build_call1(p.builder, callee_fn_type, callee_fn, arg0, call_name)
            }
            p.value_type = callee_return_type
            if sign < 0 {
                p = ensure_i32_value(p, "self codegen unary minus requires i32")
                if !p.ok { return p }
                zero := llvm.const_int(p.i32_type, 0, 1)
                p.value = llvm.build_sub(p.builder, zero, p.value, "negtmp")
            }
            return advance_sig(p)
        }

        if p.lx.kind == tok.dot() {
            p = lookup_slot(p, name)
            if !p.ok { return p }
            slot := p.value
            slot_type := p.value_type
            if slot_type != tiny_i32_struct2_type_kind() && slot_type != tiny_i32_struct3_type_kind() {
                return unsupported_parser(p, "self codegen member access currently supports two- or three-field i32 structs")
            }
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected member name after '.'")
            }
            field_ptr := build_i32_struct_field_ptr(p, slot, slot_type, p.lx.lexeme, "memberptr")
            if field_ptr == none {
                return fail_parser(p, "unknown struct field")
            }
            p.value = llvm.build_load2(p.builder, p.i32_type, field_ptr, "memberload")
            p.value_type = tiny_i32_type_kind()
            if sign < 0 {
                zero := llvm.const_int(p.i32_type, 0, 1)
                p.value = llvm.build_sub(p.builder, zero, p.value, "negtmp")
            }
            return advance_sig(p)
        }

        p = lookup_slot(p, name)
        if !p.ok { return p }
        loaded_type := p.value_type
        p.value = llvm.build_load2(p.builder, llvm_type_for_value(p, loaded_type), p.value, "loadtmp")
        p.value_type = loaded_type
        if sign < 0 {
            p = ensure_i32_value(p, "self codegen unary minus requires i32")
            if !p.ok { return p }
            zero := llvm.const_int(p.i32_type, 0, 1)
            p.value = llvm.build_sub(p.builder, zero, p.value, "negtmp")
        }
        return p
    }

    return unsupported_parser(p, "self codegen currently supports i32/bool literals, locals, and helper call expressions")
}

fn parse_i32_array3_local(p TinyIrParser, name string) TinyIrParser {
    array_type := llvm.array_type(p.i32_type, 3)
    slot := llvm.build_alloca(p.builder, array_type, name)
    p = advance_sig(p)

    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen i32 array literal requires i32 elements")
    if !p.ok { return p }
    p = store_i32_array3_element(p, slot, 0, p.value)
    if p.lx.kind != tok.comma() {
        return fail_parser(p, "expected ',' in i32 array literal")
    }
    p = advance_sig(p)

    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen i32 array literal requires i32 elements")
    if !p.ok { return p }
    p = store_i32_array3_element(p, slot, 1, p.value)
    if p.lx.kind != tok.comma() {
        return fail_parser(p, "expected ',' in i32 array literal")
    }
    p = advance_sig(p)

    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen i32 array literal requires i32 elements")
    if !p.ok { return p }
    p = store_i32_array3_element(p, slot, 2, p.value)
    if p.lx.kind != tok.rbrack() {
        return fail_parser(p, "expected ']' after i32 array literal")
    }
    p = advance_sig(p)
    return set_slot(p, name, slot, tiny_i32_array3_type_kind())
}

fn parse_struct2_local(p TinyIrParser, name string) TinyIrParser {
    if !p.saw_struct {
        return unsupported_parser(p, "self codegen struct literal requires a struct declaration")
    }
    if p.lx.kind != tok.ident() || !str.eq(p.lx.lexeme, p.struct_name) {
        return unsupported_parser(p, "self codegen struct literal type mismatch")
    }
    struct_type_kind := tiny_i32_struct2_type_kind()
    struct_type := p.struct2_type
    if p.struct_fields == 3 {
        struct_type_kind = tiny_i32_struct3_type_kind()
        struct_type = p.struct3_type
    }
    slot := llvm.build_alloca(p.builder, struct_type, name)
    p = advance_sig(p)
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after struct literal type")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() || !str.eq(p.lx.lexeme, p.struct_field0) {
        return fail_parser(p, "expected first struct field initializer")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.colon() {
        return fail_parser(p, "expected ':' after struct field name")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen struct field initializer requires i32")
    if !p.ok { return p }
    field0_ptr := llvm.build_struct_gep2(p.builder, struct_type, slot, 0, "memberptr")
    llvm.build_store(p.builder, p.value, field0_ptr)
    if p.lx.kind == tok.comma() {
        p = advance_sig(p)
    }
    if p.lx.kind != tok.ident() || !str.eq(p.lx.lexeme, p.struct_field1) {
        return fail_parser(p, "expected second struct field initializer")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.colon() {
        return fail_parser(p, "expected ':' after struct field name")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen struct field initializer requires i32")
    if !p.ok { return p }
    field1_ptr := llvm.build_struct_gep2(p.builder, struct_type, slot, 1, "memberptr")
    llvm.build_store(p.builder, p.value, field1_ptr)
    if p.struct_fields == 3 {
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
        }
        if p.lx.kind != tok.ident() || !str.eq(p.lx.lexeme, p.struct_field2) {
            return fail_parser(p, "expected third struct field initializer")
        }
        p = advance_sig(p)
        if p.lx.kind != tok.colon() {
            return fail_parser(p, "expected ':' after struct field name")
        }
        p = advance_sig(p)
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        p = ensure_i32_value(p, "self codegen struct field initializer requires i32")
        if !p.ok { return p }
        field2_ptr := llvm.build_struct_gep2(p.builder, struct_type, slot, 2, "memberptr")
        llvm.build_store(p.builder, p.value, field2_ptr)
    }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after struct literal")
    }
    p = advance_sig(p)
    return set_slot(p, name, slot, struct_type_kind)
}

fn parse_array3_assignment(p TinyIrParser, name string) TinyIrParser {
    p = lookup_slot(p, name)
    if !p.ok { return p }
    slot := p.value
    if p.value_type != tiny_i32_array3_type_kind() {
        return unsupported_parser(p, "self codegen indexed assignment requires i32[3] local")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen array index requires i32")
    if !p.ok { return p }
    index_value := p.value
    if p.lx.kind != tok.rbrack() {
        return fail_parser(p, "expected ']' after array index")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.assign() {
        return fail_parser(p, "expected '=' after indexed assignment target")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen indexed assignment requires i32 value")
    if !p.ok { return p }
    element_ptr := build_checked_i32_array3_element_ptr(p, slot, index_value, "arrayidx")
    llvm.build_store(p.builder, p.value, element_ptr)
    p.value_type = tiny_void_type_kind()
    return p
}

fn parse_struct2_member_assignment(p TinyIrParser, name string) TinyIrParser {
    p = lookup_slot(p, name)
    if !p.ok { return p }
    slot := p.value
    slot_type := p.value_type
    if slot_type != tiny_i32_struct2_type_kind() && slot_type != tiny_i32_struct3_type_kind() {
        return unsupported_parser(p, "self codegen member assignment currently supports two- or three-field i32 structs")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected member name after '.'")
    }
    field_ptr := build_i32_struct_field_ptr(p, slot, slot_type, p.lx.lexeme, "memberptr")
    if field_ptr == none {
        return fail_parser(p, "unknown struct field")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.assign() {
        return fail_parser(p, "expected '=' after member assignment target")
    }
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen member assignment requires i32 value")
    if !p.ok { return p }
    llvm.build_store(p.builder, p.value, field_ptr)
    p.value_type = tiny_void_type_kind()
    return p
}

fn parse_term(p TinyIrParser) TinyIrParser {
    p = parse_factor(p)
    for (; p.ok && (p.lx.kind == tok.star() || p.lx.kind == tok.slash() || p.lx.kind == tok.percent()); ) {
        op := p.lx.kind
        p = ensure_i32_value(p, "self codegen arithmetic currently requires i32 operands")
        if !p.ok { return p }
        left := p.value
        p = advance_sig(p)
        p = parse_factor(p)
        if !p.ok { return p }
        p = ensure_i32_value(p, "self codegen arithmetic currently requires i32 operands")
        if !p.ok { return p }
        if op == tok.star() {
            p.value = llvm.build_mul(p.builder, left, p.value, "multmp")
        } else if op == tok.slash() {
            p.value = llvm.build_sdiv(p.builder, left, p.value, "divtmp")
        } else {
            p.value = llvm.build_srem(p.builder, left, p.value, "remtmp")
        }
        p.value_type = tiny_i32_type_kind()
    }
    return p
}

fn parse_expr(p TinyIrParser) TinyIrParser {
    p = parse_term(p)
    for (; p.ok && (p.lx.kind == tok.plus() || p.lx.kind == tok.minus()); ) {
        op := p.lx.kind
        p = ensure_i32_value(p, "self codegen arithmetic currently requires i32 operands")
        if !p.ok { return p }
        left := p.value
        p = advance_sig(p)
        p = parse_term(p)
        if !p.ok { return p }
        p = ensure_i32_value(p, "self codegen arithmetic currently requires i32 operands")
        if !p.ok { return p }
        if op == tok.plus() {
            p.value = llvm.build_add(p.builder, left, p.value, "addtmp")
        } else {
            p.value = llvm.build_sub(p.builder, left, p.value, "subtmp")
        }
        p.value_type = tiny_i32_type_kind()
    }
    return p
}

fn compare_predicate(op i32) i32 {
    if op == tok.eq() { return llvm.int_eq() }
    if op == tok.neq() { return llvm.int_ne() }
    if op == tok.lt() { return llvm.int_slt() }
    if op == tok.gt() { return llvm.int_sgt() }
    if op == tok.le() { return llvm.int_sle() }
    if op == tok.ge() { return llvm.int_sge() }
    return llvm.int_ne()
}

fn parse_expr_or_comparison(p TinyIrParser) TinyIrParser {
    p = parse_expr(p)
    if !p.ok { return p }
    left := p.value
    left_type := p.value_type
    op := p.lx.kind
    if op != tok.eq() && op != tok.neq() && op != tok.lt() && op != tok.gt() && op != tok.le() && op != tok.ge() {
        return p
    }
    p = advance_sig(p)
    p = parse_expr(p)
    if !p.ok { return p }
    if left_type != p.value_type {
        return unsupported_parser(p, "self codegen comparison operands must have the same type")
    }
    if left_type == tiny_bool_type_kind() && op != tok.eq() && op != tok.neq() {
        return unsupported_parser(p, "self codegen bool comparisons support == and !=")
    }
    p.value = llvm.build_icmp(p.builder, compare_predicate(op), left, p.value, "condtmp")
    p.value_type = tiny_bool_type_kind()
    return p
}

fn parse_condition(p TinyIrParser) TinyIrParser {
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    return ensure_bool_value(p)
}

fn skip_import_or_module(p TinyIrParser) TinyIrParser {
    for (; p.ok && p.lx.kind != tok.eof() && p.lx.kind != tok.newline(); ) {
        p.lx = lexer.next(p.lx)
        if !p.lx.ok {
            p.ok = false
            p.supported = true
            p.message = p.lx.message
            p.line = p.lx.tok_line
            p.col = p.lx.tok_col
            return p
        }
    }
    return advance_sig(p)
}

fn parse_var_or_assign(p TinyIrParser) TinyIrParser {
    name := p.lx.lexeme
    p = advance_sig(p)
    if !p.ok { return p }

    if p.lx.kind == tok.lbrack() {
        return parse_array3_assignment(p, name)
    }

    if p.lx.kind == tok.dot() {
        return parse_struct2_member_assignment(p, name)
    }

    if is_declare_assign(p.lx.kind, p.lx.lexeme) {
        p = advance_sig(p)
        if p.lx.kind == tok.lbrack() {
            return parse_i32_array3_local(p, name)
        }
        if p.saw_struct && p.lx.kind == tok.ident() && str.eq(p.lx.lexeme, p.struct_name) {
            return parse_struct2_local(p, name)
        }
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        inferred_type := p.value_type
        if inferred_type == tiny_void_type_kind() {
            return unsupported_parser(p, "self codegen cannot store void expression in a local")
        }
        slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, inferred_type), name)
        llvm.build_store(p.builder, p.value, slot)
        return set_slot(p, name, slot, inferred_type)
    }

    if p.lx.kind == tok.colon() {
        p = advance_sig(p)
        if p.lx.kind == tok.assign() {
            p = advance_sig(p)
            if p.saw_struct && p.lx.kind == tok.ident() && str.eq(p.lx.lexeme, p.struct_name) {
                return parse_struct2_local(p, name)
            }
            p = parse_expr_or_comparison(p)
            if !p.ok { return p }
            inferred_type := p.value_type
            if inferred_type == tiny_void_type_kind() {
                return unsupported_parser(p, "self codegen cannot store void expression in a local")
            }
            slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, inferred_type), name)
            llvm.build_store(p.builder, p.value, slot)
            return set_slot(p, name, slot, inferred_type)
        }
        if p.lx.kind != tok.ident() {
            return fail_parser(p, "expected local type")
        }
        declared_type := tiny_type_from_name(p.lx.lexeme)
        if declared_type == 0 {
            return unsupported_parser(p, "self codegen currently supports only i32 and bool local variables")
        }
        p = advance_sig(p)
        if p.lx.kind != tok.assign() {
            return fail_parser(p, "expected '=' after local type")
        }
        p = advance_sig(p)
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        p = ensure_value_type(p, declared_type, "self codegen local initializer type mismatch")
        if !p.ok { return p }
        slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, declared_type), name)
        llvm.build_store(p.builder, p.value, slot)
        return set_slot(p, name, slot, declared_type)
    }

    if p.lx.kind == tok.assign() {
        p = lookup_slot(p, name)
        if !p.ok { return p }
        slot := p.value
        slot_type := p.value_type
        p = advance_sig(p)
        if p.lx.kind == tok.assign() {
            return unsupported_parser(p, "self codegen does not support comparison statements yet")
        }
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        p = ensure_value_type(p, slot_type, "self codegen assignment type mismatch")
        if !p.ok { return p }
        llvm.build_store(p.builder, p.value, slot)
        return p
    }

    return unsupported_parser(p, "self codegen currently supports i32/bool local declarations, assignments, calls, and return")
}

fn parse_if_statement(p TinyIrParser) TinyIrParser {
    p = advance_sig(p)
    p = parse_condition(p)
    if !p.ok { return p }
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after if condition")
    }

    then_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_if_then")
    else_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_if_else")
    done_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_if_done")
    llvm.build_cond_br(p.builder, p.value, then_block, else_block)

    llvm.position_builder_at_end(p.builder, then_block)
    p = advance_sig(p)
    then_returned := false
    then_transferred := false
    for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
        p = parse_statement(p)
        if !p.ok { return p }
        if p.returned {
            then_returned = true
            p.returned = false
        }
        if p.loop_break || p.loop_continue {
            then_transferred = true
            p.loop_break = false
            p.loop_continue = false
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.lx.kind == tok.semicolon() {
            p = advance_sig(p)
        }
    }
    if !p.ok { return p }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after if body")
    }
    if !then_returned && !then_transferred {
        llvm.build_br(p.builder, done_block)
    }
    p = advance_sig(p)

    llvm.position_builder_at_end(p.builder, else_block)
    else_returned := false
    else_transferred := false
    if p.lx.kind == tok.kw_else() {
        p = advance_sig(p)
        if p.lx.kind != tok.lbrace() {
            return fail_parser(p, "expected '{' after else")
        }
        p = advance_sig(p)
        for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
            p = parse_statement(p)
            if !p.ok { return p }
            if p.returned {
                else_returned = true
                p.returned = false
            }
            if p.loop_break || p.loop_continue {
                else_transferred = true
                p.loop_break = false
                p.loop_continue = false
                p = skip_to_block_end(p)
                if !p.ok { return p }
                break
            }
            if p.lx.kind == tok.semicolon() {
                p = advance_sig(p)
            }
        }
        if !p.ok { return p }
        if p.lx.kind != tok.rbrace() {
            return fail_parser(p, "expected '}' after else body")
        }
        p = advance_sig(p)
    }
    if !else_returned && !else_transferred {
        llvm.build_br(p.builder, done_block)
    }
    llvm.position_builder_at_end(p.builder, done_block)
    return p
}

fn parse_for_in_statement(p TinyIrParser, item_name string) TinyIrParser {
    p = advance_sig(p)
    if p.lx.kind == tok.ident() {
        array_name := p.lx.lexeme
        probe := lookup_slot(p, array_name)
        if probe.ok && probe.value_type == tiny_i32_array3_type_kind() {
            p = probe
            array_slot := p.value
            p = advance_sig(p)
            if p.lx.kind != tok.lbrace() {
                return fail_parser(p, "expected '{' after for-in header")
            }

            index_slot := llvm.build_alloca(p.builder, p.i32_type, "tiny_for_in_index")
            item_slot := llvm.build_alloca(p.builder, p.i32_type, item_name)
            zero := llvm.const_int(p.i32_type, 0, 1)
            one := llvm.const_int(p.i32_type, 1, 1)
            three := llvm.const_int(p.i32_type, 3, 1)
            llvm.build_store(p.builder, zero, index_slot)
            p = set_slot(p, item_name, item_slot, tiny_i32_type_kind())
            if !p.ok { return p }

            check_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_in_check")
            body_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_in_body")
            update_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_in_update")
            done_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_in_done")
            outer_break_block := p.current_break_block
            outer_continue_block := p.current_continue_block
            p.current_break_block = done_block
            p.current_continue_block = update_block
            llvm.build_br(p.builder, check_block)

            llvm.position_builder_at_end(p.builder, check_block)
            loaded_index := llvm.build_load2(p.builder, p.i32_type, index_slot, "tiny_for_in_index_value")
            has_next := llvm.build_icmp(p.builder, llvm.int_slt(), loaded_index, three, "tiny_for_in_has_next")
            llvm.build_cond_br(p.builder, has_next, body_block, done_block)

            llvm.position_builder_at_end(p.builder, body_block)
            element_ptr := build_checked_i32_array3_element_ptr(p, array_slot, loaded_index, "tiny_for_in_arrayidx")
            item_value := llvm.build_load2(p.builder, p.i32_type, element_ptr, "tiny_for_in_item")
            llvm.build_store(p.builder, item_value, item_slot)
            p = advance_sig(p)
            body_terminated := false
            for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
                p = parse_statement(p)
                if !p.ok { return p }
                if p.returned {
                    body_terminated = true
                    p.returned = false
                    p = skip_to_block_end(p)
                    if !p.ok { return p }
                    break
                }
                if p.loop_break || p.loop_continue {
                    body_terminated = true
                    p = skip_to_block_end(p)
                    if !p.ok { return p }
                    break
                }
                if p.lx.kind == tok.semicolon() {
                    p = advance_sig(p)
                }
            }
            if !p.ok { return p }
            if p.lx.kind != tok.rbrace() {
                return fail_parser(p, "expected '}' after for-in body")
            }
            if !body_terminated {
                llvm.build_br(p.builder, update_block)
            }

            llvm.position_builder_at_end(p.builder, update_block)
            update_index := llvm.build_load2(p.builder, p.i32_type, index_slot, "tiny_for_in_update_index")
            next_index := llvm.build_add(p.builder, update_index, one, "tiny_for_in_next_index")
            llvm.build_store(p.builder, next_index, index_slot)
            llvm.build_br(p.builder, check_block)

            llvm.position_builder_at_end(p.builder, done_block)
            p.current_break_block = outer_break_block
            p.current_continue_block = outer_continue_block
            p.loop_break = false
            p.loop_continue = false
            return advance_sig(p)
        }
    }

    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen numeric for-in limit requires i32")
    if !p.ok { return p }
    limit_value := p.value
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after for-in header")
    }

    index_slot := llvm.build_alloca(p.builder, p.i32_type, "tiny_for_in_index")
    item_slot := llvm.build_alloca(p.builder, p.i32_type, item_name)
    limit_slot := llvm.build_alloca(p.builder, p.i32_type, "tiny_for_in_limit")
    zero := llvm.const_int(p.i32_type, 0, 1)
    one := llvm.const_int(p.i32_type, 1, 1)
    llvm.build_store(p.builder, zero, index_slot)
    llvm.build_store(p.builder, limit_value, limit_slot)
    p = set_slot(p, item_name, item_slot, tiny_i32_type_kind())
    if !p.ok { return p }

    check_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_in_check")
    body_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_in_body")
    update_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_in_update")
    done_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_in_done")
    outer_break_block := p.current_break_block
    outer_continue_block := p.current_continue_block
    p.current_break_block = done_block
    p.current_continue_block = update_block
    llvm.build_br(p.builder, check_block)

    llvm.position_builder_at_end(p.builder, check_block)
    loaded_index := llvm.build_load2(p.builder, p.i32_type, index_slot, "tiny_for_in_index_value")
    loaded_limit := llvm.build_load2(p.builder, p.i32_type, limit_slot, "tiny_for_in_limit_value")
    has_next := llvm.build_icmp(p.builder, llvm.int_slt(), loaded_index, loaded_limit, "tiny_for_in_has_next")
    llvm.build_cond_br(p.builder, has_next, body_block, done_block)

    llvm.position_builder_at_end(p.builder, body_block)
    llvm.build_store(p.builder, loaded_index, item_slot)
    p = advance_sig(p)
    body_terminated := false
    for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
        p = parse_statement(p)
        if !p.ok { return p }
        if p.returned {
            body_terminated = true
            p.returned = false
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.loop_break || p.loop_continue {
            body_terminated = true
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.lx.kind == tok.semicolon() {
            p = advance_sig(p)
        }
    }
    if !p.ok { return p }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after for-in body")
    }
    if !body_terminated {
        llvm.build_br(p.builder, update_block)
    }

    llvm.position_builder_at_end(p.builder, update_block)
    update_index := llvm.build_load2(p.builder, p.i32_type, index_slot, "tiny_for_in_update_index")
    next_index := llvm.build_add(p.builder, update_index, one, "tiny_for_in_next_index")
    llvm.build_store(p.builder, next_index, index_slot)
    llvm.build_br(p.builder, check_block)

    llvm.position_builder_at_end(p.builder, done_block)
    p.current_break_block = outer_break_block
    p.current_continue_block = outer_continue_block
    p.loop_break = false
    p.loop_continue = false
    return advance_sig(p)
}

fn parse_for_statement(p TinyIrParser) TinyIrParser {
    p = advance_sig(p)
    if p.lx.kind == tok.ident() {
        item_name := p.lx.lexeme
        probe := p
        probe = advance_sig(probe)
        if !probe.ok { return probe }
        if probe.lx.kind == tok.kw_in() {
            return parse_for_in_statement(probe, item_name)
        }
    }
    if p.lx.kind != tok.lparen() {
        return unsupported_parser(p, "self codegen currently supports C-style for loops only")
    }
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected for-loop initializer")
    }
    p = parse_var_or_assign(p)
    if !p.ok { return p }
    if p.lx.kind != tok.semicolon() {
        return fail_parser(p, "expected ';' after for-loop initializer")
    }

    check_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_check")
    body_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_body")
    update_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_update")
    done_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_for_done")
    outer_break_block := p.current_break_block
    outer_continue_block := p.current_continue_block
    p.current_break_block = done_block
    p.current_continue_block = update_block
    llvm.build_br(p.builder, check_block)

    llvm.position_builder_at_end(p.builder, check_block)
    p = advance_sig(p)
    p = parse_condition(p)
    if !p.ok { return p }
    if p.lx.kind != tok.semicolon() {
        return fail_parser(p, "expected ';' after for-loop condition")
    }
    llvm.build_cond_br(p.builder, p.value, body_block, done_block)

    llvm.position_builder_at_end(p.builder, update_block)
    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected for-loop update")
    }
    p = parse_var_or_assign(p)
    if !p.ok { return p }
    if p.lx.kind != tok.rparen() {
        return fail_parser(p, "expected ')' after for-loop update")
    }
    llvm.build_br(p.builder, check_block)

    p = advance_sig(p)
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after for-loop header")
    }
    llvm.position_builder_at_end(p.builder, body_block)
    p = advance_sig(p)
    body_terminated := false
    for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
        p = parse_statement(p)
        if !p.ok { return p }
        if p.returned {
            body_terminated = true
            p.returned = false
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.loop_break || p.loop_continue {
            body_terminated = true
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.lx.kind == tok.semicolon() {
            p = advance_sig(p)
        }
    }
    if !p.ok { return p }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after for-loop body")
    }
    if !body_terminated {
        llvm.build_br(p.builder, update_block)
    }
    llvm.position_builder_at_end(p.builder, done_block)
    p.current_break_block = outer_break_block
    p.current_continue_block = outer_continue_block
    p.loop_break = false
    p.loop_continue = false
    return advance_sig(p)
}

fn parse_switch_case_value(p TinyIrParser) TinyIrParser {
    sign := 1
    if p.lx.kind == tok.minus() {
        sign = -1
        p = advance_sig(p)
    }
    if p.lx.kind != tok.int_lit() {
        return unsupported_parser(p, "self codegen switch cases currently require i32 integer literals")
    }
    p.value = llvm.const_int(p.i32_type, parse_i32(p.lx.lexeme) * sign, 1)
    p.value_type = tiny_i32_type_kind()
    return advance_sig(p)
}

fn parse_switch_case_body(p TinyIrParser, done_block *byte, label string) TinyIrParser {
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, label)
    }
    p = advance_sig(p)
    body_terminated := false
    for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
        p = parse_statement(p)
        if !p.ok { return p }
        if p.returned {
            body_terminated = true
            p.returned = false
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.loop_break || p.loop_continue {
            body_terminated = true
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.lx.kind == tok.semicolon() {
            p = advance_sig(p)
        }
    }
    if !p.ok { return p }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after switch case body")
    }
    if !body_terminated {
        llvm.build_br(p.builder, done_block)
    }
    return advance_sig(p)
}

fn parse_switch_statement(p TinyIrParser) TinyIrParser {
    p = advance_sig(p)
    p = parse_expr_or_comparison(p)
    if !p.ok { return p }
    p = ensure_i32_value(p, "self codegen switch expression currently requires i32")
    if !p.ok { return p }
    selector := p.value
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after switch expression")
    }

    default_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_switch_default")
    done_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_switch_done")
    switch_inst := llvm.build_switch(p.builder, selector, default_block, 4)
    outer_break_block := p.current_break_block
    outer_continue_block := p.current_continue_block
    p.current_break_block = done_block
    default_seen := false

    p = advance_sig(p)
    for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
        if p.lx.kind != tok.ident() {
            return fail_parser(p, "expected switch case or default")
        }
        if str.eq(p.lx.lexeme, "case") {
            p = advance_sig(p)
            p = parse_switch_case_value(p)
            if !p.ok { return p }
            case_value := p.value
            case_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "tiny_switch_case")
            llvm.add_case(switch_inst, case_value, case_block)
            llvm.position_builder_at_end(p.builder, case_block)
            p = parse_switch_case_body(p, done_block, "expected '{' after switch case")
            if !p.ok { return p }
            p.loop_break = false
            p.loop_continue = false
        } else if str.eq(p.lx.lexeme, "default") {
            if default_seen {
                return fail_parser(p, "duplicate switch default")
            }
            default_seen = true
            p = advance_sig(p)
            llvm.position_builder_at_end(p.builder, default_block)
            p = parse_switch_case_body(p, done_block, "expected '{' after switch default")
            if !p.ok { return p }
            p.loop_break = false
            p.loop_continue = false
        } else {
            return fail_parser(p, "expected switch case or default")
        }
    }
    if !p.ok { return p }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after switch")
    }
    if !default_seen {
        llvm.position_builder_at_end(p.builder, default_block)
        llvm.build_br(p.builder, done_block)
    }
    llvm.position_builder_at_end(p.builder, done_block)
    p.current_break_block = outer_break_block
    p.current_continue_block = outer_continue_block
    p.loop_break = false
    p.loop_continue = false
    return advance_sig(p)
}

fn parse_statement(p TinyIrParser) TinyIrParser {
    if p.lx.kind == tok.kw_break() {
        if p.current_break_block == none {
            return unsupported_parser(p, "break is only supported inside a self-codegen loop")
        }
        llvm.build_br(p.builder, p.current_break_block)
        p.loop_break = true
        return advance_sig(p)
    }

    if p.lx.kind == tok.kw_continue() {
        if p.current_continue_block == none {
            return unsupported_parser(p, "continue is only supported inside a self-codegen loop")
        }
        llvm.build_br(p.builder, p.current_continue_block)
        p.loop_continue = true
        return advance_sig(p)
    }

    if p.lx.kind == tok.kw_return() {
        p = advance_sig(p)
        if p.current_return_type == tiny_void_type_kind() {
            if p.lx.kind == tok.newline() || p.lx.kind == tok.semicolon() || p.lx.kind == tok.rbrace() {
                llvm.build_ret_void(p.builder)
                p.returned = true
                return p
            }
        }
        p = parse_expr_or_comparison(p)
        if !p.ok { return p }
        p = ensure_value_type(p, p.current_return_type, "self codegen return expression type mismatch")
        if !p.ok { return p }
        llvm.build_ret(p.builder, p.value)
        p.returned = true
        return p
    }

    if p.lx.kind == tok.kw_if() {
        return parse_if_statement(p)
    }

    if p.lx.kind == tok.kw_for() {
        return parse_for_statement(p)
    }

    if p.lx.kind == tok.kw_switch() {
        return parse_switch_statement(p)
    }

    if p.lx.kind == tok.ident() {
        probe := p
        probe = advance_sig(probe)
        if !probe.ok { return probe }
        if probe.lx.kind == tok.lparen() {
            p = parse_expr_or_comparison(p)
            if !p.ok { return p }
            return p
        }
        return parse_var_or_assign(p)
    }

    return unsupported_parser(p, "self codegen currently supports local statements, calls, assignments, if, for, switch, and return")
}

fn parse_function(p TinyIrParser) TinyIrParser {
    if p.lx.kind != tok.kw_fn() {
        return unsupported_parser(p, "self codegen currently supports fn main() i32 plus helper functions")
    }

    p = advance_sig(p)
    if p.lx.kind != tok.ident() {
        return fail_parser(p, "expected function name")
    }
    name := p.lx.lexeme
    is_main := str.eq(name, "main")

    p = advance_sig(p)
    if p.lx.kind != tok.lparen() {
        return fail_parser(p, "expected '(' after function name")
    }
    p = advance_sig(p)
    param_count := 0
    param_name := ""
    param1_name := ""
    param2_name := ""
    param3_name := ""
    param4_name := ""
    param5_name := ""
    param6_name := ""
    param7_name := ""
    param0_type := tiny_i32_type_kind()
    param1_type := tiny_i32_type_kind()
    param2_type := tiny_i32_type_kind()
    param3_type := tiny_i32_type_kind()
    param4_type := tiny_i32_type_kind()
    param5_type := tiny_i32_type_kind()
    param6_type := tiny_i32_type_kind()
    param7_type := tiny_i32_type_kind()
    if p.lx.kind != tok.rparen() {
        if p.lx.kind != tok.ident() {
            return fail_parser(p, "expected parameter name")
        }
        param_name = p.lx.lexeme
        p = advance_sig(p)
        p = parse_type_name(p, "expected parameter type")
        if !p.ok { return p }
        param0_type = p.value_type
        param_count = 1
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param1_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param1_type = p.value_type
            param_count = 2
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param2_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param2_type = p.value_type
            param_count = 3
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param3_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param3_type = p.value_type
            param_count = 4
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param4_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param4_type = p.value_type
            param_count = 5
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param5_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param5_type = p.value_type
            param_count = 6
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param6_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param6_type = p.value_type
            param_count = 7
        }
        if p.lx.kind == tok.comma() {
            p = advance_sig(p)
            if p.lx.kind != tok.ident() {
                return fail_parser(p, "expected parameter name")
            }
            param7_name = p.lx.lexeme
            p = advance_sig(p)
            p = parse_type_name(p, "expected parameter type")
            if !p.ok { return p }
            param7_type = p.value_type
            param_count = 8
        }
        if p.lx.kind != tok.rparen() {
            return unsupported_parser(p, "self codegen currently supports up to eight helper parameters")
        }
    }
    if is_main && param_count != 0 {
        if param_count != 2 || param0_type != tiny_i32_type_kind() || param1_type != tiny_ptr_type_kind() {
            return unsupported_parser(p, "self codegen main parameters must be () or (i32, *string)")
        }
    }
    p = advance_sig(p)
    return_type := tiny_void_type_kind()
    if p.lx.kind == tok.ident() || p.lx.kind == tok.star() {
        p = parse_type_name(p, "expected function return type")
        if !p.ok { return p }
        return_type = p.value_type
    }
    if is_main && return_type != tiny_i32_type_kind() {
        return unsupported_parser(p, "self codegen currently requires main to return i32")
    }
    if p.lx.kind != tok.lbrace() {
        return fail_parser(p, "expected '{' after function signature")
    }

    p = reset_locals(p)
    current_type := function_type_for_signature8(p, return_type, param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, param6_type, param7_type)
    p.current_return_type = return_type
    if is_main {
        if p.main_fn == none {
            return unsupported_parser(p, "self codegen missing predeclared main")
        }
        p.current_fn = p.main_fn
        p.saw_main = true
    } else {
        p = lookup_helper(p, name)
        if !p.ok { return p }
        p.current_fn = p.helper_fn
        current_type = p.helper_fn_type
        p.current_return_type = p.helper_return_type
    }
    entry := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "entry")
    llvm.position_builder_at_end(p.builder, entry)
    if param_count > 0 {
        param_value := llvm.get_param(p.current_fn, 0)
        param_slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, param0_type), param_name)
        llvm.build_store(p.builder, param_value, param_slot)
        p = set_slot(p, param_name, param_slot, param0_type)
        if !p.ok { return p }
    }
    if param_count > 1 {
        param1_value := llvm.get_param(p.current_fn, 1)
        param1_slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, param1_type), param1_name)
        llvm.build_store(p.builder, param1_value, param1_slot)
        p = set_slot(p, param1_name, param1_slot, param1_type)
        if !p.ok { return p }
    }
    if param_count > 2 {
        param2_value := llvm.get_param(p.current_fn, 2)
        param2_slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, param2_type), param2_name)
        llvm.build_store(p.builder, param2_value, param2_slot)
        p = set_slot(p, param2_name, param2_slot, param2_type)
        if !p.ok { return p }
    }
    if param_count > 3 {
        param3_value := llvm.get_param(p.current_fn, 3)
        param3_slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, param3_type), param3_name)
        llvm.build_store(p.builder, param3_value, param3_slot)
        p = set_slot(p, param3_name, param3_slot, param3_type)
        if !p.ok { return p }
    }
    if param_count > 4 {
        param4_value := llvm.get_param(p.current_fn, 4)
        param4_slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, param4_type), param4_name)
        llvm.build_store(p.builder, param4_value, param4_slot)
        p = set_slot(p, param4_name, param4_slot, param4_type)
        if !p.ok { return p }
    }
    if param_count > 5 {
        param5_value := llvm.get_param(p.current_fn, 5)
        param5_slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, param5_type), param5_name)
        llvm.build_store(p.builder, param5_value, param5_slot)
        p = set_slot(p, param5_name, param5_slot, param5_type)
        if !p.ok { return p }
    }
    if param_count > 6 {
        param6_value := llvm.get_param(p.current_fn, 6)
        param6_slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, param6_type), param6_name)
        llvm.build_store(p.builder, param6_value, param6_slot)
        p = set_slot(p, param6_name, param6_slot, param6_type)
        if !p.ok { return p }
    }
    if param_count > 7 {
        param7_value := llvm.get_param(p.current_fn, 7)
        param7_slot := llvm.build_alloca(p.builder, llvm_type_for_value(p, param7_type), param7_name)
        llvm.build_store(p.builder, param7_value, param7_slot)
        p = set_slot(p, param7_name, param7_slot, param7_type)
        if !p.ok { return p }
    }

    p = advance_sig(p)
    for (; p.ok && p.lx.kind != tok.rbrace() && p.lx.kind != tok.eof(); ) {
        p = parse_statement(p)
        if !p.ok { return p }
        if p.returned || p.loop_break || p.loop_continue {
            p = skip_to_block_end(p)
            if !p.ok { return p }
            break
        }
        if p.lx.kind == tok.semicolon() {
            p = advance_sig(p)
        }
    }
    if !p.ok { return p }
    if p.lx.kind != tok.rbrace() {
        return fail_parser(p, "expected '}' after function body")
    }
    if !p.returned {
        if p.current_return_type == tiny_void_type_kind() {
            llvm.build_ret_void(p.builder)
            return advance_sig(p)
        }
        return fail_parser(p, "non-void function is missing an explicit return")
    }
    return advance_sig(p)
}

fn parse_program(p TinyIrParser) TinyIrParser {
    p = advance_sig(p)
    if !p.ok { return p }

    for (; p.lx.kind == tok.kw_import() || p.lx.kind == tok.kw_module() || p.lx.kind == tok.kw_package(); ) {
        p = skip_import_or_module(p)
        if !p.ok { return p }
    }

    for (; p.ok && p.lx.kind != tok.eof(); ) {
        if p.lx.kind == tok.kw_extern() {
            p = skip_extern_decl(p)
        } else if p.lx.kind == tok.kw_struct() {
            p = scan_struct_decl(p)
        } else {
            p = parse_function(p)
        }
        if !p.ok { return p }
    }
    if !p.saw_main {
        return unsupported_parser(p, "self codegen currently supports fn main() i32")
    }
    return p
}

pub fn emit_file(path string, source string, out_dir string) TinyIrResult {
    ctx := llvm.context_create()
    mod := llvm.module_create_with_name_in_context("ycpl_self_tiny_ast", ctx)
    builder := llvm.create_builder_in_context(ctx)
    void_type := llvm.void_type_in_context(ctx)
    bool_type := llvm.int1_type_in_context(ctx)
    i8_type := llvm.int8_type_in_context(ctx)
    string_type := llvm.pointer_type(i8_type, 0)
    i64_type := llvm.int64_type_in_context(ctx)
    ptr_type := llvm.pointer_type(i8_type, 0)
    i32_type := llvm.int32_type_in_context(ctx)
    struct2_type := llvm.struct_type2(ctx, i32_type, i32_type, 0)
    struct3_type := llvm.struct_type3(ctx, i32_type, i32_type, i32_type, 0)
    fn_type := llvm.function_type(i32_type, none, 0, 0)
    fn_type1 := llvm.function_type1(i32_type, i32_type, 0)
    fn_type2 := llvm.function_type2(i32_type, i32_type, i32_type, 0)
    bool_fn_type := llvm.function_type(bool_type, none, 0, 0)
    bool_fn_type1 := llvm.function_type1(bool_type, i32_type, 0)
    bool_fn_type2 := llvm.function_type2(bool_type, i32_type, i32_type, 0)
    string_fn_type := llvm.function_type(string_type, none, 0, 0)
    string_fn_type1 := llvm.function_type1(string_type, i32_type, 0)
    string_fn_type2 := llvm.function_type2(string_type, i32_type, i32_type, 0)
    abort_fn_type := llvm.function_type(void_type, none, 0, 0)
    abort_fn := llvm.add_function(mod, "abort", abort_fn_type)

    p := TinyIrParser{lx: lexer.new(path, source), ok: true, supported: true, message: "", line: 1, col: 1, ctx: ctx, mod: mod, builder: builder, void_type: void_type, bool_type: bool_type, string_type: string_type, struct2_type: struct2_type, struct3_type: struct3_type, i64_type: i64_type, ptr_type: ptr_type, i32_type: i32_type, fn_type: fn_type, fn_type1: fn_type1, fn_type2: fn_type2, bool_fn_type: bool_fn_type, bool_fn_type1: bool_fn_type1, bool_fn_type2: bool_fn_type2, string_fn_type: string_fn_type, string_fn_type1: string_fn_type1, string_fn_type2: string_fn_type2, abort_fn_type: abort_fn_type, abort_fn: abort_fn, current_break_block: none, current_continue_block: none, current_fn: none, current_return_type: 0, main_fn: none, helper_fn: none, helper_fn_type: fn_type, helper_return_type: tiny_i32_type_kind(), helper_name: "", helper_param_name: "", helper_param_count: 0, helper_count: 0, helper0_name: "", helper1_name: "", helper2_name: "", helper3_name: "", helper4_name: "", helper5_name: "", helper6_name: "", helper7_name: "", helper0_fn: none, helper1_fn: none, helper2_fn: none, helper3_fn: none, helper4_fn: none, helper5_fn: none, helper6_fn: none, helper7_fn: none, helper0_type: none, helper1_type: none, helper2_type: none, helper3_type: none, helper4_type: none, helper5_type: none, helper6_type: none, helper7_type: none, helper0_params: 0, helper1_params: 0, helper2_params: 0, helper3_params: 0, helper4_params: 0, helper5_params: 0, helper6_params: 0, helper7_params: 0, helper_signature: 0, helper0_signature: 0, helper1_signature: 0, helper2_signature: 0, helper3_signature: 0, helper4_signature: 0, helper5_signature: 0, helper6_signature: 0, helper7_signature: 0, helper0_return_type: 0, helper1_return_type: 0, helper2_return_type: 0, helper3_return_type: 0, helper4_return_type: 0, helper5_return_type: 0, helper6_return_type: 0, helper7_return_type: 0, value: none, value_type: 0, vars: 0, name0: "", name1: "", name2: "", name3: "", name4: "", name5: "", name6: "", name7: "", slot0: none, slot1: none, slot2: none, slot3: none, slot4: none, slot5: none, slot6: none, slot7: none, type0: 0, type1: 0, type2: 0, type3: 0, type4: 0, type5: 0, type6: 0, type7: 0, saw_main: false, returned: false, loop_break: false, loop_continue: false, saw_struct: false, struct_name: "", struct_fields: 0, struct_field0: "", struct_field1: "", struct_field2: ""}
    p = scan_program_decls(p)
    if !p.ok {
        llvm.dispose_builder(builder)
        llvm.dispose_module(mod)
        llvm.context_dispose(ctx)
        if !p.supported {
            return unsupported_result(p.line, p.col, p.message)
        }
        return fail_result(p.line, p.col, p.message)
    }
    p.lx = lexer.new(path, source)
    p.ok = true
    p.supported = true
    p.message = ""
    p.line = 1
    p.col = 1
    p.saw_main = false
    p.returned = false
    p.current_break_block = none
    p.current_continue_block = none
    p.loop_break = false
    p.loop_continue = false
    p.current_return_type = 0
    p = parse_program(p)
    if !p.ok {
        llvm.dispose_builder(builder)
        llvm.dispose_module(mod)
        llvm.context_dispose(ctx)
        if !p.supported {
            return unsupported_result(p.line, p.col, p.message)
        }
        return fail_result(p.line, p.col, p.message)
    }

    ir := llvm.print_module_to_string(mod)
    fs.mkdir(out_dir)
    out_file := merged_ll_path(out_dir)
    wrote := fs.write_file(out_file, ir)

    llvm.dispose_message(ir)
    llvm.dispose_builder(builder)
    llvm.dispose_module(mod)
    llvm.context_dispose(ctx)

    if !wrote {
        return fail_result(1, 1, "failed to write LLVM IR")
    }
    return ok_result(out_file)
}
