struct TinyGepIndices2 {
    arg0 *byte
    arg1 *byte
}

fn ok_result(out_file string) TinyIrResult {
    return TinyIrResult{ok: true, supported: true, message: "", line: 1, col: 1, out_file: out_file}
}

fn fail_result(line i32, col i32, message string) TinyIrResult {
    return TinyIrResult{ok: false, supported: true, message: message, line: line, col: col, out_file: ""}
}

fn unsupported_result(line i32, col i32, message string) TinyIrResult {
    return TinyIrResult{ok: false, supported: false, message: message, line: line, col: col, out_file: ""}
}

fn fail_parser(p TinyIrParser, message string) TinyIrParser {
    p.ok = false
    p.supported = true
    p.message = message
    p.line = p.lx.tok_line
    p.col = p.lx.tok_col
    return p
}

fn unsupported_parser(p TinyIrParser, message string) TinyIrParser {
    p.ok = false
    p.supported = false
    p.message = message
    p.line = p.lx.tok_line
    p.col = p.lx.tok_col
    return p
}

fn merged_ll_path(out_dir string) string {
    suffix := "/merged.ll"
    left := str.len(out_dir)
    right := str.len(suffix)
    out: string := mem.calloc(left + right + 1, 1)
    mem.copy(out, out_dir, left)
    mem.copy(out + left, suffix, right)
    return out
}

fn advance_sig(p TinyIrParser) TinyIrParser {
    p.lx = lexer.next(p.lx)
    if !p.lx.ok {
        p.ok = false
        p.supported = true
        p.message = p.lx.message
        p.line = p.lx.tok_line
        p.col = p.lx.tok_col
        return p
    }
    for (; p.lx.kind == tok.newline(); ) {
        p.lx = lexer.next(p.lx)
        if !p.lx.ok {
            p.ok = false
            p.supported = true
            p.message = p.lx.message
            p.line = p.lx.tok_line
            p.col = p.lx.tok_col
            return p
        }
    }
    return p
}

fn parse_i32(text string) i32 {
    value := 0
    i: i32 := 0
    n := str.len(text)
    for (; i < n; i++) {
        ch := text[i]
        if ch >= '0' && ch <= '9' {
            value = value * 10 + (ch - '0')
        }
    }
    return value
}

fn tiny_i32_type_kind() i32 {
    return 1
}

fn tiny_bool_type_kind() i32 {
    return 2
}

fn tiny_string_type_kind() i32 {
    return 3
}

fn tiny_i64_type_kind() i32 {
    return 4
}

fn tiny_ptr_type_kind() i32 {
    return 5
}

fn tiny_void_type_kind() i32 {
    return 6
}

fn tiny_i32_array3_type_kind() i32 {
    return 7
}

fn tiny_i32_struct2_type_kind() i32 {
    return 8
}

fn tiny_i32_struct3_type_kind() i32 {
    return 9
}

fn tiny_type_from_name(name string) i32 {
    if str.eq(name, "void") {
        return tiny_void_type_kind()
    }
    if str.eq(name, "i32") {
        return tiny_i32_type_kind()
    }
    if str.eq(name, "bool") {
        return tiny_bool_type_kind()
    }
    if str.eq(name, "string") {
        return tiny_string_type_kind()
    }
    if str.eq(name, "i64") {
        return tiny_i64_type_kind()
    }
    return 0
}

fn llvm_type_for_value(p TinyIrParser, type_kind i32) *byte {
    if type_kind == tiny_void_type_kind() {
        return p.void_type
    }
    if type_kind == tiny_bool_type_kind() {
        return p.bool_type
    }
    if type_kind == tiny_string_type_kind() {
        return p.string_type
    }
    if type_kind == tiny_i64_type_kind() {
        return p.i64_type
    }
    if type_kind == tiny_ptr_type_kind() {
        return p.ptr_type
    }
    if type_kind == tiny_i32_array3_type_kind() {
        return llvm.array_type(p.i32_type, 3)
    }
    if type_kind == tiny_i32_struct2_type_kind() {
        return p.struct2_type
    }
    if type_kind == tiny_i32_struct3_type_kind() {
        return p.struct3_type
    }
    return p.i32_type
}

fn bool_const(p TinyIrParser, value bool) *byte {
    if value {
        return llvm.const_int(p.bool_type, 1, 0)
    }
    return llvm.const_int(p.bool_type, 0, 0)
}

fn ensure_i32_value(p TinyIrParser, message string) TinyIrParser {
    if p.value_type == tiny_i32_type_kind() {
        return p
    }
    return unsupported_parser(p, message)
}

fn ensure_bool_value(p TinyIrParser) TinyIrParser {
    if p.value_type == tiny_bool_type_kind() {
        return p
    }
    zero := llvm.const_int(p.i32_type, 0, 1)
    p.value = llvm.build_icmp(p.builder, llvm.int_ne(), p.value, zero, "i32_to_bool")
    p.value_type = tiny_bool_type_kind()
    return p
}

fn ensure_string_value(p TinyIrParser, message string) TinyIrParser {
    if p.value_type == tiny_string_type_kind() {
        return p
    }
    return unsupported_parser(p, message)
}

fn ensure_i64_value(p TinyIrParser, message string) TinyIrParser {
    if p.value_type == tiny_i64_type_kind() {
        return p
    }
    if p.value_type == tiny_i32_type_kind() {
        p.value = llvm.build_sext(p.builder, p.value, p.i64_type, "i32_to_i64")
        p.value_type = tiny_i64_type_kind()
        return p
    }
    return unsupported_parser(p, message)
}

fn ensure_ptr_value(p TinyIrParser, message string) TinyIrParser {
    if p.value_type == tiny_ptr_type_kind() {
        return p
    }
    return unsupported_parser(p, message)
}

fn ensure_value_type(p TinyIrParser, expected_type i32, message string) TinyIrParser {
    if expected_type == tiny_void_type_kind() {
        if p.value_type == tiny_void_type_kind() {
            return p
        }
        return unsupported_parser(p, message)
    }
    if expected_type == tiny_bool_type_kind() {
        return ensure_bool_value(p)
    }
    if expected_type == tiny_string_type_kind() {
        return ensure_string_value(p, message)
    }
    if expected_type == tiny_i64_type_kind() {
        return ensure_i64_value(p, message)
    }
    if expected_type == tiny_ptr_type_kind() {
        return ensure_ptr_value(p, message)
    }
    if expected_type == tiny_i32_array3_type_kind() {
        if p.value_type == tiny_i32_array3_type_kind() {
            return p
        }
        return unsupported_parser(p, message)
    }
    if expected_type == tiny_i32_struct2_type_kind() {
        if p.value_type == tiny_i32_struct2_type_kind() {
            return p
        }
        return unsupported_parser(p, message)
    }
    if expected_type == tiny_i32_struct3_type_kind() {
        if p.value_type == tiny_i32_struct3_type_kind() {
            return p
        }
        return unsupported_parser(p, message)
    }
    return ensure_i32_value(p, message)
}

fn struct_field_index(p TinyIrParser, field string) i32 {
    if str.eq(field, p.struct_field0) {
        return 0
    }
    if str.eq(field, p.struct_field1) {
        return 1
    }
    if p.struct_fields == 3 && str.eq(field, p.struct_field2) {
        return 2
    }
    return -1
}

fn build_i32_struct_field_ptr(p TinyIrParser, slot *byte, type_kind i32, field string, name string) *byte {
    index := struct_field_index(p, field)
    if index < 0 {
        return none
    }
    if type_kind == tiny_i32_struct3_type_kind() {
        return llvm.build_struct_gep2(p.builder, p.struct3_type, slot, index, name)
    }
    return llvm.build_struct_gep2(p.builder, p.struct2_type, slot, index, name)
}

fn build_i32_array3_element_ptr(p TinyIrParser, slot *byte, index_value *byte, name string) *byte {
    array_type := llvm.array_type(p.i32_type, 3)
    zero := llvm.const_int(p.i32_type, 0, 1)
    indices := TinyGepIndices2{arg0: zero, arg1: index_value}
    return llvm.build_gep2(p.builder, array_type, slot, &indices, 2, name)
}

fn build_checked_i32_array3_element_ptr(p TinyIrParser, slot *byte, index_value *byte, name string) *byte {
    zero := llvm.const_int(p.i32_type, 0, 1)
    three := llvm.const_int(p.i32_type, 3, 1)
    lower_ok_cond := llvm.build_icmp(p.builder, llvm.int_sge(), index_value, zero, "arrayidx_lower_ok")
    lower_ok_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "arrayidx_lower_ok")
    upper_check_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "arrayidx_upper_check")
    oob_block := llvm.append_basic_block_in_context(p.ctx, p.current_fn, "arrayidx_oob")
    llvm.build_cond_br(p.builder, lower_ok_cond, lower_ok_block, oob_block)

    llvm.position_builder_at_end(p.builder, lower_ok_block)
    upper_ok_cond := llvm.build_icmp(p.builder, llvm.int_slt(), index_value, three, "arrayidx_in_bounds")
    llvm.build_cond_br(p.builder, upper_ok_cond, upper_check_block, oob_block)

    llvm.position_builder_at_end(p.builder, oob_block)
    llvm.build_call2(p.builder, p.abort_fn_type, p.abort_fn, none, 0, "")
    llvm.build_unreachable(p.builder)

    llvm.position_builder_at_end(p.builder, upper_check_block)
    return build_i32_array3_element_ptr(p, slot, index_value, name)
}

fn store_i32_array3_element(p TinyIrParser, slot *byte, index i32, value *byte) TinyIrParser {
    index_value := llvm.const_int(p.i32_type, index, 1)
    element_ptr := build_checked_i32_array3_element_ptr(p, slot, index_value, "arrayidx")
    llvm.build_store(p.builder, value, element_ptr)
    return p
}

fn tiny_signature(param_count i32, param0_type i32, param1_type i32) i32 {
    return tiny_signature8(param_count, param0_type, param1_type, 0, 0, 0, 0, 0, 0)
}

fn tiny_signature4(param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32) i32 {
    return tiny_signature8(param_count, param0_type, param1_type, param2_type, param3_type, 0, 0, 0, 0)
}

fn tiny_signature6(param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32, param4_type i32, param5_type i32) i32 {
    return tiny_signature8(param_count, param0_type, param1_type, param2_type, param3_type, param4_type, param5_type, 0, 0)
}

fn tiny_signature8(param_count i32, param0_type i32, param1_type i32, param2_type i32, param3_type i32, param4_type i32, param5_type i32, param6_type i32, param7_type i32) i32 {
    if param_count == 0 {
        return 0
    }
    if param_count == 1 {
        return param0_type
    }
    if param_count == 2 {
        return param0_type + param1_type * 10
    }
    if param_count == 3 {
        return param0_type + param1_type * 10 + param2_type * 100
    }
    if param_count == 4 {
        return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000
    }
    if param_count == 5 {
        return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000 + param4_type * 10000
    }
    if param_count == 6 {
        return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000 + param4_type * 10000 + param5_type * 100000
    }
    if param_count == 7 {
        return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000 + param4_type * 10000 + param5_type * 100000 + param6_type * 1000000
    }
    return param0_type + param1_type * 10 + param2_type * 100 + param3_type * 1000 + param4_type * 10000 + param5_type * 100000 + param6_type * 1000000 + param7_type * 10000000
}

fn tiny_signature_param(signature i32, index i32) i32 {
    if index == 0 {
        return signature % 10
    }
    if index == 1 {
        return (signature / 10) % 10
    }
    if index == 2 {
        return (signature / 100) % 10
    }
    if index == 3 {
        return (signature / 1000) % 10
    }
    if index == 4 {
        return (signature / 10000) % 10
    }
    if index == 5 {
        return (signature / 100000) % 10
    }
    if index == 6 {
        return (signature / 1000000) % 10
    }
    return (signature / 10000000) % 10
}

fn string_literal_body(source string) string {
    n := text.len(source)
    if n < 2 {
        return ""
    }
    return text.slice(source, 1, n - 2)
}

fn reset_locals(p TinyIrParser) TinyIrParser {
    p.vars = 0
    p.name0 = ""
    p.name1 = ""
    p.name2 = ""
    p.name3 = ""
    p.name4 = ""
    p.name5 = ""
    p.name6 = ""
    p.name7 = ""
    p.name8 = ""
    p.name9 = ""
    p.name10 = ""
    p.name11 = ""
    p.name12 = ""
    p.name13 = ""
    p.name14 = ""
    p.name15 = ""
    p.type0 = 0
    p.type1 = 0
    p.type2 = 0
    p.type3 = 0
    p.type4 = 0
    p.type5 = 0
    p.type6 = 0
    p.type7 = 0
    p.type8 = 0
    p.type9 = 0
    p.type10 = 0
    p.type11 = 0
    p.type12 = 0
    p.type13 = 0
    p.type14 = 0
    p.type15 = 0
    p.value_type = 0
    p.returned = false
    p.current_break_block = none
    p.current_continue_block = none
    p.loop_break = false
    p.loop_continue = false
    return p
}

fn lookup_slot(p TinyIrParser, name string) TinyIrParser {
    if p.vars > 0 && str.eq(p.name0, name) {
        p.value = p.slot0
        p.value_type = p.type0
        return p
    }
    if p.vars > 1 && str.eq(p.name1, name) {
        p.value = p.slot1
        p.value_type = p.type1
        return p
    }
    if p.vars > 2 && str.eq(p.name2, name) {
        p.value = p.slot2
        p.value_type = p.type2
        return p
    }
    if p.vars > 3 && str.eq(p.name3, name) {
        p.value = p.slot3
        p.value_type = p.type3
        return p
    }
    if p.vars > 4 && str.eq(p.name4, name) {
        p.value = p.slot4
        p.value_type = p.type4
        return p
    }
    if p.vars > 5 && str.eq(p.name5, name) {
        p.value = p.slot5
        p.value_type = p.type5
        return p
    }
    if p.vars > 6 && str.eq(p.name6, name) {
        p.value = p.slot6
        p.value_type = p.type6
        return p
    }
    if p.vars > 7 && str.eq(p.name7, name) {
        p.value = p.slot7
        p.value_type = p.type7
        return p
    }
    if p.vars > 8 && str.eq(p.name8, name) {
        p.value = p.slot8
        p.value_type = p.type8
        return p
    }
    if p.vars > 9 && str.eq(p.name9, name) {
        p.value = p.slot9
        p.value_type = p.type9
        return p
    }
    if p.vars > 10 && str.eq(p.name10, name) {
        p.value = p.slot10
        p.value_type = p.type10
        return p
    }
    if p.vars > 11 && str.eq(p.name11, name) {
        p.value = p.slot11
        p.value_type = p.type11
        return p
    }
    if p.vars > 12 && str.eq(p.name12, name) {
        p.value = p.slot12
        p.value_type = p.type12
        return p
    }
    if p.vars > 13 && str.eq(p.name13, name) {
        p.value = p.slot13
        p.value_type = p.type13
        return p
    }
    if p.vars > 14 && str.eq(p.name14, name) {
        p.value = p.slot14
        p.value_type = p.type14
        return p
    }
    if p.vars > 15 && str.eq(p.name15, name) {
        p.value = p.slot15
        p.value_type = p.type15
        return p
    }
    return fail_parser(p, "unknown local symbol")
}

fn set_slot(p TinyIrParser, name string, slot *byte, type_kind i32) TinyIrParser {
    if p.vars > 0 && str.eq(p.name0, name) {
        p.slot0 = slot
        p.type0 = type_kind
        return p
    }
    if p.vars > 1 && str.eq(p.name1, name) {
        p.slot1 = slot
        p.type1 = type_kind
        return p
    }
    if p.vars > 2 && str.eq(p.name2, name) {
        p.slot2 = slot
        p.type2 = type_kind
        return p
    }
    if p.vars > 3 && str.eq(p.name3, name) {
        p.slot3 = slot
        p.type3 = type_kind
        return p
    }
    if p.vars > 4 && str.eq(p.name4, name) {
        p.slot4 = slot
        p.type4 = type_kind
        return p
    }
    if p.vars > 5 && str.eq(p.name5, name) {
        p.slot5 = slot
        p.type5 = type_kind
        return p
    }
    if p.vars > 6 && str.eq(p.name6, name) {
        p.slot6 = slot
        p.type6 = type_kind
        return p
    }
    if p.vars > 7 && str.eq(p.name7, name) {
        p.slot7 = slot
        p.type7 = type_kind
        return p
    }
    if p.vars > 8 && str.eq(p.name8, name) {
        p.slot8 = slot
        p.type8 = type_kind
        return p
    }
    if p.vars > 9 && str.eq(p.name9, name) {
        p.slot9 = slot
        p.type9 = type_kind
        return p
    }
    if p.vars > 10 && str.eq(p.name10, name) {
        p.slot10 = slot
        p.type10 = type_kind
        return p
    }
    if p.vars > 11 && str.eq(p.name11, name) {
        p.slot11 = slot
        p.type11 = type_kind
        return p
    }
    if p.vars > 12 && str.eq(p.name12, name) {
