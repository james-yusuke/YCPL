    b = builder_text(b, "  %callaritydigest = load i32, ptr @ycpl_ast_symbol_call_arity_digest, align 4\n")
    b = builder_text(b, "  %callaritydigestok = icmp ne i32 %callaritydigest, 17\n")
    b = builder_text(b, "  %signaturenodes = load i32, ptr @ycpl_ast_signature_nodes, align 4\n")
    b = builder_text(b, "  %signaturenodesok = icmp sgt i32 %signaturenodes, 0\n")
    b = builder_text(b, "  %signaturefns = load i32, ptr @ycpl_ast_signature_function_nodes, align 4\n")
    b = builder_text(b, "  %signaturefnsok = icmp sgt i32 %signaturefns, 0\n")
    b = builder_text(b, "  %signaturecalls = load i32, ptr @ycpl_ast_signature_call_nodes, align 4\n")
    b = builder_text(b, "  %signaturecallsok = icmp sgt i32 %signaturecalls, 0\n")
    b = builder_text(b, "  %signaturearityslots = load i32, ptr @ycpl_ast_signature_arity_slots, align 4\n")
    b = builder_text(b, "  %signaturearityslotsok = icmp sgt i32 %signaturearityslots, 0\n")
    b = builder_text(b, "  %signaturemaxarity = load i32, ptr @ycpl_ast_signature_max_arity, align 4\n")
    b = builder_text(b, "  %signaturemaxarityok = icmp sgt i32 %signaturemaxarity, 0\n")
    b = builder_text(b, "  %signaturereturns = load i32, ptr @ycpl_ast_signature_return_functions, align 4\n")
    b = builder_text(b, "  %signaturereturnsok = icmp sgt i32 %signaturereturns, 0\n")
    b = builder_text(b, "  %signaturetypedreturns = load i32, ptr @ycpl_ast_signature_typed_return_functions, align 4\n")
    b = builder_text(b, "  %signaturetypedreturnsok = icmp sgt i32 %signaturetypedreturns, 0\n")
    b = builder_text(b, "  %signaturedigest = load i32, ptr @ycpl_ast_signature_digest, align 4\n")
    b = builder_text(b, "  %signaturedigestok = icmp ne i32 %signaturedigest, 17\n")
    b = builder_text(b, "  %exprnodes = load i32, ptr @ycpl_ast_expr_table_nodes, align 4\n")
    b = builder_text(b, "  %exprnodesok = icmp sgt i32 %exprnodes, 0\n")
    b = builder_text(b, "  %exprfloor = load i32, ptr @ycpl_stage_expr_lowered_floor, align 4\n")
    b = builder_text(b, "  %exprfloorok = icmp sge i32 %exprnodes, %exprfloor\n")
    b = builder_text(b, "  %exprprimary = load i32, ptr @ycpl_ast_expr_primary_nodes, align 4\n")
    b = builder_text(b, "  %exprprimaryok = icmp sgt i32 %exprprimary, 0\n")
    b = builder_text(b, "  %exprids = load i32, ptr @ycpl_ast_expr_identifier_nodes, align 4\n")
    b = builder_text(b, "  %expridsok = icmp sgt i32 %exprids, 0\n")
    b = builder_text(b, "  %exprliterals = load i32, ptr @ycpl_ast_expr_literal_nodes, align 4\n")
    b = builder_text(b, "  %exprliteralsok = icmp sgt i32 %exprliterals, 0\n")
    b = builder_text(b, "  %exprstrings = load i32, ptr @ycpl_ast_expr_string_nodes, align 4\n")
    b = builder_text(b, "  %exprstringsok = icmp sgt i32 %exprstrings, 0\n")
    b = builder_text(b, "  %exprcalls = load i32, ptr @ycpl_ast_expr_call_nodes, align 4\n")
    b = builder_text(b, "  %exprcallsok = icmp sgt i32 %exprcalls, 0\n")
    b = builder_text(b, "  %exprmembers = load i32, ptr @ycpl_ast_expr_member_nodes, align 4\n")
    b = builder_text(b, "  %exprmembersok = icmp sgt i32 %exprmembers, 0\n")
    b = builder_text(b, "  %exprindexes = load i32, ptr @ycpl_ast_expr_index_nodes, align 4\n")
    b = builder_text(b, "  %exprindexesok = icmp sgt i32 %exprindexes, 0\n")
    b = builder_text(b, "  %exprbinary = load i32, ptr @ycpl_ast_expr_binary_nodes, align 4\n")
    b = builder_text(b, "  %exprbinaryok = icmp sgt i32 %exprbinary, 0\n")
    b = builder_text(b, "  %exprunary = load i32, ptr @ycpl_ast_expr_unary_nodes, align 4\n")
    b = builder_text(b, "  %exprunaryok = icmp sgt i32 %exprunary, 0\n")
    b = builder_text(b, "  %exprdigest = load i32, ptr @ycpl_ast_expr_table_digest, align 4\n")
    b = builder_text(b, "  %exprdigestok = icmp ne i32 %exprdigest, 17\n")
    b = builder_text(b, "  %exprslots = load i32, ptr @ycpl_ast_expr_slot_count, align 4\n")
    b = builder_text(b, "  %exprslotsok = icmp sgt i32 %exprslots, 0\n")
    b = builder_text(b, "  %exprnonempty = load i32, ptr @ycpl_ast_expr_nonempty_slots, align 4\n")
    b = builder_text(b, "  %exprnonemptyok = icmp sgt i32 %exprnonempty, 0\n")
    b = builder_text(b, "  %exprmaxslot = load i32, ptr @ycpl_ast_expr_max_nodes_per_slot, align 4\n")
    b = builder_text(b, "  %exprmaxslotok = icmp sgt i32 %exprmaxslot, 0\n")
    b = builder_text(b, "  %exprslotdigest = load i32, ptr @ycpl_ast_expr_slot_digest, align 4\n")
    b = builder_text(b, "  %exprslotdigestok = icmp ne i32 %exprslotdigest, 17\n")
    b = builder_text(b, "  %stmtexprlinks = load i32, ptr @ycpl_ast_stmt_expr_links, align 4\n")
    b = builder_text(b, "  %stmtexprlinksok = icmp sgt i32 %stmtexprlinks, 0\n")
    b = builder_text(b, "  %stmtexprtail = load i32, ptr @ycpl_ast_stmt_expr_tail_nodes, align 4\n")
    b = builder_text(b, "  %stmtexprtailok = icmp sge i32 %stmtexprtail, 0\n")
    b = builder_text(b, "  %stmtexprdigest = load i32, ptr @ycpl_ast_stmt_expr_digest, align 4\n")
    b = builder_text(b, "  %stmtexprdigestok = icmp ne i32 %stmtexprdigest, 17\n")
    b = builder_text(b, "  %symboldigest = load i32, ptr @ycpl_ast_symbol_digest, align 4\n")
    b = builder_text(b, "  %symboldigestok = icmp ne i32 %symboldigest, 17\n")
    b = builder_text(b, "  %symbolimportdigest = load i32, ptr @ycpl_ast_symbol_import_digest, align 4\n")
    b = builder_text(b, "  %symbolimportdigestok = icmp ne i32 %symbolimportdigest, 17\n")
    b = builder_text(b, "  %symbolmoduledigest = load i32, ptr @ycpl_ast_symbol_module_digest, align 4\n")
    b = builder_text(b, "  %symbolmoduledigestok = icmp ne i32 %symbolmoduledigest, 17\n")
    b = builder_text(b, "  %declsymbolshape0ok = and i1 %declsymbolsok, %declstructsok\n")
    b = builder_text(b, "  %declsymbolshape1ok = and i1 %declsymbolshape0ok, %declimportsok\n")
    b = builder_text(b, "  %declsymbolshape2ok = and i1 %declsymbolshape1ok, %stdimportsok\n")
    b = builder_text(b, "  %declsymbolshape3ok = and i1 %declsymbolshape2ok, %importaliasesok\n")
    b = builder_text(b, "  %declsymbolvis0ok = and i1 %publicsymbolsok, %localsymboldeclsok\n")
    b = builder_text(b, "  %fnsigshape0ok = and i1 %zeroparamfnsok, %nonzeroparamfnsok\n")
    b = builder_text(b, "  %fnsigshape1ok = and i1 %fnsigshape0ok, %fnparamsok\n")
    b = builder_text(b, "  %fnsigshape2ok = and i1 %fnsigshape1ok, %maxfnparamsok\n")
    b = builder_text(b, "  %fnsigshape3ok = and i1 %fnsigshape2ok, %fnreturnsok\n")
    b = builder_text(b, "  %fnsigok = and i1 %fnsigshape3ok, %fnsigdigestok\n")
    b = builder_text(b, "  %callarityshape0ok = and i1 %callsitesok, %zeroargcallsok\n")
    b = builder_text(b, "  %callarityshape1ok = and i1 %callarityshape0ok, %nonzeroargcallsok\n")
    b = builder_text(b, "  %callarityshape2ok = and i1 %callarityshape1ok, %callargsok\n")
    b = builder_text(b, "  %callarityshape3ok = and i1 %callarityshape2ok, %maxcallargsok\n")
    b = builder_text(b, "  %callarityok = and i1 %callarityshape3ok, %callaritydigestok\n")
    b = builder_text(b, "  %signaturetable0ok = and i1 %signaturenodesok, %signaturefnsok\n")
    b = builder_text(b, "  %signaturetable1ok = and i1 %signaturetable0ok, %signaturecallsok\n")
    b = builder_text(b, "  %signaturetable2ok = and i1 %signaturetable1ok, %signaturearityslotsok\n")
    b = builder_text(b, "  %signaturetable3ok = and i1 %signaturetable2ok, %signaturemaxarityok\n")
    b = builder_text(b, "  %signaturetable4ok = and i1 %signaturetable3ok, %signaturereturnsok\n")
    b = builder_text(b, "  %signaturetable5ok = and i1 %signaturetable4ok, %signaturetypedreturnsok\n")
    b = builder_text(b, "  %signaturetableok = and i1 %signaturetable5ok, %signaturedigestok\n")
    b = builder_text(b, "  %exprfloorchainok = and i1 %exprnodesok, %exprfloorok\n")
    b = builder_text(b, "  %exprtable0ok = and i1 %exprfloorchainok, %exprprimaryok\n")
    b = builder_text(b, "  %exprtable1ok = and i1 %exprtable0ok, %expridsok\n")
    b = builder_text(b, "  %exprtable2ok = and i1 %exprtable1ok, %exprliteralsok\n")
    b = builder_text(b, "  %exprtable3ok = and i1 %exprtable2ok, %exprstringsok\n")
    b = builder_text(b, "  %exprtable4ok = and i1 %exprtable3ok, %exprcallsok\n")
    b = builder_text(b, "  %exprtable5ok = and i1 %exprtable4ok, %exprmembersok\n")
    b = builder_text(b, "  %exprtable6ok = and i1 %exprtable5ok, %exprindexesok\n")
    b = builder_text(b, "  %exprtable7ok = and i1 %exprtable6ok, %exprbinaryok\n")
    b = builder_text(b, "  %exprtable8ok = and i1 %exprtable7ok, %exprunaryok\n")
    b = builder_text(b, "  %exprtable9ok = and i1 %exprtable8ok, %exprdigestok\n")
    b = builder_text(b, "  %exprslot0ok = and i1 %exprslotsok, %exprnonemptyok\n")
    b = builder_text(b, "  %exprslot1ok = and i1 %exprslot0ok, %exprmaxslotok\n")
    b = builder_text(b, "  %exprslotok = and i1 %exprslot1ok, %exprslotdigestok\n")
    b = builder_text(b, "  %stmtexpr0ok = and i1 %stmtexprlinksok, %stmtexprtailok\n")
    b = builder_text(b, "  %stmtexprok = and i1 %stmtexpr0ok, %stmtexprdigestok\n")
    b = builder_text(b, "  %exprslotandstmtok = and i1 %exprslotok, %stmtexprok\n")
    b = builder_text(b, "  %exprtableok = and i1 %exprtable9ok, %exprslotandstmtok\n")
    b = builder_text(b, "  %symbolarity0ok = and i1 %fnsigok, %callarityok\n")
    b = builder_text(b, "  %symbolarityok = and i1 %symbolarity0ok, %signaturetableok\n")
    b = builder_text(b, "  %declsymboldigests0ok = and i1 %symboldigestok, %symbolimportdigestok\n")
    b = builder_text(b, "  %declsymboldigestsok = and i1 %declsymboldigests0ok, %symbolmoduledigestok\n")
    b = builder_text(b, "  %declsymbolmeta0ok = and i1 %declsymbolshape3ok, %declsymbolvis0ok\n")
    b = builder_text(b, "  %declsymbolmeta1ok = and i1 %declsymbolmeta0ok, %symbolarityok\n")
    b = builder_text(b, "  %declsymboltableok = and i1 %declsymbolmeta1ok, %declsymboldigestsok\n")
    b = builder_text(b, "  %symbolok = and i1 %hasmainok, %digestok\n")
    b = builder_text(b, "  %bodycountok = and i1 %bodiesok, %bodytokensok\n")
    b = builder_text(b, "  %bodyshape0ok = and i1 %bodynodesok, %nodedigestok\n")
    b = builder_text(b, "  %bodyshape1ok = and i1 %bodyshape0ok, %transitiondigestok\n")
    b = builder_text(b, "  %bodyslotshape0ok = and i1 %bodyslotsok, %bodynonemptyok\n")
    b = builder_text(b, "  %bodyslotshape1ok = and i1 %bodyslotshape0ok, %bodymaxnodesok\n")
    b = builder_text(b, "  %bodyslotok = and i1 %bodyslotshape1ok, %bodyslotdigestok\n")
    b = builder_text(b, "  %bodyshape2ok = and i1 %bodyshape1ok, %payloadok\n")
    b = builder_text(b, "  %bodyshape3ok = and i1 %bodyshape2ok, %semanticok\n")
    b = builder_text(b, "  %bodyshape4ok = and i1 %bodyshape3ok, %bodyslotok\n")
    b = builder_text(b, "  %bodyshapeok = and i1 %bodyshape4ok, %controlnodesok\n")
    b = builder_text(b, "  %bodydigestallok = and i1 %bodydigestok, %bodyshapeok\n")
    b = builder_text(b, "  %bodyok = and i1 %bodycountok, %bodydigestallok\n")
    b = builder_text(b, "  %returnok = and i1 %returnexprsok, %retdigestok\n")
    b = builder_text(b, "  %symbolmetaok = and i1 %symbolok, %declsymboltableok\n")
    b = builder_text(b, "  %symbolbodyok = and i1 %symbolmetaok, %bodyok\n")
    b = builder_text(b, "  %astexprok = and i1 %symbolbodyok, %exprtableok\n")
    b = builder_text(b, "  %astok = and i1 %astexprok, %returnok\n")
    b = builder_text(b, "  %asttypedok = and i1 %astok, %typedok\n")
    b = builder_text(b, "  %astprojectok = and i1 %asttypedok, %projectbodyok\n")
    b = builder_text(b, "  %ok = and i1 %sumok, %astprojectok\n")
    b = builder_text(b, "  br i1 %ok, label %done, label %bad\n")
    b = builder_text(b, "bad:\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "done:\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "}\n")

    return b
}

pub fn emit_project(root string, out_dir string) IrResult {
    checked := resolver.check_project(root)
    if !checked.ok {
        return fail_supported(checked.line, checked.col, checked.message)
    }

    b := emit_project_ir_text(checked)
    if !b.ok {
        return fail_supported(1, 1, "project LLVM IR builder overflow")
    }

    fs.mkdir(out_dir)
    local_return := nodeir.write_local_return_probe(checked, out_dir)
    if !local_return.ok {
        return fail_supported(1, 1, local_return.message)
    }

    project_body := projectir.write_statement_expr_lowering(checked, root, out_dir)
    if !project_body.ok {
        return fail_supported(1, 1, project_body.message)
    }

    merge_cap := b.len + str.len(project_body.merge_text) + str.len(local_return.merge_text) + 4096
    merged := builder_new(merge_cap)
    merged = builder_text(merged, b.data)
    merged = builder_text(merged, "\n; project statement/expression lowering generated through std/llvm wrappers\n")
    merged = builder_text(merged, project_body.merge_text)
    merged = builder_text(merged, "\n; node sequence probe generated through std/llvm wrappers\n")
    merged = builder_text(merged, local_return.merge_text)
    b = merged
    if !b.ok {
        return fail_supported(1, 1, "project LLVM IR builder overflow")
    }

    out_file := merged_ll_path(out_dir)
    wrote := fs.write_file(out_file, b.data)
    if !wrote {
        return fail_supported(1, 1, "failed to write project LLVM IR")
    }

    return ok(out_file)
}

pub fn emit_file(path string, out_dir string) IrResult {
    src := source.load(path)
    if !src.ok {
        return fail_supported(1, 1, "could not read file")
    }

    tiny := tinyir.emit_file(path, src.text, out_dir)
    if !tiny.ok {
        if !tiny.supported {
            return fail_unsupported(tiny.line, tiny.col, tiny.message)
        }
        return fail_supported(tiny.line, tiny.col, tiny.message)
    }

    return ok(tiny.out_file)
}
