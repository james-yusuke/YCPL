    b = builder_text(b, "  %dynamicvalue = phi i32 [ %dynamicv0, %dynamic_return_emit0 ], [ %dynamicv1, %dynamic_return_emit1 ], [ %dynamicv2, %dynamic_return_emit2 ]\n")
