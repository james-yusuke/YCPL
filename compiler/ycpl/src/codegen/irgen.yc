    b = builder_text(b, "dynamic_if_pattern_probe:\n")
    b = emit_string_ptr(b, "dynamicifpattern", if_pattern_name, "if probe == 0")
    b = builder_text(b, "  %dynamicifmarker = call ptr @strstr(ptr %bufptr, ptr %dynamicifpattern)\n")
    b = builder_text(b, "  %hasdynamicif = icmp ne ptr %dynamicifmarker, null\n")
    b = builder_text(b, "  br i1 %hasdynamicif, label %dynamic_if_first_return_probe, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_if_first_return_probe:\n")
    b = emit_string_ptr(b, "dynamicifreturnpattern", return_pattern_name, "return ")
    b = builder_text(b, "  %dynamicifthenreturnmarker = call ptr @strstr(ptr %dynamicifmarker, ptr %dynamicifreturnpattern)\n")
    b = builder_text(b, "  %hasdynamicifthenreturn = icmp ne ptr %dynamicifthenreturnmarker, null\n")
    b = builder_text(b, "  br i1 %hasdynamicifthenreturn, label %dynamic_if_second_return_probe, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_if_second_return_probe:\n")
    b = builder_text(b, "  %dynamicifthenreturndigits = getelementptr inbounds i8, ptr %dynamicifthenreturnmarker, i64 7\n")
    b = builder_text(b, "  %dynamicifafterthen = getelementptr inbounds i8, ptr %dynamicifthenreturndigits, i64 1\n")
    b = builder_text(b, "  %dynamicifelsereturnmarker = call ptr @strstr(ptr %dynamicifafterthen, ptr %dynamicifreturnpattern)\n")
    b = builder_text(b, "  %hasdynamicifelsereturn = icmp ne ptr %dynamicifelsereturnmarker, null\n")
    b = builder_text(b, "  br i1 %hasdynamicifelsereturn, label %dynamic_if_probe_parse, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_if_probe_parse:\n")
    b = emit_dynamic_i32_parser(b, "dynamicifprobe", "dynamicifdeclmarker", 9, fallback_label, "dynamic_if_then_parse", "dynamicifprobevalue")
    b = builder_text(b, "  br label %dynamic_if_then_parse_start\n")
    b = builder_text(b, "dynamic_if_then_parse_start:\n")
    b = emit_dynamic_i32_parser(b, "dynamicifthen", "dynamicifthenreturnmarker", 7, fallback_label, "dynamic_if_else_parse", "dynamicifthenvalue")
    b = builder_text(b, "  br label %dynamic_if_else_parse_start\n")
    b = builder_text(b, "dynamic_if_else_parse_start:\n")
    b = emit_dynamic_i32_parser(b, "dynamicifelse", "dynamicifelsereturnmarker", 7, fallback_label, "dynamic_if_emit", "dynamicifelsevalue")
    b = builder_text(b, "  %dynamicifout = call ptr @malloc(i64 1024)\n")
    b = emit_string_ptr(b, "dynamicifformat", format_name, "; YCPL dynamic if-return IR\ndefine i32 @main() {\nentry:\n  %%probe = alloca i32, align 4\n  store i32 %d, ptr %%probe, align 4\n  %%loadprobe = load i32, ptr %%probe, align 4\n  %%iftmp = icmp eq i32 %%loadprobe, 0\n  br i1 %%iftmp, label %%then, label %%cont\nthen:\n  ret i32 %d\ncont:\n  ret i32 %d\n}\n")
    b = builder_text(b, "  %dynamicifn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %dynamicifout, i64 1024, ptr %dynamicifformat, i32 %dynamicifprobevalue, i32 %dynamicifthenvalue, i32 %dynamicifelsevalue)\n")
    b = builder_text(b, "  ret ptr %dynamicifout\n")
    return b
}

fn emit_dynamic_for_return_select_path(b TextBuilder, sum_pattern_name string, limit_pattern_name string, add_pattern_name string, return_pattern_name string, format_name string, fallback_label string) TextBuilder {
    b = emit_string_ptr(b, "dynamicforsumpattern", sum_pattern_name, "sum := ")
    b = builder_text(b, "  %dynamicforsummarker = call ptr @strstr(ptr %bufptr, ptr %dynamicforsumpattern)\n")
    b = builder_text(b, "  %hasdynamicforsum = icmp ne ptr %dynamicforsummarker, null\n")
    b = builder_text(b, "  br i1 %hasdynamicforsum, label %dynamic_for_limit_probe, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_for_limit_probe:\n")
    b = emit_string_ptr(b, "dynamicforlimitpattern", limit_pattern_name, "i < ")
    b = builder_text(b, "  %dynamicforlimitmarker = call ptr @strstr(ptr %bufptr, ptr %dynamicforlimitpattern)\n")
    b = builder_text(b, "  %hasdynamicforlimit = icmp ne ptr %dynamicforlimitmarker, null\n")
    b = builder_text(b, "  br i1 %hasdynamicforlimit, label %dynamic_for_add_probe, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_for_add_probe:\n")
    b = emit_string_ptr(b, "dynamicforaddpattern", add_pattern_name, "sum = sum + ")
    b = builder_text(b, "  %dynamicforaddmarker = call ptr @strstr(ptr %bufptr, ptr %dynamicforaddpattern)\n")
    b = builder_text(b, "  %hasdynamicforadd = icmp ne ptr %dynamicforaddmarker, null\n")
    b = builder_text(b, "  br i1 %hasdynamicforadd, label %dynamic_for_return_probe, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_for_return_probe:\n")
    b = emit_string_ptr(b, "dynamicforreturnpattern", return_pattern_name, "return sum")
    b = builder_text(b, "  %dynamicforreturnmarker = call ptr @strstr(ptr %bufptr, ptr %dynamicforreturnpattern)\n")
    b = builder_text(b, "  %hasdynamicforreturn = icmp ne ptr %dynamicforreturnmarker, null\n")
    b = builder_text(b, "  br i1 %hasdynamicforreturn, label %dynamic_for_sum_parse, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_for_sum_parse:\n")
    b = emit_dynamic_i32_parser(b, "dynamicforsum", "dynamicforsummarker", 7, fallback_label, "dynamic_for_limit_parse", "dynamicforsumvalue")
    b = builder_text(b, "  br label %dynamic_for_limit_parse_start\n")
    b = builder_text(b, "dynamic_for_limit_parse_start:\n")
    b = emit_dynamic_i32_parser(b, "dynamicforlimit", "dynamicforlimitmarker", 4, fallback_label, "dynamic_for_add_parse", "dynamicforlimitvalue")
    b = builder_text(b, "  br label %dynamic_for_add_parse_start\n")
    b = builder_text(b, "dynamic_for_add_parse_start:\n")
    b = emit_dynamic_i32_parser(b, "dynamicforadd", "dynamicforaddmarker", 12, fallback_label, "dynamic_for_emit", "dynamicforaddvalue")
    b = builder_text(b, "  %dynamicforout = call ptr @malloc(i64 1536)\n")
    b = emit_string_ptr(b, "dynamicforformat", format_name, "; YCPL dynamic for-return IR\ndefine i32 @main() {\nentry:\n  %%sum = alloca i32, align 4\n  %%i = alloca i32, align 4\n  store i32 %d, ptr %%sum, align 4\n  store i32 0, ptr %%i, align 4\n  br label %%loop_check\nloop_check:\n  %%iload = load i32, ptr %%i, align 4\n  %%cmptmp = icmp slt i32 %%iload, %d\n  br i1 %%cmptmp, label %%loop_body, label %%loop_done\nloop_body:\n  %%sumload = load i32, ptr %%sum, align 4\n  %%addtmp = add i32 %%sumload, %d\n  store i32 %%addtmp, ptr %%sum, align 4\n  br label %%loop_update\nloop_update:\n  %%iload2 = load i32, ptr %%i, align 4\n  %%nexti = add i32 %%iload2, 1\n  store i32 %%nexti, ptr %%i, align 4\n  br label %%loop_check\nloop_done:\n  %%result = load i32, ptr %%sum, align 4\n  ret i32 %%result\n}\n")
    b = builder_text(b, "  %dynamicforn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %dynamicforout, i64 1536, ptr %dynamicforformat, i32 %dynamicforsumvalue, i32 %dynamicforlimitvalue, i32 %dynamicforaddvalue)\n")
    b = builder_text(b, "  ret ptr %dynamicforout\n")
    return b
}

fn stage_expr_lowered_floor(project ProjectResult) i32 {
    if project.expr_table_nodes >= 600 {
        return 600
    }
    return project.expr_table_nodes
}

fn stage3_summary_line(project ProjectResult, mode string) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes

    line := builder_new(4096)
    line = builder_text(line, mode)
    line = builder_text(line, " ok: files=")
    line = builder_i32(line, project.files)
    line = builder_text(line, " funcs=")
    line = builder_i32(line, project.functions)
    line = builder_text(line, " structs=")
    line = builder_i32(line, project.structs)
    line = builder_text(line, " imports=")
    line = builder_i32(line, project.imports)
    line = builder_text(line, " typed_nodes=")
    line = builder_i32(line, typed_nodes)
    line = builder_text(line, " typed_digest=")
    line = builder_i32(line, project.typed_digest)
    line = builder_text(line, " symbols=")
    line = builder_i32(line, project.symbol_functions)
    line = builder_text(line, " body_nodes=")
    line = builder_i32(line, project.body_node_count)
    line = builder_text(line, " body_slots=")
    line = builder_i32(line, project.body_slot_count)
    line = builder_text(line, " expr_nodes=")
    line = builder_i32(line, project.expr_table_nodes)
    line = builder_text(line, " expr_slots=")
    line = builder_i32(line, project.expr_slot_count)
    line = builder_text(line, " stmt_expr_links=")
    line = builder_i32(line, project.stmt_expr_links)
    line = builder_text(line, " stmt_expr_tail=")
    line = builder_i32(line, project.stmt_expr_tail_nodes)
    line = builder_text(line, " stmt_expr_digest=")
    line = builder_i32(line, project.stmt_expr_digest)
    line = builder_text(line, " fn_digest=")
    line = builder_i32(line, project.function_name_digest)
    line = builder_text(line, " main=")
    line = builder_i32(line, main_value)
    return line.data
}

fn emit_stage_body_lowering_probe(b TextBuilder, name string, global_prefix string) TextBuilder {
    b = builder_text(b, "define i32 @")
    b = builder_text(b, name)
    b = builder_text(b, "() {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %function_body_statement_ast_value_slot = alloca i32, align 4\n")
    b = builder_text(b, "  %function_body_statement_resolved_type_slot = alloca i32, align 4\n")
    b = builder_text(b, "  %function_body_local_state = alloca i32, align 4\n")
    b = builder_text(b, "  %function_body_assignment_state = alloca i32, align 4\n")
    b = builder_text(b, "  %function_body_call_state = alloca i32, align 4\n")
    b = builder_text(b, "  %function_body_return_state = alloca i32, align 4\n")
    b = builder_text(b, "  store i32 0, ptr %function_body_statement_ast_value_slot, align 4\n")
    b = builder_text(b, "  store i32 0, ptr %function_body_statement_resolved_type_slot, align 4\n")
    b = builder_text(b, "  store i32 0, ptr %function_body_local_state, align 4\n")
    b = builder_text(b, "  store i32 0, ptr %function_body_assignment_state, align 4\n")
    b = builder_text(b, "  store i32 0, ptr %function_body_call_state, align 4\n")
    b = builder_text(b, "  store i32 0, ptr %function_body_return_state, align 4\n")
    b = builder_text(b, "  %stage_body_local_nodes = load i32, ptr @")
    b = builder_text(b, global_prefix)
    b = builder_text(b, "_body_local_nodes, align 4\n")
    b = builder_text(b, "  %stage_body_assignment_nodes = load i32, ptr @")
    b = builder_text(b, global_prefix)
    b = builder_text(b, "_body_assignment_nodes, align 4\n")
    b = builder_text(b, "  %stage_body_call_nodes = load i32, ptr @")
    b = builder_text(b, global_prefix)
    b = builder_text(b, "_body_call_nodes, align 4\n")
    b = builder_text(b, "  %stage_body_return_nodes = load i32, ptr @")
    b = builder_text(b, global_prefix)
    b = builder_text(b, "_body_return_nodes, align 4\n")
    b = builder_text(b, "  %stage_stmt_expr_links = load i32, ptr @")
    b = builder_text(b, global_prefix)
    b = builder_text(b, "_stmt_expr_links, align 4\n")
    b = builder_text(b, "  store i32 %stage_stmt_expr_links, ptr %function_body_statement_ast_value_slot, align 4\n")
    b = builder_text(b, "  store i32 %stage_body_call_nodes, ptr %function_body_statement_resolved_type_slot, align 4\n")
    b = builder_text(b, "  %function_body_resolved_statement_ast_value = load i32, ptr %function_body_statement_ast_value_slot, align 4\n")
    b = builder_text(b, "  %function_body_resolved_statement_type_value = load i32, ptr %function_body_statement_resolved_type_slot, align 4\n")
    b = builder_text(b, "  %function_body_resolved_statement_value = add i32 %function_body_resolved_statement_ast_value, %function_body_resolved_statement_type_value\n")
    b = builder_text(b, "  %function_body_resolved_local_value = add i32 %function_body_resolved_statement_value, %stage_body_local_nodes\n")
    b = builder_text(b, "  store i32 %function_body_resolved_local_value, ptr %function_body_local_state, align 4\n")
    b = builder_text(b, "  %function_body_resolved_local_loaded = load i32, ptr %function_body_local_state, align 4\n")
    b = builder_text(b, "  %function_body_resolved_assignment_value = add i32 %function_body_resolved_local_loaded, %stage_body_assignment_nodes\n")
    b = builder_text(b, "  store i32 %function_body_resolved_assignment_value, ptr %function_body_assignment_state, align 4\n")
    b = builder_text(b, "  %function_body_resolved_assignment_loaded = load i32, ptr %function_body_assignment_state, align 4\n")
    b = builder_text(b, "  %function_body_resolved_call_value = add i32 %function_body_resolved_assignment_loaded, %stage_body_call_nodes\n")
    b = builder_text(b, "  store i32 %function_body_resolved_call_value, ptr %function_body_call_state, align 4\n")
    b = builder_text(b, "  %function_body_resolved_call_loaded = load i32, ptr %function_body_call_state, align 4\n")
    b = builder_text(b, "  %function_body_resolved_return_value = add i32 %function_body_resolved_call_loaded, %stage_body_return_nodes\n")
    b = builder_text(b, "  store i32 %function_body_resolved_return_value, ptr %function_body_return_state, align 4\n")
    b = builder_text(b, "  %function_body_resolved_return_loaded = load i32, ptr %function_body_return_state, align 4\n")
    b = builder_text(b, "  %function_body_resolved_statement_lowered_state = add i32 %function_body_resolved_return_loaded, %function_body_resolved_statement_type_value\n")
    b = builder_text(b, "  ret i32 %function_body_resolved_statement_lowered_state\n")
    b = builder_text(b, "}\n")
    return b
}

fn stage5_ir_text(project ProjectResult) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes

    b := builder_new(32768)
    b = builder_text(b, "; YCPL stage5 AST IR\n")
    b = emit_string_global(b, ".stage5.msg", "YCPL stage5 AST IR")
    b = emit_global_i32(b, "ycpl_stage5_ast_has_main", main_value)
    b = emit_global_i32(b, "ycpl_stage5_ast_typed_nodes", typed_nodes)
    b = emit_global_i32(b, "ycpl_stage5_ast_function_bodies", project.function_bodies)
    b = emit_global_i32(b, "ycpl_stage5_ast_expr_nodes", project.expr_table_nodes)
    b = emit_global_i32(b, "ycpl_stage5_body_local_nodes", project.body_local_nodes)
    b = emit_global_i32(b, "ycpl_stage5_body_assignment_nodes", project.body_assignment_nodes)
    b = emit_global_i32(b, "ycpl_stage5_body_call_nodes", project.body_call_nodes)
    b = emit_global_i32(b, "ycpl_stage5_body_return_nodes", project.body_return_nodes)
    b = emit_global_i32(b, "ycpl_stage5_stmt_expr_links", project.stmt_expr_links)
    b = builder_text(b, "declare i32 @puts(ptr)\n")
    b = emit_stage_body_lowering_probe(b, "ycpl_stage5_project_body_lowering", "ycpl_stage5")
    b = builder_text(b, "define i32 @main() {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %msg = getelementptr inbounds [19 x i8], ptr @.stage5.msg, i32 0, i32 0\n")
    b = builder_text(b, "  %printed = call i32 @puts(ptr %msg)\n")
    b = builder_text(b, "  %hasmain = load i32, ptr @ycpl_stage5_ast_has_main, align 4\n")
    b = builder_text(b, "  %hasmainok = icmp eq i32 %hasmain, 1\n")
    b = builder_text(b, "  %typednodes = load i32, ptr @ycpl_stage5_ast_typed_nodes, align 4\n")
    b = builder_text(b, "  %typedok = icmp sgt i32 %typednodes, 0\n")
    b = builder_text(b, "  %bodies = load i32, ptr @ycpl_stage5_ast_function_bodies, align 4\n")
    b = builder_text(b, "  %bodiesok = icmp sgt i32 %bodies, 0\n")
    b = builder_text(b, "  %exprnodes = load i32, ptr @ycpl_stage5_ast_expr_nodes, align 4\n")
    b = builder_text(b, "  %exprok = icmp sgt i32 %exprnodes, 0\n")
    b = builder_text(b, "  %bodylowered = call i32 @ycpl_stage5_project_body_lowering()\n")
    b = builder_text(b, "  %bodyloweredok = icmp sgt i32 %bodylowered, 0\n")
    b = builder_text(b, "  %ok0 = and i1 %hasmainok, %typedok\n")
    b = builder_text(b, "  %ok1 = and i1 %bodiesok, %exprok\n")
    b = builder_text(b, "  %ok2 = and i1 %ok1, %bodyloweredok\n")
    b = builder_text(b, "  %ok = and i1 %ok0, %ok2\n")
    b = builder_text(b, "  br i1 %ok, label %done, label %bad\n")
    b = builder_text(b, "bad:\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "done:\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "}\n")
    return b.data
}

fn stage4_ir_text(project ProjectResult) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes
    parse_line := stage3_summary_line(project, "parse")
    check_line := stage3_summary_line(project, "check")
    stage5_ir := stage5_ir_text(project)

    b := builder_new(98304)
    b = builder_text(b, "; YCPL stage4 compiler-smoke IR\n")
    b = emit_string_global(b, ".stage4.msg", "YCPL stage4 AST IR")
    b = emit_string_global(b, ".stage4.usage", "usage: ycc-ycpl <parse|check|build-ir|build> <file.yc|dir> [-o dir]")
    b = emit_string_global(b, ".stage4.parse.mode", "parse")
    b = emit_string_global(b, ".stage4.check.mode", "check")
    b = emit_string_global(b, ".stage4.buildir.mode", "build-ir")
    b = emit_string_global(b, ".stage4.build.mode", "build")
    b = emit_string_global(b, ".stage4.ll.mode", "ll")
    b = emit_string_global(b, ".stage4.parse.line", parse_line)
    b = emit_string_global(b, ".stage4.check.line", check_line)
    b = emit_string_global(b, ".stage4.stage5.ir", stage5_ir)
    b = emit_string_global(b, ".stage4.default.out", ".")
    b = emit_string_global(b, ".stage4.out.format", "%s/merged.ll")
    b = emit_string_global(b, ".stage4.write.mode", "w")
    b = emit_string_global(b, ".stage4.write.ok", "Wrote stage5 IR to stage output")
    b = emit_string_global(b, ".stage4.write.fail", "failed to write stage5 IR")
    b = emit_string_global(b, ".stage4.native.ok", "Wrote stage5 native stage output")
    b = emit_string_global(b, ".stage4.native.fail", "failed to build stage5 native stage output")
    b = emit_string_global(b, ".stage4.env.llc", "LLC")
    b = emit_string_global(b, ".stage4.env.clang", "CLANG")
    b = emit_string_global(b, ".stage4.env.bindir", "LLVM_BINDIR")
    b = emit_string_global(b, ".stage4.default.llc", llvm_tool_default_command("llc"))
    b = emit_string_global(b, ".stage4.default.clang", llvm_tool_default_command("clang"))
    b = emit_string_global(b, ".stage4.llc.format", "%s -filetype=obj %s/merged.ll -o %s/merged.o")
    b = emit_string_global(b, ".stage4.llc.bindir.format", "%s/llc -filetype=obj %s/merged.ll -o %s/merged.o")
    b = emit_string_global(b, ".stage4.clang.format", "%s %s/merged.o -o %s/merged")
    b = emit_string_global(b, ".stage4.clang.bindir.format", "%s/clang %s/merged.o -o %s/merged")
    b = emit_global_i32(b, "ycpl_stage4_ast_has_main", main_value)
    b = emit_global_i32(b, "ycpl_stage4_ast_typed_nodes", typed_nodes)
    b = emit_global_i32(b, "ycpl_stage4_ast_function_bodies", project.function_bodies)
    b = emit_global_i32(b, "ycpl_stage4_ast_expr_nodes", project.expr_table_nodes)
    b = emit_global_i32(b, "ycpl_stage4_body_local_nodes", project.body_local_nodes)
    b = emit_global_i32(b, "ycpl_stage4_body_assignment_nodes", project.body_assignment_nodes)
    b = emit_global_i32(b, "ycpl_stage4_body_call_nodes", project.body_call_nodes)
    b = emit_global_i32(b, "ycpl_stage4_body_return_nodes", project.body_return_nodes)
    b = emit_global_i32(b, "ycpl_stage4_stmt_expr_links", project.stmt_expr_links)
    b = builder_text(b, "declare i32 @puts(ptr)\n")
    b = builder_text(b, "declare i32 @strcmp(ptr, ptr)\n")
    b = builder_text(b, "declare i32 @mkdir(ptr, i32)\n")
    b = builder_text(b, "declare i32 @snprintf(ptr, i64, ptr, ...)\n")
    b = builder_text(b, "declare i32 @system(ptr)\n")
    b = builder_text(b, "declare ptr @getenv(ptr)\n")
    b = builder_text(b, "declare ptr @fopen(ptr, ptr)\n")
    b = builder_text(b, "declare i32 @fputs(ptr, ptr)\n")
    b = builder_text(b, "declare i32 @fclose(ptr)\n")
    b = emit_stage_body_lowering_probe(b, "ycpl_stage4_project_body_lowering", "ycpl_stage4")
    b = builder_text(b, "define i32 @ycpl_stage4_write_ir_text(ptr %outdir, ptr %irtext) {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %pathbuf = alloca [4096 x i8], align 1\n")
    b = builder_text(b, "  %path = getelementptr inbounds [4096 x i8], ptr %pathbuf, i32 0, i32 0\n")
    b = emit_string_ptr(b, "fmtpath", ".stage4.out.format", "%s/merged.ll")
    b = builder_text(b, "  %mk = call i32 @mkdir(ptr %outdir, i32 493)\n")
    b = builder_text(b, "  %n = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %path, i64 4096, ptr %fmtpath, ptr %outdir)\n")
    b = emit_string_ptr(b, "wmode", ".stage4.write.mode", "w")
    b = builder_text(b, "  %file = call ptr @fopen(ptr %path, ptr %wmode)\n")
    b = builder_text(b, "  %isnull = icmp eq ptr %file, null\n")
    b = builder_text(b, "  br i1 %isnull, label %fail, label %write\n")
    b = builder_text(b, "write:\n")
    b = builder_text(b, "  %wrote = call i32 @fputs(ptr %irtext, ptr %file)\n")
    b = builder_text(b, "  %closed = call i32 @fclose(ptr %file)\n")
    b = emit_string_ptr(b, "okmsg", ".stage4.write.ok", "Wrote stage5 IR to stage output")
    b = builder_text(b, "  %printed = call i32 @puts(ptr %okmsg)\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "fail:\n")
    b = emit_string_ptr(b, "failmsg", ".stage4.write.fail", "failed to write stage5 IR")
    b = builder_text(b, "  %printedfail = call i32 @puts(ptr %failmsg)\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "}\n")
    b = builder_text(b, "define i32 @ycpl_stage4_build_native_from_ir_text(ptr %outdir, ptr %irtext) {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %writecode = call i32 @ycpl_stage4_write_ir_text(ptr %outdir, ptr %irtext)\n")
    b = builder_text(b, "  %writefail = icmp ne i32 %writecode, 0\n")
    b = builder_text(b, "  br i1 %writefail, label %fail, label %compile\n")
    b = builder_text(b, "compile:\n")
    b = builder_text(b, "  %llccmdbuf = alloca [4096 x i8], align 1\n")
    b = builder_text(b, "  %llccmd = getelementptr inbounds [4096 x i8], ptr %llccmdbuf, i32 0, i32 0\n")
    b = emit_string_ptr(b, "llcenvname", ".stage4.env.llc", "LLC")
    b = builder_text(b, "  %llcenv = call ptr @getenv(ptr %llcenvname)\n")
    b = builder_text(b, "  %hasllcenv = icmp ne ptr %llcenv, null\n")
    b = builder_text(b, "  br i1 %hasllcenv, label %llcenvcmd, label %llcbindircheck\n")
    b = builder_text(b, "llcenvcmd:\n")
    b = emit_string_ptr(b, "llcfmtenv", ".stage4.llc.format", "%s -filetype=obj %s/merged.ll -o %s/merged.o")
    b = builder_text(b, "  %llcenvn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %llccmd, i64 4096, ptr %llcfmtenv, ptr %llcenv, ptr %outdir, ptr %outdir)\n")
    b = builder_text(b, "  br label %runllc\n")
    b = builder_text(b, "llcbindircheck:\n")
    b = emit_string_ptr(b, "bindirname", ".stage4.env.bindir", "LLVM_BINDIR")
    b = builder_text(b, "  %bindir = call ptr @getenv(ptr %bindirname)\n")
    b = builder_text(b, "  %hasbindir = icmp ne ptr %bindir, null\n")
    b = builder_text(b, "  br i1 %hasbindir, label %llcbindircmd, label %llcdefaultcmd\n")
    b = builder_text(b, "llcbindircmd:\n")
    b = emit_string_ptr(b, "llcfmtbindir", ".stage4.llc.bindir.format", "%s/llc -filetype=obj %s/merged.ll -o %s/merged.o")
    b = builder_text(b, "  %llcbindirn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %llccmd, i64 4096, ptr %llcfmtbindir, ptr %bindir, ptr %outdir, ptr %outdir)\n")
    b = builder_text(b, "  br label %runllc\n")
    b = builder_text(b, "llcdefaultcmd:\n")
    b = emit_string_ptr(b, "defaultllc", ".stage4.default.llc", "llc")
    b = emit_string_ptr(b, "llcfmtdefault", ".stage4.llc.format", "%s -filetype=obj %s/merged.ll -o %s/merged.o")
    b = builder_text(b, "  %llcdefaultn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %llccmd, i64 4096, ptr %llcfmtdefault, ptr %defaultllc, ptr %outdir, ptr %outdir)\n")
    b = builder_text(b, "  br label %runllc\n")
    b = builder_text(b, "runllc:\n")
    b = builder_text(b, "  %llcrc = call i32 @system(ptr %llccmd)\n")
    b = builder_text(b, "  %llcfail = icmp ne i32 %llcrc, 0\n")
    b = builder_text(b, "  br i1 %llcfail, label %fail, label %link\n")
    b = builder_text(b, "link:\n")
    b = builder_text(b, "  %clangcmdbuf = alloca [4096 x i8], align 1\n")
    b = builder_text(b, "  %clangcmd = getelementptr inbounds [4096 x i8], ptr %clangcmdbuf, i32 0, i32 0\n")
    b = emit_string_ptr(b, "clangenvname", ".stage4.env.clang", "CLANG")
    b = builder_text(b, "  %clangenv = call ptr @getenv(ptr %clangenvname)\n")
    b = builder_text(b, "  %hasclangenv = icmp ne ptr %clangenv, null\n")
    b = builder_text(b, "  br i1 %hasclangenv, label %clangenvcmd, label %clangbindircheck\n")
    b = builder_text(b, "clangenvcmd:\n")
    b = emit_string_ptr(b, "clangfmtenv", ".stage4.clang.format", "%s %s/merged.o -o %s/merged")
    b = builder_text(b, "  %clangenvn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %clangcmd, i64 4096, ptr %clangfmtenv, ptr %clangenv, ptr %outdir, ptr %outdir)\n")
    b = builder_text(b, "  br label %runclang\n")
    b = builder_text(b, "clangbindircheck:\n")
    b = emit_string_ptr(b, "clangbindirname", ".stage4.env.bindir", "LLVM_BINDIR")
    b = builder_text(b, "  %clangbindir = call ptr @getenv(ptr %clangbindirname)\n")
    b = builder_text(b, "  %hasclangbindir = icmp ne ptr %clangbindir, null\n")
    b = builder_text(b, "  br i1 %hasclangbindir, label %clangbindircmd, label %clangdefaultcmd\n")
    b = builder_text(b, "clangbindircmd:\n")
    b = emit_string_ptr(b, "clangfmtbindir", ".stage4.clang.bindir.format", "%s/clang %s/merged.o -o %s/merged")
    b = builder_text(b, "  %clangbindirn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %clangcmd, i64 4096, ptr %clangfmtbindir, ptr %clangbindir, ptr %outdir, ptr %outdir)\n")
    b = builder_text(b, "  br label %runclang\n")
    b = builder_text(b, "clangdefaultcmd:\n")
    b = emit_string_ptr(b, "defaultclang", ".stage4.default.clang", "clang")
    b = emit_string_ptr(b, "clangfmtdefault", ".stage4.clang.format", "%s %s/merged.o -o %s/merged")
    b = builder_text(b, "  %clangdefaultn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %clangcmd, i64 4096, ptr %clangfmtdefault, ptr %defaultclang, ptr %outdir, ptr %outdir)\n")
    b = builder_text(b, "  br label %runclang\n")
    b = builder_text(b, "runclang:\n")
    b = builder_text(b, "  %clangrc = call i32 @system(ptr %clangcmd)\n")
    b = builder_text(b, "  %clangfail = icmp ne i32 %clangrc, 0\n")
    b = builder_text(b, "  br i1 %clangfail, label %fail, label %done\n")
    b = builder_text(b, "done:\n")
    b = emit_string_ptr(b, "nativeok", ".stage4.native.ok", "Wrote stage5 native stage output")
    b = builder_text(b, "  %okprinted = call i32 @puts(ptr %nativeok)\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "fail:\n")
    b = emit_string_ptr(b, "nativefail", ".stage4.native.fail", "failed to build stage5 native stage output")
    b = builder_text(b, "  %failprinted = call i32 @puts(ptr %nativefail)\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "}\n")
    b = builder_text(b, "define i32 @main(i32 %argc, ptr %argv) {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %hasmode = icmp slt i32 %argc, 2\n")
    b = builder_text(b, "  br i1 %hasmode, label %smoke, label %dispatch\n")
    b = builder_text(b, "dispatch:\n")
    b = builder_text(b, "  %modeptrptr = getelementptr inbounds ptr, ptr %argv, i64 1\n")
    b = builder_text(b, "  %mode = load ptr, ptr %modeptrptr\n")
    b = emit_string_ptr(b, "parseptr", ".stage4.parse.mode", "parse")
    b = builder_text(b, "  %parsecmp = call i32 @strcmp(ptr %mode, ptr %parseptr)\n")
    b = builder_text(b, "  %isparse = icmp eq i32 %parsecmp, 0\n")
    b = builder_text(b, "  br i1 %isparse, label %parse, label %check_mode\n")
    b = builder_text(b, "parse:\n")
    b = emit_string_ptr(b, "parseline", ".stage4.parse.line", parse_line)
    b = builder_text(b, "  %parseprinted = call i32 @puts(ptr %parseline)\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "check_mode:\n")
    b = emit_string_ptr(b, "checkptr", ".stage4.check.mode", "check")
    b = builder_text(b, "  %checkcmp = call i32 @strcmp(ptr %mode, ptr %checkptr)\n")
    b = builder_text(b, "  %ischeck = icmp eq i32 %checkcmp, 0\n")
    b = builder_text(b, "  br i1 %ischeck, label %check, label %buildir_mode\n")
    b = builder_text(b, "check:\n")
    b = emit_string_ptr(b, "checkline", ".stage4.check.line", check_line)
    b = builder_text(b, "  %checkprinted = call i32 @puts(ptr %checkline)\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "buildir_mode:\n")
    b = emit_string_ptr(b, "buildirptr", ".stage4.buildir.mode", "build-ir")
    b = builder_text(b, "  %buildircmp = call i32 @strcmp(ptr %mode, ptr %buildirptr)\n")
    b = builder_text(b, "  %isbuildir = icmp eq i32 %buildircmp, 0\n")
    b = builder_text(b, "  br i1 %isbuildir, label %buildir, label %ll_mode\n")
    b = builder_text(b, "ll_mode:\n")
    b = emit_string_ptr(b, "llptr", ".stage4.ll.mode", "ll")
    b = builder_text(b, "  %llcmp = call i32 @strcmp(ptr %mode, ptr %llptr)\n")
    b = builder_text(b, "  %isll = icmp eq i32 %llcmp, 0\n")
    b = builder_text(b, "  br i1 %isll, label %buildir, label %build_mode\n")
    b = builder_text(b, "build_mode:\n")
    b = emit_string_ptr(b, "buildptr", ".stage4.build.mode", "build")
    b = builder_text(b, "  %buildcmp = call i32 @strcmp(ptr %mode, ptr %buildptr)\n")
    b = builder_text(b, "  %isbuild = icmp eq i32 %buildcmp, 0\n")
    b = builder_text(b, "  br i1 %isbuild, label %build, label %usage\n")
    b = builder_text(b, "usage:\n")
    b = emit_string_ptr(b, "usageptr", ".stage4.usage", "usage: ycc-ycpl <parse|check|build-ir|build> <file.yc|dir> [-o dir]")
    b = builder_text(b, "  %usageprinted = call i32 @puts(ptr %usageptr)\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "buildir:\n")
    b = builder_text(b, "  %hasout = icmp sge i32 %argc, 5\n")
    b = builder_text(b, "  br i1 %hasout, label %outarg, label %defaultout\n")
    b = builder_text(b, "outarg:\n")
    b = builder_text(b, "  %outptrptr = getelementptr inbounds ptr, ptr %argv, i64 4\n")
    b = builder_text(b, "  %out = load ptr, ptr %outptrptr\n")
    b = emit_string_ptr(b, "stage5ir", ".stage4.stage5.ir", stage5_ir)
    b = builder_text(b, "  %outcode = call i32 @ycpl_stage4_write_ir_text(ptr %out, ptr %stage5ir)\n")
    b = builder_text(b, "  ret i32 %outcode\n")
    b = builder_text(b, "defaultout:\n")
    b = emit_string_ptr(b, "defaultoutptr", ".stage4.default.out", ".")
    b = emit_string_ptr(b, "defaultstage5ir", ".stage4.stage5.ir", stage5_ir)
    b = builder_text(b, "  %defaultcode = call i32 @ycpl_stage4_write_ir_text(ptr %defaultoutptr, ptr %defaultstage5ir)\n")
    b = builder_text(b, "  ret i32 %defaultcode\n")
    b = builder_text(b, "build:\n")
    b = builder_text(b, "  %hasbuildout = icmp sge i32 %argc, 5\n")
    b = builder_text(b, "  br i1 %hasbuildout, label %buildoutarg, label %builddefaultout\n")
    b = builder_text(b, "buildoutarg:\n")
    b = builder_text(b, "  %buildoutptrptr = getelementptr inbounds ptr, ptr %argv, i64 4\n")
    b = builder_text(b, "  %buildout = load ptr, ptr %buildoutptrptr\n")
    b = emit_string_ptr(b, "buildstage5ir", ".stage4.stage5.ir", stage5_ir)
    b = builder_text(b, "  %buildcode = call i32 @ycpl_stage4_build_native_from_ir_text(ptr %buildout, ptr %buildstage5ir)\n")
    b = builder_text(b, "  ret i32 %buildcode\n")
    b = builder_text(b, "builddefaultout:\n")
    b = emit_string_ptr(b, "builddefaultoutptr", ".stage4.default.out", ".")
    b = emit_string_ptr(b, "builddefaultstage5ir", ".stage4.stage5.ir", stage5_ir)
    b = builder_text(b, "  %builddefaultcode = call i32 @ycpl_stage4_build_native_from_ir_text(ptr %builddefaultoutptr, ptr %builddefaultstage5ir)\n")
    b = builder_text(b, "  ret i32 %builddefaultcode\n")
    b = builder_text(b, "smoke:\n")
    b = builder_text(b, "  %msg = getelementptr inbounds [19 x i8], ptr @.stage4.msg, i32 0, i32 0\n")
    b = builder_text(b, "  %printed = call i32 @puts(ptr %msg)\n")
    b = builder_text(b, "  %hasmain = load i32, ptr @ycpl_stage4_ast_has_main, align 4\n")
    b = builder_text(b, "  %hasmainok = icmp eq i32 %hasmain, 1\n")
    b = builder_text(b, "  %typednodes = load i32, ptr @ycpl_stage4_ast_typed_nodes, align 4\n")
    b = builder_text(b, "  %typedok = icmp sgt i32 %typednodes, 0\n")
    b = builder_text(b, "  %bodies = load i32, ptr @ycpl_stage4_ast_function_bodies, align 4\n")
    b = builder_text(b, "  %bodiesok = icmp sgt i32 %bodies, 0\n")
    b = builder_text(b, "  %exprnodes = load i32, ptr @ycpl_stage4_ast_expr_nodes, align 4\n")
    b = builder_text(b, "  %exprok = icmp sgt i32 %exprnodes, 0\n")
    b = builder_text(b, "  %bodylowered = call i32 @ycpl_stage4_project_body_lowering()\n")
    b = builder_text(b, "  %bodyloweredok = icmp sgt i32 %bodylowered, 0\n")
    b = builder_text(b, "  %ok0 = and i1 %hasmainok, %typedok\n")
    b = builder_text(b, "  %ok1 = and i1 %bodiesok, %exprok\n")
    b = builder_text(b, "  %ok2 = and i1 %ok1, %bodyloweredok\n")
    b = builder_text(b, "  %ok = and i1 %ok0, %ok2\n")
    b = builder_text(b, "  br i1 %ok, label %done, label %bad\n")
    b = builder_text(b, "bad:\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "done:\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "}\n")
    return b.data
}

fn stage3_ir_text(project ProjectResult) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes
    expr_lowered_floor := stage_expr_lowered_floor(project)
    parse_line := stage3_summary_line(project, "parse")
    check_line := stage3_summary_line(project, "check")
    stage4_ir := stage4_ir_text(project)
    tiny42_ir := tiny42_ir_text()
    tiny13_ir := tiny13_ir_text()
    tinycall_ir := tiny_call13_ir_text()
    tinyparam_ir := tiny_param13_ir_text()
    tinychain_ir := tiny_chain13_ir_text()
    tinytwoarg_ir := tiny_two_arg13_ir_text()
    tinycontrol_ir := tiny_control13_ir_text()
    tinyelse_ir := tiny_else13_ir_text()
    tinybool_ir := tiny_bool13_ir_text()
    tinyboolhelper_ir := tiny_bool_helper13_ir_text()
    tinyarray_ir := tiny_array13_ir_text()
    tinystring_ir := tiny_string13_ir_text()
    tinyexternstring_ir := tiny_extern_string13_ir_text()
    tinyexternmalloc_ir := tiny_extern_malloc13_ir_text()
    tinyllvmcapi_ir := tiny_llvm_c_api13_ir_text()
    tinyvoidextern_ir := tiny_void_extern13_ir_text()
    tinyllvmfunctiontype_ir := tiny_llvm_function_type13_ir_text()
    tinyllvmbuildermemory_ir := tiny_llvm_builder_memory13_ir_text()
    tinyllvmcall2icmp_ir := tiny_llvm_call2_icmp13_ir_text()

    b := builder_new(524288)
    b = builder_text(b, "; YCPL stage-generated IR\n")
    b = emit_string_global(b, ".msg", "YCPL stage3 AST IR")
    b = emit_string_global(b, ".stage3.usage", "usage: ycc-ycpl <parse|check|build-ir|build> <file.yc|dir> [-o dir]")
    b = emit_string_global(b, ".stage3.parse.mode", "parse")
    b = emit_string_global(b, ".stage3.check.mode", "check")
    b = emit_string_global(b, ".stage3.buildir.mode", "build-ir")
    b = emit_string_global(b, ".stage3.build.mode", "build")
    b = emit_string_global(b, ".stage3.ll.mode", "ll")
    b = emit_string_global(b, ".stage3.read.mode", "r")
    b = emit_string_global(b, ".stage3.project.pattern", "compiler/ycpl")
    b = emit_dynamic_return_globals(b, ".stage3.dynamic.return.pattern", ".stage3.dynamic.return.format")
    b = emit_dynamic_local_return_globals(b, ".stage3.dynamic.local.assign.pattern", ".stage3.dynamic.local.return.pattern", ".stage3.dynamic.local.format")
    b = emit_dynamic_assignment_return_globals(b, ".stage3.dynamic.assignment.decl.pattern", ".stage3.dynamic.assignment.assign.pattern", ".stage3.dynamic.assignment.return.pattern", ".stage3.dynamic.assignment.format")
    b = emit_dynamic_binary_add_return_globals(b, ".stage3.dynamic.binary.left.pattern", ".stage3.dynamic.binary.right.pattern", ".stage3.dynamic.binary.return.pattern", ".stage3.dynamic.binary.format")
    b = emit_dynamic_compare_if_return_globals(b, ".stage3.dynamic.compare.left.pattern", ".stage3.dynamic.compare.right.pattern", ".stage3.dynamic.compare.if.pattern", ".stage3.dynamic.compare.return.pattern", ".stage3.dynamic.compare.format")
    b = emit_dynamic_zero_call_globals(b, ".stage3.dynamic.zero.call.pattern", ".stage3.dynamic.zero.return.pattern", ".stage3.dynamic.zero.call.format")
    b = emit_dynamic_if_return_globals(b, ".stage3.dynamic.if.decl.pattern", ".stage3.dynamic.if.pattern", ".stage3.dynamic.if.return.pattern", ".stage3.dynamic.if.format")
    b = emit_dynamic_for_return_globals(b, ".stage3.dynamic.for.sum.pattern", ".stage3.dynamic.for.limit.pattern", ".stage3.dynamic.for.add.pattern", ".stage3.dynamic.for.return.pattern", ".stage3.dynamic.for.format")
    b = emit_string_global(b, ".stage3.tinyllvmcall2icmp.pattern", "LLVMBuildCall2")
    b = emit_string_global(b, ".stage3.tinyllvmbuildermemory.pattern", "LLVMBuildAlloca")
    b = emit_string_global(b, ".stage3.tinyllvmfunctiontype.pattern", "LLVMFunctionType")
    b = emit_string_global(b, ".stage3.tinyvoidextern.pattern", "LLVMContextDispose")
    b = emit_string_global(b, ".stage3.tinyllvmcapi.pattern", "LLVMModuleCreateWithNameInContext")
    b = emit_string_global(b, ".stage3.tinyexternmalloc.pattern", "c_malloc")
    b = emit_string_global(b, ".stage3.tinyexternstring.pattern", "c_strcmp")
    b = emit_string_global(b, ".stage3.tinystring.pattern", "message: string")
    b = emit_string_global(b, ".stage3.tinyarray.pattern", "items := [4, 2, 7]")
    b = emit_string_global(b, ".stage3.tinyboolhelper.pattern", "ready()")
    b = emit_string_global(b, ".stage3.tinybool.pattern", "flag: bool")
    b = emit_string_global(b, ".stage3.tinyelse.pattern", "base()")
    b = emit_string_global(b, ".stage3.tinycontrol.pattern", "total == 0")
    b = emit_string_global(b, ".stage3.tinychain.pattern", "bump(")
    b = emit_string_global(b, ".stage3.tinytwoarg.pattern", "add_pair(")
    b = emit_string_global(b, ".stage3.tinyparam.pattern", "inc(")
    b = emit_string_global(b, ".stage3.tinycall.pattern", "x := seed()")
    b = emit_string_global(b, ".stage3.tiny42.pattern", "return 42")
    b = emit_string_global(b, ".stage3.tiny13.pattern", "return x - 1")
    b = emit_string_global(b, ".stage3.parse.line", parse_line)
    b = emit_string_global(b, ".stage3.check.line", check_line)
    b = emit_string_global(b, ".stage3.stage4.ir", stage4_ir)
    b = emit_string_global(b, ".stage3.tinyllvmcall2icmp.ir", tinyllvmcall2icmp_ir)
    b = emit_string_global(b, ".stage3.tinyllvmbuildermemory.ir", tinyllvmbuildermemory_ir)
    b = emit_string_global(b, ".stage3.tinyllvmfunctiontype.ir", tinyllvmfunctiontype_ir)
    b = emit_string_global(b, ".stage3.tinyvoidextern.ir", tinyvoidextern_ir)
    b = emit_string_global(b, ".stage3.tinyllvmcapi.ir", tinyllvmcapi_ir)
    b = emit_string_global(b, ".stage3.tinyexternmalloc.ir", tinyexternmalloc_ir)
    b = emit_string_global(b, ".stage3.tinyexternstring.ir", tinyexternstring_ir)
    b = emit_string_global(b, ".stage3.tinystring.ir", tinystring_ir)
    b = emit_string_global(b, ".stage3.tinyarray.ir", tinyarray_ir)
    b = emit_string_global(b, ".stage3.tinyboolhelper.ir", tinyboolhelper_ir)
    b = emit_string_global(b, ".stage3.tinybool.ir", tinybool_ir)
    b = emit_string_global(b, ".stage3.tinyelse.ir", tinyelse_ir)
    b = emit_string_global(b, ".stage3.tinycontrol.ir", tinycontrol_ir)
    b = emit_string_global(b, ".stage3.tinychain.ir", tinychain_ir)
