    b = builder_text(b, "  %dynamicv2 = add i32 %dynamicv1x10, %dynamicv2digit\n")
    b = builder_text(b, "  br label %dynamic_return_emit2\n")
    b = builder_text(b, "dynamic_return_emit0:\n")
    b = builder_text(b, "  br label %dynamic_return_emit\n")
    b = builder_text(b, "dynamic_return_emit1:\n")
    b = builder_text(b, "  br label %dynamic_return_emit\n")
