    b = builder_text(b, "  %buf = alloca [65536 x i8], align 1\n")
    b = builder_text(b, "  %bufptr = getelementptr inbounds [65536 x i8], ptr %buf, i32 0, i32 0\n")
    b = emit_string_ptr(b, "projectpattern", ".stage3.project.pattern", "compiler/ycpl")
    b = builder_text(b, "  %foundproject = call ptr @strstr(ptr %input, ptr %projectpattern)\n")
