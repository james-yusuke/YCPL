    b = builder_text(b, "define i32 @ycpl_branch_smoke(i32 %x) {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %cmp = icmp sgt i32 %x, 0\n")
    b = builder_text(b, "  br i1 %cmp, label %then, label %else\n")
    b = builder_text(b, "then:\n")
    b = builder_text(b, "  br label %merge\n")
    b = builder_text(b, "else:\n")
    b = builder_text(b, "  br label %loop\n")
    b = builder_text(b, "loop:\n")
    b = builder_text(b, "  %i = phi i32 [ 0, %else ], [ %next, %loop ]\n")
    b = builder_text(b, "  %next = add i32 %i, 1\n")
    b = builder_text(b, "  %done = icmp sge i32 %next, 2\n")
    b = builder_text(b, "  br i1 %done, label %merge, label %loop\n")
    b = builder_text(b, "merge:\n")
    b = builder_text(b, "  %result = phi i32 [ 1, %then ], [ 2, %loop ]\n")
    b = builder_text(b, "  ret i32 %result\n")
    b = builder_text(b, "}\n\n")

    b = builder_text(b, "define ptr @ycpl_select_ir(ptr %input) {\n")
