    b = emit_string_ptr(b, "dynamicreturnformat", format_name, "; YCPL dynamic constant return IR\ndefine i32 @main() {\nentry:\n  ret i32 %d\n}\n")
    b = builder_text(b, "  %dynamicn = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %dynamicout, i64 512, ptr %dynamicreturnformat, i32 %dynamicvalue)\n")
    b = builder_text(b, "  ret ptr %dynamicout\n")
