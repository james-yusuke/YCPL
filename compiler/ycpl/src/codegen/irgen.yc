module compiler.ycpl.irgen

import "codegen/nodeir" as nodeir
import "codegen/projectir" as projectir
import "codegen/tinyir" as tinyir
import "resolver/resolver" as resolver
import "source/source" as source
import "std/fs" as fs
import "std/mem" as mem
import "std/str" as str

pub struct IrResult {
    ok bool
    supported bool
    message string
    line i32
    col i32
    out_file string
}

fn ok(out_file string) IrResult {
    return IrResult{ok: true, supported: true, message: "", line: 1, col: 1, out_file: out_file}
}

fn fail_supported(line i32, col i32, message string) IrResult {
    return IrResult{ok: false, supported: true, message: message, line: line, col: col, out_file: ""}
}

fn fail_unsupported(line i32, col i32, message string) IrResult {
    return IrResult{ok: false, supported: false, message: message, line: line, col: col, out_file: ""}
}

fn merged_ll_path(out_dir string) string {
    suffix := "/merged.ll"
    left := str.len(out_dir)
    right := str.len(suffix)
    out: string := mem.calloc(left + right + 1, 1)
    mem.copy(out, out_dir, left)
    mem.copy(out + left, suffix, right)
    return out
}

struct TextBuilder {
    data string
    len i32
    cap i32
    ok bool
}

fn llvm_tool_default_command(tool string) string {
    if str.eq(tool, "llc") {
        return "sh -c 'if [ -n \"$LLVM_CONFIG\" ]; then \"$(dirname \"$LLVM_CONFIG\")/llc\" \"$@\"; else PATH=/opt/homebrew/opt/llvm/bin:/opt/homebrew/opt/llvm@22/bin:/usr/local/opt/llvm/bin:/usr/lib/llvm-22/bin:/usr/lib/llvm-18/bin:/usr/lib/llvm-17/bin:/usr/lib/llvm-16/bin:/usr/lib/llvm-15/bin:/usr/lib/llvm-14/bin:$PATH llc \"$@\"; fi' ycpl-llc"
    }
    return "sh -c 'if [ -n \"$LLVM_CONFIG\" ]; then \"$(dirname \"$LLVM_CONFIG\")/clang\" \"$@\"; else PATH=/opt/homebrew/opt/llvm/bin:/opt/homebrew/opt/llvm@22/bin:/usr/local/opt/llvm/bin:/usr/lib/llvm-22/bin:/usr/lib/llvm-18/bin:/usr/lib/llvm-17/bin:/usr/lib/llvm-16/bin:/usr/lib/llvm-15/bin:/usr/lib/llvm-14/bin:$PATH clang \"$@\"; fi' ycpl-clang"
}

fn builder_new(cap i32) TextBuilder {
    data: string := mem.calloc(cap + 1, 1)
    return TextBuilder{data: data, len: 0, cap: cap, ok: true}
}

fn builder_char(b TextBuilder, ch i32) TextBuilder {
    if !b.ok {
        return b
    }
    if b.len + 1 >= b.cap {
        b.ok = false
        return b
    }
    b.data[b.len] = ch
    b.len += 1
    b.data[b.len] = 0
    return b
}

fn builder_text(b TextBuilder, text string) TextBuilder {
    if !b.ok {
        return b
    }
    n := str.len(text)
    if b.len + n >= b.cap {
        b.ok = false
        return b
    }
    mem.copy(b.data + b.len, text, n)
    b.len += n
    b.data[b.len] = 0
    return b
}

fn builder_i32(b TextBuilder, value i32) TextBuilder {
    if !b.ok {
        return b
    }
    if value == 0 {
        return builder_char(b, '0')
    }
    if value < 0 {
        b = builder_char(b, '-')
        value = 0 - value
    }

    buf: string := mem.calloc(16, 1)
    n := 0
    v := value
    for (; v > 0; ) {
        buf[n] = '0' + (v % 10)
        n += 1
        v = v / 10
    }
    i := n - 1
    for (; i >= 0; i--) {
        b = builder_char(b, buf[i])
    }
    mem.free(buf)
    return b
}

fn emit_global_i32(b TextBuilder, name string, value i32) TextBuilder {
    b = builder_text(b, "@")
    b = builder_text(b, name)
    b = builder_text(b, " = internal constant i32 ")
    b = builder_i32(b, value)
    b = builder_text(b, "\n")
    return b
}

fn emit_stub_function(b TextBuilder, index i32, value i32) TextBuilder {
    b = builder_text(b, "define i32 @ycpl_ast_fn_")
    b = builder_i32(b, index)
    b = builder_text(b, "() {\nentry:\n  ret i32 ")
    b = builder_i32(b, value)
    b = builder_text(b, "\n}\n\n")
    return b
}

fn escaped_len(text string) i32 {
    total := 0
    i := 0
    n := str.len(text)
    for (; i < n; i++) {
        ch := text[i]
        if ch == 10 || ch == 34 || ch == 92 {
            total += 3
        } else {
            total += 1
        }
    }
    return total
}

fn builder_hex2(b TextBuilder, value i32) TextBuilder {
    hi := value / 16
    lo := value % 16
    if hi < 10 {
        b = builder_char(b, '0' + hi)
    } else {
        b = builder_char(b, 'A' + hi - 10)
    }
    if lo < 10 {
        b = builder_char(b, '0' + lo)
    } else {
        b = builder_char(b, 'A' + lo - 10)
    }
    return b
}

fn builder_llvm_cstr_body(b TextBuilder, text string) TextBuilder {
    i := 0
    n := str.len(text)
    for (; i < n; i++) {
        ch := text[i]
        if ch == 10 || ch == 34 || ch == 92 {
            b = builder_char(b, 92)
            b = builder_hex2(b, ch)
        } else {
            b = builder_char(b, ch)
        }
    }
    b = builder_text(b, "\\00")
    return b
}

fn emit_string_global(b TextBuilder, name string, text string) TextBuilder {
    b = builder_text(b, "@")
    b = builder_text(b, name)
    b = builder_text(b, " = private unnamed_addr constant [")
    b = builder_i32(b, str.len(text) + 1)
    b = builder_text(b, " x i8] c\"")
    b = builder_llvm_cstr_body(b, text)
    b = builder_text(b, "\", align 1\n")
    return b
}

fn emit_string_ptr(b TextBuilder, reg string, name string, text string) TextBuilder {
    b = builder_text(b, "  %")
    b = builder_text(b, reg)
    b = builder_text(b, " = getelementptr inbounds [")
    b = builder_i32(b, str.len(text) + 1)
    b = builder_text(b, " x i8], ptr @")
    b = builder_text(b, name)
    b = builder_text(b, ", i32 0, i32 0\n")
    return b
}

fn emit_dynamic_return_globals(b TextBuilder, pattern_name string, format_name string) TextBuilder {
    b = emit_string_global(b, pattern_name, "return ")
    return emit_string_global(b, format_name, "; YCPL dynamic constant return IR\ndefine i32 @main() {\nentry:\n  ret i32 %d\n}\n")
}

fn emit_dynamic_local_return_globals(b TextBuilder, assign_pattern_name string, return_pattern_name string, format_name string) TextBuilder {
    b = emit_string_global(b, assign_pattern_name, ":= ")
    b = emit_string_global(b, return_pattern_name, "return x")
    return emit_string_global(b, format_name, "; YCPL dynamic local return IR\ndefine i32 @main() {\nentry:\n  %%x = alloca i32, align 4\n  store i32 %d, ptr %%x, align 4\n  %%loadtmp = load i32, ptr %%x, align 4\n  ret i32 %%loadtmp\n}\n")
}

fn emit_dynamic_assignment_return_globals(b TextBuilder, decl_pattern_name string, assign_pattern_name string, return_pattern_name string, format_name string) TextBuilder {
    b = emit_string_global(b, decl_pattern_name, ":= ")
    b = emit_string_global(b, assign_pattern_name, "x = ")
    b = emit_string_global(b, return_pattern_name, "return x")
    return emit_string_global(b, format_name, "; YCPL dynamic assignment return IR\ndefine i32 @main() {\nentry:\n  %%x = alloca i32, align 4\n  store i32 %d, ptr %%x, align 4\n  store i32 %d, ptr %%x, align 4\n  %%loadtmp = load i32, ptr %%x, align 4\n  ret i32 %%loadtmp\n}\n")
}

fn emit_dynamic_binary_add_return_globals(b TextBuilder, left_pattern_name string, right_pattern_name string, return_pattern_name string, format_name string) TextBuilder {
    b = emit_string_global(b, left_pattern_name, "left := ")
    b = emit_string_global(b, right_pattern_name, "right := ")
    b = emit_string_global(b, return_pattern_name, "return left + right")
    return emit_string_global(b, format_name, "; YCPL dynamic binary add return IR\ndefine i32 @main() {\nentry:\n  %%left = alloca i32, align 4\n  %%right = alloca i32, align 4\n  store i32 %d, ptr %%left, align 4\n  store i32 %d, ptr %%right, align 4\n  %%leftload = load i32, ptr %%left, align 4\n  %%rightload = load i32, ptr %%right, align 4\n  %%addtmp = add i32 %%leftload, %%rightload\n  ret i32 %%addtmp\n}\n")
}

fn emit_dynamic_compare_if_return_globals(b TextBuilder, left_pattern_name string, right_pattern_name string, if_pattern_name string, return_pattern_name string, format_name string) TextBuilder {
    b = emit_string_global(b, left_pattern_name, "left := ")
    b = emit_string_global(b, right_pattern_name, "right := ")
    b = emit_string_global(b, if_pattern_name, "if left < right")
    b = emit_string_global(b, return_pattern_name, "return ")
    return emit_string_global(b, format_name, "; YCPL dynamic compare-if return IR\ndefine i32 @main() {\nentry:\n  %%left = alloca i32, align 4\n  %%right = alloca i32, align 4\n  store i32 %d, ptr %%left, align 4\n  store i32 %d, ptr %%right, align 4\n  %%leftload = load i32, ptr %%left, align 4\n  %%rightload = load i32, ptr %%right, align 4\n  %%cmptmp = icmp slt i32 %%leftload, %%rightload\n  br i1 %%cmptmp, label %%then, label %%cont\nthen:\n  ret i32 %d\ncont:\n  ret i32 %d\n}\n")
}

fn emit_dynamic_zero_call_globals(b TextBuilder, call_pattern_name string, return_pattern_name string, format_name string) TextBuilder {
    b = emit_string_global(b, call_pattern_name, "dyn_seed()")
    b = emit_string_global(b, return_pattern_name, "return ")
    return emit_string_global(b, format_name, "; YCPL dynamic zero-arg call IR\ndefine i32 @dyn_seed() {\nentry:\n  ret i32 %d\n}\n\ndefine i32 @main() {\nentry:\n  %%x = alloca i32, align 4\n  %%calltmp = call i32 @dyn_seed()\n  store i32 %%calltmp, ptr %%x, align 4\n  %%loadtmp = load i32, ptr %%x, align 4\n  ret i32 %%loadtmp\n}\n")
}

fn emit_dynamic_if_return_globals(b TextBuilder, decl_pattern_name string, if_pattern_name string, return_pattern_name string, format_name string) TextBuilder {
    b = emit_string_global(b, decl_pattern_name, "probe := ")
    b = emit_string_global(b, if_pattern_name, "if probe == 0")
    b = emit_string_global(b, return_pattern_name, "return ")
    return emit_string_global(b, format_name, "; YCPL dynamic if-return IR\ndefine i32 @main() {\nentry:\n  %%probe = alloca i32, align 4\n  store i32 %d, ptr %%probe, align 4\n  %%loadprobe = load i32, ptr %%probe, align 4\n  %%iftmp = icmp eq i32 %%loadprobe, 0\n  br i1 %%iftmp, label %%then, label %%cont\nthen:\n  ret i32 %d\ncont:\n  ret i32 %d\n}\n")
}

fn emit_dynamic_for_return_globals(b TextBuilder, sum_pattern_name string, limit_pattern_name string, add_pattern_name string, return_pattern_name string, format_name string) TextBuilder {
    b = emit_string_global(b, sum_pattern_name, "sum := ")
    b = emit_string_global(b, limit_pattern_name, "i < ")
    b = emit_string_global(b, add_pattern_name, "sum = sum + ")
    b = emit_string_global(b, return_pattern_name, "return sum")
    return emit_string_global(b, format_name, "; YCPL dynamic for-return IR\ndefine i32 @main() {\nentry:\n  %%sum = alloca i32, align 4\n  %%i = alloca i32, align 4\n  store i32 %d, ptr %%sum, align 4\n  store i32 0, ptr %%i, align 4\n  br label %%loop_check\nloop_check:\n  %%iload = load i32, ptr %%i, align 4\n  %%cmptmp = icmp slt i32 %%iload, %d\n  br i1 %%cmptmp, label %%loop_body, label %%loop_done\nloop_body:\n  %%sumload = load i32, ptr %%sum, align 4\n  %%addtmp = add i32 %%sumload, %d\n  store i32 %%addtmp, ptr %%sum, align 4\n  br label %%loop_update\nloop_update:\n  %%iload2 = load i32, ptr %%i, align 4\n  %%nexti = add i32 %%iload2, 1\n  store i32 %%nexti, ptr %%i, align 4\n  br label %%loop_check\nloop_done:\n  %%result = load i32, ptr %%sum, align 4\n  ret i32 %%result\n}\n")
}

fn emit_dynamic_i32_parser(b TextBuilder, prefix string, marker_reg string, digit_offset i32, fallback_label string, emit_label string, value_reg string) TextBuilder {
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "digits = getelementptr inbounds i8, ptr %")
    b = builder_text(b, marker_reg)
    b = builder_text(b, ", i64 ")
    b = builder_i32(b, digit_offset)
    b = builder_text(b, "\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0 = load i8, ptr %")
    b = builder_text(b, prefix)
    b = builder_text(b, "digits, align 1\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0lo = icmp sge i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0, 48\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0hi = icmp sle i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0, 57\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0ok = and i1 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0lo, %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0hi\n")
    b = builder_text(b, "  br i1 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0ok, label %")
    b = builder_text(b, prefix)
    b = builder_text(b, "digit0, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, prefix)
    b = builder_text(b, "digit0:\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0wide = sext i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0 to i32\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v0 = sub i32 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d0wide, 48\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "p1 = getelementptr inbounds i8, ptr %")
    b = builder_text(b, prefix)
    b = builder_text(b, "digits, i64 1\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1 = load i8, ptr %")
    b = builder_text(b, prefix)
    b = builder_text(b, "p1, align 1\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1lo = icmp sge i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1, 48\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1hi = icmp sle i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1, 57\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1ok = and i1 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1lo, %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1hi\n")
    b = builder_text(b, "  br i1 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1ok, label %")
    b = builder_text(b, prefix)
    b = builder_text(b, "digit1, label %")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit0\n")
    b = builder_text(b, prefix)
    b = builder_text(b, "digit1:\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v0x10 = mul i32 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v0, 10\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1wide = sext i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1 to i32\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v1digit = sub i32 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d1wide, 48\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v1 = add i32 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v0x10, %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v1digit\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "p2 = getelementptr inbounds i8, ptr %")
    b = builder_text(b, prefix)
    b = builder_text(b, "digits, i64 2\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2 = load i8, ptr %")
    b = builder_text(b, prefix)
    b = builder_text(b, "p2, align 1\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2lo = icmp sge i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2, 48\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2hi = icmp sle i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2, 57\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2ok = and i1 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2lo, %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2hi\n")
    b = builder_text(b, "  br i1 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2ok, label %")
    b = builder_text(b, prefix)
    b = builder_text(b, "digit2, label %")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit1\n")
    b = builder_text(b, prefix)
    b = builder_text(b, "digit2:\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v1x10 = mul i32 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v1, 10\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2wide = sext i8 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2 to i32\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v2digit = sub i32 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "d2wide, 48\n")
    b = builder_text(b, "  %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v2 = add i32 %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v1x10, %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v2digit\n")
    b = builder_text(b, "  br label %")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit2\n")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit0:\n")
    b = builder_text(b, "  br label %")
    b = builder_text(b, emit_label)
    b = builder_text(b, "\n")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit1:\n")
    b = builder_text(b, "  br label %")
    b = builder_text(b, emit_label)
    b = builder_text(b, "\n")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit2:\n")
    b = builder_text(b, "  br label %")
    b = builder_text(b, emit_label)
    b = builder_text(b, "\n")
    b = builder_text(b, emit_label)
    b = builder_text(b, ":\n")
    b = builder_text(b, "  %")
    b = builder_text(b, value_reg)
    b = builder_text(b, " = phi i32 [ %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v0, %")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit0 ], [ %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v1, %")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit1 ], [ %")
    b = builder_text(b, prefix)
    b = builder_text(b, "v2, %")
    b = builder_text(b, prefix)
    b = builder_text(b, "emit2 ]\n")
    return b
}

fn emit_dynamic_return_select_path(b TextBuilder, pattern_name string, format_name string, fallback_label string) TextBuilder {
    b = emit_string_ptr(b, "dynamicreturnpattern", pattern_name, "return ")
    b = builder_text(b, "  %dynamicreturnmarker = call ptr @strstr(ptr %bufptr, ptr %dynamicreturnpattern)\n")
    b = builder_text(b, "  %hasdynamicreturn = icmp ne ptr %dynamicreturnmarker, null\n")
    b = builder_text(b, "  br i1 %hasdynamicreturn, label %dynamic_return_start, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_return_start:\n")
    b = builder_text(b, "  %dynamicdigits = getelementptr inbounds i8, ptr %dynamicreturnmarker, i64 7\n")
    b = builder_text(b, "  %dynamicd0 = load i8, ptr %dynamicdigits, align 1\n")
    b = builder_text(b, "  %dynamicd0lo = icmp sge i8 %dynamicd0, 48\n")
    b = builder_text(b, "  %dynamicd0hi = icmp sle i8 %dynamicd0, 57\n")
    b = builder_text(b, "  %dynamicd0ok = and i1 %dynamicd0lo, %dynamicd0hi\n")
    b = builder_text(b, "  br i1 %dynamicd0ok, label %dynamic_return_digit0, label %")
    b = builder_text(b, fallback_label)
    b = builder_text(b, "\n")
    b = builder_text(b, "dynamic_return_digit0:\n")
    b = builder_text(b, "  %dynamicd0wide = sext i8 %dynamicd0 to i32\n")
    b = builder_text(b, "  %dynamicv0 = sub i32 %dynamicd0wide, 48\n")
