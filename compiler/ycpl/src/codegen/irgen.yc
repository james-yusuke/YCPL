    b = builder_text(b, "  %symbolarity0ok = and i1 %fnsigok, %callarityok\n")
    b = builder_text(b, "  %symbolarityok = and i1 %symbolarity0ok, %signaturetableok\n")
    b = builder_text(b, "  %declsymboldigests0ok = and i1 %symboldigestok, %symbolimportdigestok\n")
    b = builder_text(b, "  %declsymboldigestsok = and i1 %declsymboldigests0ok, %symbolmoduledigestok\n")
    b = builder_text(b, "  %declsymbolmeta0ok = and i1 %declsymbolshape3ok, %declsymbolvis0ok\n")
    b = builder_text(b, "  %declsymbolmeta1ok = and i1 %declsymbolmeta0ok, %symbolarityok\n")
    b = builder_text(b, "  %declsymboltableok = and i1 %declsymbolmeta1ok, %declsymboldigestsok\n")
    b = builder_text(b, "  %symbolok = and i1 %hasmainok, %digestok\n")
    b = builder_text(b, "  %bodycountok = and i1 %bodiesok, %bodytokensok\n")
    b = builder_text(b, "  %bodyshape0ok = and i1 %bodynodesok, %nodedigestok\n")
    b = builder_text(b, "  %bodyshape1ok = and i1 %bodyshape0ok, %transitiondigestok\n")
    b = builder_text(b, "  %bodyslotshape0ok = and i1 %bodyslotsok, %bodynonemptyok\n")
    b = builder_text(b, "  %bodyslotshape1ok = and i1 %bodyslotshape0ok, %bodymaxnodesok\n")
    b = builder_text(b, "  %bodyslotok = and i1 %bodyslotshape1ok, %bodyslotdigestok\n")
    b = builder_text(b, "  %bodyshape2ok = and i1 %bodyshape1ok, %payloadok\n")
    b = builder_text(b, "  %bodyshape3ok = and i1 %bodyshape2ok, %semanticok\n")
    b = builder_text(b, "  %bodyshape4ok = and i1 %bodyshape3ok, %bodyslotok\n")
    b = builder_text(b, "  %bodyshapeok = and i1 %bodyshape4ok, %controlnodesok\n")
    b = builder_text(b, "  %bodydigestallok = and i1 %bodydigestok, %bodyshapeok\n")
    b = builder_text(b, "  %bodyok = and i1 %bodycountok, %bodydigestallok\n")
    b = builder_text(b, "  %returnok = and i1 %returnexprsok, %retdigestok\n")
    b = builder_text(b, "  %symbolmetaok = and i1 %symbolok, %declsymboltableok\n")
    b = builder_text(b, "  %symbolbodyok = and i1 %symbolmetaok, %bodyok\n")
    b = builder_text(b, "  %astexprok = and i1 %symbolbodyok, %exprtableok\n")
    b = builder_text(b, "  %astok = and i1 %astexprok, %returnok\n")
    b = builder_text(b, "  %ok = and i1 %astok, %typedok\n")
    b = builder_text(b, "  br i1 %ok, label %done, label %bad\n")
    b = builder_text(b, "bad:\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "done:\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "}\n")
    return b.data
}

fn tiny42_ir_text() string {
    return "; YCPL tiny stage IR\ndefine i32 @main() {\nentry:\n  ret i32 42\n}\n"
}

fn tiny13_ir_text() string {
    return "; YCPL tiny stage IR\ndefine i32 @main() {\nentry:\n  ret i32 13\n}\n"
}

fn project_parse_line(project ProjectResult) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes

    transitions := project.body_local_assign_edges + project.body_assign_call_edges + project.body_call_return_edges + project.body_return_local_edges + project.body_if_for_edges + project.body_for_return_edges

    line := builder_new(12288)
    line = builder_text(line, "parse ok: files=")
    line = builder_i32(line, project.files)
    line = builder_text(line, " tokens=")
    line = builder_i32(line, project.tokens)
    line = builder_text(line, " decls=")
    line = builder_i32(line, project.decls)
    line = builder_text(line, " funcs=")
    line = builder_i32(line, project.functions)
    line = builder_text(line, " structs=")
    line = builder_i32(line, project.structs)
    line = builder_text(line, " imports=")
    line = builder_i32(line, project.imports)
    line = builder_text(line, " nodes=")
    line = builder_i32(line, project.nodes)
    line = builder_text(line, " typed_nodes=")
    line = builder_i32(line, typed_nodes)
    line = builder_text(line, " typed_digest=")
    line = builder_i32(line, project.typed_digest)
    line = builder_text(line, " symbols=")
    line = builder_i32(line, project.symbol_functions)
    line = builder_text(line, " symbol_structs=")
    line = builder_i32(line, project.symbol_structs)
    line = builder_text(line, " symbol_imports=")
    line = builder_i32(line, project.symbol_imports)
    line = builder_text(line, " std_imports=")
    line = builder_i32(line, project.symbol_std_imports)
    line = builder_text(line, " import_aliases=")
