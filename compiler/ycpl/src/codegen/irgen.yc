    b = builder_text(b, "  %foundllvmcall2icmp = call ptr @strstr(ptr %bufptr, ptr %tinyllvmcall2icmppattern)\n")
    b = builder_text(b, "  %isllvmcall2icmp = icmp ne ptr %foundllvmcall2icmp, null\n")
    b = builder_text(b, "  br i1 %isllvmcall2icmp, label %retllvmcall2icmp, label %checkllvmbuildermemory\n")
