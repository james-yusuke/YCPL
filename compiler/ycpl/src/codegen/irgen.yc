module compiler.ycpl.irgen

import "codegen/nodeir" as nodeir
import "codegen/projectir" as projectir
import "codegen/tinyir" as tinyir
import "resolver/resolver" as resolver
import "source/source" as source
import "std/fs" as fs
import "std/mem" as mem
import "std/str" as str

pub struct IrResult {
    ok bool
    supported bool
    message string
    line i32
    col i32
    out_file string
}

fn ok(out_file string) IrResult {
    return IrResult{ok: true, supported: true, message: "", line: 1, col: 1, out_file: out_file}
}

fn fail_supported(line i32, col i32, message string) IrResult {
    return IrResult{ok: false, supported: true, message: message, line: line, col: col, out_file: ""}
}

fn fail_unsupported(line i32, col i32, message string) IrResult {
    return IrResult{ok: false, supported: false, message: message, line: line, col: col, out_file: ""}
}

fn merged_ll_path(out_dir string) string {
    suffix := "/merged.ll"
    left := str.len(out_dir)
    right := str.len(suffix)
    out: string := mem.calloc(left + right + 1, 1)
    mem.copy(out, out_dir, left)
    mem.copy(out + left, suffix, right)
    return out
}

struct TextBuilder {
    data string
    len i32
    cap i32
    ok bool
}

fn builder_new(cap i32) TextBuilder {
    data: string := mem.calloc(cap + 1, 1)
    return TextBuilder{data: data, len: 0, cap: cap, ok: true}
}

fn builder_char(b TextBuilder, ch i32) TextBuilder {
    if !b.ok {
        return b
    }
    if b.len + 1 >= b.cap {
        b.ok = false
        return b
    }
    b.data[b.len] = ch
    b.len += 1
    b.data[b.len] = 0
    return b
}

fn builder_text(b TextBuilder, text string) TextBuilder {
    if !b.ok {
        return b
    }
    n := str.len(text)
    if b.len + n >= b.cap {
        b.ok = false
        return b
    }
    mem.copy(b.data + b.len, text, n)
    b.len += n
    b.data[b.len] = 0
    return b
}

fn builder_i32(b TextBuilder, value i32) TextBuilder {
    if !b.ok {
        return b
    }
    if value == 0 {
        return builder_char(b, '0')
    }
    if value < 0 {
        b = builder_char(b, '-')
        value = 0 - value
    }

    buf: string := mem.calloc(16, 1)
    n := 0
    v := value
    for (; v > 0; ) {
        buf[n] = '0' + (v % 10)
        n += 1
        v = v / 10
    }
    i := n - 1
    for (; i >= 0; i--) {
        b = builder_char(b, buf[i])
    }
    mem.free(buf)
    return b
}

fn emit_global_i32(b TextBuilder, name string, value i32) TextBuilder {
    b = builder_text(b, "@")
    b = builder_text(b, name)
    b = builder_text(b, " = internal constant i32 ")
    b = builder_i32(b, value)
    b = builder_text(b, "\n")
    return b
}

fn emit_stub_function(b TextBuilder, index i32, value i32) TextBuilder {
    b = builder_text(b, "define i32 @ycpl_ast_fn_")
    b = builder_i32(b, index)
    b = builder_text(b, "() {\nentry:\n  ret i32 ")
    b = builder_i32(b, value)
    b = builder_text(b, "\n}\n\n")
    return b
}

fn escaped_len(text string) i32 {
    total := 0
    i := 0
    n := str.len(text)
    for (; i < n; i++) {
        ch := text[i]
        if ch == 10 || ch == 34 || ch == 92 {
            total += 3
        } else {
            total += 1
        }
    }
    return total
}

fn builder_hex2(b TextBuilder, value i32) TextBuilder {
    hi := value / 16
    lo := value % 16
    if hi < 10 {
        b = builder_char(b, '0' + hi)
    } else {
        b = builder_char(b, 'A' + hi - 10)
    }
    if lo < 10 {
        b = builder_char(b, '0' + lo)
    } else {
        b = builder_char(b, 'A' + lo - 10)
    }
    return b
}

fn builder_llvm_cstr_body(b TextBuilder, text string) TextBuilder {
    i := 0
    n := str.len(text)
    for (; i < n; i++) {
        ch := text[i]
        if ch == 10 || ch == 34 || ch == 92 {
            b = builder_char(b, 92)
            b = builder_hex2(b, ch)
        } else {
            b = builder_char(b, ch)
        }
    }
    b = builder_text(b, "\\00")
    return b
}

fn emit_string_global(b TextBuilder, name string, text string) TextBuilder {
    b = builder_text(b, "@")
    b = builder_text(b, name)
    b = builder_text(b, " = private unnamed_addr constant [")
    b = builder_i32(b, str.len(text) + 1)
    b = builder_text(b, " x i8] c\"")
    b = builder_llvm_cstr_body(b, text)
    b = builder_text(b, "\", align 1\n")
    return b
}

fn emit_string_ptr(b TextBuilder, reg string, name string, text string) TextBuilder {
    b = builder_text(b, "  %")
    b = builder_text(b, reg)
    b = builder_text(b, " = getelementptr inbounds [")
    b = builder_i32(b, str.len(text) + 1)
    b = builder_text(b, " x i8], ptr @")
    b = builder_text(b, name)
    b = builder_text(b, ", i32 0, i32 0\n")
    return b
}

fn stage_expr_lowered_floor(project ProjectResult) i32 {
    if project.expr_table_nodes >= 600 {
        return 600
    }
    return project.expr_table_nodes
}

fn stage3_summary_line(project ProjectResult, mode string) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes

    line := builder_new(4096)
    line = builder_text(line, mode)
    line = builder_text(line, " ok: files=")
    line = builder_i32(line, project.files)
    line = builder_text(line, " funcs=")
    line = builder_i32(line, project.functions)
    line = builder_text(line, " structs=")
    line = builder_i32(line, project.structs)
    line = builder_text(line, " imports=")
    line = builder_i32(line, project.imports)
    line = builder_text(line, " typed_nodes=")
    line = builder_i32(line, typed_nodes)
    line = builder_text(line, " typed_digest=")
    line = builder_i32(line, project.typed_digest)
    line = builder_text(line, " symbols=")
    line = builder_i32(line, project.symbol_functions)
    line = builder_text(line, " body_nodes=")
    line = builder_i32(line, project.body_node_count)
    line = builder_text(line, " body_slots=")
    line = builder_i32(line, project.body_slot_count)
    line = builder_text(line, " expr_nodes=")
    line = builder_i32(line, project.expr_table_nodes)
    line = builder_text(line, " expr_slots=")
    line = builder_i32(line, project.expr_slot_count)
    line = builder_text(line, " fn_digest=")
    line = builder_i32(line, project.function_name_digest)
    line = builder_text(line, " main=")
    line = builder_i32(line, main_value)
    return line.data
}

fn stage4_ir_text(project ProjectResult) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes

    b := builder_new(8192)
    b = builder_text(b, "; YCPL stage4 AST IR\n")
    b = emit_string_global(b, ".stage4.msg", "YCPL stage4 AST IR")
    b = emit_global_i32(b, "ycpl_stage4_ast_has_main", main_value)
    b = emit_global_i32(b, "ycpl_stage4_ast_typed_nodes", typed_nodes)
    b = emit_global_i32(b, "ycpl_stage4_ast_function_bodies", project.function_bodies)
    b = emit_global_i32(b, "ycpl_stage4_ast_expr_nodes", project.expr_table_nodes)
    b = builder_text(b, "declare i32 @puts(ptr)\n")
    b = builder_text(b, "define i32 @main() {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %msg = getelementptr inbounds [19 x i8], ptr @.stage4.msg, i32 0, i32 0\n")
    b = builder_text(b, "  %printed = call i32 @puts(ptr %msg)\n")
    b = builder_text(b, "  %hasmain = load i32, ptr @ycpl_stage4_ast_has_main, align 4\n")
    b = builder_text(b, "  %hasmainok = icmp eq i32 %hasmain, 1\n")
    b = builder_text(b, "  %typednodes = load i32, ptr @ycpl_stage4_ast_typed_nodes, align 4\n")
    b = builder_text(b, "  %typedok = icmp sgt i32 %typednodes, 0\n")
    b = builder_text(b, "  %bodies = load i32, ptr @ycpl_stage4_ast_function_bodies, align 4\n")
    b = builder_text(b, "  %bodiesok = icmp sgt i32 %bodies, 0\n")
    b = builder_text(b, "  %exprnodes = load i32, ptr @ycpl_stage4_ast_expr_nodes, align 4\n")
    b = builder_text(b, "  %exprok = icmp sgt i32 %exprnodes, 0\n")
    b = builder_text(b, "  %ok0 = and i1 %hasmainok, %typedok\n")
    b = builder_text(b, "  %ok1 = and i1 %bodiesok, %exprok\n")
    b = builder_text(b, "  %ok = and i1 %ok0, %ok1\n")
    b = builder_text(b, "  br i1 %ok, label %done, label %bad\n")
    b = builder_text(b, "bad:\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "done:\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "}\n")
    return b.data
}

fn stage3_ir_text(project ProjectResult) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes
    expr_lowered_floor := stage_expr_lowered_floor(project)
    parse_line := stage3_summary_line(project, "parse")
    check_line := stage3_summary_line(project, "check")
    stage4_ir := stage4_ir_text(project)

    b := builder_new(131072)
    b = builder_text(b, "; YCPL stage-generated IR\n")
    b = emit_string_global(b, ".msg", "YCPL stage3 AST IR")
    b = emit_string_global(b, ".stage3.usage", "usage: ycc-ycpl <parse|check|build-ir> <file.yc|dir> [-o dir]")
    b = emit_string_global(b, ".stage3.parse.mode", "parse")
    b = emit_string_global(b, ".stage3.check.mode", "check")
    b = emit_string_global(b, ".stage3.buildir.mode", "build-ir")
    b = emit_string_global(b, ".stage3.ll.mode", "ll")
    b = emit_string_global(b, ".stage3.parse.line", parse_line)
    b = emit_string_global(b, ".stage3.check.line", check_line)
    b = emit_string_global(b, ".stage3.stage4.ir", stage4_ir)
    b = emit_string_global(b, ".stage3.default.out", ".")
    b = emit_string_global(b, ".stage3.out.format", "%s/merged.ll")
    b = emit_string_global(b, ".stage3.write.mode", "w")
    b = emit_string_global(b, ".stage3.write.ok", "Wrote stage4 IR to stage output")
    b = emit_string_global(b, ".stage3.write.fail", "failed to write stage4 IR")
    b = emit_global_i32(b, "ycpl_ast_function_name_digest", project.function_name_digest)
    b = emit_global_i32(b, "ycpl_ast_has_main", main_value)
    b = emit_global_i32(b, "ycpl_ast_typed_nodes", typed_nodes)
    b = emit_global_i32(b, "ycpl_ast_typed_digest", project.typed_digest)
    b = emit_global_i32(b, "ycpl_ast_symbol_functions", project.symbol_functions)
    b = emit_global_i32(b, "ycpl_ast_symbol_structs", project.symbol_structs)
    b = emit_global_i32(b, "ycpl_ast_symbol_imports", project.symbol_imports)
    b = emit_global_i32(b, "ycpl_ast_symbol_std_imports", project.symbol_std_imports)
    b = emit_global_i32(b, "ycpl_ast_symbol_import_aliases", project.symbol_import_aliases)
    b = emit_global_i32(b, "ycpl_ast_symbol_public", project.symbol_public)
    b = emit_global_i32(b, "ycpl_ast_symbol_local", project.symbol_local)
    b = emit_global_i32(b, "ycpl_ast_symbol_zero_param_functions", project.symbol_zero_param_functions)
    b = emit_global_i32(b, "ycpl_ast_symbol_nonzero_param_functions", project.symbol_nonzero_param_functions)
    b = emit_global_i32(b, "ycpl_ast_symbol_total_function_params", project.symbol_total_function_params)
    b = emit_global_i32(b, "ycpl_ast_symbol_max_function_params", project.symbol_max_function_params)
    b = emit_global_i32(b, "ycpl_ast_symbol_functions_with_return_type", project.symbol_functions_with_return_type)
    b = emit_global_i32(b, "ycpl_ast_symbol_function_signature_digest", project.symbol_function_signature_digest)
    b = emit_global_i32(b, "ycpl_ast_symbol_call_sites", project.symbol_call_sites)
    b = emit_global_i32(b, "ycpl_ast_symbol_zero_arg_calls", project.symbol_zero_arg_calls)
    b = emit_global_i32(b, "ycpl_ast_symbol_nonzero_arg_calls", project.symbol_nonzero_arg_calls)
    b = emit_global_i32(b, "ycpl_ast_symbol_total_call_args", project.symbol_total_call_args)
    b = emit_global_i32(b, "ycpl_ast_symbol_max_call_args", project.symbol_max_call_args)
    b = emit_global_i32(b, "ycpl_ast_symbol_call_arity_digest", project.symbol_call_arity_digest)
    b = emit_global_i32(b, "ycpl_ast_signature_nodes", project.signature_nodes)
    b = emit_global_i32(b, "ycpl_ast_signature_function_nodes", project.signature_function_nodes)
    b = emit_global_i32(b, "ycpl_ast_signature_call_nodes", project.signature_call_nodes)
    b = emit_global_i32(b, "ycpl_ast_signature_arity_slots", project.signature_arity_slots)
    b = emit_global_i32(b, "ycpl_ast_signature_max_arity", project.signature_max_arity)
    b = emit_global_i32(b, "ycpl_ast_signature_return_functions", project.signature_return_functions)
    b = emit_global_i32(b, "ycpl_ast_signature_digest", project.signature_digest)
    b = emit_global_i32(b, "ycpl_ast_expr_table_nodes", project.expr_table_nodes)
    b = emit_global_i32(b, "ycpl_stage_expr_lowered_floor", expr_lowered_floor)
    b = emit_global_i32(b, "ycpl_ast_expr_primary_nodes", project.expr_primary_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_identifier_nodes", project.expr_identifier_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_literal_nodes", project.expr_literal_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_string_nodes", project.expr_string_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_call_nodes", project.expr_call_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_member_nodes", project.expr_member_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_index_nodes", project.expr_index_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_binary_nodes", project.expr_binary_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_unary_nodes", project.expr_unary_nodes)
    b = emit_global_i32(b, "ycpl_ast_expr_table_digest", project.expr_table_digest)
    b = emit_global_i32(b, "ycpl_ast_expr_slot_count", project.expr_slot_count)
    b = emit_global_i32(b, "ycpl_ast_expr_nonempty_slots", project.expr_nonempty_slots)
    b = emit_global_i32(b, "ycpl_ast_expr_max_nodes_per_slot", project.expr_max_nodes_per_slot)
    b = emit_global_i32(b, "ycpl_ast_expr_slot_digest", project.expr_slot_digest)
    b = emit_global_i32(b, "ycpl_ast_symbol_digest", project.symbol_digest)
    b = emit_global_i32(b, "ycpl_ast_symbol_import_digest", project.symbol_import_digest)
    b = emit_global_i32(b, "ycpl_ast_symbol_module_digest", project.symbol_module_digest)
    b = emit_global_i32(b, "ycpl_ast_function_bodies", project.function_bodies)
    b = emit_global_i32(b, "ycpl_ast_function_body_tokens", project.function_body_tokens)
    b = emit_global_i32(b, "ycpl_ast_function_body_digest", project.function_body_digest)
    b = emit_global_i32(b, "ycpl_ast_body_node_count", project.body_node_count)
    b = emit_global_i32(b, "ycpl_ast_body_node_digest", project.body_node_digest)
    b = emit_global_i32(b, "ycpl_ast_body_transition_digest", project.body_transition_digest)
    b = emit_global_i32(b, "ycpl_ast_body_slot_count", project.body_slot_count)
    b = emit_global_i32(b, "ycpl_ast_body_nonempty_slots", project.body_nonempty_slots)
    b = emit_global_i32(b, "ycpl_ast_body_max_nodes_per_slot", project.body_max_nodes_per_slot)
    b = emit_global_i32(b, "ycpl_ast_body_slot_digest", project.body_slot_digest)
    b = emit_global_i32(b, "ycpl_ast_body_identifier_payloads", project.body_identifier_payloads)
    b = emit_global_i32(b, "ycpl_ast_body_literal_payloads", project.body_literal_payloads)
    b = emit_global_i32(b, "ycpl_ast_body_type_payloads", project.body_type_payloads)
    b = emit_global_i32(b, "ycpl_ast_body_control_payloads", project.body_control_payloads)
    b = emit_global_i32(b, "ycpl_ast_body_payload_digest", project.body_payload_digest)
    b = emit_global_i32(b, "ycpl_ast_body_local_symbol_refs", project.body_local_symbol_refs)
    b = emit_global_i32(b, "ycpl_ast_body_assignment_target_refs", project.body_assignment_target_refs)
    b = emit_global_i32(b, "ycpl_ast_body_call_target_refs", project.body_call_target_refs)
    b = emit_global_i32(b, "ycpl_ast_body_return_symbol_refs", project.body_return_symbol_refs)
    b = emit_global_i32(b, "ycpl_ast_body_return_literal_refs", project.body_return_literal_refs)
    b = emit_global_i32(b, "ycpl_ast_body_type_refs", project.body_type_refs)
    b = emit_global_i32(b, "ycpl_ast_body_control_refs", project.body_control_refs)
    b = emit_global_i32(b, "ycpl_ast_body_semantic_digest", project.body_semantic_digest)
    b = emit_global_i32(b, "ycpl_ast_body_if_nodes", project.body_if_nodes)
    b = emit_global_i32(b, "ycpl_ast_body_for_nodes", project.body_for_nodes)
    b = emit_global_i32(b, "ycpl_ast_return_exprs", project.return_exprs)
    b = emit_global_i32(b, "ycpl_ast_return_expr_digest", project.return_expr_digest)
    b = builder_text(b, "declare i32 @puts(ptr)\n")
    b = builder_text(b, "declare i32 @strcmp(ptr, ptr)\n")
    b = builder_text(b, "declare i32 @mkdir(ptr, i32)\n")
    b = builder_text(b, "declare i32 @snprintf(ptr, i64, ptr, ...)\n")
    b = builder_text(b, "declare ptr @fopen(ptr, ptr)\n")
    b = builder_text(b, "declare i32 @fputs(ptr, ptr)\n")
    b = builder_text(b, "declare i32 @fclose(ptr)\n")
    b = builder_text(b, "define i32 @ycpl_stage3_write_ir_text(ptr %outdir, ptr %irtext) {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %pathbuf = alloca [4096 x i8], align 1\n")
    b = builder_text(b, "  %path = getelementptr inbounds [4096 x i8], ptr %pathbuf, i32 0, i32 0\n")
    b = emit_string_ptr(b, "fmtpath", ".stage3.out.format", "%s/merged.ll")
    b = builder_text(b, "  %mk = call i32 @mkdir(ptr %outdir, i32 493)\n")
    b = builder_text(b, "  %n = call i32 (ptr, i64, ptr, ...) @snprintf(ptr %path, i64 4096, ptr %fmtpath, ptr %outdir)\n")
    b = emit_string_ptr(b, "wmode", ".stage3.write.mode", "w")
    b = builder_text(b, "  %file = call ptr @fopen(ptr %path, ptr %wmode)\n")
    b = builder_text(b, "  %isnull = icmp eq ptr %file, null\n")
    b = builder_text(b, "  br i1 %isnull, label %fail, label %write\n")
    b = builder_text(b, "write:\n")
    b = builder_text(b, "  %wrote = call i32 @fputs(ptr %irtext, ptr %file)\n")
    b = builder_text(b, "  %closed = call i32 @fclose(ptr %file)\n")
    b = emit_string_ptr(b, "okmsg", ".stage3.write.ok", "Wrote stage4 IR to stage output")
    b = builder_text(b, "  %printed = call i32 @puts(ptr %okmsg)\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "fail:\n")
    b = emit_string_ptr(b, "failmsg", ".stage3.write.fail", "failed to write stage4 IR")
    b = builder_text(b, "  %printedfail = call i32 @puts(ptr %failmsg)\n")
    b = builder_text(b, "  ret i32 1\n")
    b = builder_text(b, "}\n")
    b = builder_text(b, "define i32 @main(i32 %argc, ptr %argv) {\n")
    b = builder_text(b, "entry:\n")
    b = builder_text(b, "  %hasmode = icmp slt i32 %argc, 2\n")
    b = builder_text(b, "  br i1 %hasmode, label %smoke, label %dispatch\n")
    b = builder_text(b, "dispatch:\n")
    b = builder_text(b, "  %modeptrptr = getelementptr inbounds ptr, ptr %argv, i64 1\n")
    b = builder_text(b, "  %mode = load ptr, ptr %modeptrptr\n")
    b = emit_string_ptr(b, "parseptr", ".stage3.parse.mode", "parse")
    b = builder_text(b, "  %parsecmp = call i32 @strcmp(ptr %mode, ptr %parseptr)\n")
    b = builder_text(b, "  %isparse = icmp eq i32 %parsecmp, 0\n")
    b = builder_text(b, "  br i1 %isparse, label %parse, label %check_mode\n")
    b = builder_text(b, "parse:\n")
    b = emit_string_ptr(b, "parseline", ".stage3.parse.line", parse_line)
    b = builder_text(b, "  %parseprinted = call i32 @puts(ptr %parseline)\n")
    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "check_mode:\n")
    b = emit_string_ptr(b, "checkptr", ".stage3.check.mode", "check")
    b = builder_text(b, "  %checkcmp = call i32 @strcmp(ptr %mode, ptr %checkptr)\n")
    b = builder_text(b, "  %ischeck = icmp eq i32 %checkcmp, 0\n")
    b = builder_text(b, "  br i1 %ischeck, label %check, label %buildir_mode\n")
    b = builder_text(b, "check:\n")
    b = emit_string_ptr(b, "checkline", ".stage3.check.line", check_line)
    b = builder_text(b, "  %checkprinted = call i32 @puts(ptr %checkline)\n")
