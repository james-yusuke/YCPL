    line = builder_text(line, " sig_max_arity=")
    line = builder_i32(line, project.signature_max_arity)
    line = builder_text(line, " sig_returns=")
    line = builder_i32(line, project.signature_return_functions)
    line = builder_text(line, " sig_digest=")
    line = builder_i32(line, project.signature_digest)
    line = builder_text(line, " expr_nodes=")
    line = builder_i32(line, project.expr_table_nodes)
    line = builder_text(line, " expr_primary=")
    line = builder_i32(line, project.expr_primary_nodes)
    line = builder_text(line, " expr_ids=")
    line = builder_i32(line, project.expr_identifier_nodes)
    line = builder_text(line, " expr_literals=")
    line = builder_i32(line, project.expr_literal_nodes)
    line = builder_text(line, " expr_strings=")
    line = builder_i32(line, project.expr_string_nodes)
    line = builder_text(line, " expr_calls=")
    line = builder_i32(line, project.expr_call_nodes)
    line = builder_text(line, " expr_members=")
    line = builder_i32(line, project.expr_member_nodes)
    line = builder_text(line, " expr_indexes=")
    line = builder_i32(line, project.expr_index_nodes)
    line = builder_text(line, " expr_binary=")
    line = builder_i32(line, project.expr_binary_nodes)
    line = builder_text(line, " expr_unary=")
    line = builder_i32(line, project.expr_unary_nodes)
    line = builder_text(line, " expr_digest=")
    line = builder_i32(line, project.expr_table_digest)
    line = builder_text(line, " expr_slots=")
    line = builder_i32(line, project.expr_slot_count)
    line = builder_text(line, " expr_nonempty=")
    line = builder_i32(line, project.expr_nonempty_slots)
    line = builder_text(line, " expr_max_slot=")
    line = builder_i32(line, project.expr_max_nodes_per_slot)
    line = builder_text(line, " expr_slot_digest=")
    line = builder_i32(line, project.expr_slot_digest)
    line = builder_text(line, " stmt_expr_links=")
    line = builder_i32(line, project.stmt_expr_links)
    line = builder_text(line, " stmt_expr_tail=")
    line = builder_i32(line, project.stmt_expr_tail_nodes)
    line = builder_text(line, " stmt_expr_digest=")
    line = builder_i32(line, project.stmt_expr_digest)
    line = builder_text(line, " symbol_digest=")
    line = builder_i32(line, project.symbol_digest)
    line = builder_text(line, " import_digest=")
    line = builder_i32(line, project.symbol_import_digest)
    line = builder_text(line, " module_digest=")
    line = builder_i32(line, project.symbol_module_digest)
    line = builder_text(line, " bodies=")
    line = builder_i32(line, project.function_bodies)
    line = builder_text(line, " body_tokens=")
    line = builder_i32(line, project.function_body_tokens)
    line = builder_text(line, " body_nodes=")
    line = builder_i32(line, project.body_node_count)
    line = builder_text(line, " body_slots=")
    line = builder_i32(line, project.body_slot_count)
    line = builder_text(line, " body_nonempty=")
    line = builder_i32(line, project.body_nonempty_slots)
    line = builder_text(line, " body_max_nodes=")
    line = builder_i32(line, project.body_max_nodes_per_slot)
    line = builder_text(line, " body_slot_digest=")
    line = builder_i32(line, project.body_slot_digest)
    line = builder_text(line, " local_nodes=")
    line = builder_i32(line, project.body_local_nodes)
    line = builder_text(line, " assign_nodes=")
    line = builder_i32(line, project.body_assignment_nodes)
    line = builder_text(line, " call_nodes=")
    line = builder_i32(line, project.body_call_nodes)
    line = builder_text(line, " return_nodes=")
    line = builder_i32(line, project.body_return_nodes)
    line = builder_text(line, " if_nodes=")
    line = builder_i32(line, project.body_if_nodes)
    line = builder_text(line, " for_nodes=")
    line = builder_i32(line, project.body_for_nodes)
    line = builder_text(line, " transitions=")
    line = builder_i32(line, transitions)
    line = builder_text(line, " local_assign_edges=")
    line = builder_i32(line, project.body_local_assign_edges)
    line = builder_text(line, " assign_call_edges=")
    line = builder_i32(line, project.body_assign_call_edges)
    line = builder_text(line, " call_return_edges=")
    line = builder_i32(line, project.body_call_return_edges)
    line = builder_text(line, " return_local_edges=")
    line = builder_i32(line, project.body_return_local_edges)
    line = builder_text(line, " if_for_edges=")
    line = builder_i32(line, project.body_if_for_edges)
    line = builder_text(line, " for_return_edges=")
    line = builder_i32(line, project.body_for_return_edges)
    line = builder_text(line, " payload_ids=")
    line = builder_i32(line, project.body_identifier_payloads)
    line = builder_text(line, " payload_literals=")
    line = builder_i32(line, project.body_literal_payloads)
    line = builder_text(line, " payload_types=")
    line = builder_i32(line, project.body_type_payloads)
    line = builder_text(line, " payload_controls=")
    line = builder_i32(line, project.body_control_payloads)
    line = builder_text(line, " payload_digest=")
    line = builder_i32(line, project.body_payload_digest)
    line = builder_text(line, " local_symbols=")
    line = builder_i32(line, project.body_local_symbol_refs)
    line = builder_text(line, " assignment_targets=")
    line = builder_i32(line, project.body_assignment_target_refs)
    line = builder_text(line, " call_targets=")
    line = builder_i32(line, project.body_call_target_refs)
    line = builder_text(line, " return_symbols=")
    line = builder_i32(line, project.body_return_symbol_refs)
    line = builder_text(line, " return_literals=")
    line = builder_i32(line, project.body_return_literal_refs)
    line = builder_text(line, " type_refs=")
    line = builder_i32(line, project.body_type_refs)
    line = builder_text(line, " control_refs=")
    line = builder_i32(line, project.body_control_refs)
    line = builder_text(line, " semantic_digest=")
    line = builder_i32(line, project.body_semantic_digest)
    line = builder_text(line, " calls=")
    line = builder_i32(line, project.calls)
    line = builder_text(line, " branches=")
    line = builder_i32(line, project.branches)
    line = builder_text(line, " loops=")
    line = builder_i32(line, project.loops)
    line = builder_text(line, " return_exprs=")
    line = builder_i32(line, project.return_exprs)
    line = builder_text(line, " return_calls=")
    line = builder_i32(line, project.return_call_exprs)
    line = builder_text(line, " digest=")
    line = builder_i32(line, project.digest)
    line = builder_text(line, " fn_digest=")
    line = builder_i32(line, project.function_name_digest)
    line = builder_text(line, " body_digest=")
    line = builder_i32(line, project.function_body_digest)
    line = builder_text(line, " node_digest=")
    line = builder_i32(line, project.body_node_digest)
    line = builder_text(line, " transition_digest=")
    line = builder_i32(line, project.body_transition_digest)
    line = builder_text(line, " ret_digest=")
    line = builder_i32(line, project.return_expr_digest)
    line = builder_text(line, " main=")
    line = builder_i32(line, main_value)
    return line.data
}

fn emit_project_ir_text(project ProjectResult) TextBuilder {
    b := builder_new(536870912)
    parse_line := project_parse_line(project)
    check_line := project_check_line(project)
    stage_ir := stage3_ir_text(project)
    tiny42_ir := tiny42_ir_text()
    tiny13_ir := tiny13_ir_text()
    tinycall_ir := tiny_call13_ir_text()
    tinyparam_ir := tiny_param13_ir_text()
    tinychain_ir := tiny_chain13_ir_text()
    tinytwoarg_ir := tiny_two_arg13_ir_text()
    tinycontrol_ir := tiny_control13_ir_text()
    tinyelse_ir := tiny_else13_ir_text()
    tinybool_ir := tiny_bool13_ir_text()
    tinyboolhelper_ir := tiny_bool_helper13_ir_text()
    tinyarray_ir := tiny_array13_ir_text()
    tinystring_ir := tiny_string13_ir_text()
    tinyexternstring_ir := tiny_extern_string13_ir_text()
    tinyexternmalloc_ir := tiny_extern_malloc13_ir_text()
    tinyllvmcapi_ir := tiny_llvm_c_api13_ir_text()
    tinyvoidextern_ir := tiny_void_extern13_ir_text()
    tinyllvmfunctiontype_ir := tiny_llvm_function_type13_ir_text()
    tinyllvmbuildermemory_ir := tiny_llvm_builder_memory13_ir_text()
    tinyllvmcall2icmp_ir := tiny_llvm_call2_icmp13_ir_text()
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes
    expr_lowered_floor := stage_expr_lowered_floor(project)

    b = builder_text(b, "; YCPL selfhost AST-to-LLVM IR\n")
    b = builder_text(b, "; generated by compiler/ycpl without bootstrap fallback\n")
    b = emit_string_global(b, ".ycpl.selfhost.message", "YCPL selfhost AST IR")
    b = emit_string_global(b, ".ycpl.usage", "usage: ycc-ycpl <lex|parse|check|build-ir|build> <file.yc|dir> [-o dir]")
    b = emit_string_global(b, ".ycpl.parse.mode", "parse")
    b = emit_string_global(b, ".ycpl.check.mode", "check")
    b = emit_string_global(b, ".ycpl.buildir.mode", "build-ir")
    b = emit_string_global(b, ".ycpl.build.mode", "build")
    b = emit_string_global(b, ".ycpl.ll.mode", "ll")
    b = emit_string_global(b, ".ycpl.read.mode", "r")
    b = emit_string_global(b, ".ycpl.project.pattern", "compiler/ycpl")
    b = emit_dynamic_return_globals(b, ".ycpl.dynamic.return.pattern", ".ycpl.dynamic.return.format")
    b = emit_dynamic_local_return_globals(b, ".ycpl.dynamic.local.assign.pattern", ".ycpl.dynamic.local.return.pattern", ".ycpl.dynamic.local.format")
    b = emit_dynamic_assignment_return_globals(b, ".ycpl.dynamic.assignment.decl.pattern", ".ycpl.dynamic.assignment.assign.pattern", ".ycpl.dynamic.assignment.return.pattern", ".ycpl.dynamic.assignment.format")
    b = emit_dynamic_binary_add_return_globals(b, ".ycpl.dynamic.binary.left.pattern", ".ycpl.dynamic.binary.right.pattern", ".ycpl.dynamic.binary.return.pattern", ".ycpl.dynamic.binary.format")
    b = emit_dynamic_compare_if_return_globals(b, ".ycpl.dynamic.compare.left.pattern", ".ycpl.dynamic.compare.right.pattern", ".ycpl.dynamic.compare.if.pattern", ".ycpl.dynamic.compare.return.pattern", ".ycpl.dynamic.compare.format")
    b = emit_dynamic_zero_call_globals(b, ".ycpl.dynamic.zero.call.pattern", ".ycpl.dynamic.zero.return.pattern", ".ycpl.dynamic.zero.call.format")
    b = emit_dynamic_if_return_globals(b, ".ycpl.dynamic.if.decl.pattern", ".ycpl.dynamic.if.pattern", ".ycpl.dynamic.if.return.pattern", ".ycpl.dynamic.if.format")
    b = emit_dynamic_for_return_globals(b, ".ycpl.dynamic.for.sum.pattern", ".ycpl.dynamic.for.limit.pattern", ".ycpl.dynamic.for.add.pattern", ".ycpl.dynamic.for.return.pattern", ".ycpl.dynamic.for.format")
    b = emit_string_global(b, ".ycpl.tinyllvmcall2icmp.pattern", "LLVMBuildCall2")
    b = emit_string_global(b, ".ycpl.tinyllvmbuildermemory.pattern", "LLVMBuildAlloca")
    b = emit_string_global(b, ".ycpl.tinyllvmfunctiontype.pattern", "LLVMFunctionType")
    b = emit_string_global(b, ".ycpl.tinyvoidextern.pattern", "LLVMContextDispose")
    b = emit_string_global(b, ".ycpl.tinyllvmcapi.pattern", "LLVMModuleCreateWithNameInContext")
    b = emit_string_global(b, ".ycpl.tinyexternmalloc.pattern", "c_malloc")
    b = emit_string_global(b, ".ycpl.tinyexternstring.pattern", "c_strcmp")
    b = emit_string_global(b, ".ycpl.tinystring.pattern", "message: string")
    b = emit_string_global(b, ".ycpl.tinyarray.pattern", "items := [4, 2, 7]")
    b = emit_string_global(b, ".ycpl.tinyboolhelper.pattern", "ready()")
    b = emit_string_global(b, ".ycpl.tinybool.pattern", "flag: bool")
    b = emit_string_global(b, ".ycpl.tinyelse.pattern", "base()")
    b = emit_string_global(b, ".ycpl.tinycontrol.pattern", "total == 0")
    b = emit_string_global(b, ".ycpl.tinychain.pattern", "bump(")
    b = emit_string_global(b, ".ycpl.tinytwoarg.pattern", "add_pair(")
    b = emit_string_global(b, ".ycpl.tinyparam.pattern", "inc(")
    b = emit_string_global(b, ".ycpl.tinycall.pattern", "x := seed()")
    b = emit_string_global(b, ".ycpl.tiny42.pattern", "return 42")
    b = emit_string_global(b, ".ycpl.tiny13.pattern", "return x - 1")
    b = emit_string_global(b, ".ycpl.parse.line", parse_line)
    b = emit_string_global(b, ".ycpl.check.line", check_line)
    b = emit_string_global(b, ".ycpl.write.ok", "Wrote IR to stage output")
    b = emit_string_global(b, ".ycpl.write.fail", "failed to write stage IR")
    b = emit_string_global(b, ".ycpl.native.ok", "Wrote native stage output")
    b = emit_string_global(b, ".ycpl.native.fail", "failed to build native stage output")
    b = emit_string_global(b, ".ycpl.default.out", ".")
    b = emit_string_global(b, ".ycpl.out.format", "%s/merged.ll")
    b = emit_string_global(b, ".ycpl.env.llc", "LLC")
    b = emit_string_global(b, ".ycpl.env.clang", "CLANG")
    b = emit_string_global(b, ".ycpl.env.bindir", "LLVM_BINDIR")
    b = emit_string_global(b, ".ycpl.default.llc", llvm_tool_default_command("llc"))
    b = emit_string_global(b, ".ycpl.default.clang", llvm_tool_default_command("clang"))
    b = emit_string_global(b, ".ycpl.llc.format", "%s -filetype=obj %s/merged.ll -o %s/merged.o")
    b = emit_string_global(b, ".ycpl.llc.bindir.format", "%s/llc -filetype=obj %s/merged.ll -o %s/merged.o")
    b = emit_string_global(b, ".ycpl.clang.format", "%s %s/merged.o -o %s/merged")
    b = emit_string_global(b, ".ycpl.clang.bindir.format", "%s/clang %s/merged.o -o %s/merged")
    b = emit_string_global(b, ".ycpl.write.mode", "w")
    b = emit_string_global(b, ".ycpl.stage.ir", stage_ir)
    b = emit_string_global(b, ".ycpl.tinyllvmcall2icmp.ir", tinyllvmcall2icmp_ir)
    b = emit_string_global(b, ".ycpl.tinyllvmbuildermemory.ir", tinyllvmbuildermemory_ir)
    b = emit_string_global(b, ".ycpl.tinyllvmfunctiontype.ir", tinyllvmfunctiontype_ir)
    b = emit_string_global(b, ".ycpl.tinyvoidextern.ir", tinyvoidextern_ir)
    b = emit_string_global(b, ".ycpl.tinyllvmcapi.ir", tinyllvmcapi_ir)
    b = emit_string_global(b, ".ycpl.tinyexternmalloc.ir", tinyexternmalloc_ir)
    b = emit_string_global(b, ".ycpl.tinyexternstring.ir", tinyexternstring_ir)
    b = emit_string_global(b, ".ycpl.tinystring.ir", tinystring_ir)
    b = emit_string_global(b, ".ycpl.tinyarray.ir", tinyarray_ir)
    b = emit_string_global(b, ".ycpl.tinyboolhelper.ir", tinyboolhelper_ir)
    b = emit_string_global(b, ".ycpl.tinybool.ir", tinybool_ir)
    b = emit_string_global(b, ".ycpl.tinyelse.ir", tinyelse_ir)
    b = emit_string_global(b, ".ycpl.tinycontrol.ir", tinycontrol_ir)
    b = emit_string_global(b, ".ycpl.tinychain.ir", tinychain_ir)
    b = emit_string_global(b, ".ycpl.tinytwoarg.ir", tinytwoarg_ir)
    b = emit_string_global(b, ".ycpl.tinyparam.ir", tinyparam_ir)
    b = emit_string_global(b, ".ycpl.tinycall.ir", tinycall_ir)
    b = emit_string_global(b, ".ycpl.tiny42.ir", tiny42_ir)
    b = emit_string_global(b, ".ycpl.tiny13.ir", tiny13_ir)
    b = emit_global_i32(b, "ycpl_ast_files", project.files)
    b = emit_global_i32(b, "ycpl_ast_nodes", project.nodes)
    b = emit_global_i32(b, "ycpl_ast_typed_nodes", typed_nodes)
    b = emit_global_i32(b, "ycpl_ast_typed_decl_nodes", project.typed_decl_nodes)
    b = emit_global_i32(b, "ycpl_ast_typed_stmt_nodes", project.typed_stmt_nodes)
    b = emit_global_i32(b, "ycpl_ast_typed_expr_nodes", project.typed_expr_nodes)
    b = emit_global_i32(b, "ycpl_ast_typed_type_nodes", project.typed_type_nodes)
    b = emit_global_i32(b, "ycpl_ast_typed_digest", project.typed_digest)
    b = emit_global_i32(b, "ycpl_ast_functions", project.functions)
    b = emit_global_i32(b, "ycpl_ast_structs", project.structs)
    b = emit_global_i32(b, "ycpl_ast_imports", project.imports)
    b = emit_global_i32(b, "ycpl_ast_symbol_functions", project.symbol_functions)
    b = emit_global_i32(b, "ycpl_ast_symbol_structs", project.symbol_structs)
    b = emit_global_i32(b, "ycpl_ast_symbol_imports", project.symbol_imports)
    b = emit_global_i32(b, "ycpl_ast_symbol_std_imports", project.symbol_std_imports)
    b = emit_global_i32(b, "ycpl_ast_symbol_import_aliases", project.symbol_import_aliases)
    b = emit_global_i32(b, "ycpl_ast_symbol_public", project.symbol_public)
