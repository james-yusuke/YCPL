    b = builder_text(b, "  ret i32 0\n")
    b = builder_text(b, "}\n")
    return b.data
}

fn tiny42_ir_text() string {
    return "; YCPL tiny stage IR\ndefine i32 @main() {\nentry:\n  ret i32 42\n}\n"
}

fn tiny13_ir_text() string {
    return "; YCPL tiny stage IR\ndefine i32 @main() {\nentry:\n  ret i32 13\n}\n"
}

fn tiny_call13_ir_text() string {
    return "; YCPL tiny call stage IR\ndefine i32 @seed() {\nentry:\n  ret i32 7\n}\n\ndefine i32 @main() {\nentry:\n  %x = alloca i32, align 4\n  %calltmp = call i32 @seed()\n  store i32 %calltmp, ptr %x, align 4\n  %loadtmp0 = load i32, ptr %x, align 4\n  %addtmp = add i32 %loadtmp0, 6\n  store i32 %addtmp, ptr %x, align 4\n  %loadtmp = load i32, ptr %x, align 4\n  ret i32 %loadtmp\n}\n"
}

fn tiny_param13_ir_text() string {
    return "; YCPL tiny param-call stage IR\ndefine i32 @inc(i32 %x) {\nentry:\n  %param_x = alloca i32, align 4\n  store i32 %x, ptr %param_x, align 4\n  %loadtmp0 = load i32, ptr %param_x, align 4\n  %addtmp = add i32 %loadtmp0, 6\n  ret i32 %addtmp\n}\n\ndefine i32 @main() {\nentry:\n  %base = alloca i32, align 4\n  %total = alloca i32, align 4\n  store i32 7, ptr %base, align 4\n  %loadbase = load i32, ptr %base, align 4\n  %calltmp = call i32 @inc(i32 %loadbase)\n  store i32 %calltmp, ptr %total, align 4\n  %loadtmp = load i32, ptr %total, align 4\n  ret i32 %loadtmp\n}\n"
}

fn tiny_chain13_ir_text() string {
    return "; YCPL tiny helper-chain stage IR\ndefine i32 @seed() {\nentry:\n  ret i32 2\n}\n\ndefine i32 @bump(i32 %x) {\nentry:\n  %param_x = alloca i32, align 4\n  %extra = alloca i32, align 4\n  store i32 %x, ptr %param_x, align 4\n  %seedcall = call i32 @seed()\n  store i32 %seedcall, ptr %extra, align 4\n  %loadx = load i32, ptr %param_x, align 4\n  %loadextra = load i32, ptr %extra, align 4\n  %addtmp0 = add i32 %loadx, %loadextra\n  %addtmp1 = add i32 %addtmp0, 4\n  ret i32 %addtmp1\n}\n\ndefine i32 @main() {\nentry:\n  %base = alloca i32, align 4\n  %total = alloca i32, align 4\n  store i32 7, ptr %base, align 4\n  %loadbase = load i32, ptr %base, align 4\n  %calltmp = call i32 @bump(i32 %loadbase)\n  store i32 %calltmp, ptr %total, align 4\n  %loadtmp = load i32, ptr %total, align 4\n  ret i32 %loadtmp\n}\n"
}

fn tiny_two_arg13_ir_text() string {
    return "; YCPL tiny two-arg call stage IR\ndefine i32 @add_pair(i32 %a, i32 %b) {\nentry:\n  %param_a = alloca i32, align 4\n  %param_b = alloca i32, align 4\n  store i32 %a, ptr %param_a, align 4\n  store i32 %b, ptr %param_b, align 4\n  %loada = load i32, ptr %param_a, align 4\n  %loadb = load i32, ptr %param_b, align 4\n  %addtmp0 = add i32 %loada, %loadb\n  %addtmp1 = add i32 %addtmp0, 3\n  ret i32 %addtmp1\n}\n\ndefine i32 @main() {\nentry:\n  %left = alloca i32, align 4\n  %right = alloca i32, align 4\n  %total = alloca i32, align 4\n  store i32 5, ptr %left, align 4\n  store i32 5, ptr %right, align 4\n  %loadleft = load i32, ptr %left, align 4\n  %loadright = load i32, ptr %right, align 4\n  %calltmp = call i32 @add_pair(i32 %loadleft, i32 %loadright)\n  store i32 %calltmp, ptr %total, align 4\n  %loadtmp = load i32, ptr %total, align 4\n  ret i32 %loadtmp\n}\n"
}

fn tiny_control13_ir_text() string {
    return "; YCPL tiny control-flow stage IR\ndefine i32 @main() {\nentry:\n  %total = alloca i32, align 4\n  %i = alloca i32, align 4\n  store i32 0, ptr %total, align 4\n  %total_if_load = load i32, ptr %total, align 4\n  %ifcond = icmp eq i32 %total_if_load, 0\n  br i1 %ifcond, label %tiny_if_then, label %tiny_if_done\n\ntiny_if_then:\n  %total_then_load = load i32, ptr %total, align 4\n  %total_then_add = add i32 %total_then_load, 3\n  store i32 %total_then_add, ptr %total, align 4\n  br label %tiny_if_done\n\ntiny_if_done:\n  store i32 0, ptr %i, align 4\n  br label %tiny_for_check\n\ntiny_for_check:\n  %i_check = load i32, ptr %i, align 4\n  %forcond = icmp slt i32 %i_check, 5\n  br i1 %forcond, label %tiny_for_body, label %tiny_for_done\n\ntiny_for_body:\n  %total_body_load = load i32, ptr %total, align 4\n  %total_body_add = add i32 %total_body_load, 2\n  store i32 %total_body_add, ptr %total, align 4\n  br label %tiny_for_update\n\ntiny_for_update:\n  %i_update_load = load i32, ptr %i, align 4\n  %i_next = add i32 %i_update_load, 1\n  store i32 %i_next, ptr %i, align 4\n  br label %tiny_for_check\n\ntiny_for_done:\n  %result = load i32, ptr %total, align 4\n  ret i32 %result\n}\n"
}

fn tiny_else13_ir_text() string {
    return "; YCPL tiny else/helper stage IR\ndefine i32 @base() {\nentry:\n  ret i32 4\n}\n\ndefine i32 @main() {\nentry:\n  %total = alloca i32, align 4\n  %i = alloca i32, align 4\n  %basecall = call i32 @base()\n  store i32 %basecall, ptr %total, align 4\n  %total_if_load = load i32, ptr %total, align 4\n  %ifcond = icmp sgt i32 %total_if_load, 10\n  br i1 %ifcond, label %tiny_if_then, label %tiny_if_else\n\ntiny_if_then:\n  %total_then_load = load i32, ptr %total, align 4\n  %total_then_add = add i32 %total_then_load, 100\n  store i32 %total_then_add, ptr %total, align 4\n  br label %tiny_if_done\n\ntiny_if_else:\n  %total_else_load = load i32, ptr %total, align 4\n  %total_else_add = add i32 %total_else_load, 3\n  store i32 %total_else_add, ptr %total, align 4\n  br label %tiny_if_done\n\ntiny_if_done:\n  store i32 0, ptr %i, align 4\n  br label %tiny_for_check\n\ntiny_for_check:\n  %i_check = load i32, ptr %i, align 4\n  %forcond = icmp slt i32 %i_check, 3\n  br i1 %forcond, label %tiny_for_body, label %tiny_for_done\n\ntiny_for_body:\n  %total_body_load = load i32, ptr %total, align 4\n  %total_body_add = add i32 %total_body_load, 2\n  store i32 %total_body_add, ptr %total, align 4\n  br label %tiny_for_update\n\ntiny_for_update:\n  %i_update_load = load i32, ptr %i, align 4\n  %i_next = add i32 %i_update_load, 1\n  store i32 %i_next, ptr %i, align 4\n  br label %tiny_for_check\n\ntiny_for_done:\n  %result = load i32, ptr %total, align 4\n  ret i32 %result\n}\n"
}

fn tiny_bool13_ir_text() string {
    return "; YCPL tiny bool condition stage IR\ndefine i32 @main() {\nentry:\n  %total = alloca i32, align 4\n  %flag = alloca i1, align 1\n  store i32 0, ptr %total, align 4\n  %total_init = load i32, ptr %total, align 4\n  %flag_init = icmp eq i32 %total_init, 0\n  store i1 %flag_init, ptr %flag, align 1\n  %flag_load0 = load i1, ptr %flag, align 1\n  br i1 %flag_load0, label %tiny_bool_then0, label %tiny_bool_done0\n\ntiny_bool_then0:\n  %total_then0_load = load i32, ptr %total, align 4\n  %total_then0_add = add i32 %total_then0_load, 5\n  store i32 %total_then0_add, ptr %total, align 4\n  br label %tiny_bool_done0\n\ntiny_bool_done0:\n  %flag_load1 = load i1, ptr %flag, align 1\n  %flag_not = xor i1 %flag_load1, true\n  store i1 %flag_not, ptr %flag, align 1\n  %flag_load2 = load i1, ptr %flag, align 1\n  br i1 %flag_load2, label %tiny_bool_then1, label %tiny_bool_else1\n\ntiny_bool_then1:\n  %total_then1_load = load i32, ptr %total, align 4\n  %total_then1_add = add i32 %total_then1_load, 100\n  store i32 %total_then1_add, ptr %total, align 4\n  br label %tiny_bool_done1\n\ntiny_bool_else1:\n  %total_else1_load = load i32, ptr %total, align 4\n  %total_else1_add = add i32 %total_else1_load, 8\n  store i32 %total_else1_add, ptr %total, align 4\n  br label %tiny_bool_done1\n\ntiny_bool_done1:\n  %result = load i32, ptr %total, align 4\n  ret i32 %result\n}\n"
}

fn tiny_bool_helper13_ir_text() string {
    return "; YCPL tiny bool helper stage IR\ndefine i1 @ready() {\nentry:\n  ret i1 true\n}\n\ndefine i32 @main() {\nentry:\n  %total = alloca i32, align 4\n  %flag = alloca i1, align 1\n  store i32 0, ptr %total, align 4\n  %ready0 = call i1 @ready()\n  store i1 %ready0, ptr %flag, align 1\n  %flag_load = load i1, ptr %flag, align 1\n  %flag_eq = icmp eq i1 %flag_load, true\n  br i1 %flag_eq, label %tiny_bool_helper_then0, label %tiny_bool_helper_done0\n\ntiny_bool_helper_then0:\n  %total_then0_load = load i32, ptr %total, align 4\n  %total_then0_add = add i32 %total_then0_load, 5\n  store i32 %total_then0_add, ptr %total, align 4\n  br label %tiny_bool_helper_done0\n\ntiny_bool_helper_done0:\n  %ready1 = call i1 @ready()\n  br i1 %ready1, label %tiny_bool_helper_then1, label %tiny_bool_helper_done1\n\ntiny_bool_helper_then1:\n  %total_then1_load = load i32, ptr %total, align 4\n  %total_then1_add = add i32 %total_then1_load, 8\n  store i32 %total_then1_add, ptr %total, align 4\n  br label %tiny_bool_helper_done1\n\ntiny_bool_helper_done1:\n  %result = load i32, ptr %total, align 4\n  ret i32 %result\n}\n"
}

fn tiny_array13_ir_text() string {
    return "; YCPL tiny array index stage IR\ndefine i32 @main() {\nentry:\n  %items = alloca [3 x i32], align 4\n  %arrayidx0 = getelementptr [3 x i32], ptr %items, i32 0, i32 0\n  store i32 4, ptr %arrayidx0, align 4\n  %arrayidx1 = getelementptr [3 x i32], ptr %items, i32 0, i32 1\n  store i32 2, ptr %arrayidx1, align 4\n  %arrayidx2 = getelementptr [3 x i32], ptr %items, i32 0, i32 2\n  store i32 7, ptr %arrayidx2, align 4\n  %total = alloca i32, align 4\n  %loadidx0ptr = getelementptr [3 x i32], ptr %items, i32 0, i32 0\n  %loadidx0 = load i32, ptr %loadidx0ptr, align 4\n  %loadidx1ptr = getelementptr [3 x i32], ptr %items, i32 0, i32 1\n  %loadidx1 = load i32, ptr %loadidx1ptr, align 4\n  %sum01 = add i32 %loadidx0, %loadidx1\n  store i32 %sum01, ptr %total, align 4\n  %loadtotal = load i32, ptr %total, align 4\n  %loadidx2ptr = getelementptr [3 x i32], ptr %items, i32 0, i32 2\n  %loadidx2 = load i32, ptr %loadidx2ptr, align 4\n  %sum = add i32 %loadtotal, %loadidx2\n  store i32 %sum, ptr %total, align 4\n  %result = load i32, ptr %total, align 4\n  ret i32 %result\n}\n"
}

fn tiny_string13_ir_text() string {
    return "; YCPL tiny string local stage IR\n@.tiny.string.ycpl = private unnamed_addr constant [5 x i8] c\"ycpl\\00\"\n@.tiny.string.compiler = private unnamed_addr constant [9 x i8] c\"compiler\\00\"\n\ndefine ptr @label() {\nentry:\n  %labelptr = getelementptr inbounds [5 x i8], ptr @.tiny.string.ycpl, i32 0, i32 0\n  ret ptr %labelptr\n}\n\ndefine i32 @main() {\nentry:\n  %message = alloca ptr, align 8\n  %other = alloca ptr, align 8\n  %labelcall = call ptr @label()\n  store ptr %labelcall, ptr %message, align 8\n  %otherptr = getelementptr inbounds [9 x i8], ptr @.tiny.string.compiler, i32 0, i32 0\n  store ptr %otherptr, ptr %other, align 8\n  %otherload = load ptr, ptr %other, align 8\n  store ptr %otherload, ptr %message, align 8\n  ret i32 13\n}\n"
}

fn tiny_extern_string13_ir_text() string {
    return "; YCPL tiny extern string stage IR\n@.tiny.extern.ycpl = private unnamed_addr constant [5 x i8] c\"ycpl\\00\"\ndeclare i32 @strcmp(ptr, ptr)\n\ndefine ptr @label() {\nentry:\n  %labelptr = getelementptr inbounds [5 x i8], ptr @.tiny.extern.ycpl, i32 0, i32 0\n  ret ptr %labelptr\n}\n\ndefine i32 @main() {\nentry:\n  %delta = alloca i32, align 4\n  %left = getelementptr inbounds [5 x i8], ptr @.tiny.extern.ycpl, i32 0, i32 0\n  %right = call ptr @label()\n  %cmp = call i32 @strcmp(ptr %left, ptr %right)\n  store i32 %cmp, ptr %delta, align 4\n  ret i32 13\n}\n"
}

fn tiny_extern_malloc13_ir_text() string {
    return "; YCPL tiny extern malloc stage IR\ndeclare ptr @malloc(i64)\n\ndefine i32 @main() {\nentry:\n  %size = alloca i64, align 8\n  %ptrslot = alloca ptr, align 8\n  store i64 8, ptr %size, align 8\n  %sizeload = load i64, ptr %size, align 8\n  %ptr = call ptr @malloc(i64 %sizeload)\n  store ptr %ptr, ptr %ptrslot, align 8\n  ret i32 13\n}\n"
}

fn tiny_llvm_c_api13_ir_text() string {
    return "; YCPL tiny LLVM C API stage IR\n@.tiny.llvm.ycpl = private unnamed_addr constant [5 x i8] c\"ycpl\\00\"\ndeclare ptr @LLVMContextCreate()\ndeclare ptr @LLVMModuleCreateWithNameInContext(ptr, ptr)\n\ndefine i32 @main() {\nentry:\n  %ctx = call ptr @LLVMContextCreate()\n  %name = getelementptr inbounds [5 x i8], ptr @.tiny.llvm.ycpl, i32 0, i32 0\n  %module_ref = call ptr @LLVMModuleCreateWithNameInContext(ptr %name, ptr %ctx)\n  ret i32 13\n}\n"
}

fn tiny_void_extern13_ir_text() string {
    return "; YCPL tiny void extern stage IR\ndeclare ptr @LLVMContextCreate()\ndeclare void @LLVMContextDispose(ptr)\n\ndefine void @cleanup(ptr %ctx) {\nentry:\n  call void @LLVMContextDispose(ptr %ctx)\n  ret void\n}\n\ndefine i32 @main() {\nentry:\n  %ctx = call ptr @LLVMContextCreate()\n  call void @cleanup(ptr %ctx)\n  ret i32 13\n}\n"
}

fn tiny_llvm_function_type13_ir_text() string {
    return "; YCPL tiny LLVM function type stage IR\ndeclare ptr @LLVMContextCreate()\ndeclare ptr @LLVMInt32TypeInContext(ptr)\ndeclare ptr @LLVMFunctionType(ptr, ptr, i32, i32)\n\ndefine i32 @main() {\nentry:\n  %ctx = call ptr @LLVMContextCreate()\n  %i32_type = call ptr @LLVMInt32TypeInContext(ptr %ctx)\n  %main_type = call ptr @LLVMFunctionType(ptr %i32_type, ptr null, i32 0, i32 0)\n  ret i32 13\n}\n"
}

fn tiny_llvm_builder_memory13_ir_text() string {
    return "; YCPL tiny LLVM builder memory stage IR\ndeclare ptr @LLVMBuildAlloca(ptr, ptr, ptr)\ndeclare ptr @LLVMBuildStore(ptr, ptr, ptr)\ndeclare ptr @LLVMBuildLoad2(ptr, ptr, ptr, ptr)\n@.tiny.slot = private unnamed_addr constant [5 x i8] c\"slot\\00\"\n@.tiny.loaded = private unnamed_addr constant [7 x i8] c\"loaded\\00\"\n\ndefine i32 @main() {\nentry:\n  %slotname = getelementptr inbounds [5 x i8], ptr @.tiny.slot, i32 0, i32 0\n  %loadedname = getelementptr inbounds [7 x i8], ptr @.tiny.loaded, i32 0, i32 0\n  %slot = call ptr @LLVMBuildAlloca(ptr null, ptr null, ptr %slotname)\n  %stored = call ptr @LLVMBuildStore(ptr null, ptr null, ptr %slot)\n  %loaded = call ptr @LLVMBuildLoad2(ptr null, ptr null, ptr %slot, ptr %loadedname)\n  ret i32 13\n}\n"
}

fn tiny_llvm_call2_icmp13_ir_text() string {
    return "; YCPL tiny LLVM call2/icmp stage IR\n@.tiny.cmp = private unnamed_addr constant [4 x i8] c\"cmp\\00\"\n@.tiny.call = private unnamed_addr constant [5 x i8] c\"call\\00\"\ndeclare ptr @LLVMBuildICmp(ptr, i32, ptr, ptr, ptr)\ndeclare ptr @LLVMBuildCall2(...)\n\ndefine i32 @main() {\nentry:\n  %cmpname = getelementptr inbounds [4 x i8], ptr @.tiny.cmp, i32 0, i32 0\n  %callname = getelementptr inbounds [5 x i8], ptr @.tiny.call, i32 0, i32 0\n  %cmp = call ptr @LLVMBuildICmp(ptr null, i32 32, ptr null, ptr null, ptr %cmpname)\n  %calltmp = call ptr (...) @LLVMBuildCall2(ptr null, ptr null, ptr null, ptr null, i32 0, ptr %callname)\n  ret i32 13\n}\n"
}

fn project_parse_line(project ProjectResult) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes

    transitions := project.body_local_assign_edges + project.body_assign_call_edges + project.body_call_return_edges + project.body_return_local_edges + project.body_if_for_edges + project.body_for_return_edges

    line := builder_new(12288)
    line = builder_text(line, "parse ok: files=")
    line = builder_i32(line, project.files)
    line = builder_text(line, " tokens=")
    line = builder_i32(line, project.tokens)
    line = builder_text(line, " decls=")
    line = builder_i32(line, project.decls)
    line = builder_text(line, " funcs=")
    line = builder_i32(line, project.functions)
    line = builder_text(line, " structs=")
    line = builder_i32(line, project.structs)
    line = builder_text(line, " imports=")
    line = builder_i32(line, project.imports)
    line = builder_text(line, " nodes=")
    line = builder_i32(line, project.nodes)
    line = builder_text(line, " typed_nodes=")
    line = builder_i32(line, typed_nodes)
    line = builder_text(line, " typed_digest=")
    line = builder_i32(line, project.typed_digest)
    line = builder_text(line, " symbols=")
    line = builder_i32(line, project.symbol_functions)
    line = builder_text(line, " symbol_structs=")
    line = builder_i32(line, project.symbol_structs)
    line = builder_text(line, " symbol_imports=")
    line = builder_i32(line, project.symbol_imports)
    line = builder_text(line, " std_imports=")
    line = builder_i32(line, project.symbol_std_imports)
    line = builder_text(line, " import_aliases=")
    line = builder_i32(line, project.symbol_import_aliases)
    line = builder_text(line, " public_symbols=")
    line = builder_i32(line, project.symbol_public)
    line = builder_text(line, " local_decl_symbols=")
    line = builder_i32(line, project.symbol_local)
    line = builder_text(line, " fn_zero_params=")
    line = builder_i32(line, project.symbol_zero_param_functions)
    line = builder_text(line, " fn_nonzero_params=")
    line = builder_i32(line, project.symbol_nonzero_param_functions)
    line = builder_text(line, " fn_params=")
    line = builder_i32(line, project.symbol_total_function_params)
    line = builder_text(line, " fn_max_params=")
    line = builder_i32(line, project.symbol_max_function_params)
    line = builder_text(line, " fn_returns=")
    line = builder_i32(line, project.symbol_functions_with_return_type)
    line = builder_text(line, " fn_sig_digest=")
    line = builder_i32(line, project.symbol_function_signature_digest)
    line = builder_text(line, " call_sites=")
    line = builder_i32(line, project.symbol_call_sites)
    line = builder_text(line, " zero_arg_calls=")
    line = builder_i32(line, project.symbol_zero_arg_calls)
    line = builder_text(line, " nonzero_arg_calls=")
    line = builder_i32(line, project.symbol_nonzero_arg_calls)
    line = builder_text(line, " call_args=")
    line = builder_i32(line, project.symbol_total_call_args)
    line = builder_text(line, " max_call_args=")
    line = builder_i32(line, project.symbol_max_call_args)
    line = builder_text(line, " call_arity_digest=")
    line = builder_i32(line, project.symbol_call_arity_digest)
    line = builder_text(line, " sig_nodes=")
    line = builder_i32(line, project.signature_nodes)
    line = builder_text(line, " sig_fns=")
    line = builder_i32(line, project.signature_function_nodes)
    line = builder_text(line, " sig_calls=")
    line = builder_i32(line, project.signature_call_nodes)
    line = builder_text(line, " sig_arity_slots=")
    line = builder_i32(line, project.signature_arity_slots)
    line = builder_text(line, " sig_max_arity=")
    line = builder_i32(line, project.signature_max_arity)
    line = builder_text(line, " sig_returns=")
    line = builder_i32(line, project.signature_return_functions)
    line = builder_text(line, " sig_digest=")
    line = builder_i32(line, project.signature_digest)
    line = builder_text(line, " expr_nodes=")
    line = builder_i32(line, project.expr_table_nodes)
    line = builder_text(line, " expr_primary=")
    line = builder_i32(line, project.expr_primary_nodes)
    line = builder_text(line, " expr_ids=")
    line = builder_i32(line, project.expr_identifier_nodes)
    line = builder_text(line, " expr_literals=")
    line = builder_i32(line, project.expr_literal_nodes)
    line = builder_text(line, " expr_strings=")
    line = builder_i32(line, project.expr_string_nodes)
    line = builder_text(line, " expr_calls=")
    line = builder_i32(line, project.expr_call_nodes)
    line = builder_text(line, " expr_members=")
    line = builder_i32(line, project.expr_member_nodes)
    line = builder_text(line, " expr_indexes=")
    line = builder_i32(line, project.expr_index_nodes)
    line = builder_text(line, " expr_binary=")
    line = builder_i32(line, project.expr_binary_nodes)
    line = builder_text(line, " expr_unary=")
    line = builder_i32(line, project.expr_unary_nodes)
    line = builder_text(line, " expr_digest=")
    line = builder_i32(line, project.expr_table_digest)
    line = builder_text(line, " expr_slots=")
    line = builder_i32(line, project.expr_slot_count)
    line = builder_text(line, " expr_nonempty=")
    line = builder_i32(line, project.expr_nonempty_slots)
    line = builder_text(line, " expr_max_slot=")
    line = builder_i32(line, project.expr_max_nodes_per_slot)
    line = builder_text(line, " expr_slot_digest=")
    line = builder_i32(line, project.expr_slot_digest)
    line = builder_text(line, " stmt_expr_links=")
    line = builder_i32(line, project.stmt_expr_links)
    line = builder_text(line, " stmt_expr_tail=")
    line = builder_i32(line, project.stmt_expr_tail_nodes)
    line = builder_text(line, " stmt_expr_digest=")
    line = builder_i32(line, project.stmt_expr_digest)
    line = builder_text(line, " symbol_digest=")
    line = builder_i32(line, project.symbol_digest)
    line = builder_text(line, " import_digest=")
    line = builder_i32(line, project.symbol_import_digest)
    line = builder_text(line, " module_digest=")
    line = builder_i32(line, project.symbol_module_digest)
    line = builder_text(line, " bodies=")
    line = builder_i32(line, project.function_bodies)
    line = builder_text(line, " body_tokens=")
    line = builder_i32(line, project.function_body_tokens)
    line = builder_text(line, " body_nodes=")
    line = builder_i32(line, project.body_node_count)
    line = builder_text(line, " body_slots=")
    line = builder_i32(line, project.body_slot_count)
    line = builder_text(line, " body_nonempty=")
    line = builder_i32(line, project.body_nonempty_slots)
    line = builder_text(line, " body_max_nodes=")
    line = builder_i32(line, project.body_max_nodes_per_slot)
    line = builder_text(line, " body_slot_digest=")
    line = builder_i32(line, project.body_slot_digest)
    line = builder_text(line, " transitions=")
    line = builder_i32(line, transitions)
    line = builder_text(line, " payload_ids=")
    line = builder_i32(line, project.body_identifier_payloads)
    line = builder_text(line, " payload_literals=")
    line = builder_i32(line, project.body_literal_payloads)
    line = builder_text(line, " payload_types=")
    line = builder_i32(line, project.body_type_payloads)
    line = builder_text(line, " payload_controls=")
    line = builder_i32(line, project.body_control_payloads)
    line = builder_text(line, " payload_digest=")
    line = builder_i32(line, project.body_payload_digest)
    line = builder_text(line, " local_symbols=")
    line = builder_i32(line, project.body_local_symbol_refs)
    line = builder_text(line, " assignment_targets=")
    line = builder_i32(line, project.body_assignment_target_refs)
    line = builder_text(line, " call_targets=")
    line = builder_i32(line, project.body_call_target_refs)
    line = builder_text(line, " return_symbols=")
    line = builder_i32(line, project.body_return_symbol_refs)
    line = builder_text(line, " return_literals=")
    line = builder_i32(line, project.body_return_literal_refs)
    line = builder_text(line, " type_refs=")
    line = builder_i32(line, project.body_type_refs)
    line = builder_text(line, " control_refs=")
    line = builder_i32(line, project.body_control_refs)
    line = builder_text(line, " semantic_digest=")
    line = builder_i32(line, project.body_semantic_digest)
    line = builder_text(line, " returns=")
    line = builder_i32(line, project.returns)
    line = builder_text(line, " return_exprs=")
    line = builder_i32(line, project.return_exprs)
    line = builder_text(line, " digest=")
    line = builder_i32(line, project.digest)
    line = builder_text(line, " fn_digest=")
    line = builder_i32(line, project.function_name_digest)
    line = builder_text(line, " body_digest=")
    line = builder_i32(line, project.function_body_digest)
    line = builder_text(line, " node_digest=")
    line = builder_i32(line, project.body_node_digest)
    line = builder_text(line, " transition_digest=")
    line = builder_i32(line, project.body_transition_digest)
    line = builder_text(line, " ret_digest=")
    line = builder_i32(line, project.return_expr_digest)
    line = builder_text(line, " main=")
    line = builder_i32(line, main_value)
    return line.data
}

fn project_check_line(project ProjectResult) string {
    main_value := 0
    if project.has_main {
        main_value = 1
    }
    typed_nodes := project.typed_decl_nodes + project.typed_stmt_nodes + project.typed_expr_nodes + project.typed_type_nodes

    transitions := project.body_local_assign_edges + project.body_assign_call_edges + project.body_call_return_edges + project.body_return_local_edges + project.body_if_for_edges + project.body_for_return_edges

    line := builder_new(12288)
    line = builder_text(line, "check ok: files=")
    line = builder_i32(line, project.files)
    line = builder_text(line, " tokens=")
    line = builder_i32(line, project.tokens)
    line = builder_text(line, " decls=")
    line = builder_i32(line, project.decls)
    line = builder_text(line, " funcs=")
    line = builder_i32(line, project.functions)
    line = builder_text(line, " structs=")
    line = builder_i32(line, project.structs)
    line = builder_text(line, " imports=")
    line = builder_i32(line, project.imports)
    line = builder_text(line, " nodes=")
    line = builder_i32(line, project.nodes)
    line = builder_text(line, " typed_nodes=")
    line = builder_i32(line, typed_nodes)
    line = builder_text(line, " typed_digest=")
    line = builder_i32(line, project.typed_digest)
    line = builder_text(line, " symbols=")
    line = builder_i32(line, project.symbol_functions)
    line = builder_text(line, " symbol_structs=")
    line = builder_i32(line, project.symbol_structs)
    line = builder_text(line, " symbol_imports=")
    line = builder_i32(line, project.symbol_imports)
    line = builder_text(line, " std_imports=")
    line = builder_i32(line, project.symbol_std_imports)
    line = builder_text(line, " import_aliases=")
    line = builder_i32(line, project.symbol_import_aliases)
    line = builder_text(line, " public_symbols=")
    line = builder_i32(line, project.symbol_public)
    line = builder_text(line, " local_decl_symbols=")
    line = builder_i32(line, project.symbol_local)
    line = builder_text(line, " fn_zero_params=")
    line = builder_i32(line, project.symbol_zero_param_functions)
    line = builder_text(line, " fn_nonzero_params=")
    line = builder_i32(line, project.symbol_nonzero_param_functions)
    line = builder_text(line, " fn_params=")
    line = builder_i32(line, project.symbol_total_function_params)
    line = builder_text(line, " fn_max_params=")
    line = builder_i32(line, project.symbol_max_function_params)
    line = builder_text(line, " fn_returns=")
    line = builder_i32(line, project.symbol_functions_with_return_type)
    line = builder_text(line, " fn_sig_digest=")
    line = builder_i32(line, project.symbol_function_signature_digest)
    line = builder_text(line, " call_sites=")
    line = builder_i32(line, project.symbol_call_sites)
    line = builder_text(line, " zero_arg_calls=")
    line = builder_i32(line, project.symbol_zero_arg_calls)
    line = builder_text(line, " nonzero_arg_calls=")
    line = builder_i32(line, project.symbol_nonzero_arg_calls)
    line = builder_text(line, " call_args=")
    line = builder_i32(line, project.symbol_total_call_args)
    line = builder_text(line, " max_call_args=")
    line = builder_i32(line, project.symbol_max_call_args)
    line = builder_text(line, " call_arity_digest=")
    line = builder_i32(line, project.symbol_call_arity_digest)
    line = builder_text(line, " sig_nodes=")
