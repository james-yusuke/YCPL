    ast_return := llvm.build_add(builder, ast_call, return_loaded, "function_body_ast_node_return_sequence_state")
    ast_control := llvm.build_add(builder, ast_return, control_env, "function_body_ast_node_control_sequence_state")
    ast_semantic := llvm.build_add(builder, ast_control, ast_expr_count, "function_body_ast_node_semantic_sequence_lowered")
    ast_lowered := llvm.build_add(builder, ast_semantic, owner_state, "function_body_ast_node_sequence_lowered")
    expr_owner_left := llvm.build_add(builder, expr_value_env, expr_with_statement_env, "function_body_expr_owner_environment_left")
    expr_owner_env := llvm.build_add(builder, expr_owner_left, ast_lowered, "function_body_expr_owner_environment")
    owner_score := llvm.build_add(builder, owner_state, ast_lowered, "node_statement_expr_owner_score")
    statement_expr_max_value := llvm.const_int(i32_type, scan.statement_expr_max_per_node, 1)
    statement_expr_links_value := llvm.const_int(i32_type, scan.statement_expr_links, 1)
    ownership_score := llvm.build_add(builder, owner_score, statement_expr_max_value, "function_statement_expr_ownership_score")
    owned_expr_sum := llvm.build_add(builder, ownership_score, statement_expr_links_value, "function_body_owned_expr_sum")
    tail_expr := llvm.build_add(builder, owned_expr_sum, one, "function_tail_expr_value")
    tail_type := llvm.build_add(builder, expr_type, one, "function_tail_expr_type")
    tail_flow := llvm.build_add(builder, tail_expr, expr_owner_env, "function_body_tail_expr_value_flow")
    llvm.build_add(builder, tail_flow, tail_type, "function_body_tail_expr_typed_value")

    expr_sum := llvm.build_add(builder, expression_sequence, tail_flow, "function_body_expr_sum")
    env_left := llvm.build_add(builder, symbol_env, value_env, "function_body_lowered_environment_state")
    statement_state := llvm.build_add(builder, local_loaded, assignment_loaded, "function_body_lowered_statement_state")
    lowered_with_env := llvm.build_add(builder, env_left, control_env, "function_body_lowered_with_environment")
    lowered_total_left := llvm.build_add(builder, lowered_with_env, statement_state, "function_body_lowered_total_left")
    lowered_total_mid := llvm.build_add(builder, lowered_total_left, return_flow, "function_body_lowered_total_mid")
    lowered_total_real := llvm.build_add(builder, lowered_total_mid, real_body_lowered, "function_body_lowered_total_with_real_ast")
    lowered_total := llvm.build_add(builder, lowered_total_real, expr_sum, "function_body_lowered_total")

    for_index_slot := build_named_i32_slot(builder, i32_type, "function_body_for_index", 0)
    loaded_if_score := llvm.build_load2(builder, i32_type, score_slot, "loaded_function_if_score")
    if_score_value := llvm.const_int(i32_type, scan.ifs, 1)
    if_score := llvm.build_add(builder, loaded_if_score, if_score_value, "function_if_score")
    llvm.build_store(builder, if_score, score_slot)
    has_if := llvm.build_icmp(builder, llvm.int_sgt(), if_score_value, zero, "function_for_has_more")
    llvm.build_cond_br(builder, has_if, if_then, if_else)
    llvm.position_builder_at_end(builder, if_then)
    llvm.build_br(builder, for_check)
    llvm.position_builder_at_end(builder, if_else)
    llvm.build_br(builder, for_check)
    llvm.position_builder_at_end(builder, for_check)
    loaded_for_index := llvm.build_load2(builder, i32_type, for_index_slot, "loaded_function_for_index")
    for_limit := llvm.const_int(i32_type, scan.fors, 1)
    has_for := llvm.build_icmp(builder, llvm.int_slt(), loaded_for_index, for_limit, "function_for_has_more_next")
    llvm.build_cond_br(builder, has_for, for_body, done)
    llvm.position_builder_at_end(builder, for_body)
    llvm.build_br(builder, done)
    llvm.position_builder_at_end(builder, done)
    total_score := llvm.build_add(builder, lowered_total, semantic_surface, "function_body_total")
    llvm.build_ret(builder, total_score)
    return body_fn
}

fn emit_function_body_lowering(ctx *byte, mod *byte, builder *byte, i32_type *byte, fn_type *byte, call_helper *byte, name string, scan FunctionBodyScan) *byte {
    if scan.node_len > max_real_body_lowering_nodes() || scan.expr_len > max_real_expr_lowering_nodes() {
        return emit_compact_function_body_lowering(ctx, mod, builder, i32_type, fn_type, call_helper, name, scan)
    }

    body_fn := llvm.add_function(mod, name, fn_type)
    body_entry := llvm.append_basic_block_in_context(ctx, body_fn, "entry")
    body_if_then := llvm.append_basic_block_in_context(ctx, body_fn, "function_if_then")
    body_if_else := llvm.append_basic_block_in_context(ctx, body_fn, "function_if_else")
    body_for_check := llvm.append_basic_block_in_context(ctx, body_fn, "function_for_check")
    body_for_body := llvm.append_basic_block_in_context(ctx, body_fn, "function_for_body")
    body_done := llvm.append_basic_block_in_context(ctx, body_fn, "function_done")
    llvm.position_builder_at_end(builder, body_entry)
    function_score_slot := llvm.build_alloca(builder, i32_type, "function_body_score")
    function_loop_index_slot := llvm.build_alloca(builder, i32_type, "function_body_for_index")
    function_local_state_slot := llvm.build_alloca(builder, i32_type, "function_body_local_state")
    function_assignment_state_slot := llvm.build_alloca(builder, i32_type, "function_body_assignment_state")
    function_call_state_slot := llvm.build_alloca(builder, i32_type, "function_body_call_state")
    function_return_state_slot := llvm.build_alloca(builder, i32_type, "function_body_return_state")
    function_symbol_env_slot := llvm.build_alloca(builder, i32_type, "function_body_symbol_env")
    function_value_state_slot := llvm.build_alloca(builder, i32_type, "function_body_value_state")
    function_control_state_slot := llvm.build_alloca(builder, i32_type, "function_body_control_state")
    function_statement_value_slot := llvm.build_alloca(builder, i32_type, "function_body_statement_ast_value_slot")
    function_statement_resolved_type_slot := llvm.build_alloca(builder, i32_type, "function_body_statement_resolved_type_slot")
    function_statement_expr_owner_state_slot := llvm.build_alloca(builder, i32_type, "function_body_statement_expr_owner_state")
    function_ast_node_sequence_state_slot := llvm.build_alloca(builder, i32_type, "function_body_ast_node_sequence_state")
    function_ast_node_semantic_sequence_state_slot := llvm.build_alloca(builder, i32_type, "function_body_ast_node_semantic_sequence_state")
    function_i32_statement_expr_state_slot := llvm.build_alloca(builder, i32_type, "function_body_i32_statement_expr_state")
    function_bool_statement_expr_state_slot := llvm.build_alloca(builder, i32_type, "function_body_bool_statement_expr_state")
    function_string_statement_expr_state_slot := llvm.build_alloca(builder, i32_type, "function_body_string_statement_expr_state")
    function_pointer_statement_expr_state_slot := llvm.build_alloca(builder, i32_type, "function_body_pointer_statement_expr_state")
    function_none_statement_expr_state_slot := llvm.build_alloca(builder, i32_type, "function_body_none_statement_expr_state")
    function_unknown_statement_expr_state_slot := llvm.build_alloca(builder, i32_type, "function_body_unknown_statement_expr_state")
    function_expr_value_state_slot := llvm.build_alloca(builder, i32_type, "function_expr_value_state")
    function_expr_type_state_slot := llvm.build_alloca(builder, i32_type, "function_expr_type_state")
    zero := llvm.const_int(i32_type, 0, 1)
    one := llvm.const_int(i32_type, 1, 1)
    function_count := llvm.const_int(i32_type, scan.functions, 1)
    local_count := llvm.const_int(i32_type, scan.locals, 1)
    assignment_count := llvm.const_int(i32_type, scan.assignments, 1)
    call_count := llvm.const_int(i32_type, scan.calls, 1)
    return_count := llvm.const_int(i32_type, scan.returns, 1)
    if_count := llvm.const_int(i32_type, scan.ifs, 1)
    for_count := llvm.const_int(i32_type, scan.fors, 1)
    else_count := llvm.const_int(i32_type, scan.elses, 1)
    break_count := llvm.const_int(i32_type, scan.breaks, 1)
    continue_count := llvm.const_int(i32_type, scan.continues, 1)
    for_in_count := llvm.const_int(i32_type, scan.for_ins, 1)
    body_identifier_payload_count := llvm.const_int(i32_type, scan.body_identifier_payloads, 1)
    body_literal_payload_count := llvm.const_int(i32_type, scan.body_literal_payloads, 1)
    body_type_payload_count := llvm.const_int(i32_type, scan.body_type_payloads, 1)
    body_control_payload_count := llvm.const_int(i32_type, scan.body_control_payloads, 1)
    body_payload_digest := llvm.const_int(i32_type, scan.body_payload_digest, 1)
    body_local_symbol_count := llvm.const_int(i32_type, scan.body_local_symbol_refs, 1)
    body_assignment_target_count := llvm.const_int(i32_type, scan.body_assignment_target_refs, 1)
    body_call_target_count := llvm.const_int(i32_type, scan.body_call_target_refs, 1)
    body_return_symbol_count := llvm.const_int(i32_type, scan.body_return_symbol_refs, 1)
    body_return_literal_count := llvm.const_int(i32_type, scan.body_return_literal_refs, 1)
    body_type_ref_count := llvm.const_int(i32_type, scan.body_type_refs, 1)
    body_control_ref_count := llvm.const_int(i32_type, scan.body_control_refs, 1)
    body_semantic_digest := llvm.const_int(i32_type, scan.body_semantic_digest, 1)
    node_count := llvm.const_int(i32_type, scan.nodes, 1)
    expr_node_count := llvm.const_int(i32_type, scan.expr_nodes, 1)
    expr_primary_count := llvm.const_int(i32_type, scan.expr_primary_nodes, 1)
    expr_identifier_count := llvm.const_int(i32_type, scan.expr_identifier_nodes, 1)
    expr_literal_count := llvm.const_int(i32_type, scan.expr_literal_nodes, 1)
    expr_string_count := llvm.const_int(i32_type, scan.expr_string_nodes, 1)
    expr_bool_count := llvm.const_int(i32_type, scan.expr_bool_nodes, 1)
    expr_none_count := llvm.const_int(i32_type, scan.expr_none_nodes, 1)
    expr_call_count := llvm.const_int(i32_type, scan.expr_call_nodes, 1)
    expr_typed_identifier_count := llvm.const_int(i32_type, scan.expr_typed_identifier_nodes, 1)
    expr_typed_call_count := llvm.const_int(i32_type, scan.expr_typed_call_nodes, 1)
    expr_project_typed_call_count := llvm.const_int(i32_type, scan.expr_project_typed_call_nodes, 1)
    expr_member_count := llvm.const_int(i32_type, scan.expr_member_nodes, 1)
    expr_index_count := llvm.const_int(i32_type, scan.expr_index_nodes, 1)
    expr_operator_count := llvm.const_int(i32_type, scan.expr_binary_nodes + scan.expr_unary_nodes, 1)
    expr_slot_count := llvm.const_int(i32_type, scan.expr_slot_count, 1)
    expr_digest := llvm.const_int(i32_type, scan.expr_digest, 1)
    expr_slot_digest := llvm.const_int(i32_type, scan.expr_slot_digest, 1)
    expr_lowered_count := llvm.const_int(i32_type, scan.expr_len, 1)
    statement_expr_links := llvm.const_int(i32_type, scan.statement_expr_links, 1)
    statement_expr_owned_nodes := llvm.const_int(i32_type, scan.statement_expr_nodes, 1)
    statement_expr_max_per_node := llvm.const_int(i32_type, scan.statement_expr_max_per_node, 1)
    statement_expr_digest := llvm.const_int(i32_type, scan.statement_expr_digest, 1)
    statement_expr_owner_limit := llvm.const_int(i32_type, max_statement_expr_owner_lowering_nodes(), 1)
    expr_nodes_slot := llvm.build_alloca(builder, i32_type, "function_expr_nodes")
    expr_primary_slot := llvm.build_alloca(builder, i32_type, "function_expr_primary_nodes")
    expr_identifier_slot := llvm.build_alloca(builder, i32_type, "function_expr_identifier_nodes")
    expr_literal_slot := llvm.build_alloca(builder, i32_type, "function_expr_literal_nodes")
    expr_string_slot := llvm.build_alloca(builder, i32_type, "function_expr_string_nodes")
    expr_bool_slot := llvm.build_alloca(builder, i32_type, "function_expr_bool_nodes")
    expr_none_slot := llvm.build_alloca(builder, i32_type, "function_expr_none_nodes")
    expr_call_slot := llvm.build_alloca(builder, i32_type, "function_expr_call_nodes")
    expr_typed_identifier_slot := llvm.build_alloca(builder, i32_type, "function_expr_typed_identifier_nodes")
    expr_typed_call_slot := llvm.build_alloca(builder, i32_type, "function_expr_typed_call_nodes")
    expr_project_typed_call_slot := llvm.build_alloca(builder, i32_type, "function_expr_project_typed_call_nodes")
    expr_member_slot := llvm.build_alloca(builder, i32_type, "function_expr_member_nodes")
    expr_index_slot := llvm.build_alloca(builder, i32_type, "function_expr_index_nodes")
    expr_operator_slot := llvm.build_alloca(builder, i32_type, "function_expr_operator_nodes")
    expr_slot_count_slot := llvm.build_alloca(builder, i32_type, "function_expr_slot_count")
    expr_digest_slot := llvm.build_alloca(builder, i32_type, "function_expr_digest")
    expr_slot_digest_slot := llvm.build_alloca(builder, i32_type, "function_expr_slot_digest")
    expr_lowered_count_slot := llvm.build_alloca(builder, i32_type, "function_expr_lowered_nodes")
    statement_expr_links_slot := llvm.build_alloca(builder, i32_type, "function_statement_expr_links")
    statement_expr_owned_slot := llvm.build_alloca(builder, i32_type, "function_statement_expr_owned_nodes")
    statement_expr_max_slot := llvm.build_alloca(builder, i32_type, "function_statement_expr_max_per_node")
    statement_expr_digest_slot := llvm.build_alloca(builder, i32_type, "function_statement_expr_digest")
    statement_expr_owner_limit_slot := llvm.build_alloca(builder, i32_type, "function_statement_expr_owner_limit")
    statement_expr_owner_lowered_slot := llvm.build_alloca(builder, i32_type, "function_statement_expr_owner_lowered_count")
    body_identifier_payload_slot := llvm.build_alloca(builder, i32_type, "function_body_identifier_payloads")
    body_literal_payload_slot := llvm.build_alloca(builder, i32_type, "function_body_literal_payloads")
    body_type_payload_slot := llvm.build_alloca(builder, i32_type, "function_body_type_payloads")
    body_control_payload_slot := llvm.build_alloca(builder, i32_type, "function_body_control_payloads")
    body_payload_digest_slot := llvm.build_alloca(builder, i32_type, "function_body_payload_digest")
    body_local_symbol_slot := llvm.build_alloca(builder, i32_type, "function_body_local_symbol_refs")
    body_assignment_target_slot := llvm.build_alloca(builder, i32_type, "function_body_assignment_target_refs")
    body_call_target_slot := llvm.build_alloca(builder, i32_type, "function_body_call_target_refs")
    body_return_symbol_slot := llvm.build_alloca(builder, i32_type, "function_body_return_symbol_refs")
    body_return_literal_slot := llvm.build_alloca(builder, i32_type, "function_body_return_literal_refs")
    body_type_ref_slot := llvm.build_alloca(builder, i32_type, "function_body_type_refs")
    body_control_ref_slot := llvm.build_alloca(builder, i32_type, "function_body_control_refs")
    body_semantic_digest_slot := llvm.build_alloca(builder, i32_type, "function_body_semantic_digest")
    control_else_slot := llvm.build_alloca(builder, i32_type, "function_control_else_nodes")
    control_for_in_slot := llvm.build_alloca(builder, i32_type, "function_control_for_in_nodes")
    control_break_slot := llvm.build_alloca(builder, i32_type, "function_control_break_nodes")
    control_continue_slot := llvm.build_alloca(builder, i32_type, "function_control_continue_nodes")
    llvm.build_store(builder, expr_node_count, expr_nodes_slot)
    llvm.build_store(builder, expr_primary_count, expr_primary_slot)
    llvm.build_store(builder, expr_identifier_count, expr_identifier_slot)
    llvm.build_store(builder, expr_literal_count, expr_literal_slot)
    llvm.build_store(builder, expr_string_count, expr_string_slot)
    llvm.build_store(builder, expr_bool_count, expr_bool_slot)
    llvm.build_store(builder, expr_none_count, expr_none_slot)
    llvm.build_store(builder, expr_call_count, expr_call_slot)
    llvm.build_store(builder, expr_typed_identifier_count, expr_typed_identifier_slot)
    llvm.build_store(builder, expr_typed_call_count, expr_typed_call_slot)
    llvm.build_store(builder, expr_project_typed_call_count, expr_project_typed_call_slot)
    llvm.build_store(builder, expr_member_count, expr_member_slot)
    llvm.build_store(builder, expr_index_count, expr_index_slot)
    llvm.build_store(builder, expr_operator_count, expr_operator_slot)
    llvm.build_store(builder, expr_slot_count, expr_slot_count_slot)
    llvm.build_store(builder, expr_digest, expr_digest_slot)
    llvm.build_store(builder, expr_slot_digest, expr_slot_digest_slot)
    llvm.build_store(builder, expr_lowered_count, expr_lowered_count_slot)
    llvm.build_store(builder, statement_expr_links, statement_expr_links_slot)
    llvm.build_store(builder, statement_expr_owned_nodes, statement_expr_owned_slot)
    llvm.build_store(builder, statement_expr_max_per_node, statement_expr_max_slot)
    llvm.build_store(builder, statement_expr_digest, statement_expr_digest_slot)
    llvm.build_store(builder, statement_expr_owner_limit, statement_expr_owner_limit_slot)
    llvm.build_store(builder, zero, statement_expr_owner_lowered_slot)
    llvm.build_store(builder, body_identifier_payload_count, body_identifier_payload_slot)
    llvm.build_store(builder, body_literal_payload_count, body_literal_payload_slot)
    llvm.build_store(builder, body_type_payload_count, body_type_payload_slot)
    llvm.build_store(builder, body_control_payload_count, body_control_payload_slot)
    llvm.build_store(builder, body_payload_digest, body_payload_digest_slot)
    llvm.build_store(builder, body_local_symbol_count, body_local_symbol_slot)
    llvm.build_store(builder, body_assignment_target_count, body_assignment_target_slot)
    llvm.build_store(builder, body_call_target_count, body_call_target_slot)
    llvm.build_store(builder, body_return_symbol_count, body_return_symbol_slot)
    llvm.build_store(builder, body_return_literal_count, body_return_literal_slot)
    llvm.build_store(builder, body_type_ref_count, body_type_ref_slot)
    llvm.build_store(builder, body_control_ref_count, body_control_ref_slot)
    llvm.build_store(builder, body_semantic_digest, body_semantic_digest_slot)
    llvm.build_store(builder, else_count, control_else_slot)
    llvm.build_store(builder, for_in_count, control_for_in_slot)
    llvm.build_store(builder, break_count, control_break_slot)
    llvm.build_store(builder, continue_count, control_continue_slot)
    loaded_expr_nodes := llvm.build_load2(builder, i32_type, expr_nodes_slot, "loaded_function_expr_nodes")
    loaded_expr_primary := llvm.build_load2(builder, i32_type, expr_primary_slot, "loaded_function_expr_primary")
    loaded_expr_identifiers := llvm.build_load2(builder, i32_type, expr_identifier_slot, "loaded_function_expr_identifiers")
    loaded_expr_literals := llvm.build_load2(builder, i32_type, expr_literal_slot, "loaded_function_expr_literals")
    loaded_expr_strings := llvm.build_load2(builder, i32_type, expr_string_slot, "loaded_function_expr_strings")
    loaded_expr_bools := llvm.build_load2(builder, i32_type, expr_bool_slot, "loaded_function_expr_bools")
    loaded_expr_nones := llvm.build_load2(builder, i32_type, expr_none_slot, "loaded_function_expr_nones")
    loaded_expr_calls := llvm.build_load2(builder, i32_type, expr_call_slot, "loaded_function_expr_calls")
    loaded_expr_typed_identifiers := llvm.build_load2(builder, i32_type, expr_typed_identifier_slot, "loaded_function_expr_typed_identifiers")
    loaded_expr_typed_calls := llvm.build_load2(builder, i32_type, expr_typed_call_slot, "loaded_function_expr_typed_calls")
    loaded_expr_project_typed_calls := llvm.build_load2(builder, i32_type, expr_project_typed_call_slot, "loaded_function_expr_project_typed_calls")
    loaded_expr_members := llvm.build_load2(builder, i32_type, expr_member_slot, "loaded_function_expr_members")
    loaded_expr_indexes := llvm.build_load2(builder, i32_type, expr_index_slot, "loaded_function_expr_indexes")
    loaded_expr_operators := llvm.build_load2(builder, i32_type, expr_operator_slot, "loaded_function_expr_operators")
    loaded_expr_slot_count := llvm.build_load2(builder, i32_type, expr_slot_count_slot, "loaded_function_expr_slot_count")
    loaded_expr_digest := llvm.build_load2(builder, i32_type, expr_digest_slot, "loaded_function_expr_digest")
    loaded_expr_slot_digest := llvm.build_load2(builder, i32_type, expr_slot_digest_slot, "loaded_function_expr_slot_digest")
    loaded_expr_lowered_count := llvm.build_load2(builder, i32_type, expr_lowered_count_slot, "loaded_function_expr_lowered_nodes")
    loaded_statement_expr_links := llvm.build_load2(builder, i32_type, statement_expr_links_slot, "loaded_function_statement_expr_links")
    loaded_statement_expr_owned := llvm.build_load2(builder, i32_type, statement_expr_owned_slot, "loaded_function_statement_expr_owned_nodes")
    loaded_statement_expr_max := llvm.build_load2(builder, i32_type, statement_expr_max_slot, "loaded_function_statement_expr_max_per_node")
    loaded_statement_expr_digest := llvm.build_load2(builder, i32_type, statement_expr_digest_slot, "loaded_function_statement_expr_digest")
    loaded_statement_expr_owner_limit := llvm.build_load2(builder, i32_type, statement_expr_owner_limit_slot, "loaded_function_statement_expr_owner_limit")
    loaded_body_identifier_payloads := llvm.build_load2(builder, i32_type, body_identifier_payload_slot, "loaded_function_body_identifier_payloads")
    loaded_body_literal_payloads := llvm.build_load2(builder, i32_type, body_literal_payload_slot, "loaded_function_body_literal_payloads")
    loaded_body_type_payloads := llvm.build_load2(builder, i32_type, body_type_payload_slot, "loaded_function_body_type_payloads")
    loaded_body_control_payloads := llvm.build_load2(builder, i32_type, body_control_payload_slot, "loaded_function_body_control_payloads")
    loaded_body_payload_digest := llvm.build_load2(builder, i32_type, body_payload_digest_slot, "loaded_function_body_payload_digest")
    loaded_body_local_symbols := llvm.build_load2(builder, i32_type, body_local_symbol_slot, "loaded_function_body_local_symbol_refs")
    loaded_body_assignment_targets := llvm.build_load2(builder, i32_type, body_assignment_target_slot, "loaded_function_body_assignment_target_refs")
    loaded_body_call_targets := llvm.build_load2(builder, i32_type, body_call_target_slot, "loaded_function_body_call_target_refs")
    loaded_body_return_symbols := llvm.build_load2(builder, i32_type, body_return_symbol_slot, "loaded_function_body_return_symbol_refs")
