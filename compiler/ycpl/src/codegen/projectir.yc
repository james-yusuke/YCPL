}

pub struct ProjectIrResult {
    ok bool
    message string
    out_file string
    merge_text string
}

fn ok_with_text(out_file string, merge_text string) ProjectIrResult {
    return ProjectIrResult{ok: true, message: "", out_file: out_file, merge_text: merge_text}
}

fn fail(message string) ProjectIrResult {
    return ProjectIrResult{ok: false, message: message, out_file: "", merge_text: ""}
}

fn join_path(left string, right string) string {
    left_len := str.len(left)
    right_len := str.len(right)
    needs_slash := true
    if left_len > 0 && left[left_len - 1] == '/' {
        needs_slash = false
    }

    extra := 1
    if !needs_slash {
        extra = 0
    }

    out: string := mem.calloc(left_len + right_len + extra + 1, 1)
    mem.copy(out, left, left_len)
    at := left_len
    if needs_slash {
        out[at] = '/'
        at += 1
    }
    mem.copy(out + at, right, right_len)
    return out
}

fn decimal_len(value i32) i32 {
    if value == 0 {
        return 1
    }
    len := 0
    v := value
    if v < 0 {
        len += 1
        v = 0 - v
    }
    for (; v > 0; ) {
        len += 1
        v = v / 10
    }
    return len
}

fn write_i32_decimal(out string, start i32, value i32) i32 {
    at := start
    if value == 0 {
        out[at] = '0'
        return at + 1
    }
    v := value
    if v < 0 {
        out[at] = '-'
        at += 1
        v = 0 - v
    }
    digits := decimal_len(v)
    pos := at + digits - 1
    for (; v > 0; ) {
        out[pos] = '0' + (v % 10)
        pos -= 1
        v = v / 10
    }
    return at + digits
}

fn indexed_name(prefix string, index i32) string {
    prefix_len := str.len(prefix)
    digits := decimal_len(index)
    out: string := mem.calloc(prefix_len + digits + 1, 1)
    mem.copy(out, prefix, prefix_len)
    write_i32_decimal(out, prefix_len, index)
    return out
}

fn project_body_path(out_dir string) string {
    return join_path(out_dir, "project_body.ll")
}

fn starts_define(text string, at i32) bool {
    return text[at] == 'd' && text[at + 1] == 'e' && text[at + 2] == 'f' && text[at + 3] == 'i' && text[at + 4] == 'n' && text[at + 5] == 'e' && text[at + 6] == ' '
}

fn first_define_offset(text string) i32 {
    n := str.len(text)
    i := 0
    for (; i + 6 < n; i++) {
        if starts_define(text, i) {
            return i
        }
    }
    return 0
}

fn copy_from(text string, start i32) string {
    n := str.len(text)
    count := n - start
    out: string := mem.calloc(count + 1, 1)
    mem.copy(out, text + start, count)
    return out
}

fn mergeable_ir_text(ir string) string {
    return copy_from(ir, first_define_offset(ir))
}

fn parse_i32(text string) i32 {
    value := 0
    i: i32 := 0
    n := str.len(text)
    for (; i < n; i++) {
        ch := text[i]
        if ch >= '0' && ch <= '9' {
            value = value * 10 + (ch - '0')
        }
    }
    return value
}

fn max_expr_lowering_nodes() i32 {
    return 1024
}

fn max_regular_expr_lowering_nodes() i32 {
    return 768
}

fn max_statement_expr_owner_lowering_nodes() i32 {
    return lowerstats.statement_expr_owner_limit()
}

fn max_real_body_lowering_nodes() i32 {
    return lowerstats.real_body_node_limit()
}

fn max_real_expr_lowering_nodes() i32 {
    return lowerstats.real_expr_limit()
}

fn max_real_statement_expr_lowering_nodes() i32 {
    return lowerstats.real_statement_expr_limit()
}

fn project_expr_type_table_ok() ProjectExprTypeTable {
    return ProjectExprTypeTable{ok: true, message: "", line: 1, col: 1, name_data: none, type_data: none, arity_data: none, len: 0, cap: 0, typed_returns: 0, field_name_data: none, field_index_data: none, field_len: 0, field_cap: 0, field_count: 0, field_digest: 17}
}

fn project_expr_type_table_fail(line i32, col i32, message string) ProjectExprTypeTable {
    return ProjectExprTypeTable{ok: false, message: message, line: line, col: col, name_data: none, type_data: none, arity_data: none, len: 0, cap: 0, typed_returns: 0, field_name_data: none, field_index_data: none, field_len: 0, field_cap: 0, field_count: 0, field_digest: 17}
}

fn expr_type_hash(name string) i32 {
    h := 17
    i := 0
    n := str.len(name)
    for (; i < n; i++) {
        h = h * 33 + name[i]
    }
    if h < 0 {
        h = 0 - h
    }
    return (h % 97) + 1
}

fn expr_type_kind_from_name(name string) i32 {
    if str.eq(name, "i64") {
        return astexpr.i64_type_kind()
    }
    if str.eq(name, "i32") || str.eq(name, "byte") {
        return astexpr.i32_type_kind()
    }
    if str.eq(name, "bool") {
        return astexpr.bool_type_kind()
    }
    if str.eq(name, "string") {
        return astexpr.string_type_kind()
    }
    if str.eq(name, "none") || str.eq(name, "void") {
        return astexpr.none_type_kind()
    }
    return astexpr.struct_type_kind()
}

fn expr_type_kind_from_token(kind i32, text string, pointer_pending bool) i32 {
    if pointer_pending {
        return astexpr.pointer_type_kind()
    }
    if kind == tok.lbrack() {
        return astexpr.slice_type_kind()
    }
    if kind == tok.kw_byte() {
        return astexpr.i32_type_kind()
    }
    if kind == tok.ident() {
        return expr_type_kind_from_name(text)
    }
    return astexpr.unknown_type_kind()
}

fn bounded_project_arity(value i32) i32 {
    if value < 0 {
        return 0
    }
    if value > 250 {
        return 250
    }
    return value
}

fn ensure_project_expr_type_table(table ProjectExprTypeTable, needed i32) ProjectExprTypeTable {
    if table.cap >= needed {
        return table
    }
    next_cap := table.cap
    if next_cap <= 0 {
        next_cap = 64
    }
    for (; next_cap < needed; ) {
        next_cap = next_cap * 2
    }
    if table.name_data == none {
        table.name_data = mem.calloc(next_cap + 1, 1)
        table.type_data = mem.calloc(next_cap + 1, 1)
        table.arity_data = mem.calloc(next_cap + 1, 1)
    } else {
        table.name_data = mem.realloc(table.name_data, next_cap + 1)
        table.type_data = mem.realloc(table.type_data, next_cap + 1)
        table.arity_data = mem.realloc(table.arity_data, next_cap + 1)
    }
    table.cap = next_cap
    return table
}

fn add_project_expr_type(table ProjectExprTypeTable, name string, type_kind i32, arity i32) ProjectExprTypeTable {
    if !table.ok || type_kind <= 0 {
        return table
    }
    name_hash := expr_type_hash(name)
    bounded_arity := bounded_project_arity(arity)
    i := 0
    for (; i < table.len; i++) {
        if table.name_data[i] == name_hash {
            table.type_data[i] = type_kind
            table.arity_data[i] = bounded_arity
            return table
        }
    }
    table = ensure_project_expr_type_table(table, table.len + 1)
    table.name_data[table.len] = name_hash
    table.type_data[table.len] = type_kind
    table.arity_data[table.len] = bounded_arity
    table.len += 1
    table.name_data[table.len] = 0
    table.type_data[table.len] = 0
    table.arity_data[table.len] = 0
    table.typed_returns += 1
    return table
}

fn lookup_project_expr_type(table ProjectExprTypeTable, name_hash i32) i32 {
    if !table.ok || name_hash <= 0 {
        return astexpr.unknown_type_kind()
    }
    i := 0
    for (; i < table.len; i++) {
        if table.name_data[i] == name_hash {
            return table.type_data[i]
        }
    }
    return astexpr.unknown_type_kind()
}

fn lookup_project_expr_arity(table ProjectExprTypeTable, name_hash i32) i32 {
    if !table.ok || name_hash <= 0 {
        return -1
    }
    i := 0
    for (; i < table.len; i++) {
        if table.name_data[i] == name_hash {
            return table.arity_data[i]
        }
    }
    return -1
}

fn ensure_project_field_table(table ProjectExprTypeTable, needed i32) ProjectExprTypeTable {
    if table.field_cap >= needed {
        return table
    }
    next_cap := table.field_cap
    if next_cap <= 0 {
        next_cap = 64
    }
    for (; next_cap < needed; ) {
        next_cap = next_cap * 2
    }
    if table.field_name_data == none {
        table.field_name_data = mem.calloc(next_cap + 1, 1)
        table.field_index_data = mem.calloc(next_cap + 1, 1)
    } else {
        table.field_name_data = mem.realloc(table.field_name_data, next_cap + 1)
        table.field_index_data = mem.realloc(table.field_index_data, next_cap + 1)
    }
    table.field_cap = next_cap
    return table
}

fn add_project_field_index(table ProjectExprTypeTable, name_hash i32, encoded_index i32) ProjectExprTypeTable {
    if !table.ok || name_hash <= 0 || encoded_index <= 0 {
        return table
    }
    i := 0
    for (; i < table.field_len; i++) {
        if table.field_name_data[i] == name_hash {
            table.field_digest = table.field_digest * 31 + name_hash + encoded_index
            table.field_count += 1
            return table
        }
    }
    table = ensure_project_field_table(table, table.field_len + 1)
    table.field_name_data[table.field_len] = name_hash
    table.field_index_data[table.field_len] = encoded_index
    table.field_len += 1
    table.field_name_data[table.field_len] = 0
    table.field_index_data[table.field_len] = 0
    table.field_count += 1
    table.field_digest = table.field_digest * 31 + name_hash
    table.field_digest = table.field_digest * 31 + encoded_index
    return table
}

fn merge_project_fields(table ProjectExprTypeTable, fields StructFieldTable) ProjectExprTypeTable {
    if !fields.ok {
        return project_expr_type_table_fail(fields.line, fields.col, fields.message)
    }
    i := 0
    for (; i < fields.len; i++) {
        table = add_project_field_index(table, fields.name_data[i], fields.index_data[i])
    }
    return table
}

fn lookup_project_field_index(table ProjectExprTypeTable, name_hash i32) i32 {
    if !table.ok || name_hash <= 0 {
        return 0
    }
    i := 0
    for (; i < table.field_len; i++) {
        if table.field_name_data[i] == name_hash {
            return table.field_index_data[i]
        }
    }
    return 0
}

fn scan_project_expr_types_in_source(table ProjectExprTypeTable, path string, text string) ProjectExprTypeTable {
    lx := lexer.new(path, text)
    pending_function_name := false
    await_function_lparen := false
    in_function_params := false
    function_param_depth := 0
    function_param_commas := 0
    function_param_tokens := 0
    await_return_type := false
    pointer_return_type := false
    function_name := ""
    function_params := 0
    function_return_type := astexpr.unknown_type_kind()

    for (; true; ) {
        lx = lexer.next(lx)
        if !lx.ok {
            return project_expr_type_table_fail(lx.tok_line, lx.tok_col, lx.message)
        }
        if lx.kind == tok.eof() {
            break
        }

        if pending_function_name && lx.kind == tok.ident() {
            function_name = lx.lexeme
            pending_function_name = false
            await_function_lparen = true
        }

        if in_function_params {
            if lx.kind == tok.lparen() {
                function_param_depth += 1
                if function_param_depth > 1 {
                    function_param_tokens += 1
                }
            } else if lx.kind == tok.rparen() {
                function_param_depth -= 1
                if function_param_depth == 0 {
                    function_params = 0
                    if function_param_tokens > 0 {
                        function_params = function_param_commas + 1
                    }
                    in_function_params = false
                    function_param_commas = 0
                    function_param_tokens = 0
                    await_return_type = true
                    pointer_return_type = false
                    function_return_type = astexpr.unknown_type_kind()
                } else {
                    function_param_tokens += 1
                }
            } else {
                if function_param_depth == 1 && lx.kind == tok.comma() {
                    function_param_commas += 1
                } else if lx.kind != tok.newline() {
                    function_param_tokens += 1
                }
            }
        } else if await_return_type {
            if lx.kind == tok.star() {
                pointer_return_type = true
            } else {
                detected := expr_type_kind_from_token(lx.kind, lx.lexeme, pointer_return_type)
                if detected > 0 && function_return_type == astexpr.unknown_type_kind() {
                    function_return_type = detected
                }
                if lx.kind == tok.lbrace() || lx.kind == tok.newline() || lx.kind == tok.kw_as() {
                    table = add_project_expr_type(table, function_name, function_return_type, function_params)
                    await_return_type = false
                    pointer_return_type = false
                    function_name = ""
                    function_params = 0
                    function_return_type = astexpr.unknown_type_kind()
                }
            }
        }

        if lx.kind == tok.kw_fn() {
            pending_function_name = true
        }
        if await_function_lparen && lx.kind == tok.lparen() {
            in_function_params = true
            function_param_depth = 1
            function_param_commas = 0
            function_param_tokens = 0
            await_function_lparen = false
        }
    }

    if await_return_type {
        table = add_project_expr_type(table, function_name, function_return_type, function_params)
    }
    return table
}

fn scan_project_expr_types_from_sources(sources SourceList) ProjectExprTypeTable {
    table := project_expr_type_table_ok()
    i := 0
    n := sources.count
    for (; i < n; i++) {
        path := resolver.source_path_at(sources, i)
        src := source.load(path)
        if !src.ok {
            return project_expr_type_table_fail(1, 1, "could not read project source")
        }
        table = scan_project_expr_types_in_source(table, path, src.text)
        if !table.ok {
            return table
        }
        fields := fieldparser.parse(path, src.text)
        if !fields.ok {
            return project_expr_type_table_fail(fields.line, fields.col, fields.message)
        }
        table = merge_project_fields(table, fields)
        if !table.ok {
            return table
        }
    }
    return table
}

fn apply_project_expr_types(table ExpressionTable, project_types ProjectExprTypeTable) ExpressionTable {
    if !table.ok || !project_types.ok {
        return table
    }
    i := 0
    for (; i < table.node_len; i++) {
        if table.kind_data[i] == astexpr.call_expr_kind() {
            resolved_arity := lookup_project_expr_arity(project_types, table.meta_data[i])
            if resolved_arity >= 0 {
                table.op_data[i] = resolved_arity + 1
                table.digest = table.digest * 31 + table.op_data[i]
            }
            if table.type_data[i] <= astexpr.unknown_type_kind() {
                resolved := lookup_project_expr_type(project_types, table.meta_data[i])
                if resolved > 0 {
                    table.type_data[i] = resolved + 16
                }
            }
        }
    }
    return table
}

fn apply_project_field_indices(table ExpressionTable, project_types ProjectExprTypeTable) ExpressionTable {
    if !table.ok || !project_types.ok {
        return table
    }
    i := 0
    for (; i < table.node_len; i++) {
        if table.kind_data[i] == astexpr.member_expr_kind() {
            resolved_field := lookup_project_field_index(project_types, table.meta_data[i])
            if resolved_field > 0 {
                table.op_data[i] = resolved_field
                table.digest = table.digest * 31 + resolved_field
            }
        }
    }
    return table
}

fn ensure_node_arena(scan FunctionBodyScan, needed i32) FunctionBodyScan {
    if scan.node_cap >= needed {
        return scan
    }
    next_cap := scan.node_cap
    if next_cap <= 0 {
        next_cap = 64
    }
    for (; next_cap < needed; ) {
        next_cap = next_cap * 2
    }
    if scan.node_data == none {
        scan.node_data = mem.calloc(next_cap + 1, 1)
        scan.node_meta_data = mem.calloc(next_cap + 1, 1)
        scan.node_pos_data = mem.calloc(next_cap + 1, 1)
        scan.node_payload_data = mem.calloc(next_cap + 1, 1)
        scan.node_role_data = mem.calloc(next_cap + 1, 1)
        scan.node_expr_count_data = mem.calloc(next_cap + 1, 1)
    } else {
        scan.node_data = mem.realloc(scan.node_data, next_cap + 1)
        scan.node_meta_data = mem.realloc(scan.node_meta_data, next_cap + 1)
        scan.node_pos_data = mem.realloc(scan.node_pos_data, next_cap + 1)
        scan.node_payload_data = mem.realloc(scan.node_payload_data, next_cap + 1)
        scan.node_role_data = mem.realloc(scan.node_role_data, next_cap + 1)
        scan.node_expr_count_data = mem.realloc(scan.node_expr_count_data, next_cap + 1)
    }
    scan.node_cap = next_cap
    return scan
}

fn ensure_expr_arena(scan FunctionBodyScan, needed i32) FunctionBodyScan {
    if scan.expr_cap >= needed {
        return scan
    }
    next_cap := scan.expr_cap
    if next_cap <= 0 {
        next_cap = 32
    }
    for (; next_cap < needed; ) {
        next_cap = next_cap * 2
    }
    if next_cap > max_expr_lowering_nodes() {
        next_cap = max_expr_lowering_nodes()
    }
    if scan.expr_kind_data == none {
        scan.expr_kind_data = mem.calloc(next_cap + 1, 1)
        scan.expr_meta_data = mem.calloc(next_cap + 1, 1)
        scan.expr_pos_data = mem.calloc(next_cap + 1, 1)
        scan.expr_op_data = mem.calloc(next_cap + 1, 1)
        scan.expr_type_data = mem.calloc(next_cap + 1, 1)
    } else {
        scan.expr_kind_data = mem.realloc(scan.expr_kind_data, next_cap + 1)
        scan.expr_meta_data = mem.realloc(scan.expr_meta_data, next_cap + 1)
        scan.expr_pos_data = mem.realloc(scan.expr_pos_data, next_cap + 1)
        scan.expr_op_data = mem.realloc(scan.expr_op_data, next_cap + 1)
        scan.expr_type_data = mem.realloc(scan.expr_type_data, next_cap + 1)
    }
    scan.expr_cap = next_cap
    return scan
}

fn append_expr_node(scan FunctionBodyScan, kind i32, meta i32, pos i32, op_kind i32, type_kind i32) FunctionBodyScan {
    if kind <= 0 {
        return scan
    }
    if scan.expr_len >= max_expr_lowering_nodes() {
        return scan
    }
    scan = ensure_expr_arena(scan, scan.expr_len + 1)
    scan.expr_kind_data[scan.expr_len] = kind
    scan.expr_meta_data[scan.expr_len] = meta
    scan.expr_pos_data[scan.expr_len] = pos
    scan.expr_op_data[scan.expr_len] = op_kind
    scan.expr_type_data[scan.expr_len] = type_kind
    scan.expr_len += 1
    scan.expr_kind_data[scan.expr_len] = 0
    scan.expr_meta_data[scan.expr_len] = 0
    scan.expr_pos_data[scan.expr_len] = 0
    scan.expr_op_data[scan.expr_len] = 0
    scan.expr_type_data[scan.expr_len] = 0
    return scan
}

fn expr_arena_has_kind(scan FunctionBodyScan, kind i32) bool {
    i := 0
    for (; i < scan.expr_len; i++) {
        if scan.expr_kind_data[i] == kind {
            return true
        }
    }
    return false
}

fn expr_arena_has_kind_op(scan FunctionBodyScan, kind i32, op_kind i32) bool {
    i := 0
    for (; i < scan.expr_len; i++) {
        if scan.expr_kind_data[i] == kind && scan.expr_op_data[i] == op_kind {
            return true
        }
    }
    return false
}

fn append_first_expr_kind(scan FunctionBodyScan, table ExpressionTable, kind i32) FunctionBodyScan {
    if expr_arena_has_kind(scan, kind) {
        return scan
    }
    i := 0
    for (; i < table.node_len; i++) {
        if table.kind_data[i] == kind {
            return append_expr_node(scan, table.kind_data[i], table.meta_data[i], table.pos_data[i], table.op_data[i], table.type_data[i])
        }
    }
    return scan
}

fn append_first_expr_kind_op(scan FunctionBodyScan, table ExpressionTable, kind i32, op_kind i32) FunctionBodyScan {
    if expr_arena_has_kind_op(scan, kind, op_kind) {
        return scan
    }
    i := 0
    for (; i < table.node_len; i++) {
        if table.kind_data[i] == kind && table.op_data[i] == op_kind {
            return append_expr_node(scan, table.kind_data[i], table.meta_data[i], table.pos_data[i], table.op_data[i], table.type_data[i])
        }
    }
    return scan
}

fn append_first_expr_kind_from_scan(left FunctionBodyScan, right FunctionBodyScan, kind i32) FunctionBodyScan {
    if expr_arena_has_kind(left, kind) {
        return left
    }
    i := 0
    for (; i < right.expr_len; i++) {
        if right.expr_kind_data[i] == kind {
            return append_expr_node(left, right.expr_kind_data[i], right.expr_meta_data[i], right.expr_pos_data[i], right.expr_op_data[i], right.expr_type_data[i])
        }
    }
    return left
}

fn append_first_expr_kind_op_from_scan(left FunctionBodyScan, right FunctionBodyScan, kind i32, op_kind i32) FunctionBodyScan {
    if expr_arena_has_kind_op(left, kind, op_kind) {
        return left
    }
    i := 0
    for (; i < right.expr_len; i++) {
        if right.expr_kind_data[i] == kind && right.expr_op_data[i] == op_kind {
            return append_expr_node(left, right.expr_kind_data[i], right.expr_meta_data[i], right.expr_pos_data[i], right.expr_op_data[i], right.expr_type_data[i])
        }
    }
    return left
}

fn append_arena_node_meta_expr(scan FunctionBodyScan, kind i32, meta i32, pos i32, payload i32, role i32, expr_count i32) FunctionBodyScan {
    if kind <= 0 {
        return scan
    }
    scan = ensure_node_arena(scan, scan.node_len + 1)
    scan.node_data[scan.node_len] = kind
    scan.node_meta_data[scan.node_len] = meta
    scan.node_pos_data[scan.node_len] = pos
    scan.node_payload_data[scan.node_len] = payload
    scan.node_role_data[scan.node_len] = role
    scan.node_expr_count_data[scan.node_len] = expr_count
    scan.node_len += 1
    scan.node_data[scan.node_len] = 0
    scan.node_meta_data[scan.node_len] = 0
    scan.node_pos_data[scan.node_len] = 0
    scan.node_payload_data[scan.node_len] = 0
    scan.node_role_data[scan.node_len] = 0
    scan.node_expr_count_data[scan.node_len] = 0
    return scan
}

fn append_arena_node_meta(scan FunctionBodyScan, kind i32, meta i32, pos i32, payload i32, role i32) FunctionBodyScan {
    return append_arena_node_meta_expr(scan, kind, meta, pos, payload, role, 0)
}

fn append_arena_node(scan FunctionBodyScan, kind i32) FunctionBodyScan {
    return append_arena_node_meta(scan, kind, kind, 1, astbody.no_payload_kind(), astbody.no_semantic_role())
}

