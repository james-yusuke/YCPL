    resolved_assignment_numeric_state := llvm.build_load2(builder, i32_type, resolved_assignment_numeric_slot, "function_body_resolved_assignment_numeric_type_state")
    resolved_assignment_reference_state := llvm.build_load2(builder, i32_type, resolved_assignment_reference_slot, "function_body_resolved_assignment_reference_type_state")
    resolved_call_numeric_state := llvm.build_load2(builder, i32_type, resolved_call_numeric_slot, "function_body_resolved_call_numeric_type_state")
