    function_body_extended_left := llvm.build_add(builder, function_body_pair16, function_body_pair17, "function_body_extended_left")
    function_body_extended_mid := llvm.build_add(builder, function_body_pair18, function_body_pair19, "function_body_extended_mid")
    function_body_extended_right := llvm.build_add(builder, function_body_pair20, function_body_pair21, "function_body_extended_right")
    function_body_extended_tail := llvm.build_add(builder, function_body_pair22, function_body_pair23, "function_body_extended_tail")
    function_body_extended_extra_left := llvm.build_add(builder, function_body_pair24, function_body_pair25, "function_body_extended_extra_left")
    function_body_extended_extra_mid := llvm.build_add(builder, function_body_pair26, function_body_pair27, "function_body_extended_extra_mid")
    function_body_extended_extra_right := llvm.build_add(builder, function_body_pair28, function_body_pair29, "function_body_extended_extra_right")
    function_body_extended_extra_tail := llvm.build_add(builder, function_body_pair30, function_body_pair31, "function_body_extended_extra_tail")
    function_body_first_half := llvm.build_add(builder, function_body_left, function_body_mid, "function_body_first_half")
    function_body_second_half := llvm.build_add(builder, function_body_right, function_body_tail, "function_body_second_half")
    function_body_extra_first := llvm.build_add(builder, function_body_extra_left, function_body_extra_mid, "function_body_extra_first")
    function_body_extra_second := llvm.build_add(builder, function_body_extra_right, function_body_extra_tail, "function_body_extra_second")
    function_body_extra_slots := llvm.build_add(builder, function_body_extra_first, function_body_extra_second, "function_body_extra_slots")
    function_body_extended_first := llvm.build_add(builder, function_body_extended_left, function_body_extended_mid, "function_body_extended_first")
    function_body_extended_second := llvm.build_add(builder, function_body_extended_right, function_body_extended_tail, "function_body_extended_second")
    function_body_extended_extra_first := llvm.build_add(builder, function_body_extended_extra_left, function_body_extended_extra_mid, "function_body_extended_extra_first")
    function_body_extended_extra_second := llvm.build_add(builder, function_body_extended_extra_right, function_body_extended_extra_tail, "function_body_extended_extra_second")
    function_body_extended_base := llvm.build_add(builder, function_body_extended_first, function_body_extended_second, "function_body_extended_base")
    function_body_extended_extra := llvm.build_add(builder, function_body_extended_extra_first, function_body_extended_extra_second, "function_body_extended_extra")
    function_body_extended_slots := llvm.build_add(builder, function_body_extended_base, function_body_extended_extra, "function_body_extended_slots")
    function_body_base_slots := llvm.build_add(builder, function_body_first_half, function_body_second_half, "function_body_base_slots")
    function_body_slots_lowered := llvm.build_add(builder, function_body_base_slots, function_body_extra_slots, "function_body_slots_lowered")
