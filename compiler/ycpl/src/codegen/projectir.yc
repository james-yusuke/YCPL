        stmtlower.lower_body_node(ctx, body_fn, builder, i32_type, fn_type, call_helper, function_score_slot, function_local_state_slot, function_assignment_state_slot, function_call_state_slot, function_return_state_slot, function_symbol_env_slot, function_value_state_slot, function_control_state_slot, scan.node_data[arena_index], scan.node_meta_data[arena_index], scan.node_pos_data[arena_index], scan.node_payload_data[arena_index], scan.node_role_data[arena_index])
