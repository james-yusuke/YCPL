struct ConstFunctionScan {
    ok bool
    message string
    line i32
    col i32
    count i32
    sum i32
    first_value i32
    has_first bool
}

struct FunctionBodyScan {
    ok bool
    message string
    line i32
    col i32
    has_body bool
    functions i32
    nodes i32
    locals i32
    assignments i32
    calls i32
    returns i32
    ifs i32
    fors i32
    expr_nodes i32
    expr_primary_nodes i32
    expr_call_nodes i32
    expr_binary_nodes i32
    expr_unary_nodes i32
    expr_digest i32
    expr_slot_count i32
    expr_slot_digest i32
    expr_kind_data string
    expr_meta_data string
    expr_pos_data string
    expr_op_data string
    expr_len i32
    expr_cap i32
    node_data string
    node_meta_data string
    node_pos_data string
    node_payload_data string
    node_role_data string
    node_len i32
    node_cap i32
    listed_nodes i32
    node0 i32
    node1 i32
    node2 i32
    node3 i32
    node4 i32
    node5 i32
    node6 i32
    node7 i32
