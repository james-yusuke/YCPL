fn node_kind_at(scan FunctionBodyScan, index i32) i32 {
    if index == 0 { return scan.node0 }
    if index == 1 { return scan.node1 }
    if index == 2 { return scan.node2 }
    if index == 3 { return scan.node3 }
    if index == 4 { return scan.node4 }
    if index == 5 { return scan.node5 }
    if index == 6 { return scan.node6 }
    if index == 7 { return scan.node7 }
    if index == 8 { return scan.node8 }
    if index == 9 { return scan.node9 }
    if index == 10 { return scan.node10 }
    if index == 11 { return scan.node11 }
    if index == 12 { return scan.node12 }
    if index == 13 { return scan.node13 }
    if index == 14 { return scan.node14 }
    if index == 15 { return scan.node15 }
    return 0
}

fn append_listed_node(scan FunctionBodyScan, kind i32) FunctionBodyScan {
    if kind <= 0 {
        return scan
    }
    if scan.listed_nodes == 0 { scan.node0 = kind }
    if scan.listed_nodes == 1 { scan.node1 = kind }
    if scan.listed_nodes == 2 { scan.node2 = kind }
    if scan.listed_nodes == 3 { scan.node3 = kind }
    if scan.listed_nodes == 4 { scan.node4 = kind }
    if scan.listed_nodes == 5 { scan.node5 = kind }
    if scan.listed_nodes == 6 { scan.node6 = kind }
    if scan.listed_nodes == 7 { scan.node7 = kind }
    if scan.listed_nodes == 8 { scan.node8 = kind }
    if scan.listed_nodes == 9 { scan.node9 = kind }
    if scan.listed_nodes == 10 { scan.node10 = kind }
    if scan.listed_nodes == 11 { scan.node11 = kind }
    if scan.listed_nodes == 12 { scan.node12 = kind }
    if scan.listed_nodes == 13 { scan.node13 = kind }
    if scan.listed_nodes == 14 { scan.node14 = kind }
    if scan.listed_nodes == 15 { scan.node15 = kind }
    if scan.listed_nodes < 16 {
        scan.listed_nodes += 1
    }
    return scan
}

fn append_listed_and_arena_node(scan FunctionBodyScan, kind i32) FunctionBodyScan {
    scan = append_listed_node(scan, kind)
    scan = append_arena_node_meta(scan, kind, kind, 1, astbody.control_payload_kind(), astbody.control_flow_role())
    return scan
}

fn listed_nodes_have_kind(scan FunctionBodyScan, kind i32) bool {
    if scan.node0 == kind { return true }
    if scan.node1 == kind { return true }
    if scan.node2 == kind { return true }
    if scan.node3 == kind { return true }
    if scan.node4 == kind { return true }
    if scan.node5 == kind { return true }
    if scan.node6 == kind { return true }
    if scan.node7 == kind { return true }
    if scan.node8 == kind { return true }
    if scan.node9 == kind { return true }
    if scan.node10 == kind { return true }
    if scan.node11 == kind { return true }
    if scan.node12 == kind { return true }
    if scan.node13 == kind { return true }
    if scan.node14 == kind { return true }
    if scan.node15 == kind { return true }
    return false
}

fn ensure_control_nodes_listed(scan FunctionBodyScan) FunctionBodyScan {
    if scan.ifs > 0 && !listed_nodes_have_kind(scan, astbody.if_node_kind()) {
        if scan.listed_nodes < 16 {
            scan = append_listed_and_arena_node(scan, astbody.if_node_kind())
        } else {
            scan.node14 = astbody.if_node_kind()
            scan = append_arena_node_meta(scan, astbody.if_node_kind(), astbody.if_node_kind(), 1, astbody.control_payload_kind(), astbody.control_flow_role())
        }
        scan.sequence_digest = scan.sequence_digest * 31 + astbody.if_node_kind()
    }
    if scan.fors > 0 && !listed_nodes_have_kind(scan, astbody.for_node_kind()) {
        if scan.listed_nodes < 16 {
            scan = append_listed_and_arena_node(scan, astbody.for_node_kind())
        } else {
            scan.node15 = astbody.for_node_kind()
            scan = append_arena_node_meta(scan, astbody.for_node_kind(), astbody.for_node_kind(), 1, astbody.control_payload_kind(), astbody.control_flow_role())
        }
        scan.sequence_digest = scan.sequence_digest * 31 + astbody.for_node_kind()
    }
    return scan
}

fn merge_body_scan(left FunctionBodyScan, right FunctionBodyScan) FunctionBodyScan {
    if !left.ok {
        return left
    }
    if !right.ok {
        return right
    }
    if !right.has_body {
        left.functions += right.functions
        return left
    }

    left.has_body = true
    left.functions += right.functions
    left.nodes += right.nodes
    left.locals += right.locals
    left.assignments += right.assignments
    left.calls += right.calls
    left.returns += right.returns
    left.ifs += right.ifs
    left.fors += right.fors
    left.elses += right.elses
    left.breaks += right.breaks
    left.continues += right.continues
    left.for_ins += right.for_ins
    left.body_identifier_payloads += right.body_identifier_payloads
    left.body_literal_payloads += right.body_literal_payloads
    left.body_type_payloads += right.body_type_payloads
    left.body_control_payloads += right.body_control_payloads
    left.body_payload_digest = left.body_payload_digest * 131 + right.body_payload_digest
    left.body_local_symbol_refs += right.body_local_symbol_refs
    left.body_assignment_target_refs += right.body_assignment_target_refs
    left.body_call_target_refs += right.body_call_target_refs
    left.body_return_symbol_refs += right.body_return_symbol_refs
    left.body_return_literal_refs += right.body_return_literal_refs
    left.body_type_refs += right.body_type_refs
    left.body_control_refs += right.body_control_refs
    left.body_semantic_digest = left.body_semantic_digest * 131 + right.body_semantic_digest
    left.expr_nodes += right.expr_nodes
    left.expr_primary_nodes += right.expr_primary_nodes
    left.expr_identifier_nodes += right.expr_identifier_nodes
    left.expr_literal_nodes += right.expr_literal_nodes
    left.expr_string_nodes += right.expr_string_nodes
    left.expr_bool_nodes += right.expr_bool_nodes
    left.expr_none_nodes += right.expr_none_nodes
    left.expr_call_nodes += right.expr_call_nodes
    left.expr_typed_identifier_nodes += right.expr_typed_identifier_nodes
    left.expr_typed_call_nodes += right.expr_typed_call_nodes
    left.expr_project_typed_call_nodes += right.expr_project_typed_call_nodes
    left.expr_member_nodes += right.expr_member_nodes
    left.expr_index_nodes += right.expr_index_nodes
    left.expr_binary_nodes += right.expr_binary_nodes
    left.expr_unary_nodes += right.expr_unary_nodes
    left.expr_digest = left.expr_digest * 131 + right.expr_digest
    left.expr_slot_count += right.expr_slot_count
    left.expr_slot_digest = left.expr_slot_digest * 131 + right.expr_slot_digest
    left = append_first_expr_kind_from_scan(left, right, astexpr.identifier_expr_kind())
    left = append_first_expr_kind_from_scan(left, right, astexpr.literal_expr_kind())
    left = append_first_expr_kind_from_scan(left, right, astexpr.call_expr_kind())
    left = append_first_expr_kind_from_scan(left, right, astexpr.member_expr_kind())
    left = append_first_expr_kind_from_scan(left, right, astexpr.index_expr_kind())
    left = append_first_expr_kind_from_scan(left, right, astexpr.binary_expr_kind())
    left = append_first_expr_kind_from_scan(left, right, astexpr.unary_expr_kind())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.plus())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.minus())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.star())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.slash())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.percent())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.eq())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.neq())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.lt())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.gt())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.le())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.binary_expr_kind(), tok.ge())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.unary_expr_kind(), tok.minus())
    left = append_first_expr_kind_op_from_scan(left, right, astexpr.unary_expr_kind(), tok.bang())
    k := 0
    for (; k < right.expr_len && left.expr_len < max_regular_expr_lowering_nodes(); k++) {
        left = append_expr_node(left, right.expr_kind_data[k], right.expr_meta_data[k], right.expr_pos_data[k], right.expr_op_data[k], right.expr_type_data[k])
    }
    left.digest = left.digest * 131 + right.digest
    left.sequence_digest = left.sequence_digest * 131 + right.sequence_digest
    left.statement_expr_links += right.statement_expr_links
    left.statement_expr_nodes += right.statement_expr_nodes
    left.statement_expr_orphans += right.statement_expr_orphans
    if right.statement_expr_max_per_node > left.statement_expr_max_per_node {
        left.statement_expr_max_per_node = right.statement_expr_max_per_node
    }
    left.statement_expr_digest = left.statement_expr_digest * 131 + right.statement_expr_digest
    j := 0
    for (; j < right.node_len; j++) {
        left = append_arena_node_meta_expr(left, right.node_data[j], right.node_meta_data[j], right.node_pos_data[j], right.node_payload_data[j], right.node_role_data[j], right.node_expr_count_data[j])
    }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node0) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node1) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node2) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node3) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node4) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node5) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node6) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node7) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node8) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node9) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node10) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node11) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node12) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node13) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node14) }
    if left.listed_nodes < 16 { left = append_listed_node(left, right.node15) }
    left.line = right.line
    left.col = right.col
    return left
}

fn body_sequence_to_scan(seq BodyNodeSequence) FunctionBodyScan {
    if !seq.ok {
        return body_scan_fail(seq.line, seq.col, seq.message)
    }
    scan := FunctionBodyScan{ok: true, message: "", line: seq.line, col: seq.col, has_body: seq.selected_body, functions: seq.function_bodies, nodes: seq.nodes, locals: seq.local_nodes, assignments: seq.assignment_nodes, calls: seq.call_nodes, returns: seq.return_nodes, ifs: seq.if_nodes, fors: seq.for_nodes, elses: seq.else_nodes, breaks: seq.break_nodes, continues: seq.continue_nodes, for_ins: seq.for_in_nodes, body_identifier_payloads: seq.identifier_payloads, body_literal_payloads: seq.literal_payloads, body_type_payloads: seq.type_payloads, body_control_payloads: seq.control_payloads, body_payload_digest: seq.payload_digest, body_local_symbol_refs: seq.local_symbol_refs, body_assignment_target_refs: seq.assignment_target_refs, body_call_target_refs: seq.call_target_refs, body_return_symbol_refs: seq.return_symbol_refs, body_return_literal_refs: seq.return_literal_refs, body_type_refs: seq.type_refs, body_control_refs: seq.control_refs, body_semantic_digest: seq.semantic_digest, expr_nodes: 0, expr_primary_nodes: 0, expr_identifier_nodes: 0, expr_literal_nodes: 0, expr_string_nodes: 0, expr_bool_nodes: 0, expr_none_nodes: 0, expr_call_nodes: 0, expr_typed_identifier_nodes: 0, expr_typed_call_nodes: 0, expr_project_typed_call_nodes: 0, expr_member_nodes: 0, expr_index_nodes: 0, expr_binary_nodes: 0, expr_unary_nodes: 0, expr_digest: 17, expr_slot_count: 0, expr_slot_digest: 17, expr_kind_data: none, expr_meta_data: none, expr_pos_data: none, expr_op_data: none, expr_type_data: none, expr_len: 0, expr_cap: 0, node_data: seq.node_data, node_meta_data: seq.node_meta_data, node_pos_data: seq.node_pos_data, node_payload_data: seq.node_payload_data, node_role_data: seq.node_role_data, node_expr_count_data: seq.node_expr_count_data, node_len: seq.node_len, node_cap: seq.node_cap, statement_expr_links: seq.statement_expr_links, statement_expr_nodes: seq.statement_expr_nodes, statement_expr_orphans: seq.statement_expr_orphans, statement_expr_max_per_node: seq.statement_expr_max_per_node, statement_expr_digest: seq.statement_expr_digest, listed_nodes: 0, node0: 0, node1: 0, node2: 0, node3: 0, node4: 0, node5: 0, node6: 0, node7: 0, node8: 0, node9: 0, node10: 0, node11: 0, node12: 0, node13: 0, node14: 0, node15: 0, sequence_digest: seq.transition_digest, digest: seq.digest}
    j := 0
    for (; j < seq.node_len && j < 16; j++) {
        scan = append_listed_node(scan, seq.node_data[j])
    }
    return scan
}

fn attach_expr_table(scan FunctionBodyScan, table ExpressionTable) FunctionBodyScan {
    if !scan.ok {
        return scan
    }
    if !table.ok {
        return body_scan_fail(table.line, table.col, table.message)
    }
    scan.expr_nodes += table.nodes
    scan.expr_primary_nodes += table.primary_nodes
    scan.expr_identifier_nodes += table.identifier_nodes
    scan.expr_literal_nodes += table.literal_nodes
    scan.expr_string_nodes += table.string_nodes
    scan.expr_bool_nodes += table.bool_nodes
    scan.expr_none_nodes += table.none_nodes
    scan.expr_call_nodes += table.call_nodes
    scan.expr_member_nodes += table.member_nodes
    scan.expr_index_nodes += table.index_nodes
    scan.expr_binary_nodes += table.binary_nodes
    scan.expr_unary_nodes += table.unary_nodes
    scan.expr_digest = scan.expr_digest * 31 + table.digest
    scan.expr_slot_count += table.expr_slot_count
    scan.expr_slot_digest = scan.expr_slot_digest * 31 + table.expr_slot_digest
    j := 0
    for (; j < table.node_len; j++) {
        if table.kind_data[j] == astexpr.identifier_expr_kind() && table.type_data[j] > astexpr.unknown_type_kind() {
            scan.expr_typed_identifier_nodes += 1
        }
        if table.kind_data[j] == astexpr.call_expr_kind() {
            if table.type_data[j] > 16 {
                scan.expr_project_typed_call_nodes += 1
            } else if table.type_data[j] > astexpr.unknown_type_kind() {
                scan.expr_typed_call_nodes += 1
            }
        }
        if scan.expr_len < max_regular_expr_lowering_nodes() {
            scan = append_expr_node(scan, table.kind_data[j], table.meta_data[j], table.pos_data[j], table.op_data[j], table.type_data[j])
        }
    }
    scan = append_first_expr_kind(scan, table, astexpr.identifier_expr_kind())
    scan = append_first_expr_kind(scan, table, astexpr.literal_expr_kind())
    scan = append_first_expr_kind(scan, table, astexpr.call_expr_kind())
    scan = append_first_expr_kind(scan, table, astexpr.member_expr_kind())
    scan = append_first_expr_kind(scan, table, astexpr.index_expr_kind())
    scan = append_first_expr_kind(scan, table, astexpr.binary_expr_kind())
    scan = append_first_expr_kind(scan, table, astexpr.unary_expr_kind())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.plus())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.minus())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.star())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.slash())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.percent())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.eq())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.neq())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.lt())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.gt())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.le())
    scan = append_first_expr_kind_op(scan, table, astexpr.binary_expr_kind(), tok.ge())
    scan = append_first_expr_kind_op(scan, table, astexpr.unary_expr_kind(), tok.minus())
    scan = append_first_expr_kind_op(scan, table, astexpr.unary_expr_kind(), tok.bang())
    return scan
}

fn attach_expr_table_with_project_types(scan FunctionBodyScan, table ExpressionTable, project_types ProjectExprTypeTable) FunctionBodyScan {
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    table = apply_project_expr_types(table, project_types)
    table = apply_project_field_indices(table, project_types)
    return attach_expr_table(scan, table)
}

fn scan_nth_function_body(root string, target_index i32) FunctionBodyScan {
    sources := resolver.discover_sources(root)
    if !sources.ok {
        return body_scan_fail(1, 1, sources.message)
    }

    return scan_nth_function_body_from_sources(sources, target_index)
}

fn scan_nth_function_body_from_sources(sources SourceList, target_index i32) FunctionBodyScan {
    project_types := scan_project_expr_types_from_sources(sources)
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    return scan_nth_function_body_from_sources_with_project_types(sources, target_index, project_types)
}

fn scan_nth_function_body_from_sources_with_project_types(sources SourceList, target_index i32, project_types ProjectExprTypeTable) FunctionBodyScan {
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    remaining := target_index
    i := 0
    n := sources.count
    for (; i < n; i++) {
        path := resolver.source_path_at(sources, i)
        src := source.load(path)
        if !src.ok {
            return body_scan_fail(1, 1, "could not read project source")
        }
        body_nodes := bodyparser.parse_function(path, src.text, remaining)
        scan := body_sequence_to_scan(body_nodes)
        if !scan.ok {
            return scan
        }
        if scan.has_body {
            expr_nodes := exprparser.parse_function(path, src.text, remaining)
            scan = attach_expr_table_with_project_types(scan, expr_nodes, project_types)
            return scan
        }
        remaining -= scan.functions
    }

    return body_scan_empty()
}

fn scan_function_body_range(root string, start_index i32, count i32) FunctionBodyScan {
    sources := resolver.discover_sources(root)
    if !sources.ok {
        return body_scan_fail(1, 1, sources.message)
    }

    return scan_function_body_range_from_sources(sources, start_index, count)
}

fn scan_function_body_range_from_sources(sources SourceList, start_index i32, count i32) FunctionBodyScan {
    project_types := scan_project_expr_types_from_sources(sources)
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    return scan_function_body_range_from_sources_with_project_types(sources, start_index, count, project_types)
}

fn scan_function_body_range_from_sources_with_project_types(sources SourceList, start_index i32, count i32, project_types ProjectExprTypeTable) FunctionBodyScan {
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    aggregate := body_scan_empty()
    remaining_start := start_index
    remaining_count := count
    i := 0
    n := sources.count
    for (; i < n && remaining_count > 0; i++) {
        path := resolver.source_path_at(sources, i)
        src := source.load(path)
        if !src.ok {
            return body_scan_fail(1, 1, "could not read project source")
        }

        all_nodes := bodyparser.parse(path, src.text)
        if !all_nodes.ok {
            return body_scan_fail(all_nodes.line, all_nodes.col, all_nodes.message)
        }
        file_bodies := all_nodes.function_bodies
        if remaining_start >= file_bodies {
            remaining_start -= file_bodies
        } else {
            body_nodes := bodyparser.parse_range(path, src.text, remaining_start, remaining_count)
            scan := body_sequence_to_scan(body_nodes)
            if !scan.ok {
                return scan
            }
            expr_nodes := exprparser.parse_range(path, src.text, remaining_start, remaining_count)
            scan = attach_expr_table_with_project_types(scan, expr_nodes, project_types)
            if !scan.ok {
                return scan
            }
            if scan.has_body {
                aggregate = merge_body_scan(aggregate, scan)
                remaining_count -= scan.functions
            }
            remaining_start = 0
        }
    }

    if !aggregate.has_body {
        return body_scan_fail(1, 1, "project range has no function body to lower")
    }
    return aggregate
}

fn scan_all_function_bodies(root string) FunctionBodyScan {
    sources := resolver.discover_sources(root)
    if !sources.ok {
        return body_scan_fail(1, 1, sources.message)
    }

    return scan_all_function_bodies_from_sources(sources)
}

fn scan_all_function_bodies_from_sources(sources SourceList) FunctionBodyScan {
    project_types := scan_project_expr_types_from_sources(sources)
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    return scan_all_function_bodies_from_sources_with_project_types(sources, project_types)
}

fn scan_all_function_bodies_from_sources_with_project_types(sources SourceList, project_types ProjectExprTypeTable) FunctionBodyScan {
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    aggregate := body_scan_empty()
    i := 0
    n := sources.count
    for (; i < n; i++) {
        path := resolver.source_path_at(sources, i)
        src := source.load(path)
        if !src.ok {
            return body_scan_fail(1, 1, "could not read project source")
        }
        body_nodes := bodyparser.parse(path, src.text)
        scan := body_sequence_to_scan(body_nodes)
        if !scan.ok {
            return scan
        }
        expr_nodes := exprparser.parse(path, src.text)
        scan = attach_expr_table_with_project_types(scan, expr_nodes, project_types)
        if !scan.ok {
            return scan
        }
        aggregate = merge_body_scan(aggregate, scan)
    }

    if !aggregate.has_body {
        return body_scan_fail(1, 1, "project has no function body to lower")
    }
    return aggregate
}

fn scan_control_function_body(root string) FunctionBodyScan {
    sources := resolver.discover_sources(root)
    if !sources.ok {
        return body_scan_fail(1, 1, sources.message)
    }

    return scan_control_function_body_from_sources(sources)
}

fn scan_control_function_body_from_sources(sources SourceList) FunctionBodyScan {
    project_types := scan_project_expr_types_from_sources(sources)
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    return scan_control_function_body_from_sources_with_project_types(sources, project_types)
}

fn scan_control_function_body_from_sources_with_project_types(sources SourceList, project_types ProjectExprTypeTable) FunctionBodyScan {
    if !project_types.ok {
        return body_scan_fail(project_types.line, project_types.col, project_types.message)
    }
    fallback := body_scan_empty()
    has_fallback := false
    i := 0
    for (; i < 512; i++) {
        scan := scan_nth_function_body_from_sources_with_project_types(sources, i, project_types)
        if !scan.ok {
            return scan
        }
        if !scan.has_body {
            break
        }
        if !has_fallback {
            fallback = scan
            has_fallback = true
        }
        if scan.ifs > 0 || scan.fors > 0 {
            fallback = scan
        }
        if scan.ifs > 0 && scan.fors > 0 {
            return ensure_control_nodes_listed(scan)
        }
    }
    if has_fallback {
        return ensure_control_nodes_listed(fallback)
    }
    return body_scan_fail(1, 1, "project has no function body to lower")
}

fn scan_const_functions_in_source(path string, text string) ConstFunctionScan {
    lx := lexer.new(path, text)
    prev0 := tok.eof()
    prev1 := tok.eof()
    prev2 := tok.eof()
    prev3 := tok.eof()
    prev4 := tok.eof()
    prev5 := tok.eof()
    count := 0
    sum := 0
    first_value := 0
    has_first := false

    for (; true; ) {
        lx = lexer.next(lx)
        if !lx.ok {
            return ConstFunctionScan{ok: false, message: lx.message, line: lx.tok_line, col: lx.tok_col, count: 0, sum: 0, first_value: 0, has_first: false}
        }
        if lx.kind == tok.eof() {
            break
        }

        if lx.kind == tok.int_lit() && prev0 == tok.kw_return() && prev1 == tok.lbrace() && prev2 == tok.ident() && prev3 == tok.rparen() && prev4 == tok.lparen() && prev5 == tok.ident() {
            value := parse_i32(lx.lexeme)
            count += 1
            sum += value
            if !has_first {
                first_value = value
                has_first = true
            }
        }

        if lx.kind != tok.newline() {
            prev5 = prev4
            prev4 = prev3
            prev3 = prev2
            prev2 = prev1
            prev1 = prev0
            prev0 = lx.kind
        }
    }

    return ConstFunctionScan{ok: true, message: "", line: 1, col: 1, count: count, sum: sum, first_value: first_value, has_first: has_first}
}

fn scan_const_functions(root string) ConstFunctionScan {
    sources := resolver.discover_sources(root)
    if !sources.ok {
        return ConstFunctionScan{ok: false, message: sources.message, line: 1, col: 1, count: 0, sum: 0, first_value: 0, has_first: false}
    }

    return scan_const_functions_from_sources(sources)
}

fn scan_const_functions_from_sources(sources SourceList) ConstFunctionScan {
    total_count := 0
    total_sum := 0
    first_value := 0
    has_first := false
    i := 0
    n := sources.count
    for (; i < n; i++) {
        path := resolver.source_path_at(sources, i)
        src := source.load(path)
        if !src.ok {
            return ConstFunctionScan{ok: false, message: "could not read project source", line: 1, col: 1, count: 0, sum: 0, first_value: 0, has_first: false}
        }
        scan := scan_const_functions_in_source(path, src.text)
        if !scan.ok {
            return scan
        }
        total_count += scan.count
        total_sum += scan.sum
        if !has_first && scan.has_first {
            first_value = scan.first_value
            has_first = true
        }
    }
    return ConstFunctionScan{ok: true, message: "", line: 1, col: 1, count: total_count, sum: total_sum, first_value: first_value, has_first: has_first}
}

fn build_named_i32_slot(builder *byte, i32_type *byte, name string, value i32) *byte {
    slot := llvm.build_alloca(builder, i32_type, name)
    constant := llvm.const_int(i32_type, value, 1)
    llvm.build_store(builder, constant, slot)
    return slot
}

fn build_loaded_i32_slot(builder *byte, i32_type *byte, name string, value i32, loaded_name string) *byte {
    slot := build_named_i32_slot(builder, i32_type, name, value)
    return llvm.build_load2(builder, i32_type, slot, loaded_name)
}

fn emit_compact_function_body_lowering(ctx *byte, mod *byte, builder *byte, i32_type *byte, fn_type *byte, call_helper *byte, name string, scan FunctionBodyScan) *byte {
    body_fn := llvm.add_function(mod, name, fn_type)
    entry := llvm.append_basic_block_in_context(ctx, body_fn, "entry")
    if_then := llvm.append_basic_block_in_context(ctx, body_fn, "function_if_then")
    if_else := llvm.append_basic_block_in_context(ctx, body_fn, "function_if_else")
    for_check := llvm.append_basic_block_in_context(ctx, body_fn, "function_for_check")
    for_body := llvm.append_basic_block_in_context(ctx, body_fn, "function_for_body")
    done := llvm.append_basic_block_in_context(ctx, body_fn, "done")
    llvm.position_builder_at_end(builder, entry)

    zero := llvm.const_int(i32_type, 0, 1)
    one := llvm.const_int(i32_type, 1, 1)
    local_state_slot := build_named_i32_slot(builder, i32_type, "function_body_local_state", scan.locals)
    assignment_state_slot := build_named_i32_slot(builder, i32_type, "function_body_assignment_state", scan.assignments)
    call_state_slot := build_named_i32_slot(builder, i32_type, "function_body_call_state", scan.calls)
    return_state_slot := build_named_i32_slot(builder, i32_type, "function_body_return_state", scan.returns)
    local_loaded := llvm.build_load2(builder, i32_type, local_state_slot, "function_body_resolved_local_loaded")
    assignment_loaded := llvm.build_load2(builder, i32_type, assignment_state_slot, "function_body_resolved_assignment_loaded")
    call_loaded := llvm.build_load2(builder, i32_type, call_state_slot, "function_body_resolved_call_loaded")
    return_loaded := llvm.build_load2(builder, i32_type, return_state_slot, "function_body_resolved_return_loaded")
    score_slot := build_named_i32_slot(builder, i32_type, "function_body_score", scan.nodes)
    symbol_env_slot := build_named_i32_slot(builder, i32_type, "function_body_symbol_env", scan.body_local_symbol_refs + scan.body_assignment_target_refs)
    value_state_slot := build_named_i32_slot(builder, i32_type, "function_body_value_state", scan.body_call_target_refs + scan.body_return_symbol_refs)
    control_state_slot := build_named_i32_slot(builder, i32_type, "function_body_control_state", scan.ifs + scan.fors + scan.elses + scan.breaks + scan.continues + scan.for_ins)
    symbol_env := llvm.build_load2(builder, i32_type, symbol_env_slot, "function_body_lowered_symbol_env")
    value_env := llvm.build_load2(builder, i32_type, value_state_slot, "function_body_lowered_value_state")
    control_env := llvm.build_load2(builder, i32_type, control_state_slot, "function_body_lowered_control_state")
    build_named_i32_slot(builder, i32_type, "function_body_identifier_payloads", scan.body_identifier_payloads)
    build_named_i32_slot(builder, i32_type, "function_body_literal_payloads", scan.body_literal_payloads)
    build_named_i32_slot(builder, i32_type, "function_body_type_payloads", scan.body_type_payloads)
    build_named_i32_slot(builder, i32_type, "function_body_control_payloads", scan.body_control_payloads)
    build_named_i32_slot(builder, i32_type, "function_body_local_symbol_refs", scan.body_local_symbol_refs)
    build_named_i32_slot(builder, i32_type, "function_body_assignment_target_refs", scan.body_assignment_target_refs)
    build_named_i32_slot(builder, i32_type, "function_body_call_target_refs", scan.body_call_target_refs)
    build_named_i32_slot(builder, i32_type, "function_body_return_symbol_refs", scan.body_return_symbol_refs)
    semantic_surface := build_loaded_i32_slot(builder, i32_type, "function_body_semantic_surface", scan.body_semantic_digest, "function_body_semantic_node_sum")
    build_named_i32_slot(builder, i32_type, "node_lower_local_slot", scan.locals)
    build_named_i32_slot(builder, i32_type, "node_lower_assignment_slot", scan.assignments)
    build_named_i32_slot(builder, i32_type, "node_lower_call_value", scan.calls)
    build_named_i32_slot(builder, i32_type, "node_lower_return_slot", scan.returns)
    build_named_i32_slot(builder, i32_type, "node_lower_else_body", scan.elses)
    build_named_i32_slot(builder, i32_type, "node_lower_break_slot", scan.breaks)
    build_named_i32_slot(builder, i32_type, "node_lower_continue_slot", scan.continues)
    build_named_i32_slot(builder, i32_type, "node_lower_for_in_check", scan.for_ins)
    build_named_i32_slot(builder, i32_type, "node_lower_if_then", scan.ifs)
    build_named_i32_slot(builder, i32_type, "node_lower_for_check", scan.fors)
    build_named_i32_slot(builder, i32_type, "node_lower_for_has_more", scan.fors)
    build_named_i32_slot(builder, i32_type, "function_for_has_more", scan.fors)
    build_named_i32_slot(builder, i32_type, "function_if_else_surface", scan.elses)
    build_named_i32_slot(builder, i32_type, "function_for_in_surface", scan.for_ins)
    build_named_i32_slot(builder, i32_type, "function_break_continue_surface", scan.breaks + scan.continues)
    build_named_i32_slot(builder, i32_type, "function_control_surface", scan.ifs + scan.fors + scan.elses + scan.for_ins)
    build_named_i32_slot(builder, i32_type, "node_sequence_digest_score", scan.sequence_digest)
    build_named_i32_slot(builder, i32_type, "node_sequence_score", scan.listed_nodes)
    build_named_i32_slot(builder, i32_type, "node_metadata_score", scan.body_payload_digest)
    build_named_i32_slot(builder, i32_type, "node_source_pos_score", scan.body_control_refs)
    build_named_i32_slot(builder, i32_type, "node_payload_score", scan.body_identifier_payloads + scan.body_literal_payloads + scan.body_type_payloads)
    build_named_i32_slot(builder, i32_type, "node_semantic_role_score", scan.body_semantic_digest)

    build_named_i32_slot(builder, i32_type, "function_expr_nodes", scan.expr_nodes)
    expr_value_state_slot := build_named_i32_slot(builder, i32_type, "function_expr_value_state", scan.expr_nodes)
    expr_type_state_slot := build_named_i32_slot(builder, i32_type, "function_expr_type_state", scan.expr_digest)
    real_statement_value_slot := build_named_i32_slot(builder, i32_type, "function_body_real_statement_ast_value_slot", 0)
    real_statement_type_slot := build_named_i32_slot(builder, i32_type, "function_body_real_statement_resolved_type_slot", 0)
    real_ast_sequence_slot := build_named_i32_slot(builder, i32_type, "function_body_real_ast_node_sequence_state", 0)
    real_ast_semantic_slot := build_named_i32_slot(builder, i32_type, "function_body_real_ast_node_semantic_sequence_state", 0)
    real_owner_slot := build_named_i32_slot(builder, i32_type, "function_body_real_statement_expr_owner_state", 0)
    real_i32_slot := build_named_i32_slot(builder, i32_type, "function_body_real_i32_statement_expr_state", 0)
    real_bool_slot := build_named_i32_slot(builder, i32_type, "function_body_real_bool_statement_expr_state", 0)
    real_string_slot := build_named_i32_slot(builder, i32_type, "function_body_real_string_statement_expr_state", 0)
    real_pointer_slot := build_named_i32_slot(builder, i32_type, "function_body_real_pointer_statement_expr_state", 0)
    real_none_slot := build_named_i32_slot(builder, i32_type, "function_body_real_none_statement_expr_state", 0)
    real_unknown_slot := build_named_i32_slot(builder, i32_type, "function_body_real_unknown_statement_expr_state", 0)
    resolved_local_numeric_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_local_numeric_type_flow_slot", 0)
    resolved_local_reference_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_local_reference_type_flow_slot", 0)
    resolved_assignment_numeric_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_assignment_numeric_type_flow_slot", 0)
    resolved_assignment_reference_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_assignment_reference_type_flow_slot", 0)
    resolved_call_numeric_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_call_numeric_type_flow_slot", 0)
    resolved_call_reference_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_call_reference_type_flow_slot", 0)
    resolved_return_numeric_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_return_numeric_type_flow_slot", 0)
    resolved_return_reference_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_return_reference_type_flow_slot", 0)
    resolved_unknown_type_slot := build_named_i32_slot(builder, i32_type, "function_body_resolved_unknown_role_type_flow_slot", 0)
    build_named_i32_slot(builder, i32_type, "function_body_real_node_lowering_limit", max_real_body_lowering_nodes())
    build_named_i32_slot(builder, i32_type, "function_body_real_expr_lowering_limit", max_real_expr_lowering_nodes())
    build_named_i32_slot(builder, i32_type, "function_body_real_statement_expr_lowering_limit", max_real_statement_expr_lowering_nodes())
    actual_node_index := 0
    actual_expr_cursor := 0
    for (; actual_node_index < scan.node_len && actual_node_index < max_real_body_lowering_nodes(); actual_node_index++) {
        node_kind := scan.node_data[actual_node_index]
        node_meta := scan.node_meta_data[actual_node_index]
        node_pos := scan.node_pos_data[actual_node_index]
        node_payload := scan.node_payload_data[actual_node_index]
        node_role := scan.node_role_data[actual_node_index]
        node_exprs := scan.node_expr_count_data[actual_node_index]
        stmtlower.lower_body_node(ctx, body_fn, builder, i32_type, fn_type, call_helper, score_slot, local_state_slot, assignment_state_slot, call_state_slot, return_state_slot, symbol_env_slot, value_state_slot, control_state_slot, node_kind, node_meta, node_pos, node_payload, node_role)
        stmtlower.lower_ast_node_sequence_state(builder, i32_type, real_ast_sequence_slot, node_kind, node_meta, node_pos, node_payload, node_role, node_exprs)
        stmtlower.lower_ast_node_semantic_sequence_state(builder, i32_type, real_ast_semantic_slot, node_kind, node_meta, node_pos, node_payload, node_role, node_exprs)
        if node_exprs > 0 {
            stmtlower.lower_statement_expr_owner_node(builder, i32_type, score_slot, real_owner_slot, value_state_slot, node_kind, node_meta, node_pos, node_payload, node_role, node_exprs)
        }
        bodyflow.begin_statement_value(builder, i32_type, real_statement_value_slot, node_kind, node_meta, node_pos, node_payload, node_role, node_exprs)
        bodyflow.begin_statement_resolved_type(builder, i32_type, real_statement_type_slot)
        per_statement_expr := 0
        for (; per_statement_expr < node_exprs && actual_expr_cursor < scan.expr_len && actual_expr_cursor < max_real_expr_lowering_nodes() && per_statement_expr < max_real_statement_expr_lowering_nodes(); per_statement_expr++) {
            exprlower.lower_expr_node(ctx, body_fn, builder, i32_type, fn_type, call_helper, score_slot, expr_value_state_slot, expr_type_state_slot, scan.expr_kind_data[actual_expr_cursor], scan.expr_meta_data[actual_expr_cursor], scan.expr_pos_data[actual_expr_cursor], scan.expr_op_data[actual_expr_cursor], scan.expr_type_data[actual_expr_cursor])
            real_expr_value := llvm.build_load2(builder, i32_type, expr_value_state_slot, "function_body_real_statement_expr_value")
            real_expr_type := llvm.build_load2(builder, i32_type, expr_type_state_slot, "function_body_real_statement_expr_type")
