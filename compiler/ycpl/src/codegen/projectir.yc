    function_body_range_mid := llvm.build_add(builder, function_body_range2_lowered, function_body_range3_lowered, "function_body_range_mid")
    function_body_range_right := llvm.build_add(builder, function_body_range4_lowered, function_body_range5_lowered, "function_body_range_right")
    function_body_range_tail := llvm.build_add(builder, function_body_range_right, function_body_range6_lowered, "function_body_range_tail")
    function_body_range_first := llvm.build_add(builder, function_body_range_left, function_body_range_mid, "function_body_range_first")
    function_body_ranges_lowered := llvm.build_add(builder, function_body_range_first, function_body_range_tail, "function_body_ranges_lowered")
    dynamic_range_first_bucket := emit_dynamic_function_body_bucket_lowering(ctx, mod, builder, i32_type, fn_type, call_fn, entry, individual_sources, 0, 64, 1, project.function_bodies, "ycpl_project_dynamic_range_body_", "function_body_dynamic_range_lowered_", "function_body_dynamic_range_total_")
    dynamic_range_tail_bucket := emit_dynamic_function_body_bucket_lowering(ctx, mod, builder, i32_type, fn_type, call_fn, entry, individual_sources, 384, 64, 1, project.function_bodies, "ycpl_project_dynamic_range_body_", "function_body_dynamic_range_lowered_", "function_body_dynamic_range_total_")
    dynamic_range_buckets_lowered := llvm.build_add(builder, dynamic_range_first_bucket, dynamic_range_tail_bucket, "function_body_dynamic_range_buckets_lowered")
    function_body_dynamic_range_gate := llvm.build_add(builder, function_body_ranges_lowered, dynamic_range_buckets_lowered, "function_body_dynamic_range_gate")
    function_body_aggregate_lowered := llvm.build_add(builder, all_function_bodies_lowered, control_function_body_lowered, "function_body_aggregate_lowered")
    function_body_slot_and_range_lowered := llvm.build_add(builder, function_body_first64_slots_lowered, function_body_dynamic_range_gate, "function_body_slot_and_range_lowered")
    function_body_lowered := llvm.build_add(builder, function_body_aggregate_lowered, function_body_slot_and_range_lowered, "function_body_lowered")
    dynamic_first64_lowered := emit_dynamic_function_body_lowering_range(ctx, mod, builder, i32_type, fn_type, call_fn, entry, individual_sources, 0, 64, project.function_bodies, "ycpl_project_dynamic_first_body_", "function_body_dynamic_first_lowered_", "function_body_dynamic_first_total_")
    remaining_individual_bodies_lowered := emit_remaining_individual_function_body_lowering(ctx, mod, builder, i32_type, fn_type, call_fn, entry, individual_sources, 64, project.function_bodies)
    dynamic_selfhost_body_gate := llvm.build_add(builder, dynamic_first64_lowered, remaining_individual_bodies_lowered, "function_body_dynamic_selfhost_gate")
    all_individual_function_bodies_lowered := llvm.build_add(builder, function_body_lowered, dynamic_selfhost_body_gate, "function_body_all_individual_lowered")

    returns_value := llvm.const_int(i32_type, project.returns, 1)
    expr_table_with_slots := llvm.build_add(builder, expression_table_lowered, expression_slot_lowered, "expr_table_with_slots")
    expr_with_table := llvm.build_add(builder, loaded_expressions, expr_table_with_slots, "expr_with_table")
    expr_return_sum := llvm.build_add(builder, expr_with_table, returns_value, "expr_return_sum")
    statement_expr_sum := llvm.build_add(builder, loaded_statements, expr_return_sum, "statement_expr_sum")
    body_without_consts := llvm.build_add(builder, statement_expr_sum, lowered_locals, "body_without_consts")
    body_with_function := llvm.build_add(builder, body_without_consts, all_individual_function_bodies_lowered, "body_with_function_lowering")
    total := llvm.build_add(builder, body_with_function, const_lowered, "project_body_total")
    llvm.build_ret(builder, total)

    ir := llvm.print_module_to_string(mod)
    merge_text := mergeable_ir_text(ir)
    fs.mkdir(out_dir)
    out_file := project_body_path(out_dir)
    wrote := fs.write_file(out_file, ir)

    llvm.dispose_message(ir)
    llvm.dispose_builder(builder)
    llvm.dispose_module(mod)
    llvm.context_dispose(ctx)

    if !wrote {
        return fail("failed to write project statement/expression LLVM IR")
    }
    return ok_with_text(out_file, merge_text)
}
