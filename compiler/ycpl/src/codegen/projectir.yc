    lowered_environment_state := llvm.build_add(builder, lowered_environment_state_left, lowered_control_state, "function_body_lowered_environment_state")
    function_body_statement_expr_numeric_bool := llvm.build_add(builder, lowered_i32_statement_expr_state, lowered_bool_statement_expr_state, "function_body_statement_expr_numeric_bool_environment")
    function_body_statement_expr_string_pointer := llvm.build_add(builder, lowered_string_statement_expr_state, lowered_pointer_statement_expr_state, "function_body_statement_expr_string_pointer_environment")
    function_body_statement_expr_none_unknown := llvm.build_add(builder, lowered_none_statement_expr_state, lowered_unknown_statement_expr_state, "function_body_statement_expr_none_unknown_environment")
    function_body_statement_expr_typed_left := llvm.build_add(builder, function_body_statement_expr_numeric_bool, function_body_statement_expr_string_pointer, "function_body_statement_expr_typed_left_environment")
    function_body_statement_expr_typed_environment := llvm.build_add(builder, function_body_statement_expr_typed_left, function_body_statement_expr_none_unknown, "function_body_statement_expr_typed_environment")
    function_body_expr_typed_environment := llvm.build_add(builder, lowered_expr_value_state, lowered_expr_type_state, "function_body_expr_typed_environment")
    function_body_expr_typed_with_statement_environment := llvm.build_add(builder, function_body_expr_typed_environment, function_body_statement_expr_typed_environment, "function_body_expr_typed_with_statement_environment")
    function_body_expr_value_environment := llvm.build_add(builder, lowered_environment_state, function_body_expr_typed_with_statement_environment, "function_body_expr_value_environment")
    function_body_expr_owner_state_base := llvm.build_add(builder, lowered_statement_expr_owner_state, lowered_statement_expr_owner_count, "function_body_statement_expr_owner_lowered_state")
    function_body_resolved_statement_state := llvm.build_add(builder, lowered_statement_ast_value, lowered_statement_resolved_type, "function_body_resolved_statement_lowered_state")
    function_body_expr_owner_state := llvm.build_add(builder, function_body_expr_owner_state_base, function_body_resolved_statement_state, "function_body_statement_ast_lowered_state")
    function_body_ast_node_semantic_sequence_lowered := llvm.build_add(builder, lowered_ast_node_sequence_state, lowered_ast_node_semantic_sequence_state, "function_body_ast_node_semantic_sequence_lowered")
    function_body_ast_node_sequence_lowered := llvm.build_add(builder, function_body_expr_owner_state, function_body_ast_node_semantic_sequence_lowered, "function_body_ast_node_sequence_lowered")
    function_body_expr_owner_environment := llvm.build_add(builder, function_body_expr_value_environment, function_body_ast_node_sequence_lowered, "function_body_expr_owner_environment")
    function_body_lowered_with_env := llvm.build_add(builder, function_body_total, function_body_expr_owner_environment, "function_body_lowered_with_environment")
    function_body_lowered_total := llvm.build_add(builder, function_body_lowered_with_env, lowered_statement_state, "function_body_lowered_total")
    llvm.build_ret(builder, function_body_lowered_total)
    return body_fn
}

fn emit_dynamic_function_body_lowering_range(ctx *byte, mod *byte, builder *byte, i32_type *byte, fn_type *byte, call_helper *byte, main_entry *byte, sources SourceList, project_types ProjectExprTypeTable, start_index i32, max_count i32, function_count i32, function_prefix string, call_prefix string, sum_prefix string) *byte {
    total := llvm.const_int(i32_type, 0, 1)
    i := start_index
    emitted := 0
    for (; i < function_count; i++) {
        if max_count >= 0 && emitted >= max_count {
            break
        }
        scan := scan_nth_function_body_from_sources_with_project_types(sources, i, project_types)
        if scan.ok && scan.has_body {
            body_name := indexed_name(function_prefix, i)
            call_name := indexed_name(call_prefix, i)
            sum_name := indexed_name(sum_prefix, i)
            body_fn := emit_function_body_lowering(ctx, mod, builder, i32_type, fn_type, call_helper, body_name, scan)
            llvm.position_builder_at_end(builder, main_entry)
            lowered := llvm.build_call2(builder, fn_type, body_fn, none, 0, call_name)
            total = llvm.build_add(builder, total, lowered, sum_name)
        }
        emitted += 1
    }
    llvm.position_builder_at_end(builder, main_entry)
    return total
}

fn emit_remaining_individual_function_body_lowering(ctx *byte, mod *byte, builder *byte, i32_type *byte, fn_type *byte, call_helper *byte, main_entry *byte, sources SourceList, project_types ProjectExprTypeTable, start_index i32, function_count i32) *byte {
    return emit_dynamic_function_body_lowering_range(ctx, mod, builder, i32_type, fn_type, call_helper, main_entry, sources, project_types, start_index, -1, function_count, "ycpl_project_function_body_", "function_body_dynamic_lowered_", "function_body_dynamic_total_")
}

fn emit_dynamic_function_body_bucket_lowering(ctx *byte, mod *byte, builder *byte, i32_type *byte, fn_type *byte, call_helper *byte, main_entry *byte, sources SourceList, project_types ProjectExprTypeTable, start_index i32, bucket_size i32, max_buckets i32, function_count i32, function_prefix string, call_prefix string, sum_prefix string) *byte {
    total := llvm.const_int(i32_type, 0, 1)
    start := start_index
    bucket := start_index / bucket_size
    emitted := 0
    for (; start < function_count; ) {
        if max_buckets >= 0 && emitted >= max_buckets {
            break
        }
        count := bucket_size
        remaining := function_count - start
        if count > remaining {
            count = remaining
        }
        scan := scan_function_body_range_from_sources_with_project_types(sources, start, count, project_types)
        if scan.ok && scan.has_body {
            body_name := indexed_name(function_prefix, bucket)
            call_name := indexed_name(call_prefix, bucket)
            sum_name := indexed_name(sum_prefix, bucket)
            body_fn := emit_function_body_lowering(ctx, mod, builder, i32_type, fn_type, call_helper, body_name, scan)
            llvm.position_builder_at_end(builder, main_entry)
            lowered := llvm.build_call2(builder, fn_type, body_fn, none, 0, call_name)
            total = llvm.build_add(builder, total, lowered, sum_name)
        }
        start += bucket_size
        bucket += 1
        emitted += 1
    }
    llvm.position_builder_at_end(builder, main_entry)
    return total
}

