    function_body_pair16 := llvm.build_add(builder, function_body32_lowered, function_body33_lowered, "function_body_pair16")
    function_body_pair17 := llvm.build_add(builder, function_body34_lowered, function_body35_lowered, "function_body_pair17")
    function_body_pair18 := llvm.build_add(builder, function_body36_lowered, function_body37_lowered, "function_body_pair18")
    function_body_pair19 := llvm.build_add(builder, function_body38_lowered, function_body39_lowered, "function_body_pair19")
    function_body_pair20 := llvm.build_add(builder, function_body40_lowered, function_body41_lowered, "function_body_pair20")
    function_body_pair21 := llvm.build_add(builder, function_body42_lowered, function_body43_lowered, "function_body_pair21")
    function_body_pair22 := llvm.build_add(builder, function_body44_lowered, function_body45_lowered, "function_body_pair22")
    function_body_pair23 := llvm.build_add(builder, function_body46_lowered, function_body47_lowered, "function_body_pair23")
    function_body_pair24 := llvm.build_add(builder, function_body48_lowered, function_body49_lowered, "function_body_pair24")
    function_body_pair25 := llvm.build_add(builder, function_body50_lowered, function_body51_lowered, "function_body_pair25")
    function_body_pair26 := llvm.build_add(builder, function_body52_lowered, function_body53_lowered, "function_body_pair26")
    function_body_pair27 := llvm.build_add(builder, function_body54_lowered, function_body55_lowered, "function_body_pair27")
    function_body_pair28 := llvm.build_add(builder, function_body56_lowered, function_body57_lowered, "function_body_pair28")
    function_body_pair29 := llvm.build_add(builder, function_body58_lowered, function_body59_lowered, "function_body_pair29")
    function_body_pair30 := llvm.build_add(builder, function_body60_lowered, function_body61_lowered, "function_body_pair30")
    function_body_pair31 := llvm.build_add(builder, function_body62_lowered, function_body63_lowered, "function_body_pair31")
    function_body_left := llvm.build_add(builder, function_body_pair0, function_body_pair1, "function_body_left")
    function_body_mid := llvm.build_add(builder, function_body_pair2, function_body_pair3, "function_body_mid")
    function_body_right := llvm.build_add(builder, function_body_pair4, function_body_pair5, "function_body_right")
    function_body_tail := llvm.build_add(builder, function_body_pair6, function_body_pair7, "function_body_tail")
    function_body_extra_left := llvm.build_add(builder, function_body_pair8, function_body_pair9, "function_body_extra_left")
    function_body_extra_mid := llvm.build_add(builder, function_body_pair10, function_body_pair11, "function_body_extra_mid")
    function_body_extra_right := llvm.build_add(builder, function_body_pair12, function_body_pair13, "function_body_extra_right")
    function_body_extra_tail := llvm.build_add(builder, function_body_pair14, function_body_pair15, "function_body_extra_tail")
    function_body_extended_left := llvm.build_add(builder, function_body_pair16, function_body_pair17, "function_body_extended_left")
    function_body_extended_mid := llvm.build_add(builder, function_body_pair18, function_body_pair19, "function_body_extended_mid")
    function_body_extended_right := llvm.build_add(builder, function_body_pair20, function_body_pair21, "function_body_extended_right")
    function_body_extended_tail := llvm.build_add(builder, function_body_pair22, function_body_pair23, "function_body_extended_tail")
    function_body_extended_extra_left := llvm.build_add(builder, function_body_pair24, function_body_pair25, "function_body_extended_extra_left")
    function_body_extended_extra_mid := llvm.build_add(builder, function_body_pair26, function_body_pair27, "function_body_extended_extra_mid")
    function_body_extended_extra_right := llvm.build_add(builder, function_body_pair28, function_body_pair29, "function_body_extended_extra_right")
    function_body_extended_extra_tail := llvm.build_add(builder, function_body_pair30, function_body_pair31, "function_body_extended_extra_tail")
    function_body_first_half := llvm.build_add(builder, function_body_left, function_body_mid, "function_body_first_half")
    function_body_second_half := llvm.build_add(builder, function_body_right, function_body_tail, "function_body_second_half")
    function_body_extra_first := llvm.build_add(builder, function_body_extra_left, function_body_extra_mid, "function_body_extra_first")
    function_body_extra_second := llvm.build_add(builder, function_body_extra_right, function_body_extra_tail, "function_body_extra_second")
    function_body_extra_slots := llvm.build_add(builder, function_body_extra_first, function_body_extra_second, "function_body_extra_slots")
    function_body_extended_first := llvm.build_add(builder, function_body_extended_left, function_body_extended_mid, "function_body_extended_first")
    function_body_extended_second := llvm.build_add(builder, function_body_extended_right, function_body_extended_tail, "function_body_extended_second")
    function_body_extended_extra_first := llvm.build_add(builder, function_body_extended_extra_left, function_body_extended_extra_mid, "function_body_extended_extra_first")
    function_body_extended_extra_second := llvm.build_add(builder, function_body_extended_extra_right, function_body_extended_extra_tail, "function_body_extended_extra_second")
    function_body_extended_base := llvm.build_add(builder, function_body_extended_first, function_body_extended_second, "function_body_extended_base")
    function_body_extended_extra := llvm.build_add(builder, function_body_extended_extra_first, function_body_extended_extra_second, "function_body_extended_extra")
    function_body_extended_slots := llvm.build_add(builder, function_body_extended_base, function_body_extended_extra, "function_body_extended_slots")
    function_body_base_slots := llvm.build_add(builder, function_body_first_half, function_body_second_half, "function_body_base_slots")
    function_body_slots_lowered := llvm.build_add(builder, function_body_base_slots, function_body_extra_slots, "function_body_slots_lowered")
    function_body_first64_slots_lowered := llvm.build_add(builder, function_body_slots_lowered, function_body_extended_slots, "function_body_first64_slots_lowered")
    function_body_range_left := llvm.build_add(builder, function_body_range0_lowered, function_body_range1_lowered, "function_body_range_left")
    function_body_range_mid := llvm.build_add(builder, function_body_range2_lowered, function_body_range3_lowered, "function_body_range_mid")
    function_body_range_right := llvm.build_add(builder, function_body_range4_lowered, function_body_range5_lowered, "function_body_range_right")
    function_body_range_tail := llvm.build_add(builder, function_body_range_right, function_body_range6_lowered, "function_body_range_tail")
    function_body_range_first := llvm.build_add(builder, function_body_range_left, function_body_range_mid, "function_body_range_first")
    function_body_ranges_lowered := llvm.build_add(builder, function_body_range_first, function_body_range_tail, "function_body_ranges_lowered")
    dynamic_range_first_bucket := emit_dynamic_function_body_bucket_lowering(ctx, mod, builder, i32_type, fn_type, call_fn, entry, individual_sources, project_types, 0, 64, 1, project.function_bodies, "ycpl_project_dynamic_range_body_", "function_body_dynamic_range_lowered_", "function_body_dynamic_range_total_")
    dynamic_range_tail_bucket := emit_dynamic_function_body_bucket_lowering(ctx, mod, builder, i32_type, fn_type, call_fn, entry, individual_sources, project_types, 384, 64, 1, project.function_bodies, "ycpl_project_dynamic_range_body_", "function_body_dynamic_range_lowered_", "function_body_dynamic_range_total_")
    dynamic_range_buckets_lowered := llvm.build_add(builder, dynamic_range_first_bucket, dynamic_range_tail_bucket, "function_body_dynamic_range_buckets_lowered")
    function_body_dynamic_range_gate := llvm.build_add(builder, function_body_ranges_lowered, dynamic_range_buckets_lowered, "function_body_dynamic_range_gate")
    source_traversal_count := llvm.const_int(i32_type, individual_sources.count, 1)
    function_body_source_traversal_gate := llvm.build_add(builder, function_body_dynamic_range_gate, source_traversal_count, "function_body_source_traversal_gate")
    function_body_aggregate_lowered := llvm.build_add(builder, all_function_bodies_lowered, control_function_body_lowered, "function_body_aggregate_lowered")
    function_body_slot_and_range_lowered := llvm.build_add(builder, function_body_first64_slots_lowered, function_body_source_traversal_gate, "function_body_slot_and_range_lowered")
    function_body_lowered := llvm.build_add(builder, function_body_aggregate_lowered, function_body_slot_and_range_lowered, "function_body_lowered")
    dynamic_first64_lowered := emit_dynamic_function_body_lowering_range(ctx, mod, builder, i32_type, fn_type, call_fn, entry, individual_sources, project_types, 0, 64, project.function_bodies, "ycpl_project_dynamic_first_body_", "function_body_dynamic_first_lowered_", "function_body_dynamic_first_total_")
    remaining_individual_bodies_lowered := emit_remaining_individual_function_body_lowering(ctx, mod, builder, i32_type, fn_type, call_fn, entry, individual_sources, project_types, 64, project.function_bodies)
    dynamic_selfhost_body_gate := llvm.build_add(builder, dynamic_first64_lowered, remaining_individual_bodies_lowered, "function_body_dynamic_selfhost_gate")
    all_individual_function_bodies_lowered := llvm.build_add(builder, function_body_lowered, dynamic_selfhost_body_gate, "function_body_all_individual_lowered")

    returns_value := llvm.const_int(i32_type, project.returns, 1)
    expr_table_with_slots := llvm.build_add(builder, expression_table_lowered, expression_slot_lowered, "expr_table_with_slots")
    expr_with_table := llvm.build_add(builder, loaded_expressions, expr_table_with_slots, "expr_with_table")
    expr_return_sum := llvm.build_add(builder, expr_with_table, returns_value, "expr_return_sum")
    statement_expr_sum := llvm.build_add(builder, loaded_statements, expr_return_sum, "statement_expr_sum")
    body_without_consts := llvm.build_add(builder, statement_expr_sum, lowered_locals, "body_without_consts")
    body_with_function := llvm.build_add(builder, body_without_consts, all_individual_function_bodies_lowered, "body_with_function_lowering")
    total := llvm.build_add(builder, body_with_function, const_lowered, "project_body_total")
    llvm.build_ret(builder, total)

    ir := llvm.print_module_to_string(mod)
    merge_text := mergeable_ir_text(ir)
    fs.mkdir(out_dir)
    out_file := project_body_path(out_dir)
    wrote := fs.write_file(out_file, ir)

    llvm.dispose_message(ir)
    llvm.dispose_builder(builder)
    llvm.dispose_module(mod)
    llvm.context_dispose(ctx)

    if !wrote {
        return fail("failed to write project statement/expression LLVM IR")
    }
    return ok_with_text(out_file, merge_text)
}
