(* YCPL EBNF. This tracks the parser-facing public syntax. *)

source_file        = separators
                     [ module_decl separators ]
                     { import_decl separators }
                     { top_level_decl separators } ;

separators         = { newline } ;
module_decl        = ( "module" | "package" ) qualified_name ;
import_decl        = "import" string_literal [ "as" identifier ] ;

top_level_decl     = function_decl
                   | extern_function_decl
                   | intrinsic_function_decl
                   | struct_decl
                   | enum_decl
                   | type_alias_decl
                   | const_decl ;

visibility         = "pub" ;
function_decl      = [ visibility ] "fn" identifier
                     "(" [ parameter_list ] ")" [ type ] block ;
extern_function_decl
                   = [ visibility ] "extern" "fn" identifier
                     "(" [ parameter_list ] ")" [ type ]
                     [ "as" string_literal ] ;
intrinsic_function_decl
                   = [ visibility ] "intrinsic" "fn" identifier
                     "(" [ parameter_list ] ")" [ type ] ;

parameter_list     = parameter { "," parameter } [ "," ] ;
parameter          = identifier type ;

struct_decl        = [ visibility ] "struct" identifier "{"
                     separators
                     { field_decl separators }
                     "}" ;
field_decl         = [ visibility ] identifier type ;

enum_decl          = [ visibility ] "enum" identifier "{"
                     separators
                     { enum_variant [ "," ] separators }
                     "}" ;
enum_variant       = identifier [ "=" integer_literal ] ;

type_alias_decl    = [ visibility ] "type" identifier [ "=" ] type ;
const_decl         = "const" identifier [ ":" type ] ":=" expression ;

type               = [ "owned" ] type_primary ;
type_primary       = primitive_type
                   | pointer_type
                   | slice_type
                   | vec_type
                   | map_type
                   | qualified_name ;
pointer_type       = ( "*" | "&" ) type ;
slice_type         = "[]" type ;
vec_type           = "Vec" "<" type ">" ;
map_type           = "Map" "<" type "," type ">" ;

primitive_type     = "i32" | "i64" | "bool" | "char" | "byte" | "string"
                   | "float" | "double" | "void" | "size_t"
                   | "Type" | "T" | "any" ;

block              = "{" separators { statement separators } "}" ;
statement          = var_decl
                   | const_decl
                   | assignment
                   | defer_statement
                   | scope_statement
                   | if_statement
                   | for_statement
                   | switch_statement
                   | return_statement
                   | break_statement
                   | continue_statement
                   | expression ;

var_decl           = identifier [ ":" type ] ":=" expression ;
assignment         = expression assignment_operator expression ;
assignment_operator
                   = "=" | "+=" | "-=" | "*=" | "/=" | "%=" ;

defer_statement    = "defer" ( expression | block ) ;
scope_statement    = "scope" [ identifier ] block ;
if_statement       = "if" expression block [ "else" ( block | if_statement ) ] ;
for_statement      = "for" ( for_c_style | for_in | [ expression ] ) block ;
for_c_style        = [ simple_statement ] ";" [ expression ] ";" [ simple_statement ] ;
for_in             = identifier "in" expression ;
simple_statement   = var_decl | assignment | expression ;

switch_statement   = "switch" expression "{"
                     separators
                     { switch_case separators }
                     [ switch_default separators ]
                     "}" ;
switch_case        = "case" expression block ;
switch_default     = "default" block ;
return_statement   = "return" [ expression ] ;
break_statement    = "break" ;
continue_statement = "continue" ;

expression         = logical_or ;
logical_or         = logical_and { "||" logical_and } ;
logical_and        = equality { "&&" equality } ;
equality           = comparison { ( "==" | "!=" ) comparison } ;
comparison         = shift { ( "<" | "<=" | ">" | ">=" ) shift } ;
shift              = additive { ( "<<" | ">>" ) additive } ;
additive           = multiplicative { ( "+" | "-" ) multiplicative } ;
multiplicative     = unary { ( "*" | "/" | "%" ) unary } ;
unary              = [ "!" | "-" | "+" | "++" | "--" | "*" | "&" ] postfix ;
postfix            = primary
                     { call_suffix | index_suffix | member_suffix | postfix_update } ;
call_suffix        = "(" [ argument_list ] ")" ;
index_suffix       = "[" expression "]" ;
member_suffix      = "." identifier ;
postfix_update     = "++" | "--" ;
argument_list      = expression { "," expression } [ "," ] ;

primary            = identifier
                   | literal
                   | array_literal
                   | struct_literal
                   | vec_literal
                   | cast_expression
                   | "(" expression ")" ;

array_literal      = "[" [ argument_list ] "]" ;
struct_literal     = qualified_name "{"
                     [ field_initializer { "," field_initializer } [ "," ] ]
                     "}" ;
vec_literal        = "Vec" "<" type ">" "{"
                     [ "capacity" ":" expression [ "," ] ]
                     "}" ;
field_initializer  = identifier ":" expression ;
cast_expression    = "cast" "(" type "," expression ")" ;

literal            = integer_literal
                   | float_literal
                   | char_literal
                   | string_literal
                   | raw_string_literal
                   | "true"
                   | "false"
                   | "none" ;

qualified_name     = identifier { "." identifier } ;
identifier         = identifier_start { identifier_continue } ;
identifier_start   = "A".."Z" | "a".."z" | "_" ;
identifier_continue
                   = identifier_start | "0".."9" ;

integer_literal    = decimal_literal | hex_literal | binary_literal ;
decimal_literal    = "0" | "1".."9" { "0".."9" } ;
hex_literal        = "0x" hex_digit { hex_digit } ;
binary_literal     = "0b" ( "0" | "1" ) { "0" | "1" } ;
float_literal      = decimal_literal "." { "0".."9" } ;
char_literal       = "'" character "'" ;
string_literal     = '"' { character } '"' ;
raw_string_literal = "`" { character } "`" ;
character          = ? any Unicode scalar value, with escapes in normal strings/chars ? ;
hex_digit          = "0".."9" | "A".."F" | "a".."f" ;
newline            = "\n" | "\r\n" ;
