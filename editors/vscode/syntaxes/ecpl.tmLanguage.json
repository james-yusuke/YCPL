{
  "scopeName": "source.YCPL",
  "name": "YCPL",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#module"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#structs"
    },
    {
      "include": "#calls"
    },
    {
      "include": "#fields"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.YCPL",
          "match": "//.*$"
        },
        {
          "name": "comment.block.YCPL",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "comment.block.documentation.YCPL",
              "match": "^\\s*\\*.*$"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.YCPL",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.YCPL",
              "match": "\\\\(n|r|t|\\\\|\"|'|u[0-9A-Fa-f]{4}|x[0-9A-Fa-f]{2}|.)"
            }
          ]
        },
        {
          "name": "string.quoted.raw.YCPL",
          "begin": "`",
          "end": "`"
        },
        {
          "name": "constant.character.YCPL",
          "match": "'([^'\\\\]|\\\\(n|r|t|\\\\|\"|'|x[0-9A-Fa-f]{2}|.))'"
        }
      ]
    },
    "module": {
      "patterns": [
        {
          "name": "meta.module.YCPL",
          "match": "\\b(module|package)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "keyword.control.module.YCPL"
            },
            "2": {
              "name": "entity.name.namespace.YCPL"
            }
          }
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.YCPL",
          "match": "\\b(import)\\s+(\"[^\"]+\")\\s*(?:(as)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": {
              "name": "keyword.control.import.YCPL"
            },
            "2": {
              "name": "string.quoted.double.import-path.YCPL"
            },
            "3": {
              "name": "keyword.operator.alias.YCPL"
            },
            "4": {
              "name": "entity.name.namespace.alias.YCPL"
            }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.YCPL",
          "match": "\\b(?:(pub|extern|intrinsic)\\s+)?(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.YCPL"
            },
            "2": {
              "name": "keyword.declaration.function.YCPL"
            },
            "3": {
              "name": "entity.name.function.YCPL"
            }
          }
        }
      ]
    },
    "structs": {
      "patterns": [
        {
          "name": "meta.struct.declaration.YCPL",
          "match": "\\b(?:(pub)\\s+)?(struct)\\s+([A-Z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.YCPL"
            },
            "2": {
              "name": "keyword.declaration.struct.YCPL"
            },
            "3": {
              "name": "entity.name.type.struct.YCPL"
            }
          }
        },
        {
          "name": "meta.struct.literal.YCPL",
          "match": "\\b([A-Z_][A-Za-z0-9_]*)\\s*(?=\\{)",
          "captures": {
            "1": {
              "name": "support.type.struct.YCPL"
            }
          }
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "meta.function-call.qualified.YCPL",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.namespace.YCPL"
            },
            "2": {
              "name": "punctuation.accessor.YCPL"
            },
            "3": {
              "name": "entity.name.function.YCPL"
            }
          }
        },
        {
          "name": "meta.function-call.YCPL",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.YCPL"
            }
          }
        }
      ]
    },
    "fields": {
      "patterns": [
        {
          "name": "variable.other.member.YCPL",
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "punctuation.accessor.YCPL"
            },
            "2": {
              "name": "variable.other.property.YCPL"
            }
          }
        },
        {
          "name": "variable.other.field.struct-literal.YCPL",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": {
              "name": "variable.other.property.YCPL"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.YCPL",
          "match": "\\b(if|else|for|in|return|break|continue|match|switch|select|go|defer)\\b"
        },
        {
          "name": "keyword.declaration.YCPL",
          "match": "\\b(pub|extern|intrinsic|fn|struct|enum|interface|const|mut|as|is)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.YCPL",
          "match": "\\b(i32|i64|bool|char|byte|string|float|double|void|size_t|Type|T|any)\\b"
        },
        {
          "name": "storage.type.slice.YCPL",
          "match": "\\[\\]\\s*(i32|i64|bool|char|byte|string|float|double|[A-Z_][A-Za-z0-9_]*)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.YCPL",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.YCPL",
          "match": "\\b(none)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.YCPL",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.YCPL",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.float.YCPL",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.YCPL",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.YCPL",
          "match": "(:=|\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.comparison.YCPL",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.YCPL",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.YCPL",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    }
  }
}
