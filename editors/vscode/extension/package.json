{
  "name": "ycpl-vscode",
  "displayName": "YCPL",
  "description": "YCPL language support powered by the YCPL Language Server.",
  "version": "0.1.0",
  "publisher": "YCPL",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:ycpl",
    "onCommand:YCPL.restartLanguageServer"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build"
  },
  "contributes": {
    "languages": [
      {
        "id": "ycpl",
        "aliases": [
          "YCPL",
          "ycpl"
        ],
        "extensions": [
          ".yc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ycpl",
        "scopeName": "source.ycpl",
        "path": "./syntaxes/ycpl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ycpl",
        "path": "./snippets/ycpl.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "YCPL.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "YCPL"
      }
    ],
    "configuration": {
      "title": "YCPL",
      "properties": {
        "YCPL.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to a ycpl-language-server executable. Leave empty to use the bundled workspace server."
        },
        "YCPL.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication with the YCPL language server."
        },
        "YCPL.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable YCPL inlay hints."
        }
      }
    },
    "configurationDefaults": {
      "[ycpl]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.semanticHighlighting.enabled": true,
        "editor.formatOnSave": false
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.8.2"
  }
}
