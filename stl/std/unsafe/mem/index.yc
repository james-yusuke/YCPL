module std.unsafe.mem

import "c/stdlib" as cstdlib

pub fn alloc(size i64) *byte {
    return cstdlib.malloc(size)
}

pub fn calloc(count i64, size i64) *byte {
    return cstdlib.calloc(count, size)
}

pub fn realloc(ptr *byte, size i64) *byte {
    return cstdlib.realloc(ptr, size)
}

pub fn free(ptr *byte) {
    cstdlib.free(ptr)
}
