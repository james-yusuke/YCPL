}

pub fn context_create() *byte {
    return llvm.context_create()
}

pub fn context_dispose(ctx *byte) {
    llvm.context_dispose(ctx)
}

pub fn module_create_with_name_in_context(name string, ctx *byte) *byte {
    return llvm.module_create(name, ctx)
}

pub fn dispose_module(mod *byte) {
    llvm.module_dispose(mod)
}

pub fn print_module_to_string(mod *byte) string {
    return llvm.module_to_string(mod)
}

pub fn print_module_to_file(mod *byte, path string) bool {
    message: string := none
    rc := llvm.module_to_file_raw(mod, path, &message)
    if message != none {
        llvm.dispose_message(message)
    }
    return rc == 0
}

pub fn dispose_message(message string) {
    llvm.dispose_message(message)
}

pub fn create_builder_in_context(ctx *byte) *byte {
    return llvm.builder_create(ctx)
}

pub fn dispose_builder(builder *byte) {
    llvm.builder_dispose(builder)
}

pub fn position_builder_at_end(builder *byte, block *byte) {
    llvm.position_at_end(builder, block)
}

pub fn get_insert_block(builder *byte) *byte {
    return llvm.insert_block(builder)
}

pub fn get_basic_block_terminator(block *byte) *byte {
    return llvm.block_terminator(block)
}

pub fn current_block_has_terminator(builder *byte) bool {
    block := llvm.insert_block(builder)
    if block == none {
        return false
    }
    return llvm.block_terminator(block) != none
}

