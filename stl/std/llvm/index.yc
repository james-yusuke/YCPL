module std.llvm

import "c/llvm" as llvm

struct RefArgs2 {
    arg0 *byte
    arg1 *byte
}

struct RefArgs3 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
}

struct RefArgs4 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
    arg3 *byte
}

struct RefArgs5 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
    arg3 *byte
    arg4 *byte
}

struct RefArgs6 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
    arg3 *byte
    arg4 *byte
    arg5 *byte
}

struct RefArgs16 {
    arg0 *byte
    arg1 *byte
