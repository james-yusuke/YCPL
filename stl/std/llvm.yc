struct RefArgs2 {
    arg0 *byte
    arg1 *byte
}

struct RefArgs3 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
}

struct RefArgs4 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
    arg3 *byte
}

struct RefArgs5 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
    arg3 *byte
    arg4 *byte
}

struct RefArgs6 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
    arg3 *byte
    arg4 *byte
    arg5 *byte
}

struct RefArgs16 {
    arg0 *byte
    arg1 *byte
    arg2 *byte
    arg3 *byte
    arg4 *byte
    arg5 *byte
    arg6 *byte
    arg7 *byte
    arg8 *byte
    arg9 *byte
    arg10 *byte
    arg11 *byte
    arg12 *byte
    arg13 *byte
    arg14 *byte
    arg15 *byte
}

pub fn context_create() *byte {
    return c_context_create()
}

pub fn context_dispose(ctx *byte) {
    c_context_dispose(ctx)
}

pub fn module_create_with_name_in_context(name string, ctx *byte) *byte {
    return c_module_create_with_name_in_context(name, ctx)
}

pub fn dispose_module(mod *byte) {
    c_dispose_module(mod)
}

pub fn print_module_to_string(mod *byte) string {
    return c_print_module_to_string(mod)
}

pub fn print_module_to_file(mod *byte, path string) bool {
    message: string := none
    rc := c_print_module_to_file(mod, path, &message)
    if message != none {
        c_dispose_message(message)
    }
    return rc == 0
}

pub fn dispose_message(message string) {
    c_dispose_message(message)
}

