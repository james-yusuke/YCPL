pub fn int_eq() i32 { return 32 }
pub fn int_ne() i32 { return 33 }
pub fn int_sgt() i32 { return 38 }
pub fn int_sge() i32 { return 39 }
pub fn int_slt() i32 { return 40 }
pub fn int_sle() i32 { return 41 }

pub fn verify_return_status_action() i32 { return 2 }

