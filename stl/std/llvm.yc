pub fn struct_type16(ctx *byte, field_type *byte, packed i32) *byte {
    fields := RefArgs16{arg0: field_type, arg1: field_type, arg2: field_type, arg3: field_type, arg4: field_type, arg5: field_type, arg6: field_type, arg7: field_type, arg8: field_type, arg9: field_type, arg10: field_type, arg11: field_type, arg12: field_type, arg13: field_type, arg14: field_type, arg15: field_type}
    return c_struct_type_in_context(ctx, &fields, 16, packed)
