module std.str

import "c/string" as cstr

pub fn len(s string) i64 {
    if s == none { return 0 }
    return cstr.strlen(s)
}

pub fn cmp(a string, b string) i32 {
    if a == none { if b == none { return 0 } return -1 }
    if b == none { return 1 }
    return cstr.strcmp(a, b)
}

pub fn copy(dst string, src string) string {
    return cstr.strcpy(dst, src)
}

pub fn eq(a string, b string) bool {
    return cmp(a, b) == 0
}
