pub extern fn build_sub(builder *byte, left *byte, right *byte, name string) *byte as "LLVMBuildSub"
pub extern fn build_mul(builder *byte, left *byte, right *byte, name string) *byte as "LLVMBuildMul"
pub extern fn build_sdiv(builder *byte, left *byte, right *byte, name string) *byte as "LLVMBuildSDiv"
pub extern fn build_srem(builder *byte, left *byte, right *byte, name string) *byte as "LLVMBuildSRem"
pub extern fn build_fadd(builder *byte, left *byte, right *byte, name string) *byte as "LLVMBuildFAdd"
pub extern fn build_fsub(builder *byte, left *byte, right *byte, name string) *byte as "LLVMBuildFSub"
pub extern fn build_fmul(builder *byte, left *byte, right *byte, name string) *byte as "LLVMBuildFMul"
pub extern fn build_fdiv(builder *byte, left *byte, right *byte, name string) *byte as "LLVMBuildFDiv"
