pub extern fn build_neg(builder *byte, value *byte, name string) *byte as "LLVMBuildNeg"
pub extern fn build_not(builder *byte, value *byte, name string) *byte as "LLVMBuildNot"
pub extern fn build_sext(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildSExt"
pub extern fn build_zext(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildZExt"
pub extern fn build_trunc(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildTrunc"
pub extern fn build_sitofp(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildSIToFP"
pub extern fn build_fptosi(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildFPToSI"
pub extern fn build_bitcast(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildBitCast"
pub extern fn build_pointer_cast(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildPointerCast"
pub extern fn build_ptr_to_int(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildPtrToInt"
pub extern fn build_int_to_ptr(builder *byte, value *byte, typ *byte, name string) *byte as "LLVMBuildIntToPtr"
pub extern fn build_icmp(builder *byte, predicate i32, left *byte, right *byte, name string) *byte as "LLVMBuildICmp"
pub extern fn build_fcmp(builder *byte, predicate i32, left *byte, right *byte, name string) *byte as "LLVMBuildFCmp"
pub extern fn build_br(builder *byte, destination *byte) *byte as "LLVMBuildBr"
pub extern fn build_cond_br(builder *byte, condition *byte, yes *byte, no *byte) *byte as "LLVMBuildCondBr"
pub extern fn build_switch(builder *byte, value *byte, otherwise *byte, count i32) *byte as "LLVMBuildSwitch"
pub extern fn add_case(switch_value *byte, value *byte, destination *byte) as "LLVMAddCase"
pub extern fn build_unreachable(builder *byte) *byte as "LLVMBuildUnreachable"
pub extern fn build_call(builder *byte, typ *byte, function *byte, args *byte, count i32, name string) *byte as "LLVMBuildCall2"
pub extern fn build_struct_gep(builder *byte, typ *byte, address *byte, index i32, name string) *byte as "LLVMBuildStructGEP2"
pub extern fn build_gep(builder *byte, typ *byte, address *byte, indices *byte, count i32, name string) *byte as "LLVMBuildGEP2"
pub extern fn build_global_string(builder *byte, value string, name string) *byte as "LLVMBuildGlobalStringPtr"
pub extern fn build_phi(builder *byte, typ *byte, name string) *byte as "LLVMBuildPhi"
pub extern fn add_incoming(phi *byte, values *byte, blocks *byte, count i32) as "LLVMAddIncoming"
pub extern fn build_extract_value(builder *byte, value *byte, index i32, name string) *byte as "LLVMBuildExtractValue"
pub extern fn build_insert_value(builder *byte, aggregate *byte, value *byte, index i32, name string) *byte as "LLVMBuildInsertValue"

pub fn verify_module(mod *byte) bool {
    message: string := none
    ok := verify_module_raw(mod, 2, &message) == 0
    if message != none { dispose_message(message) }
    return ok
}

pub fn write_module(mod *byte, path string) bool {
    message: string := none
    ok := module_to_file_raw(mod, path, &message) == 0
    if message != none { dispose_message(message) }
    return ok
}

pub fn block_has_terminator(builder *byte) bool {
    block := insert_block(builder)
    return block != none && block_terminator(block) != none
}

pub fn int_eq() i32 { return 32 }
pub fn int_ne() i32 { return 33 }
pub fn int_sgt() i32 { return 38 }
pub fn int_sge() i32 { return 39 }
pub fn int_slt() i32 { return 40 }
pub fn int_sle() i32 { return 41 }
