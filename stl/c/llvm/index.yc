module c.llvm

// LLVM 22 C API. This module intentionally exposes the raw foreign boundary;
// compiler-specific type construction and lowering live under compiler/ycpl.
pub extern fn context_create() *byte as "LLVMContextCreate"
pub extern fn context_dispose(ctx *byte) as "LLVMContextDispose"
pub extern fn module_create(name string, ctx *byte) *byte as "LLVMModuleCreateWithNameInContext"
pub extern fn module_dispose(mod *byte) as "LLVMDisposeModule"
pub extern fn module_to_string(mod *byte) string as "LLVMPrintModuleToString"
pub extern fn module_to_file_raw(mod *byte, path string, error *string) i32 as "LLVMPrintModuleToFile"
pub extern fn dispose_message(message string) as "LLVMDisposeMessage"
pub extern fn verify_module_raw(mod *byte, action i32, message *string) i32 as "LLVMVerifyModule"

pub extern fn builder_create(ctx *byte) *byte as "LLVMCreateBuilderInContext"
pub extern fn builder_dispose(builder *byte) as "LLVMDisposeBuilder"
pub extern fn position_at_end(builder *byte, block *byte) as "LLVMPositionBuilderAtEnd"
pub extern fn insert_block(builder *byte) *byte as "LLVMGetInsertBlock"
pub extern fn block_terminator(block *byte) *byte as "LLVMGetBasicBlockTerminator"
pub extern fn append_block(ctx *byte, function *byte, name string) *byte as "LLVMAppendBasicBlockInContext"

pub extern fn void_type(ctx *byte) *byte as "LLVMVoidTypeInContext"
pub extern fn i1_type(ctx *byte) *byte as "LLVMInt1TypeInContext"
pub extern fn i8_type(ctx *byte) *byte as "LLVMInt8TypeInContext"
pub extern fn i32_type(ctx *byte) *byte as "LLVMInt32TypeInContext"
pub extern fn i64_type(ctx *byte) *byte as "LLVMInt64TypeInContext"
pub extern fn float_type(ctx *byte) *byte as "LLVMFloatTypeInContext"
pub extern fn double_type(ctx *byte) *byte as "LLVMDoubleTypeInContext"
pub extern fn pointer_type(element *byte, address_space i32) *byte as "LLVMPointerType"
pub extern fn array_type(element *byte, count i64) *byte as "LLVMArrayType2"
pub extern fn struct_type(ctx *byte, fields *byte, count i32, packed i32) *byte as "LLVMStructTypeInContext"
pub extern fn named_struct(ctx *byte, name string) *byte as "LLVMStructCreateNamed"
pub extern fn set_struct_body(typ *byte, fields *byte, count i32, packed i32) as "LLVMStructSetBody"
pub extern fn function_type(result *byte, params *byte, count i32, variadic i32) *byte as "LLVMFunctionType"

pub extern fn add_function(mod *byte, name string, typ *byte) *byte as "LLVMAddFunction"
pub extern fn named_function(mod *byte, name string) *byte as "LLVMGetNamedFunction"
pub extern fn get_param(function *byte, index i32) *byte as "LLVMGetParam"
pub extern fn type_of(value *byte) *byte as "LLVMTypeOf"
pub extern fn set_value_name(value *byte, name string, length i64) as "LLVMSetValueName2"
pub extern fn add_global(mod *byte, typ *byte, name string) *byte as "LLVMAddGlobal"
pub extern fn set_initializer(global *byte, value *byte) as "LLVMSetInitializer"
pub extern fn set_global_constant(global *byte, value i32) as "LLVMSetGlobalConstant"

pub extern fn const_int(typ *byte, value i64, sign_extend i32) *byte as "LLVMConstInt"
pub extern fn const_real(typ *byte, value double) *byte as "LLVMConstReal"
pub extern fn const_null(typ *byte) *byte as "LLVMConstNull"
pub extern fn const_pointer_null(typ *byte) *byte as "LLVMConstPointerNull"

pub extern fn build_alloca(builder *byte, typ *byte, name string) *byte as "LLVMBuildAlloca"
pub extern fn build_load(builder *byte, typ *byte, address *byte, name string) *byte as "LLVMBuildLoad2"
