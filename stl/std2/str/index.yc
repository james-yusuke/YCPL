module std2.str

extern fn c_strlen(s string) i64 as "strlen"
extern fn c_strcmp(a string, b string) i32 as "strcmp"
extern fn c_strcpy(dst string, src string) string as "strcpy"

pub fn len(s string) i64 {
    return c_strlen(s)
}

pub fn cmp(a string, b string) i32 {
    return c_strcmp(a, b)
}

pub fn copy(dst string, src string) string {
    return c_strcpy(dst, src)
}

pub fn eq(a string, b string) bool {
    return c_strcmp(a, b) == 0
}
