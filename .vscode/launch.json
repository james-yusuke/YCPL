{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "YCPL: Debug VSCode Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "preLaunchTask": "YCPL: build VSCode extension and LSP",
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode/extension",
        "${workspaceFolder}"
      ]
    }
  ]
}
