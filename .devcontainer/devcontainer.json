{
  "name": "YCPL LLVM 18",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace/YCPL",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/YCPL,type=bind,consistency=cached",
  "mounts": [
    "source=YCPL-github-ssh,target=/home/ubuntu/.ssh,type=volume"
  ],
  "remoteUser": "ubuntu",
  "containerEnv": {
    "LLVM_DIR": "/usr/lib/llvm-18/cmake",
    "CC": "clang",
    "CXX": "clang++"
  },
  "runArgs": [
    "--init"
  ],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postAttachCommand": "bash .devcontainer/install-vscode-extension.sh || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools"
      ],
      "settings": {
        "cmake.buildDirectory": "${workspaceFolder}/build",
        "cmake.configureSettings": {
          "LLVM_DIR": "/usr/lib/llvm-18/cmake"
        },
        "editor.semanticHighlighting.enabled": true,
        "files.associations": {
          "*.ec": "YCPL"
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
